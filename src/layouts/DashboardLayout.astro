<OnboardingTour />
<UpgradeModal />
<FeedbackWidget />

<div id="toast-container" class="fixed bottom-20 right-4 lg:bottom-4 z-[9999] space-y-2"></div>

<script>
  const mobileMenu     = document.getElementById('mobile-menu')
  const mobileBackdrop = document.getElementById('mobile-menu-backdrop')
  function openMobile()  { mobileMenu?.classList.remove('hidden'); document.body.style.overflow = 'hidden' }
  function closeMobile() { mobileMenu?.classList.add('hidden');    document.body.style.overflow = '' }
  document.getElementById('mobile-menu-btn')?.addEventListener('click', openMobile)
  document.getElementById('mobile-menu-close')?.addEventListener('click', closeMobile)
  mobileBackdrop?.addEventListener('click', closeMobile)
  const sidebarUserBtn  = document.getElementById('sidebar-user-btn')
  const sidebarUserMenu = document.getElementById('sidebar-user-menu')
  sidebarUserBtn?.addEventListener('click', e => { e.stopPropagation(); sidebarUserMenu?.classList.toggle('hidden') })
  const topbarUserBtn  = document.getElementById('topbar-user-btn')
  const topbarUserMenu = document.getElementById('topbar-user-menu')
  topbarUserBtn?.addEventListener('click', e => { e.stopPropagation(); topbarUserMenu?.classList.toggle('hidden'); sidebarUserMenu?.classList.add('hidden') })
  document.addEventListener('click', () => { sidebarUserMenu?.classList.add('hidden'); topbarUserMenu?.classList.add('hidden') })
  document.getElementById('command-palette-trigger')?.addEventListener('click', () => window.openCommandPalette?.())
  document.addEventListener('keydown', e => { if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); window.openCommandPalette?.() } })
</script>
<script define:vars={{ chatContext }}>
(function () {
  const ctx     = JSON.parse(chatContext)
  const trigger = document.getElementById('chat-trigger')
  const panel   = document.getElementById('chat-panel')
  const iconOff = document.getElementById('chat-icon-closed')
  const iconOn  = document.getElementById('chat-icon-open')
  const pulse   = document.getElementById('chat-pulse')
  const msgBox  = document.getElementById('chat-messages')
  const input   = document.getElementById('chat-input')
  const sendBtn = document.getElementById('chat-send')
  const clearBtn= document.getElementById('chat-clear')
  const suggsEl = document.getElementById('chat-suggestions')

  let open = false, loading = false, history = []

  const botAvatar = '<div class="w-6 h-6 rounded-lg shrink-0 mt-0.5 flex items-center justify-center" style="background:linear-gradient(135deg,#7c3aed,#4f46e5);"><svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg></div>'

  const scrollBottom = () => { if (msgBox) msgBox.scrollTop = msgBox.scrollHeight }

  function addBotMsg(text) {
    const w = document.createElement('div')
    w.className = 'flex gap-2.5 items-start chat-msg'
    w.innerHTML = botAvatar + '<div class="rounded-2xl rounded-tl-md px-3.5 py-2.5 text-sm leading-relaxed whitespace-pre-wrap" style="background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.82);max-width:85%;">' + text.replace(/</g,'&lt;') + '</div>'
    msgBox?.appendChild(w); scrollBottom()
  }

  function addUserMsg(text) {
    const w = document.createElement('div')
    w.className = 'flex justify-end chat-msg'
    w.innerHTML = '<div class="rounded-2xl rounded-tr-md px-3.5 py-2.5 text-sm leading-relaxed whitespace-pre-wrap" style="background:linear-gradient(135deg,#7c3aed,#4f46e5);color:#fff;max-width:85%;">' + text.replace(/</g,'&lt;') + '</div>'
    msgBox?.appendChild(w); scrollBottom()
  }

  function addTyping() {
    const w = document.createElement('div')
    w.id = 'chat-typing'; w.className = 'flex gap-2.5 items-start chat-msg'
    w.innerHTML = botAvatar + '<div class="rounded-2xl rounded-tl-md px-4 py-3" style="background:rgba(255,255,255,0.05);"><div class="flex gap-1.5 items-center h-4"><span class="chat-dot w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.5);"></span><span class="chat-dot w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.5);"></span><span class="chat-dot w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.5);"></span></div></div>'
    msgBox?.appendChild(w); scrollBottom()
  }

  function openChat()  { open = true;  panel?.classList.add('open');    iconOff?.classList.add('hidden');    iconOn?.classList.remove('hidden'); pulse?.remove(); input?.focus(); scrollBottom() }
  function closeChat() { open = false; panel?.classList.remove('open'); iconOff?.classList.remove('hidden'); iconOn?.classList.add('hidden') }

  trigger?.addEventListener('click', () => open ? closeChat() : openChat())
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && open) closeChat() })

  async function send(text) {
    text = text.trim()
    if (!text || loading) return
    if (suggsEl) suggsEl.style.display = 'none'
    loading = true
    if (sendBtn) sendBtn.disabled = true
    addUserMsg(text)
    history.push({ role: 'user', content: text })
    if (input) { input.value = ''; input.style.height = 'auto' }
    addTyping()
    try {
      const res  = await fetch('/api/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ messages: history.slice(-12), context: ctx }) })
      document.getElementById('chat-typing')?.remove()
      if (!res.ok) throw new Error('HTTP ' + res.status)
      const data  = await res.json()
      const reply = data.content?.[0]?.text ?? "Desole, je n'ai pas pu repondre."
      addBotMsg(reply)
      history.push({ role: 'assistant', content: reply })
    } catch(err) {
      document.getElementById('chat-typing')?.remove()
      addBotMsg("Une erreur s'est produite. Reessaie dans un instant.")
    }
    loading = false
    if (sendBtn) sendBtn.disabled = false
  }

  sendBtn?.addEventListener('click', () => send(input?.value ?? ''))
  input?.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(input.value) } })
  input?.addEventListener('input', () => { input.style.height = 'auto'; input.style.height = Math.min(input.scrollHeight, 100) + 'px' })
  document.querySelectorAll('.chat-sugg').forEach(btn => { btn.addEventListener('click', () => { if (!open) openChat(); send(btn.dataset.prompt ?? '') }) })
  clearBtn?.addEventListener('click', () => {
    history = []
    if (msgBox) msgBox.innerHTML = '<div class="flex gap-2.5 items-start chat-msg">' + botAvatar + '<div class="rounded-2xl rounded-tl-md px-3.5 py-2.5 text-sm" style="background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.82);max-width:85%;">Conversation reinitialisee.</div></div>'
    if (suggsEl) suggsEl.style.display = ''
  })
})()
</script>
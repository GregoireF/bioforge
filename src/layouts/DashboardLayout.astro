          <a href={`?days=${d}`} class={`px-4 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 ${days === d ? 'bg-neon-green text-black' : 'text-gray-500 hover:text-gray-300 hover:bg-white/5'}`}>{d}j</a>
        ))}
      </div>
      <button id="export-csv-btn" class="no-print flex items-center gap-1.5 px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-400 hover:text-white hover:border-white/20 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>CSV
      </button>
      <button id="export-pdf-btn" class="no-print flex items-center gap-1.5 px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-400 hover:text-white hover:border-white/20 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>PDF
      </button>
    </div>
  </div>

  {rpcError && <div class="mb-4 p-4 rounded-xl border border-red-400/30 bg-red-400/8 text-red-400 text-sm">{rpcError}</div>}

  <!-- SECTION TABS (like Appearance) -->
  <div class="flex items-center gap-1.5 flex-wrap mb-6">
    {[
      { id:'overview', label:'📊 Overview'             },
      { id:'traffic',  label:'📈 Trafic & Audience'    },
      { id:'revenue',  label:'💰 Revenus & Conversion' },
      { id:'content',  label:'🔗 Contenu'              },
    ].map((s, i) => (
      <button class={`sec-tab px-3 py-2 rounded-xl text-xs font-semibold border border-white/8 text-gray-500 hover:text-gray-300 hover:border-white/15 ${i === 0 ? 'active' : ''}`}
        data-section={s.id}>
        {s.label}
      </button>
    ))}
  </div>

  <!-- ══ OVERVIEW ══ -->
  <div class="sec-panel active" id="panel-overview">
    <div class="space-y-5">

      <!-- KPI row -->
      <div class="grid grid-cols-2 lg:grid-cols-6 gap-3 mb-6">
        <div class="kpi-card fade-slide d-0 p-5 glass rounded-2xl border border-white/8 cursor-default" style="--glow:#00ff9d">
          <div class="flex items-start justify-between mb-4">
            <div class="w-8 h-8 rounded-lg bg-neon-green/10 border border-neon-green/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </div>
            <div set:html={viewSparkline} class="opacity-60 mt-1"></div>
          </div>
          <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">{summary.totalViews.toLocaleString('fr-FR')}</div>
          <p class="text-xs text-gray-500 mt-1.5 font-medium">Vues totales</p>
          <div class="flex items-center justify-between mt-1">
            <p class="text-xs text-gray-600">{summary.avgPerDay}/j moy.</p>
            {deltaViews.neutral ? <span class="delta-neu">—</span> : deltaViews.pos ? <span class="delta-pos">↑ {deltaViews.val}%</span> : <span class="delta-neg">↓ {deltaViews.val}%</span>}
          </div>
        </div>
        <div class="kpi-card fade-slide d-1 p-5 glass rounded-2xl border border-white/8" style="--glow:#00aaff">
          <div class="flex items-start justify-between mb-4">
            <div class="w-8 h-8 rounded-lg bg-neon-blue/10 border border-neon-blue/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            {summary.totalViews > 0 && <span class="text-xs text-neon-blue/70 bg-neon-blue/8 px-2 py-0.5 rounded-full border border-neon-blue/15 font-mono mt-1">{Math.round((summary.uniqueVisitors/summary.totalViews)*100)}%</span>}
          </div>
          <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">{summary.uniqueVisitors.toLocaleString('fr-FR')}</div>
          <p class="text-xs text-gray-500 mt-1.5 font-medium">Visiteurs uniques</p>
          <div class="flex items-center justify-between mt-1">
            <p class="text-xs text-gray-600">{summary.cleanViews.toLocaleString('fr-FR')} nettes</p>
            {deltaUniques.neutral ? <span class="delta-neu">—</span> : deltaUniques.pos ? <span class="delta-pos">↑ {deltaUniques.val}%</span> : <span class="delta-neg">↓ {deltaUniques.val}%</span>}
          </div>
        </div>
        <div class="kpi-card fade-slide d-2 p-5 glass rounded-2xl border border-white/8" style="--glow:#bf00ff">
          <div class="flex items-start justify-between mb-4">
            <div class="w-8 h-8 rounded-lg bg-neon-purple/10 border border-neon-purple/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
            </div>
            <div set:html={clickSparkline} class="opacity-60 mt-1"></div>
          </div>
          <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">{summary.totalClicks.toLocaleString('fr-FR')}</div>
          <p class="text-xs text-gray-500 mt-1.5 font-medium">Clics sur liens</p>
          <div class="flex items-center justify-between mt-1">
            <p class="text-xs text-gray-600">CTR {summary.clickRate.toFixed(1)}%</p>
            {deltaClicks.neutral ? <span class="delta-neu">—</span> : deltaClicks.pos ? <span class="delta-pos">↑ {deltaClicks.val}%</span> : <span class="delta-neg">↓ {deltaClicks.val}%</span>}
          </div>
        </div>
        <div class="kpi-card fade-slide d-3 p-5 glass rounded-2xl border border-white/8" style="--glow:#ff6b6b">
          <div class="flex items-start justify-between mb-4">
            <div class="w-8 h-8 rounded-lg bg-neon-pink/10 border border-neon-pink/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <span class={`text-xs px-2 py-0.5 rounded-full border font-mono mt-1 ${summary.clickRate >= 10 ? 'text-neon-green/70 bg-neon-green/8 border-neon-green/15' : summary.clickRate >= 5 ? 'text-yellow-400/70 bg-yellow-400/8 border-yellow-400/15' : 'text-gray-500 bg-white/5 border-white/10'}`}>
              {summary.clickRate >= 10 ? '🔥 Top' : summary.clickRate >= 5 ? '↗ Bien' : '· Faible'}
            </span>
          </div>
          <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">{summary.clickRate.toFixed(1)}<span class="text-lg text-gray-400">%</span></div>
          <p class="text-xs text-gray-500 mt-1.5 font-medium">Taux de clic</p>
          <p class="text-xs text-gray-600 mt-1">clics / vues</p>
        </div>
        <div class="kpi-card fade-slide d-4 p-5 glass rounded-2xl border border-white/8 cursor-default" style="--glow:#f59e0b">
          <div class="flex items-start justify-between mb-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.2)">
              <svg class="w-3.5 h-3.5" style="color:#f59e0b" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
            </div>
            <span class="text-xs px-2 py-0.5 rounded-full border font-mono mt-1" style="color:rgba(245,158,11,.7);background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.15)">{leadRate.toFixed(1)}%</span>
          </div>
          <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">{leads.toLocaleString('fr-FR')}</div>
          <p class="text-xs text-gray-500 mt-1.5 font-medium">Leads</p>
          <div class="flex items-center justify-between mt-1">
            <p class="text-xs text-gray-600">{sales} ventes · {convRate.toFixed(1)}%</p>
            {deltaLeads.neutral ? <span class="delta-neu">—</span> : deltaLeads.pos ? <span class="delta-pos">↑ {deltaLeads.val}%</span> : <span class="delta-neg">↓ {deltaLeads.val}%</span>}
          </div>
        </div>
        <div class="kpi-card fade-slide d-5 p-5 glass rounded-2xl border border-white/8 cursor-default" style="--glow:#a78bfa">
          <div class="flex items-start justify-between mb-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.2)">
              <svg class="w-3.5 h-3.5" style="color:#a78bfa" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div set:html={revenueSparkline} class="opacity-60 mt-1"></div>
          </div>
          <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">
            {revenue > 0 ? revenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}) : '—'}
          </div>
          <p class="text-xs text-gray-500 mt-1.5 font-medium">Revenue</p>
          <div class="flex items-center justify-between mt-1">
            <p class="text-xs text-gray-600">{sales > 0 ? `CPA ${(revenue/sales).toFixed(0)}€` : 'Aucune vente'}</p>
            {deltaRevenue.neutral ? <span class="delta-neu">—</span> : deltaRevenue.pos ? <span class="delta-pos">↑ {deltaRevenue.val}%</span> : <span class="delta-neg">↓ {deltaRevenue.val}%</span>}
          </div>
        </div>
      </div>

      <!-- Smart Alerts -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <h3 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
          Alertes intelligentes
          {alertCount > 0 && <span class="text-xs font-bold px-2 py-0.5 rounded-full" style="background:rgba(248,113,113,.12);color:#f87171;border:0.5px solid rgba(248,113,113,.25)">{alertCount} active{alertCount > 1 ? 's' : ''}</span>}
        </h3>
        <div class="space-y-2">
          {alerts.map(a => (
            <div class={`flex gap-3 p-3.5 rounded-xl border ${a.type === 'warning' ? 'alert-warning' : a.type === 'success' ? 'alert-success' : 'alert-info'}`}>
              <span class="text-lg shrink-0 leading-none mt-0.5">{a.icon}</span>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-white mb-0.5">{a.title}</p>
                <p class="text-xs text-gray-400 leading-relaxed">{a.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Funnel -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <h3 class="text-sm font-semibold text-white mb-5">Funnel de conversion <span class="text-gray-600 font-normal text-xs ml-1">· {days}j</span></h3>
        <div class="space-y-3">
          {funnelSteps.map((step, i) => {
            const prev     = i > 0 ? funnelSteps[i-1].value : step.value;
            const dropPct  = prev > 0 && i > 0 ? (1 - step.value/prev)*100 : 0;
            const widthPct = funnelSteps[0].value > 0 ? (step.value/funnelSteps[0].value)*100 : 0;
            return (
              <div>
                <div class="flex items-center justify-between mb-1.5">
                  <div class="flex items-center gap-2.5">
                    <div class="w-6 h-6 rounded-lg flex items-center justify-center text-xs font-bold shrink-0" style={`background:${step.color}18;border:.5px solid ${step.color}35;color:${step.color}`}>{i+1}</div>
                    <span class="text-sm font-semibold text-white">{step.label}</span>
                    {i > 0 && dropPct > 0 && <span class="text-xs px-2 py-0.5 rounded-full" style="color:rgba(248,113,113,.7);background:rgba(248,113,113,.08);border:.5px solid rgba(248,113,113,.15)">↓ {dropPct.toFixed(0)}% drop</span>}
                  </div>
                  <span class="text-sm font-bold tabular-nums" style={`color:${step.color}`}>{step.value.toLocaleString('fr-FR')}</span>
                </div>
                <div class="bar-track" style="height:6px"><div class="bar-fill" style={`width:${widthPct}%;background:${step.color};opacity:.75;animation-delay:${i*100}ms`}></div></div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Score IA + Prédictions + Objectifs -->
      <div class="grid lg:grid-cols-3 gap-4">
        <!-- Score -->
        <div class="p-5 glass rounded-2xl border border-white/8 flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <div><h3 class="text-sm font-semibold text-white">Score de performance</h3><p class="text-xs text-gray-500 mt-0.5">Analyse · {days}j</p></div>
            <div class="flex flex-col items-center justify-center w-14 h-14 rounded-2xl border-2" style={`border-color:${perfColor}40;background:${perfColor}10`}>
              <span class="text-xl font-black" style={`color:${perfColor}`}>{perfGrade}</span>
              <span class="text-xs font-bold" style={`color:${perfColor};opacity:.7`}>{perfScore}</span>
            </div>
          </div>
          <div>
            <div class="flex justify-between mb-1.5 text-xs"><span class="text-gray-500">Score global</span><span class="font-bold" style={`color:${perfColor}`}>{perfScore}/100</span></div>
            <div class="bar-track" style="height:6px"><div class="bar-fill" style={`width:${perfScore}%;background:${perfColor};animation-delay:200ms`}></div></div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            {[{label:'CTR',val:scoreCTR},{label:'Croissance',val:scoreGrowth},{label:'Conversion',val:scoreConversion},{label:'Revenue',val:scoreRevenue}].map(s => (
              <div class="p-2 rounded-xl" style="background:rgba(255,255,255,.04)">
                <div class="flex justify-between text-xs mb-1"><span class="text-gray-500">{s.label}</span><span class="text-white font-semibold">{s.val}/25</span></div>
                <div class="bar-track" style="height:3px"><div class="bar-fill" style={`width:${(s.val/25)*100}%;background:${perfColor};opacity:.7`}></div></div>
              </div>
            ))}
          </div>
          <div class="space-y-2 pt-2 border-t border-white/6">
            <p class="text-xs text-gray-600 uppercase tracking-widest font-medium">Recommandations</p>
            {topRecos.map(r => <div class="flex gap-2 text-xs text-gray-400 leading-relaxed"><span class="shrink-0 mt-0.5" style={`color:${perfColor}`}>→</span><span>{r}</span></div>)}
          </div>
        </div>
        <!-- Prédictions -->
        <div class="p-5 glass rounded-2xl border border-white/8 flex flex-col gap-4">
          <div><h3 class="text-sm font-semibold text-white">Prédictions 30 jours</h3><p class="text-xs text-gray-500 mt-0.5">Tendance actuelle</p></div>
          {proj30Views === 0 && proj30Clicks === 0 ? (
            <div class="flex-1 flex items-center justify-center text-gray-700 text-sm text-center py-8">Pas assez de données<br/>(min 3 jours)</div>
          ) : (
            <div class="space-y-5">
              <div>
                <div class="flex items-center justify-between mb-2"><span class="text-xs text-gray-500">Vues / 30j</span><span class="text-sm font-bold tabular-nums" style="color:#00ff9d">{proj30Views.toLocaleString('fr-FR')}</span></div>
                <div set:html={predSparkViews}></div>
              </div>
              <div>
                <div class="flex items-center justify-between mb-2"><span class="text-xs text-gray-500">Clics / 30j</span><span class="text-sm font-bold tabular-nums" style="color:#38bdf8">{proj30Clicks.toLocaleString('fr-FR')}</span></div>
                <div set:html={predSparkClicks}></div>
              </div>
              {proj30Revenue > 0 && (
                <div class="p-3 rounded-xl border" style="background:rgba(167,139,250,.06);border-color:rgba(167,139,250,.15)">
                  <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-500">Revenue projeté / 30j</span>
                    <span class="text-sm font-bold" style="color:#a78bfa">{proj30Revenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0})}</span>
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
        <!-- Objectifs -->
        <div class="p-5 glass rounded-2xl border border-white/8 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <div><h3 class="text-sm font-semibold text-white">Objectifs</h3><p class="text-xs text-gray-500 mt-0.5">Cibles pour la période</p></div>
            <button id="edit-goals-btn" class="no-print text-xs text-gray-500 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/8">Modifier</button>
          </div>
          <div id="goals-list" class="space-y-3 flex-1"><div class="flex items-center justify-center h-20 text-gray-700 text-xs text-center">Chargement…</div></div>
          <div id="goals-editor" class="hidden space-y-3 pt-3 border-t border-white/6">
            <p class="text-xs text-gray-600 uppercase tracking-widest font-medium">Définir tes objectifs</p>
            {[{id:'goal-views',label:'Vues',ph:'ex: 5000'},{id:'goal-clicks',label:'Clics',ph:'ex: 500'},{id:'goal-leads',label:'Leads',ph:'ex: 50'},{id:'goal-revenue',label:'Revenue €',ph:'ex: 1000'}].map(g => (
              <div class="flex items-center gap-2">
                <label class="text-xs text-gray-500 w-24 shrink-0">{g.label}</label>
                <input type="number" id={g.id} placeholder={g.ph} min="0" class="flex-1 px-3 py-1.5 glass border border-white/10 rounded-lg text-white text-xs focus:border-neon-green/40 focus:outline-none" />
              </div>
            ))}
            <button id="save-goals-btn" class="w-full py-2 rounded-xl text-xs font-bold" style="background:rgba(0,255,157,.1);border:1px solid rgba(0,255,157,.25);color:#00ff9d">Sauvegarder</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ TRAFIC & AUDIENCE ══ -->
  <div class="sec-panel" id="panel-traffic">
    <div class="space-y-5">

      <!-- Chart trafic + Appareils -->
      <div class="bento bento-main">
        <div class="p-5 glass rounded-2xl border border-white/8">
          <div class="flex items-center justify-between mb-5">
            <div><h3 class="text-sm font-semibold text-white">Trafic</h3><p class="text-xs text-gray-500 mt-0.5">Vues & clics · {days}j</p></div>
            <div class="flex items-center gap-4">
              <span class="flex items-center gap-1.5 text-xs text-gray-400"><span class="w-3 h-0.5 bg-neon-green rounded-full inline-block"></span>Vues</span>
              <span class="flex items-center gap-1.5 text-xs text-gray-400"><span class="w-3 h-0.5 bg-neon-purple rounded-full inline-block"></span>Clics</span>
            </div>
          </div>
          {chartLabels.length === 0 ? (
            <div class="flex flex-col items-center justify-center h-52 text-gray-600">
              <p class="text-sm">Aucune donnée sur cette période</p>
            </div>
          ) : <canvas id="traffic-chart" style="max-height:240px;width:100%"></canvas>}
        </div>
        <div class="flex flex-col gap-4">
          <div class="p-5 glass rounded-2xl border border-white/8 flex-1">
            <h3 class="text-sm font-semibold text-white mb-4">Appareils</h3>
            {deviceTotal === 0 ? <p class="text-sm text-gray-600 text-center py-6">Aucune donnée</p> : (
              <div class="space-y-3">
                {[
                  {key:'mobile', label:'Mobile', color:'#00ff9d', icon:'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z'},
                  {key:'desktop',label:'Desktop',color:'#bf00ff', icon:'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'},
                  {key:'tablet', label:'Tablet', color:'#00aaff', icon:'M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'},
                ].map(dev => {
                  const val = deviceData[dev.key as keyof typeof deviceData];
                  const pct = deviceTotal > 0 ? Math.round((val/deviceTotal)*100) : 0;
                  if (val === 0) return null;
                  return (
                    <div>
                      <div class="flex items-center justify-between mb-1.5">
                        <span class="flex items-center gap-2 text-xs text-gray-400">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" style={`color:${dev.color}`} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={dev.icon}/></svg>
                          {dev.label}
                        </span>
                        <span class="text-xs font-semibold text-white tabular-nums">{pct}%</span>
                      </div>
                      <div class="bar-track"><div class="bar-fill" style={`width:${pct}%;background:${dev.color};animation-delay:${pct*3}ms`}></div></div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
          {chartLabels.length > 0 && (
            <div class="p-5 glass rounded-2xl border border-white/8">
              <h3 class="text-sm font-semibold text-white mb-1">CTR / jour</h3>
              <canvas id="rate-chart" style="max-height:80px;width:100%"></canvas>
            </div>
          )}
        </div>
      </div>

      <!-- Retention -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-5">
          <div><h3 class="text-sm font-semibold text-white">Retention des visiteurs</h3><p class="text-xs text-gray-500 mt-0.5">Nouveaux vs récurrents · {days}j</p></div>
        </div>
        <div class="grid sm:grid-cols-3 gap-4 mb-5">
          <div class="p-4 rounded-xl" style="background:rgba(0,255,157,.06);border:.5px solid rgba(0,255,157,.15)">
            <p class="text-xs text-gray-500 mb-1">Visiteurs uniques</p>
            <p class="text-2xl font-bold text-neon-green tabular-nums">{summary.uniqueVisitors.toLocaleString('fr-FR')}</p>
            <p class="text-xs text-gray-600 mt-1">{retentionRate}% du trafic total</p>
          </div>
          <div class="p-4 rounded-xl" style="background:rgba(56,189,248,.06);border:.5px solid rgba(56,189,248,.15)">
            <p class="text-xs text-gray-500 mb-1">Visites récurrentes</p>
            <p class="text-2xl font-bold tabular-nums" style="color:#38bdf8">{returningVisitors.toLocaleString('fr-FR')}</p>
            <p class="text-xs text-gray-600 mt-1">{returningRate}% du trafic total</p>
          </div>
          <div class="p-4 rounded-xl" style="background:rgba(167,139,250,.06);border:.5px solid rgba(167,139,250,.15)">
            <p class="text-xs text-gray-500 mb-1">Taux de retour</p>
            <p class="text-2xl font-bold tabular-nums" style="color:#a78bfa">{returningRate}%</p>
            <p class="text-xs text-gray-600 mt-1">{prevRetentionRate > 0 ? `${prevRetentionRate}% période préc.` : 'Pas de comparaison'}</p>
          </div>
        </div>
        <!-- Stacked bar new vs returning per day -->
        <canvas id="retention-chart" style="max-height:120px;width:100%"></canvas>
      </div>

      <!-- Carte + Sources (tabs internes) -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center gap-1 mb-6 border-b border-white/8 pb-3 overflow-x-auto scrollbar-none">
          {[
            {id:'geo',     label:'Géographie', icon:'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064'},
            {id:'sources', label:'Sources',    icon:'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.1-1.1m-.757-4.9a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1'},
          ].map((tab, i) => (
            <button class={`insight-tab-inner flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-all ${i===0?'active text-white bg-white/8':'text-gray-500 hover:text-gray-300'}`} data-inner-tab={tab.id}>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tab.icon}/></svg>
              {tab.label}
            </button>
          ))}
        </div>
        <!-- Geo panel -->
        <div class="insight-panel active" id="inner-panel-geo">
          {topCountries.length === 0 ? (
            <p class="text-sm text-gray-600 text-center py-8">Aucune donnée géographique</p>
          ) : (
            <div>
              <div class="relative rounded-xl overflow-hidden mb-5" style="background:#07100d;">
                <div id="world-map-loader" class="absolute inset-0 flex items-center justify-center z-10"><div class="map-spinner"></div></div>
                <svg id="world-map" style="width:100%;height:320px;display:block;opacity:0;transition:opacity 0.5s;cursor:grab;"></svg>
                <div id="map-tooltip" class="pointer-events-none absolute hidden z-20 bg-black/95 border border-neon-green/25 text-white text-xs px-3 py-2 rounded-lg backdrop-blur-sm shadow-xl whitespace-nowrap"></div>
                <div class="absolute bottom-3 right-3 z-20 flex flex-col gap-1">
                  <button id="map-zoom-in"  class="w-7 h-7 rounded-lg glass border border-white/10 text-gray-400 hover:text-neon-green transition-all flex items-center justify-center text-base leading-none">+</button>
                  <button id="map-zoom-out" class="w-7 h-7 rounded-lg glass border border-white/10 text-gray-400 hover:text-neon-green transition-all flex items-center justify-center text-base leading-none">−</button>
                  <button id="map-reset"    class="w-7 h-7 rounded-lg glass border border-white/10 text-gray-400 hover:text-neon-green transition-all flex items-center justify-center">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  </button>
                </div>
              </div>
              <div class="grid sm:grid-cols-2 gap-2">
                {topCountries.slice(0,8).map((ctry,i) => {
                  const pct = Math.round((ctry.views/maxCountryViews)*100);
                  return (
                    <div class="country-row flex items-center gap-2.5 px-3 py-2 rounded-xl border border-white/5 hover:border-neon-green/20 hover:bg-neon-green/3 transition-all cursor-default group" data-iso={ctry.country}>
                      <span class="text-base leading-none shrink-0 w-6 text-center">{countryFlag(ctry.country ?? '')}</span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2 mb-1">
                          <span class="text-xs text-gray-300 font-medium group-hover:text-neon-green transition-colors truncate">{ctry.country||'??'}</span>
                          <span class="text-xs text-gray-600 tabular-nums font-mono shrink-0">{ctry.views.toLocaleString('fr-FR')}</span>
                        </div>
                        <div class="bar-track"><div class="bar-fill" style={`width:${pct}%;background:linear-gradient(90deg,#00ff9d,#00ff9d40);animation-delay:${i*50}ms`}></div></div>
                      </div>
                      <span class="text-xs shrink-0 w-5 text-right opacity-50">{i<3?['🥇','🥈','🥉'][i]:`#${i+1}`}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          )}
        </div>
        <!-- Sources panel -->
        <div class="insight-panel" id="inner-panel-sources">
          {aggregatedReferrers.length === 0 ? (
            <p class="text-sm text-gray-600 text-center py-8">Aucune source identifiée</p>
          ) : (
            <div class="space-y-3">
              {aggregatedReferrers.map((r,i) => {
                const pct   = Math.round((r.views/maxReferrerViews)*100);
                const color = CAT_COLORS[r.category] ?? '#9ca3af';
                const label = CAT_LABELS[r.category] ?? r.category;
                return (
                  <div class="flex items-center gap-3">
                    <div class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-xs font-bold text-gray-600 border border-white/8 bg-white/3">{i+1}</div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between mb-1">
                        <div class="flex items-center gap-2 min-w-0">
                          <span class="text-sm text-white font-medium truncate">{r.label}</span>
                          <span class="source-badge shrink-0" style={`background:${color}15;color:${color};border:1px solid ${color}30`}>{label}</span>
                        </div>
                        <span class="text-xs text-gray-500 tabular-nums font-mono ml-2 shrink-0">{r.views.toLocaleString('fr-FR')}</span>
                      </div>
                      <div class="bar-track"><div class="bar-fill" style={`width:${pct}%;background:${color}70;animation-delay:${i*60}ms`}></div></div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>

    </div>
  </div>

  <!-- ══ REVENUS & CONVERSION ══ -->
  <div class="sec-panel" id="panel-revenue">
    <div class="space-y-5">

      <!-- Attribution par canal -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-5">
          <div><h3 class="text-sm font-semibold text-white">Attribution par canal</h3><p class="text-xs text-gray-500 mt-0.5">Organic · Paid · Email · Influenceurs</p></div>
          {!isPro && <span class="badge-pro">⚡ Pro pour UTM réel</span>}
        </div>
        {channels.length === 0 ? (
          <p class="text-sm text-gray-700 text-center py-6">Ajoute des paramètres UTM à tes liens pour tracker les sources</p>
        ) : (
          <div class="space-y-1">
            <div class="grid grid-cols-12 gap-2 px-3 pb-2 border-b border-white/6">
              <span class="col-span-3 text-xs text-gray-600 font-medium uppercase tracking-wider">Canal</span>
              <span class="col-span-2 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Vues</span>
              <span class="col-span-2 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Leads</span>
              <span class="col-span-2 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Revenue</span>
              <span class="col-span-3 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Part</span>
            </div>
            {channels.map((ch,i) => {
              const sharePct = totalChViews > 0 ? Math.round((ch.views/totalChViews)*100) : 0;
              const chClass  = ch.name.includes('Google')?'ch-google':ch.name.includes('Meta')?'ch-meta':ch.name.includes('TikTok')?'ch-tiktok':(ch.name.includes('Organic')||ch.name==='SEO')?'ch-organic':ch.name==='Email'?'ch-email':ch.name==='Influenceurs'?'ch-infl':ch.name==='Direct'?'ch-direct':'ch-other';
              return (
                <div class="grid grid-cols-12 gap-2 items-center px-3 py-2.5 rounded-xl hover:bg-white/3 transition-colors">
                  <div class="col-span-3"><span class={`text-xs font-bold px-2 py-0.5 rounded-full ${chClass}`}>{ch.name}</span></div>
                  <span class="col-span-2 text-sm text-white font-semibold tabular-nums text-right">{ch.views.toLocaleString('fr-FR')}</span>
                  <span class="col-span-2 text-sm tabular-nums text-right" style="color:#f59e0b">{ch.leads>0?ch.leads:<span class="text-gray-700">—</span>}</span>
                  <span class="col-span-2 text-sm tabular-nums text-right" style="color:#a78bfa">{ch.revenue>0?ch.revenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}):<span class="text-gray-700">—</span>}</span>
                  <div class="col-span-3 flex items-center gap-2">
                    <div class="bar-track flex-1" style="height:4px"><div class="bar-fill" style={`width:${sharePct}%;background:#00ff9d60;animation-delay:${i*50}ms`}></div></div>
                    <span class="text-xs text-gray-500 tabular-nums w-7 text-right">{sharePct}%</span>
                  </div>
                </div>
              );
            })}
          </div>
        )}
        {isPro && channels.some(c => c.revenue > 0) && (
          <div class="mt-4 pt-4 border-t border-white/6">
            <p class="text-xs text-gray-600 uppercase tracking-widest font-medium mb-3">Revenue par canal</p>
            <canvas id="roas-chart" style="max-height:100px;width:100%"></canvas>
          </div>
        )}
      </div>

      <!-- Funnel revenue -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <h3 class="text-sm font-semibold text-white mb-5">Funnel revenus <span class="text-gray-600 font-normal text-xs ml-1">· {days}j</span></h3>
        <div class="space-y-3">
          {funnelSteps.map((step,i) => {
            const prev     = i > 0 ? funnelSteps[i-1].value : step.value;
            const dropPct  = prev > 0 && i > 0 ? (1-step.value/prev)*100 : 0;
            const widthPct = funnelSteps[0].value > 0 ? (step.value/funnelSteps[0].value)*100 : 0;
            return (
              <div>
                <div class="flex items-center justify-between mb-1.5">
                  <div class="flex items-center gap-2.5">
                    <div class="w-6 h-6 rounded-lg flex items-center justify-center text-xs font-bold shrink-0" style={`background:${step.color}18;border:.5px solid ${step.color}35;color:${step.color}`}>{i+1}</div>
                    <span class="text-sm font-semibold text-white">{step.label}</span>
                    {i > 0 && dropPct > 0 && <span class="text-xs px-2 py-0.5 rounded-full" style="color:rgba(248,113,113,.7);background:rgba(248,113,113,.08);border:.5px solid rgba(248,113,113,.15)">↓ {dropPct.toFixed(0)}% drop</span>}
                  </div>
                  <span class="text-sm font-bold tabular-nums" style={`color:${step.color}`}>{step.value.toLocaleString('fr-FR')}</span>
                </div>
                <div class="bar-track" style="height:6px"><div class="bar-fill" style={`width:${widthPct}%;background:${step.color};opacity:.75;animation-delay:${i*100}ms`}></div></div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- UTM Campaigns (Pro gate) -->
      <div class="p-5 glass rounded-2xl border border-white/8" style="position:relative;overflow:hidden">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h3 class="text-sm font-semibold text-white flex items-center gap-2">Campagnes UTM <span class="badge-pro">⚡ Pro</span></h3>
            <p class="text-xs text-gray-500 mt-0.5">source · medium · campaign · device · pays · CPA</p>
          </div>
          {isPro && utmData.length > 0 && <span class="text-xs text-gray-600">{utmData.length} événements</span>}
        </div>
        {!isPro ? (
          <div style="position:absolute;inset:0;z-index:10;display:flex;flex-direction:column;align-items:center;justify-content:center;backdrop-filter:blur(8px);background:rgba(0,0,0,.72);border-radius:inherit">
            <div class="text-center px-8 py-6">
              <div class="text-3xl mb-3">⚡</div>
              <p class="text-sm font-bold text-white mb-1">Tracking UTM avancé</p>
              <p class="text-xs text-gray-500 mb-5 max-w-xs mx-auto">Suis chaque campagne Google, Meta, TikTok avec source / medium / device / pays et calcule ROAS et CPA automatiquement.</p>
              <a href="/dashboard/billing" style="display:inline-flex;padding:10px 20px;border-radius:12px;background:rgba(168,85,247,.2);border:1px solid rgba(168,85,247,.4);color:#c084fc;font-size:14px;font-weight:700;text-decoration:none">Passer Pro →</a>
            </div>
          </div>
        ) : utmData.length === 0 ? (
          <div class="text-center py-8 text-gray-700">
            <p class="text-sm">Aucun événement UTM sur cette période</p>
            <p class="text-xs mt-1">Ajoute <code class="text-neon-green">?utm_source=google&utm_medium=cpc&utm_campaign=nom</code></p>
          </div>
        ) : (
          <div class="overflow-x-auto -mx-1 scrollbar-none">
            <table class="w-full text-sm min-w-[680px]">
              <thead>
                <tr>{['Campaign','Source','Medium','Vues','Leads','Revenue','CPA','Device','Pays'].map(h => <th class="text-left pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5 whitespace-nowrap">{h}</th>)}</tr>
              </thead>
              <tbody>
                {utmCamps.map(c => {
                  const cpa   = c.sales > 0 ? `${(c.revenue/c.sales).toFixed(0)}€` : '—';
                  const chCls = c.medium?.toLowerCase().includes('cpc') ? 'ch-google' : 'ch-organic';
                  return (
                    <tr class="border-b border-white/4 last:border-0 hover:bg-white/2 transition-colors">
                      <td class="py-2.5 px-2 text-white text-xs font-medium max-w-[110px] truncate">{c.campaign}</td>
                      <td class="py-2.5 px-2"><span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${chCls}`}>{c.source||'—'}</span></td>
                      <td class="py-2.5 px-2 text-gray-500 text-xs">{c.medium||'—'}</td>
                      <td class="py-2.5 px-2 tabular-nums font-semibold text-white">{c.views.toLocaleString('fr-FR')}</td>
                      <td class="py-2.5 px-2 tabular-nums text-xs" style="color:#f59e0b">{c.leads>0?c.leads:<span class="text-gray-700">—</span>}</td>
                      <td class="py-2.5 px-2 tabular-nums text-xs" style="color:#a78bfa">{c.revenue>0?c.revenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}):<span class="text-gray-700">—</span>}</td>
                      <td class="py-2.5 px-2 tabular-nums text-gray-400 text-xs">{cpa}</td>
                      <td class="py-2.5 px-2 text-gray-400 text-xs capitalize">{c.topDevice}</td>
                      <td class="py-2.5 px-2 text-gray-400 text-xs">{c.topCountry!=='—'?`${countryFlag(c.topCountry)} ${c.topCountry}`:'—'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>

    </div>
  </div>

  <!-- ══ CONTENU ══ -->
  <div class="sec-panel" id="panel-content">
    <div class="space-y-5">

      <!-- Heatmap Blocs -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-5">
          <div><h3 class="text-sm font-semibold text-white">Heatmap des clics</h3><p class="text-xs text-gray-500 mt-0.5">Intensité par position · {blocks.length} blocs</p></div>
        </div>
        {heatmapBlocks.length === 0 ? (
          <div class="text-center py-8">
            <p class="text-sm text-gray-600 mb-2">Aucun clic enregistré</p>
            <a href="/dashboard/blocks" class="text-xs text-neon-green hover:underline">Ajouter des blocs →</a>
          </div>
        ) : (
          <div>
            <div class="grid grid-cols-1 gap-1.5 mb-4">
              {heatmapBlocks.map((block,i) => {
                const ctr   = summary.totalViews > 0 ? ((block.clicks/summary.totalViews)*100).toFixed(1) : '0.0';
                const alpha = block.intensity > 0 ? Math.max(0.06, block.intensity*0.85) : 0.03;
                const bdr   = block.intensity > 0.5 ? `rgba(0,255,157,${Math.min(0.55,block.intensity)})` : 'rgba(255,255,255,.06)';
                const heat  = block.intensity >= 0.8 ? '🔥' : block.intensity >= 0.5 ? '↑' : '';
                return (
                  <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all" style={`background:rgba(0,255,157,${alpha});border:.5px solid ${bdr}`}>
                    <div class="w-6 h-6 rounded-lg flex items-center justify-center text-xs font-bold shrink-0 border"
                      style={block.intensity>0.5?'background:rgba(0,255,157,.15);border-color:rgba(0,255,157,.3);color:#00ff9d':'background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.1);color:#6b7280'}>
                      {block.position}
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1.5">
                        <span class="text-xs px-1.5 py-0.5 rounded border border-white/10 bg-white/5 text-gray-400">{block.type}</span>
                        <span class="text-sm font-medium truncate" style={`color:${block.intensity>0?'#fff':'rgba(255,255,255,.4)'}`}>{block.title}</span>
                        {heat && <span class="text-xs shrink-0">{heat}</span>}
                      </div>
                      <div class="relative h-2 rounded-full overflow-hidden" style="background:rgba(255,255,255,.04)">
                        <div class="h-full rounded-full" style={`width:${(block.intensity*100).toFixed(1)}%;background:linear-gradient(90deg,rgba(0,255,157,${Math.max(.3,block.intensity)}),rgba(0,255,157,${Math.max(.1,block.intensity*.4)}));animation:barGrow .9s cubic-bezier(.16,1,.3,1) both;animation-delay:${i*60}ms`}></div>
                      </div>
                    </div>
                    <div class="text-right shrink-0 pl-1">
                      <div class="text-sm font-bold tabular-nums" style={`color:${block.intensity>.5?'#00ff9d':block.intensity>0?'#fff':'rgba(255,255,255,.3)'}`}>{block.clicks.toLocaleString('fr-FR')}</div>
                      <div class="text-xs text-gray-600">{ctr}%</div>
                    </div>
                  </div>
                );
              })}
            </div>
            <div class="flex items-center gap-3 pt-3 border-t border-white/6">
              <span class="text-xs text-gray-700">Intensité :</span>
              {[.1,.3,.6,.85,1].map(v => (
                <div class="flex items-center gap-1">
                  <div class="w-4 h-4 rounded" style={`background:rgba(0,255,157,${Math.max(.06,v*.85)})`}></div>
                  <span class="text-xs text-gray-700">{Math.round(v*100)}%</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- A/B Test blocs -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-5">
          <div><h3 class="text-sm font-semibold text-white">Comparaison de blocs</h3><p class="text-xs text-gray-500 mt-0.5">Top {abBlocks.length} blocs côte-à-côte</p></div>
        </div>
        {abBlocks.length < 2 ? (
          <p class="text-sm text-gray-700 text-center py-6">Pas assez de clics pour comparer (min 2 blocs avec des clics)</p>
        ) : (
          <div class="grid sm:grid-cols-2 gap-3">
            {abBlocks.slice(0,4).map((block,i) => {
              const ctr       = summary.totalViews > 0 ? ((block.clicks/summary.totalViews)*100) : 0;
              const maxClicks = abBlocks[0]?.clicks ?? 1;
              const relScore  = maxClicks > 0 ? (block.clicks/maxClicks)*100 : 0;
              const isWinner  = i === 0;
              return (
                <div class={`p-4 rounded-xl border transition-all ${isWinner ? 'border-neon-green/25 bg-neon-green/4' : 'border-white/8 bg-white/2'}`}>
                  <div class="flex items-start justify-between mb-3">
                    <div class="flex items-center gap-2 min-w-0">
                      <span class="text-xs px-1.5 py-0.5 rounded border border-white/10 bg-white/5 text-gray-400 shrink-0">{block.type}</span>
                      <span class="text-xs font-medium text-white truncate">{block.title}</span>
                    </div>
                    {isWinner && <span class="text-xs font-bold shrink-0 ml-2" style="color:#00ff9d">🏆 Best</span>}
                  </div>
                  <div class="grid grid-cols-3 gap-2 mb-3">
                    <div class="text-center">
                      <p class="text-lg font-bold tabular-nums" style={`color:${isWinner?'#00ff9d':'#fff'}`}>{block.clicks.toLocaleString('fr-FR')}</p>
                      <p class="text-xs text-gray-600">clics</p>
                    </div>
                    <div class="text-center">
                      <p class="text-lg font-bold tabular-nums text-white">{ctr.toFixed(1)}%</p>
                      <p class="text-xs text-gray-600">CTR</p>
                    </div>
                    <div class="text-center">
                      <p class="text-lg font-bold tabular-nums text-white">#{block.position}</p>
                      <p class="text-xs text-gray-600">position</p>
                    </div>
                  </div>
                  <div class="bar-track" style="height:4px">
                    <div class="bar-fill" style={`width:${relScore}%;background:${isWinner?'#00ff9d':'rgba(255,255,255,.25)'};animation-delay:${i*80}ms`}></div>
                  </div>
                  <p class="text-xs text-gray-700 mt-1.5">{relScore.toFixed(0)}% du meilleur bloc</p>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <!-- Short URL Tracker (Creator+) -->
      {isCreator && (
        <div class="p-5 glass rounded-2xl border border-white/8">
          <div class="flex items-center justify-between mb-5">
            <div>
              <h3 class="text-sm font-semibold text-white flex items-center gap-2">Short URL Tracker <span class="badge-creator">👑 Creator</span></h3>
              <p class="text-xs text-gray-500 mt-0.5">Performance de chaque lien court · {shortUrls.length} lien{shortUrls.length!==1?'s':''}</p>
            </div>
            <a href="/dashboard/links" class="text-xs text-neon-green/70 hover:text-neon-green transition-colors">Gérer →</a>
          </div>
          {shortUrls.length === 0 ? (
            <div class="text-center py-8 text-gray-700">
              <p class="text-sm">Aucun lien court créé</p>
              <a href="/dashboard/links" class="text-xs text-neon-green hover:underline mt-1 inline-block">Créer un lien →</a>
            </div>
          ) : (
            <div class="overflow-x-auto -mx-1 scrollbar-none">
              <table class="w-full text-sm min-w-[520px]">
                <thead>
                  <tr>
                    <th class="text-left pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Lien</th>
                    <th class="text-left pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5 hidden sm:table-cell">Destination</th>
                    <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Clics</th>
                    <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5 hidden md:table-cell">Créé</th>
                    <th class="pb-3 px-2 border-b border-white/5 w-28 hidden lg:table-cell"></th>
                  </tr>
                </thead>
                <tbody>
                  {shortUrls.map((link,i) => {
                    const maxC   = shortUrls[0]?.click_count ?? 1;
                    const barPct = maxC > 0 ? Math.round((link.click_count/maxC)*100) : 0;
                    return (
                      <tr class="border-b border-white/4 last:border-0 hover:bg-white/2 transition-colors">
                        <td class="py-3 px-2">
                          <div class="flex items-center gap-2">
                            {i===0 && <span class="text-yellow-400 text-xs shrink-0">★</span>}
                            <span class="font-mono text-neon-green text-xs font-semibold">/{link.slug}</span>
                            {link.title && <span class="text-gray-500 text-xs truncate max-w-[90px] hidden sm:inline">{link.title}</span>}
                          </div>
                        </td>
                        <td class="py-3 px-2 hidden sm:table-cell"><span class="text-gray-500 text-xs">{link.target_url?.replace(/^https?:\/\/(www\.)?/,'').slice(0,36)}</span></td>
                        <td class="py-3 px-2 text-right"><span class={`font-semibold tabular-nums ${link.click_count>0?'text-neon-green':'text-gray-700'}`}>{(link.click_count??0).toLocaleString('fr-FR')}</span></td>
                        <td class="py-3 px-2 text-right text-gray-600 text-xs hidden md:table-cell">{new Date(link.created_at).toLocaleDateString('fr-FR',{day:'2-digit',month:'short'})}</td>
                        <td class="py-3 px-2 hidden lg:table-cell"><div class="bar-track" style="height:4px"><div class="bar-fill" style={`width:${barPct}%;background:#00ff9d60;animation-delay:${i*40}ms`}></div></div></td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}

      <!-- Tous les blocs -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-5">
          <div><h3 class="text-sm font-semibold text-white">Tous les blocs</h3><p class="text-xs text-gray-500 mt-0.5">Performance complète · {blocks.length} bloc{blocks.length!==1?'s':''}</p></div>
          <a href="/dashboard/blocks" class="text-xs text-neon-green/70 hover:text-neon-green transition-colors">Gérer →</a>
        </div>
        {blocks.length === 0 ? (
          <div class="text-center py-10 text-gray-600 text-sm"><a href="/dashboard/blocks" class="text-neon-green hover:underline">Ajouter des blocs</a></div>
        ) : (
          <div class="overflow-x-auto -mx-1 scrollbar-none">
            <table class="w-full text-sm min-w-[500px]">
              <thead>
                <tr>
                  <th class="text-left pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Bloc</th>
                  <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Clics</th>
                  <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">CTR</th>
                  <th class="text-center pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Statut</th>
                </tr>
              </thead>
              <tbody>
                {blocks.map((block,i) => {
                  const found       = topBlocks.find(tb => tb.block_id === block.id);
                  const blockClicks = found?.clicks ?? 0;
                  const ctr         = summary.totalViews > 0 ? ((blockClicks/summary.totalViews)*100).toFixed(1) : '0.0';
                  return (
                    <tr class="border-b border-white/4 last:border-0 hover:bg-white/2 transition-colors">
                      <td class="py-3 px-2">
                        <div class="flex items-center gap-2.5">
                          <span class="text-xs px-1.5 py-0.5 rounded border border-white/10 bg-white/5 text-gray-400">{block.type}</span>
                          <span class="text-white font-medium truncate max-w-[200px]">{block.title||'Untitled'}</span>
                          {i===0 && topBlocks.length>0 && !!found && <span class="text-xs text-yellow-400/70">★</span>}
                        </div>
                      </td>
                      <td class="py-3 px-2 text-right"><span class={`font-semibold tabular-nums ${blockClicks>0?'text-neon-green':'text-gray-700'}`}>{blockClicks.toLocaleString('fr-FR')}</span></td>
                      <td class="py-3 px-2 text-right text-gray-500 tabular-nums">{ctr}%</td>
                      <td class="py-3 px-2 text-center">
                        <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${block.active?'text-neon-green bg-neon-green/10':'text-gray-600 bg-white/5'}`}>
                          <span class={`w-1.5 h-1.5 rounded-full ${block.active?'bg-neon-green':'bg-gray-600'}`}></span>
                          {block.active?'Actif':'Inactif'}
                        </span>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>

    </div>
  </div>

  <!-- DATA BRIDGE -->
  <div aria-hidden="true" class="contents">
    <div id="chart-data" class="hidden"
      data-chart={JSON.stringify(exportedChart)}
      data-devices={JSON.stringify(exportedDevices)}
      data-days={String(exportedDays)}
      data-countries={JSON.stringify(topCountries)}
      data-channels={JSON.stringify(exportedChannels)}
      data-is-pro={String(isPro)}
      data-goals-views={String(summary.totalViews)}
      data-goals-clicks={String(summary.totalClicks)}
      data-goals-leads={String(leads)}
      data-goals-revenue={String(revenue)}
      data-retention={JSON.stringify(retentionData)}>
    </div>
  </div>

  <script>
    (async () => {
      const el = document.getElementById('chart-data');
      if (!el) return;
      const exportedChart    = JSON.parse(el.dataset.chart    ?? '{}');
      const exportedChannels = JSON.parse(el.dataset.channels ?? '[]');
      const exportedDays     = Number(el.dataset.days ?? 7);
      const isPro            = el.dataset.isPro === 'true';
      const retentionData    = JSON.parse(el.dataset.retention ?? '[]');

      // ── Chart.js ────────────────────────────────────────────────────────────
      await new Promise((resolve, reject) => {
        if (typeof Chart !== 'undefined') { resolve(null); return; }
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js';
        s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
      });

      Chart.defaults.font.family = 'DM Sans, system-ui, sans-serif';
      const GRID   = 'rgba(255,255,255,0.03)';
      const GREEN  = '#00ff9d';
      const PURPLE = '#bf00ff';

      // Traffic chart
      const trafficCtx = document.getElementById('traffic-chart');
      if (trafficCtx && exportedChart.labels?.length > 0) {
        new Chart(trafficCtx, {
          type: 'line',
          data: {
            labels: exportedChart.labels,
            datasets: [
              { label:'Vues',  data:exportedChart.views,  borderColor:GREEN,  backgroundColor:(ctx)=>{ const g=ctx.chart.ctx.createLinearGradient(0,0,0,ctx.chart.height); g.addColorStop(0,GREEN+'22'); g.addColorStop(1,GREEN+'00'); return g; }, borderWidth:2,tension:0.4,fill:true,pointRadius:0,pointHoverRadius:4,pointHoverBackgroundColor:GREEN,pointHoverBorderColor:'#0a0a0a',pointHoverBorderWidth:2 },
              { label:'Clics', data:exportedChart.clicks, borderColor:PURPLE, backgroundColor:(ctx)=>{ const g=ctx.chart.ctx.createLinearGradient(0,0,0,ctx.chart.height); g.addColorStop(0,PURPLE+'22'); g.addColorStop(1,PURPLE+'00'); return g; }, borderWidth:2,tension:0.4,fill:true,pointRadius:0,pointHoverRadius:4,pointHoverBackgroundColor:PURPLE,pointHoverBorderColor:'#0a0a0a',pointHoverBorderWidth:2 },
            ],
          },
          options: {
            responsive:true,maintainAspectRatio:false,
            interaction:{mode:'index',intersect:false},
            plugins:{ legend:{display:false}, tooltip:{backgroundColor:'#111115',titleColor:'#fff',bodyColor:'#9ca3af',borderColor:'rgba(255,255,255,0.08)',borderWidth:1,padding:12,displayColors:true,boxWidth:8,boxHeight:8,boxPadding:4,usePointStyle:true} },
            scales:{
              y:{beginAtZero:true,ticks:{color:'#4b5563',font:{size:10},maxTicksLimit:5},grid:{color:GRID},border:{display:false}},
              x:{ticks:{color:'#4b5563',font:{size:10},maxTicksLimit:exportedDays===7?7:exportedDays===30?10:12,maxRotation:0},grid:{display:false},border:{display:false}},
            },
          },
        });
      }

      // CTR mini bar
      const rateCtx = document.getElementById('rate-chart');
      if (rateCtx && exportedChart.labels?.length > 0) {
        new Chart(rateCtx, {
          type:'bar',
          data:{labels:exportedChart.labels,datasets:[{data:exportedChart.rates,backgroundColor:GREEN+'30',borderColor:GREEN+'70',borderWidth:1,borderRadius:3}]},
          options:{ responsive:true,maintainAspectRatio:false, plugins:{legend:{display:false},tooltip:{backgroundColor:'#111115',titleColor:'#fff',bodyColor:'#9ca3af',borderColor:'rgba(255,255,255,0.08)',borderWidth:1,callbacks:{label:(ctx)=>` ${ctx.parsed.y}%`}}}, scales:{y:{display:false,beginAtZero:true,grid:{display:false},border:{display:false}},x:{display:false,grid:{display:false},border:{display:false}}} },
        });
      }

      // Retention stacked bar
      const retCtx = document.getElementById('retention-chart');
      if (retCtx && retentionData.length > 0) {
        new Chart(retCtx, {
          type:'bar',
          data:{
            labels:retentionData.map(d=>d.date),
            datasets:[
              {label:'Nouveaux',  data:retentionData.map(d=>d.new),       backgroundColor:GREEN+'40',  borderColor:GREEN+'80',  borderWidth:1,borderRadius:2,stack:'s'},
              {label:'Récurrents',data:retentionData.map(d=>d.returning), backgroundColor:'#38bdf440', borderColor:'#38bdf480', borderWidth:1,borderRadius:2,stack:'s'},
            ],
          },
          options:{
            responsive:true,maintainAspectRatio:false,
            interaction:{mode:'index',intersect:false},
            plugins:{ legend:{display:true,position:'top',labels:{color:'#6b7280',font:{size:10},boxWidth:8,boxHeight:8,usePointStyle:true}}, tooltip:{backgroundColor:'#111115',titleColor:'#fff',bodyColor:'#9ca3af',borderColor:'rgba(255,255,255,0.08)',borderWidth:1} },
            scales:{
              y:{beginAtZero:true,stacked:true,ticks:{color:'#4b5563',font:{size:10},maxTicksLimit:4},grid:{color:GRID},border:{display:false}},
              x:{stacked:true,ticks:{color:'#4b5563',font:{size:10},maxTicksLimit:exportedDays===7?7:10,maxRotation:0},grid:{display:false},border:{display:false}},
            },
          },
        });
      }

      // ROAS chart
      const roasCtx = document.getElementById('roas-chart');
      if (roasCtx && isPro && exportedChannels?.length > 0) {
        const chR = exportedChannels.filter(c => c.revenue > 0);
        if (chR.length > 0) {
          const COLS = ['#a78bfa','#38bdf8',GREEN,'#f59e0b','#fb7185','#34d399'];
          new Chart(roasCtx, {
            type:'bar',
            data:{labels:chR.map(c=>c.name),datasets:[{label:'Revenue',data:chR.map(c=>c.revenue),backgroundColor:COLS.slice(0,chR.length).map(c=>c+'44'),borderColor:COLS.slice(0,chR.length),borderWidth:1.5,borderRadius:6}]},
            options:{ responsive:true,maintainAspectRatio:false, plugins:{legend:{display:false},tooltip:{backgroundColor:'#111115',titleColor:'#fff',bodyColor:'#9ca3af',borderColor:'rgba(255,255,255,0.08)',borderWidth:1,callbacks:{label:(ctx)=>` ${Number(ctx.parsed.y).toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0})}`}}}, scales:{y:{beginAtZero:true,ticks:{color:'#4b5563',font:{size:10},maxTicksLimit:4,callback:(v)=>v>=1000?`${Math.round(v/1000)}k€`:`${v}€`},grid:{color:GRID},border:{display:false}},x:{ticks:{color:'#4b5563',font:{size:10}},grid:{display:false},border:{display:false}}} },
          });
        }
      }

      // ── Exports ──────────────────────────────────────────────────────────────
      document.getElementById('export-csv-btn')?.addEventListener('click', () => {
        if (!exportedChart?.labels?.length) { alert('Aucune donnée à exporter'); return; }
        const rows = [['Date','Vues','Clics','CTR%']];
        exportedChart.labels.forEach((l, i) => rows.push([l, exportedChart.views[i], exportedChart.clicks[i], exportedChart.rates[i]]));
        const csv  = rows.map(r => r.join(',')).join('\n');
        const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
        const url  = URL.createObjectURL(blob);
        Object.assign(document.createElement('a'),{href:url,download:`analytics-${exportedDays}j.csv`}).click();
        URL.revokeObjectURL(url);
      });
      document.getElementById('export-pdf-btn')?.addEventListener('click', () => { window.print(); });

      // ── Goals ─────────────────────────────────────────────────────────────────
      const GOALS_KEY = 'bf_analytics_goals_v1';
      function loadGoals() { try { return JSON.parse(localStorage.getItem(GOALS_KEY) ?? '{}'); } catch { return {}; } }
      function saveGoals(g) { localStorage.setItem(GOALS_KEY, JSON.stringify(g)); }

      function renderGoals() {
        const goals  = loadGoals();
        const actual = { views:Number(el.dataset.goalsViews??0), clicks:Number(el.dataset.goalsClicks??0), leads:Number(el.dataset.goalsLeads??0), revenue:Number(el.dataset.goalsRevenue??0) };
        const items  = [{key:'views',label:'Vues',color:GREEN},{key:'clicks',label:'Clics',color:'#38bdf8'},{key:'leads',label:'Leads',color:'#f59e0b'},{key:'revenue',label:'Revenue',color:'#a78bfa'}];
        const list   = document.getElementById('goals-list');
        if (!list) return;
        if (!Object.values(goals).some(v => Number(v) > 0)) {
          list.innerHTML = '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:80px;gap:8px;color:rgba(255,255,255,0.25);font-size:12px;text-align:center"><span style="font-size:20px;opacity:.4">🎯</span>Aucun objectif<br>Clique sur "Modifier"</div>';
          return;
        }
        list.innerHTML = items.map(item => {
          const g = Number(goals[item.key]??0); if (!g) return '';
          const a = actual[item.key]??0;
          const pct = Math.min(100, g>0?Math.round((a/g)*100):0);
          const done = pct>=100;
          return `<div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px"><span style="font-size:11px;color:rgba(255,255,255,.4)">${item.label}</span><div style="display:flex;align-items:center;gap:6px">${done?'<span style="font-size:10px;font-weight:700;color:#00ff9d">✓ Atteint</span>':''}<span style="font-size:11px;font-weight:700;color:${done?'#00ff9d':item.color}">${pct}%</span></div></div><div style="background:rgba(255,255,255,.04);border-radius:9999px;height:5px;overflow:hidden"><div style="height:100%;border-radius:9999px;width:${pct}%;background:${done?'#00ff9d':item.color};opacity:${done?1:.7};transition:width .8s cubic-bezier(.16,1,.3,1)"></div></div><div style="font-size:10px;color:rgba(255,255,255,.2);margin-top:3px">${a.toLocaleString('fr-FR')} / ${g.toLocaleString('fr-FR')}</div></div>`;
        }).join('');
      }

      document.getElementById('edit-goals-btn')?.addEventListener('click', () => {
        const ed = document.getElementById('goals-editor');
        if (!ed) return;
        const hidden = ed.classList.contains('hidden');
        ed.classList.toggle('hidden', !hidden);
        if (!hidden) return;
        const g = loadGoals();
        ['views','clicks','leads','revenue'].forEach(k => { const inp = document.getElementById(`goal-${k}`); if (inp && g[k]) inp.value = g[k]; });
      });
      document.getElementById('save-goals-btn')?.addEventListener('click', () => {
        const g = {};
        ['views','clicks','leads','revenue'].forEach(k => { const val = parseInt(document.getElementById(`goal-${k}`)?.value??'0'); if (val>0) g[k]=val; });
        saveGoals(g); document.getElementById('goals-editor')?.classList.add('hidden'); renderGoals();
      });
      renderGoals();

      // ── Section tabs (like Appearance) ───────────────────────────────────────
      function activateTab(id) {
        document.querySelectorAll('.sec-tab').forEach(t => t.classList.toggle('active', t.dataset.section===id));
        document.querySelectorAll('.sec-panel').forEach(p => p.classList.toggle('active', p.id===`panel-${id}`));
        // Lazy-init charts when tab becomes visible
        if (id === 'traffic') initTrafficCharts();
        if (id === 'revenue') initRoasChart();
      }

      document.querySelectorAll('.sec-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.section;
          activateTab(id);
          history.replaceState(null, '', `?days=${exportedDays}&tab=${id}`);
        });
      });

      // Restore tab from URL
      const urlTab = new URLSearchParams(location.search).get('tab');
      if (urlTab && document.getElementById(`panel-${urlTab}`)) activateTab(urlTab);

      // ── Inner tabs (Geo / Sources) ───────────────────────────────────────────
      document.querySelectorAll('.insight-tab-inner').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.innerTab;
          document.querySelectorAll('.insight-tab-inner').forEach(b => b.classList.toggle('active', b===btn));
          document.querySelectorAll('.insight-panel').forEach(p => p.classList.toggle('active', p.id===`inner-panel-${id}`));
        });
      });

      // ── D3 Choropleth Map ────────────────────────────────────────────────────
      const countriesData = JSON.parse(el.dataset.countries ?? '[]');
      const mapSvgEl   = document.getElementById('world-map');
      const mapLoader  = document.getElementById('world-map-loader');
      const mapTooltip = document.getElementById('map-tooltip');

      if (mapSvgEl) {
        await Promise.all([
          new Promise((res,rej)=>{ if(window.d3){res(null);return;} const s=document.createElement('script');s.src='https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js';s.onload=res;s.onerror=rej;document.head.appendChild(s); }),
          new Promise((res,rej)=>{ if(window.topojson){res(null);return;} const s=document.createElement('script');s.src='https://cdn.jsdelivr.net/npm/topojson@3.0.2/dist/topojson.min.js';s.onload=res;s.onerror=rej;document.head.appendChild(s); }),
        ]);
        const world = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2.0.2/countries-50m.json').then(r=>r.json());
        const ISO2_NUM = {AF:'4',AL:'8',DZ:'12',AO:'24',AR:'32',AU:'36',AT:'40',AZ:'31',BD:'50',BE:'56',BJ:'204',BO:'68',BR:'76',BG:'100',CA:'124',CL:'152',CN:'156',CO:'170',CD:'180',CR:'188',HR:'191',CZ:'203',DK:'208',EG:'818',ET:'231',FI:'246',FR:'250',DE:'276',GH:'288',GR:'300',HK:'344',HU:'348',IN:'356',ID:'360',IR:'364',IQ:'368',IE:'372',IL:'376',IT:'380',CI:'384',JP:'392',JO:'400',KZ:'398',KE:'404',KR:'410',KW:'414',LB:'422',LY:'434',MA:'504',MX:'484',MM:'104',NL:'528',NZ:'554',NG:'566',NO:'578',PK:'586',PE:'604',PH:'608',PL:'616',PT:'620',QA:'634',RO:'642',RU:'643',SA:'682',SN:'686',SG:'702',SK:'703',SI:'705',SO:'706',ZA:'710',ES:'724',SE:'752',CH:'756',SY:'760',TW:'158',TZ:'834',TH:'764',TN:'788',TR:'792',UA:'804',AE:'784',GB:'826',US:'840',UY:'858',VE:'862',VN:'704',YE:'887',ZW:'716',MG:'450',CM:'120',GN:'324',ML:'466',TD:'148',NE:'562',LK:'144',KH:'116',MN:'496',IS:'352',LV:'428',LT:'440',EE:'233',RS:'688',BA:'70',MK:'807',GE:'268',BY:'112',MD:'498',AM:'51',UZ:'860',TM:'795',KG:'417',TJ:'762',LU:'442',CY:'196',MT:'470',MZ:'508',ZM:'894',MW:'454',UG:'800',RW:'646',BI:'108',SS:'728',SD:'729',LR:'430',SL:'694',BF:'854',GW:'624',GM:'270',CV:'132',GQ:'226',GA:'266',CG:'178',CF:'140',ER:'232',DJ:'262',KM:'174',SC:'690',MU:'480',MR:'478',LI:'438',MC:'492',SM:'674',VA:'336',AD:'20',ME:'499',XK:'383'};
        const maxViews=countriesData.length>0?countriesData[0].views:1;
        const viewsMap=new Map(),iso2Map=new Map(),labelMap=new Map();
        countriesData.forEach(row=>{const num=ISO2_NUM[row.country];if(!num)return;viewsMap.set(+num,row.views);iso2Map.set(+num,row.country);labelMap.set(+num,row.country);});
        const colorScale=maxViews>1?d3.scaleSequentialLog().domain([1,maxViews]).interpolator(d3.interpolate('#0f2a1a','#00ff9d')):()=>'#0f2a1a';
        const W=mapSvgEl.clientWidth||720,H=320;
        const svg=d3.select(mapSvgEl).attr('width',W).attr('height',H);
        const projection=d3.geoNaturalEarth1().scale(W/6.1).translate([W/2,H/2+15]);
        const pathGen=d3.geoPath().projection(projection);
        const g=svg.append('g').attr('class','map-root');
        g.append('path').datum({type:'Sphere'}).attr('d',pathGen).attr('fill','#060d0a').attr('stroke','rgba(0,255,157,0.04)').attr('stroke-width',0.8);
        g.append('path').datum(d3.geoGraticule().step([20,20])()).attr('d',pathGen).attr('fill','none').attr('stroke','rgba(255,255,255,0.025)').attr('stroke-width',0.4);
        const countries=topojson.feature(world,world.objects.countries);
        g.selectAll('.country').data(countries.features).join('path').attr('class','country').attr('d',pathGen).attr('fill',d=>{const v=viewsMap.get(+d.id);return v?colorScale(v):'#101f16';}).attr('stroke','#0c1a12').attr('stroke-width',0.4);
        g.append('path').datum(topojson.mesh(world,world.objects.countries,(a,b)=>a!==b)).attr('d',pathGen).attr('fill','none').attr('stroke','rgba(0,255,157,0.07)').attr('stroke-width',0.5);
        const dotsG=g.append('g');
        countriesData.slice(0,6).forEach((row,idx)=>{
          const num=ISO2_NUM[row.country];if(!num)return;
          const feat=countries.features.find(f=>+f.id===+num);if(!feat)return;
          const cen=pathGen.centroid(feat);if(!cen||isNaN(cen[0])||isNaN(cen[1]))return;
          const intensity=row.views/maxViews,r=2.5+intensity*5.5;
          dotsG.append('circle').attr('cx',cen[0]).attr('cy',cen[1]).attr('r',r+6).attr('fill',`rgba(0,255,157,${0.06+intensity*0.08})`).attr('pointer-events','none');
          dotsG.append('circle').attr('cx',cen[0]).attr('cy',cen[1]).attr('r',r).attr('fill',idx===0?'#00ff9d':`rgba(0,255,157,${0.5+intensity*0.4})`).attr('stroke',idx===0?'rgba(0,255,157,0.4)':'none').attr('stroke-width',1.5).attr('pointer-events','none');
        });
        g.selectAll('.country-hit').data(countries.features).join('path').attr('class','country-hit').attr('d',pathGen).attr('fill','transparent').attr('stroke','none')
          .attr('cursor',d=>viewsMap.has(+d.id)?'pointer':'default')
          .on('mousemove',function(event,d){
            const views=viewsMap.get(+d.id);if(!views||!mapTooltip)return;
            const iso2=iso2Map.get(+d.id)||'',name=labelMap.get(+d.id)||iso2,pct=((views/maxViews)*100).toFixed(0);
            const rect=mapSvgEl.getBoundingClientRect();
            mapTooltip.innerHTML=`<span style="color:#00ff9d;font-weight:700">${iso2} — ${name}</span><span style="color:#4b5563;margin:0 6px">·</span><span style="color:#e5e7eb">${views.toLocaleString('fr-FR')} vues</span><span style="color:#374151;margin-left:6px">${pct}%</span>`;
            let tx=event.clientX-rect.left+14,ty=event.clientY-rect.top-38;
            if(tx+240>W)tx=tx-260;if(ty<4)ty=event.clientY-rect.top+18;
            mapTooltip.style.left=tx+'px';mapTooltip.style.top=ty+'px';mapTooltip.classList.remove('hidden');
            d3.select(this.parentNode).selectAll('.country').filter(fd=>fd===d).attr('fill',v=>{const val=viewsMap.get(+v.id);return val?d3.color(colorScale(val)).brighter(0.8).formatHex():'#1e3525';});
          })
          .on('mouseleave',function(event,d){
            if(mapTooltip)mapTooltip.classList.add('hidden');
            d3.select(this.parentNode).selectAll('.country').filter(fd=>fd===d).attr('fill',fd=>{const v=viewsMap.get(+fd.id);return v?colorScale(v):'#101f16';});
          });
        const zoom=d3.zoom().scaleExtent([0.9,12]).translateExtent([[-W*.5,-H*.5],[W*1.5,H*1.5]])
          .filter(event=>{if(event.type==='dblclick')return false;return true;})
          .on('zoom',(event)=>{g.attr('transform',event.transform);const k=event.transform.k;g.selectAll('.country').attr('stroke-width',Math.max(0.2,0.4/k));mapSvgEl.style.cursor=event.sourceEvent?.buttons?'grabbing':'grab';});
        svg.call(zoom);
        document.getElementById('map-zoom-in')?.addEventListener('click',()=>svg.transition().duration(300).call(zoom.scaleBy,1.6));
        document.getElementById('map-zoom-out')?.addEventListener('click',()=>svg.transition().duration(300).call(zoom.scaleBy,0.625));
        document.getElementById('map-reset')?.addEventListener('click',()=>svg.transition().duration(450).call(zoom.transform,d3.zoomIdentity));
        document.querySelectorAll('.country-row').forEach(row=>{
          row.addEventListener('mouseenter',()=>{
            const iso2=row.getAttribute('data-iso'),num=ISO2_NUM[iso2];if(!num)return;
            const feat=countries.features.find(f=>+f.id===+num);if(!feat)return;
            g.selectAll('.country').classed('highlighted',fd=>+fd.id===+num);
            const b=pathGen.bounds(feat),dx=b[1][0]-b[0][0],dy=b[1][1]-b[0][1];
            const cx=(b[0][0]+b[1][0])/2,cy=(b[0][1]+b[1][1])/2;
            const scale=Math.max(1.2,Math.min(8,0.85/Math.max(dx/W,dy/H)));
            svg.transition().duration(550).ease(d3.easeCubicOut).call(zoom.transform,d3.zoomIdentity.translate(W/2-scale*cx,H/2-scale*cy).scale(scale));
          });
          row.addEventListener('mouseleave',()=>{
            g.selectAll('.country').classed('highlighted',false);
            svg.transition().duration(450).ease(d3.easeCubicOut).call(zoom.transform,d3.zoomIdentity);
          });
        });
        mapSvgEl.style.opacity='1';
        if(mapLoader)mapLoader.style.display='none';
        const ro=new ResizeObserver(()=>{const nW=mapSvgEl.clientWidth;if(!nW)return;projection.scale(nW/6.1).translate([nW/2,H/2+15]);svg.attr('width',nW);g.selectAll('path').attr('d',pathGen);});
        ro.observe(mapSvgEl);
      } else if(mapLoader) {
        mapLoader.innerHTML='<p style="color:#374151;font-size:12px;padding:24px">Carte non disponible</p>';
      }

    })();
  </script>

</DashboardLayout>
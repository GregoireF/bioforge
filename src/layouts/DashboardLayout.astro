    <button class="chat-sugg shrink-0 text-xs px-3 py-1.5 rounded-full border transition-all whitespace-nowrap"
      style="border-color:rgba(255,255,255,0.1); color:rgba(255,255,255,0.5);"
      data-prompt="Quelle est la différence entre les plans Free et Pro ?">
      ⭐ Plans
    </button>
  </div>

  <!-- Zone de saisie -->
  <div class="px-3 pb-3 shrink-0">
    <div class="flex items-end gap-2 rounded-2xl px-3 py-2.5"
      style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);">
      <textarea id="chat-input" rows="1"
        placeholder="Pose ta question…"
        class="flex-1 bg-transparent text-sm text-white resize-none outline-none leading-relaxed"
        style="max-height:100px; color-scheme:dark;"></textarea>
      <button id="chat-send"
        class="shrink-0 w-8 h-8 rounded-xl flex items-center justify-center transition-all hover:scale-110 active:scale-95 disabled:opacity-40"
        style="background:linear-gradient(135deg,#7c3aed,#4f46e5);"
        aria-label="Envoyer">
        <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
      </button>
    </div>
  </div>

</div>

<style>
  /* AdSense */
  .adsbygoogle { min-height: 100px; background: transparent; }
  .safe-area-pb { padding-bottom: env(safe-area-inset-bottom, 0); }

  /* Chatbot panel */
  #chat-panel.open {
    opacity: 1 !important;
    scale: 1 !important;
    pointer-events: auto !important;
  }

  /* Messages */
  .chat-msg {
    animation: chat-in 0.18s ease both;
  }
  @keyframes chat-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Scrollbar messages */
  #chat-messages {
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.08) transparent;
  }
  #chat-messages::-webkit-scrollbar { width: 3px; }
  #chat-messages::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.08);
    border-radius: 9px;
  }

  /* Suggestions */
  #chat-suggestions { scrollbar-width: none; }
  #chat-suggestions::-webkit-scrollbar { display: none; }
  .chat-sugg:hover {
    background: rgba(124,58,237,0.15) !important;
    border-color: rgba(124,58,237,0.4) !important;
    color: rgba(255,255,255,0.9) !important;
  }

  /* Typing dots */
  .chat-dot {
    animation: dot-bounce 1.2s infinite ease-in-out;
  }
  .chat-dot:nth-child(2) { animation-delay: 0.2s; }
  .chat-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dot-bounce {
    0%, 80%, 100% { transform: translateY(0);    opacity: 0.35; }
    40%            { transform: translateY(-5px); opacity: 1; }
  }
</style>

<script>
  // ── Mobile menu ──────────────────────────────────────────────────────────────
  const mobileMenu     = document.getElementById('mobile-menu');
  const mobileBackdrop = document.getElementById('mobile-menu-backdrop');

  function openMobile()  { mobileMenu?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closeMobile() { mobileMenu?.classList.add('hidden');    document.body.style.overflow = ''; }

  document.getElementById('mobile-menu-btn')?.addEventListener('click', openMobile);
  document.getElementById('mobile-more-btn')?.addEventListener('click', openMobile);
  document.getElementById('mobile-menu-close')?.addEventListener('click', closeMobile);
  mobileBackdrop?.addEventListener('click', closeMobile);

  // ── Sidebar user dropdown ────────────────────────────────────────────────────
  const sidebarUserBtn  = document.getElementById('sidebar-user-btn');
  const sidebarUserMenu = document.getElementById('sidebar-user-menu');
  sidebarUserBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    sidebarUserMenu?.classList.toggle('hidden');
  });

  // ── Topbar user dropdown ─────────────────────────────────────────────────────
  const topbarUserBtn  = document.getElementById('topbar-user-btn');
  const topbarUserMenu = document.getElementById('topbar-user-menu');
  topbarUserBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    topbarUserMenu?.classList.toggle('hidden');
    sidebarUserMenu?.classList.add('hidden');
  });

  document.addEventListener('click', () => {
    sidebarUserMenu?.classList.add('hidden');
    topbarUserMenu?.classList.add('hidden');
  });

  // ── Command palette ──────────────────────────────────────────────────────────
  document.getElementById('command-palette-trigger')?.addEventListener('click', () => {
    window.openCommandPalette?.();
  });
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      window.openCommandPalette?.();
    }
  });
</script>

<script define:vars={{ chatContext }}>
(function () {

  // ── Éléments DOM ─────────────────────────────────────────────────────────────
  const ctx      = JSON.parse(chatContext);
  const trigger  = document.getElementById('chat-trigger');
  const panel    = document.getElementById('chat-panel');
  const iconOff  = document.getElementById('chat-icon-closed');
  const iconOn   = document.getElementById('chat-icon-open');
  const pulse    = document.getElementById('chat-pulse');
  const msgBox   = document.getElementById('chat-messages');
  const input    = document.getElementById('chat-input');
  const sendBtn  = document.getElementById('chat-send');
  const clearBtn = document.getElementById('chat-clear');
  const suggsEl  = document.getElementById('chat-suggestions');

  let open      = false;
  let loading   = false;
  let history   = [];    // messages envoyés à l'API

  // ── Helpers DOM ───────────────────────────────────────────────────────────────
  const botAvatar = `
    <div class="w-6 h-6 rounded-lg shrink-0 mt-0.5 flex items-center justify-center"
      style="background:linear-gradient(135deg,#7c3aed,#4f46e5);">
      <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
    </div>`;

  function scrollBottom() {
    if (msgBox) msgBox.scrollTop = msgBox.scrollHeight;
  }

  function addBotMsg(text) {
    const wrap = document.createElement('div');
    wrap.className = 'flex gap-2.5 items-start chat-msg';
    wrap.innerHTML = `${botAvatar}
      <div class="rounded-2xl rounded-tl-md px-3.5 py-2.5 text-sm leading-relaxed whitespace-pre-wrap"
        style="background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.82); max-width:85%;"
      >${text.replace(/</g, '&lt;')}</div>`;
    msgBox?.appendChild(wrap);
    scrollBottom();
  }

  function addUserMsg(text) {
    const wrap = document.createElement('div');
    wrap.className = 'flex justify-end chat-msg';
    wrap.innerHTML = `
      <div class="rounded-2xl rounded-tr-md px-3.5 py-2.5 text-sm leading-relaxed whitespace-pre-wrap"
        style="background:linear-gradient(135deg,#7c3aed,#4f46e5); color:#fff; max-width:85%;"
      >${text.replace(/</g, '&lt;')}</div>`;
    msgBox?.appendChild(wrap);
    scrollBottom();
  }

  function addTyping() {
    const wrap = document.createElement('div');
    wrap.id = 'chat-typing';
    wrap.className = 'flex gap-2.5 items-start chat-msg';
    wrap.innerHTML = `${botAvatar}
      <div class="rounded-2xl rounded-tl-md px-4 py-3" style="background:rgba(255,255,255,0.05);">
        <div class="flex gap-1.5 items-center h-4">
          <span class="chat-dot w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.5);"></span>
          <span class="chat-dot w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.5);"></span>
          <span class="chat-dot w-1.5 h-1.5 rounded-full" style="background:rgba(255,255,255,0.5);"></span>
        </div>
      </div>`;
    msgBox?.appendChild(wrap);
    scrollBottom();
  }

  function removeTyping() {
    document.getElementById('chat-typing')?.remove();
  }

  // ── Open / Close ──────────────────────────────────────────────────────────────
  function openChat() {
    open = true;
    panel?.classList.add('open');
    iconOff?.classList.add('hidden');
    iconOn?.classList.remove('hidden');
    pulse?.remove();          // Stoppe le ring d'attention
    input?.focus();
    scrollBottom();
  }

  function closeChat() {
    open = false;
    panel?.classList.remove('open');
    iconOff?.classList.remove('hidden');
    iconOn?.classList.add('hidden');
  }

  trigger?.addEventListener('click', () => open ? closeChat() : openChat());
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && open) closeChat(); });

  // ── Envoi message ─────────────────────────────────────────────────────────────
  async function send(text) {
    text = text.trim();
    if (!text || loading) return;

    // Cache les suggestions dès le 1er envoi
    if (suggsEl) suggsEl.style.display = 'none';

    loading = true;
    if (sendBtn) sendBtn.disabled = true;

    addUserMsg(text);
    history.push({ role: 'user', content: text });
    if (input) { input.value = ''; input.style.height = 'auto'; }

    addTyping();

    try {
      const res = await fetch('/api/chat', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ messages: history.slice(-12), context: ctx }),
      });

      removeTyping();

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data  = await res.json();
      const reply = data.content?.[0]?.text
        ?? "Désolé, je n'ai pas pu répondre. Réessaie dans un instant !";

      addBotMsg(reply);
      history.push({ role: 'assistant', content: reply });

    } catch (err) {
      removeTyping();
      addBotMsg("Une erreur s'est produite 🙏 Vérifie ta connexion et réessaie.");
      console.error('[BioForge Chat]', err);
    }

    loading = false;
    if (sendBtn) sendBtn.disabled = false;
  }

  // ── Listeners ─────────────────────────────────────────────────────────────────
  sendBtn?.addEventListener('click', () => send(input?.value ?? ''));

  input?.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(input.value); }
  });

  // Auto-resize textarea
  input?.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 100) + 'px';
  });

  // Suggestions rapides
  document.querySelectorAll('.chat-sugg').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!open) openChat();
      send(btn.dataset.prompt ?? '');
    });
  });

  // Effacer conversation
  clearBtn?.addEventListener('click', () => {
    history = [];
    if (msgBox) {
      msgBox.innerHTML = `
        <div class="flex gap-2.5 items-start chat-msg">
          ${botAvatar}
          <div class="rounded-2xl rounded-tl-md px-3.5 py-2.5 text-sm leading-relaxed"
            style="background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.82); max-width:85%;">
            Conversation réinitialisée 🔄 Comment puis-je t'aider ?
          </div>
        </div>`;
    }
    if (suggsEl) suggsEl.style.display = '';
  });

})();
</script>

<script>
  function initAdsense() {
    document.querySelectorAll('.adsbygoogle').forEach(function(ins) {
      if (ins.getAttribute('data-adsbygoogle-status')) return;
      var wrap = ins.closest('[id$="-wrap"]');
      var w = ins.closest('aside')?.offsetWidth || ins.parentElement?.offsetWidth || 0;
      if (w < 50) return;
      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
        if (wrap) {
          var obs = new MutationObserver(function() {
            if (ins.getAttribute('data-adsbygoogle-status') === 'done' && ins.offsetHeight > 10) {
              wrap.style.display = '';
              obs.disconnect();
            }
          });
          obs.observe(ins, { attributes: true, childList: true, subtree: true });
          setTimeout(function() {
            if (ins.offsetHeight <= 10) { wrap.style.display = 'none'; }
            obs.disconnect();
          }, 4000);
        }
      } catch(e) {}
    });
  }
  if (document.readyState === 'complete') {
    setTimeout(initAdsense, 400);
  } else {
    window.addEventListener('load', function() { setTimeout(initAdsense, 400); });
  }
</script>

<script>
  (function() {
    var banner  = document.getElementById('promo-banner');
    var dismiss = document.getElementById('promo-dismiss');
    var msgs    = document.querySelectorAll('.promo-msg');
    var dots    = document.querySelectorAll('.pdot');
    if (!banner || !msgs.length) return;

    // Check dismissed
    if (sessionStorage.getItem('bf_promo_dismissed')) {
      banner.style.display = 'none';
      return;
    }

    var current = 0;
    var interval = null;

    function show(idx) {
      msgs.forEach(function(m, i) {
        m.style.opacity = i === idx ? '1' : '0';
        m.style.transform = i === idx ? 'translateY(0)' : 'translateY(8px)';
      });
      dots.forEach(function(d, i) {
        d.style.width    = i === idx ? '14px' : '4px';
        d.style.background = i === idx ? '#00ff9d' : 'rgba(255,255,255,0.2)';
      });
      current = idx;
    }

    function next() {
      show((current + 1) % msgs.length);
    }

    // Show first message after 300ms
    setTimeout(function() { show(0); }, 300);

    // Rotate every 5 seconds
    interval = setInterval(next, 5000);

    // Pause on hover
    banner.addEventListener('mouseenter', function() { clearInterval(interval); });
    banner.addEventListener('mouseleave', function() { interval = setInterval(next, 5000); });

    // Dismiss
    if (dismiss) {
      dismiss.addEventListener('click', function() {
        banner.style.height = '0';
        banner.style.opacity = '0';
        banner.style.overflow = 'hidden';
        banner.style.transition = 'height 0.3s ease, opacity 0.3s ease';
        clearInterval(interval);
        setTimeout(function() { banner.style.display = 'none'; }, 320);
        sessionStorage.setItem('bf_promo_dismissed', '1');
      });
    }
  })();
</script>

<script>
  /* ══ CHANGELOG ══════════════════════════════════════════════════════════════ */
  (function () {
    var btn    = document.getElementById('changelog-btn');
    var panel  = document.getElementById('changelog-panel');
    var close  = document.getElementById('changelog-close');
    if (!btn || !panel) return;

    var open = false;

    function openPanel() {
      open = true;
      panel.style.display = 'block';
      requestAnimationFrame(function () {
        panel.style.opacity   = '1';
        panel.style.transform = 'translateY(0) scale(1)';
      });
      // Mark as seen
      localStorage.setItem('bf_changelog_seen', 'true');
      var badge = btn.querySelector('span');
      if (badge) badge.remove();
    }

    function closePanel() {
      open = false;
      panel.style.opacity   = '0';
      panel.style.transform = 'translateY(-8px) scale(0.97)';
      setTimeout(function () { panel.style.display = 'none'; }, 260);
    }

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      open ? closePanel() : openPanel();
    });
    if (close) close.addEventListener('click', closePanel);

    document.addEventListener('click', function (e) {
      if (open && !panel.contains(e.target) && e.target !== btn) closePanel();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && open) closePanel();
    });

    // Hide badge if already seen
    if (localStorage.getItem('bf_changelog_seen')) {
      var badge = btn.querySelector('span');
      if (badge) badge.style.display = 'none';
    }
  })();

  /* ══ USAGE INDICATOR ════════════════════════════════════════════════════════ */
  (function () {
    var wrap  = document.getElementById('usage-indicator');
    var track = document.getElementById('usage-track');
    var label = document.getElementById('usage-label');
    if (!wrap || !track || !label) return;

    var FREE_LIMIT = 5;

    fetch('/api/blocks?count=1')
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var used = d.data?.total ?? d.data?.count ?? 0;
        var pct  = Math.min(used / FREE_LIMIT, 1);
        var isWarning = pct >= 0.8;
        var isFull    = pct >= 1;

        // Mini segmented bar (5 dots)
        track.innerHTML = '';
        for (var i = 0; i < FREE_LIMIT; i++) {
          var dot = document.createElement('div');
          dot.style.cssText = 'width:6px;height:6px;border-radius:2px;transition:background 0.3s;background:' +
            (i < used
              ? (isFull ? '#ff5050' : isWarning ? '#ffaa00' : '#00ff9d')
              : 'rgba(255,255,255,0.1)');
          track.appendChild(dot);
        }

        label.textContent = used + '/' + FREE_LIMIT + ' blocs';
        label.style.color = isFull ? '#ff5050' : isWarning ? '#ffaa00' : 'rgba(255,255,255,0.4)';

        if (isFull) {
          wrap.style.borderColor = 'rgba(255,80,80,0.25)';
          wrap.style.background  = 'rgba(255,80,80,0.04)';
        } else if (isWarning) {
          wrap.style.borderColor = 'rgba(255,170,0,0.25)';
          wrap.style.background  = 'rgba(255,170,0,0.04)';
        }
      })
      .catch(function () {
        wrap.style.display = 'none';
      });
  })();
</script>


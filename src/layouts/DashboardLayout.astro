---
// src/layouts/DashboardLayout.astro — v6
// Auth-aware layout : nav centralisée, Carbon Ads (Free/Base), user menu riche,
// Collab banner, FeedbackWidget, OnboardingTour amélioré, bottom nav mobile, plan badge

import CommandPalette from '@/components/features/CommandPalette.astro';
import OnboardingTour  from '@/components/features/OnboardingTour.astro';
import UpgradeModal    from '@/components/features/UpgradeModal.astro';
import FeedbackWidget  from '@/components/features/FeedbackWidget.astro';
import CollabBanner    from '@/components/features/CollabBanner.astro';
import '@/styles/global.css';
import { Image } from 'astro:assets';
import { withAuth } from '@/lib/auth/auth';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

// ── Auth (best-effort — layout ne redirige pas, les pages s'en chargent) ──────
let profile: any   = null;
let planLimits: any = null;
try {
  const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
  if (authResult.success && authResult.data) {
    profile    = authResult.data.profile;
    planLimits = authResult.data.planLimits;
  }
} catch {}

// ── Plan helpers ───────────────────────────────────────────────────────────────
const PAID_PLANS   = ['Pro', 'Business', 'Enterprise'];
const plan         = profile?.plan ?? 'Free';
const isPaid       = PAID_PLANS.includes(plan);
const isBasicOrFree = !isPaid;
const showAds      = isBasicOrFree;

const PLAN_COLORS: Record<string, string> = {
  Free:       'text-gray-400 bg-white/5 border-white/10',
  Basic:      'text-neon-blue bg-neon-blue/10 border-neon-blue/20',
  Pro:        'text-neon-green bg-neon-green/10 border-neon-green/20',
  Business:   'text-neon-purple bg-neon-purple/10 border-neon-purple/20',
  Enterprise: 'text-orange-400 bg-orange-400/10 border-orange-400/20',
};
const planColor = PLAN_COLORS[plan] ?? PLAN_COLORS.Free;

// ── Avatar fallback ────────────────────────────────────────────────────────────
const avatarUrl   = profile?.avatar_url ?? null;
const displayName = profile?.display_name || profile?.username || 'User';
const initials    = displayName.slice(0, 2).toUpperCase();

// ── AI Chatbot — context passé au script client ────────────────────────────────
const chatContext = JSON.stringify({
  username:    profile?.username    ?? '',
  displayName: profile?.display_name ?? profile?.username ?? 'User',
  plan,
  isPaid,
});

// ── Changelog entries ─────────────────────────────────────────────────────────
const CHANGELOG = [
  { date: 'Jan 2025', badge: '🆕', title: 'Mode Hero Photo',      desc: 'Affiche ta photo en pleine largeur avec fondu cinématique.', isNew: true },
  { date: 'Jan 2025', badge: '🎨', title: '35+ nouvelles polices', desc: 'Tech, Serif, Display, Mono — Cabinet Grotesk et plus.', isNew: true },
  { date: 'Jan 2025', badge: '🔗', title: 'Raccourcisseur de liens', desc: 'bioforge.click/s/xxx avec UTM et stats.', isNew: false },
  { date: 'Jan 2025', badge: '📊', title: 'Analytics avancées',   desc: 'Heatmaps, rétention, taux de clic par bloc.', isNew: false },
  { date: 'Déc 2024', badge: '✦',  title: 'Palettes auto-gen',    desc: 'Génère des palettes harmonieuses depuis ta couleur accent.', isNew: false },
];
const newCount = CHANGELOG.filter(c => c.isNew).length;

// ── Navigation items ───────────────────────────────────────────────────────────
const NAV_MAIN = [
  {
    href:  '/dashboard',
    label: 'Overview',
    exact: true,
    icon:  'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  },
  {
    href:  '/dashboard/blocks',
    label: 'My Page',
    exact: false,
    icon:  'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
  },
  {
    href:  '/dashboard/analytics',
    label: 'Analytics',
    exact: false,
    icon:  'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
  {
    href:  '/dashboard/appearance',
    label: 'Appearance',
    exact: false,
    icon:  'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  },
];

const NAV_SECONDARY = [
  {
    href:  '/dashboard/#',
    label: 'Billing',
    exact: false,
    icon:  'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
  },
  {
    href:  '/dashboard/#',
    label: 'Roadmap',
    exact: false,
    icon:  'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  },
  {
    href:  '/dashboard/settings',
    label: 'Settings',
    exact: false,
    icon:  'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
];

// ── Nav active helper ──────────────────────────────────────────────────────────
function isActive(href: string, exact: boolean): boolean {
  return exact ? currentPath === href : currentPath.startsWith(href);
}
function navClass(href: string, exact: boolean): string {
  return isActive(href, exact)
    ? 'flex items-center gap-3 px-3 py-2.5 rounded-xl bg-neon-green/10 text-neon-green border border-neon-green/25 font-medium text-sm'
    : 'flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all font-medium text-sm';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BioForge</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <meta name="google-adsense-account" content="ca-pub-2203788383686517" />
  {showAds && (
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2203788383686517" crossorigin="anonymous"></script>
  )}
</head>
<body class="bg-dark-900 text-white min-h-screen">

<div class="flex min-h-screen">

  <!-- ===== SIDEBAR (desktop) ===== -->
  <aside class="hidden lg:flex lg:flex-shrink-0 lg:w-60 xl:w-64 flex-col glass-strong border-r border-white/10">

    <!-- Logo -->
    <div class="flex items-center h-16 px-5 border-b border-white/10 shrink-0">
      <a href="https://bioforge.click/" class="flex items-center gap-2.5">
        <Image src="/logo.webp" alt="BioForge" width={28} height={28} class="rounded-lg" />
        <span class="text-white font-bold text-base tracking-tight">BioForge</span>
      </a>
    </div>

    <!-- Nav main -->
    <nav class="flex-1 px-3 py-5 space-y-0.5 overflow-y-auto">
      <p class="px-3 mb-2 text-xs font-semibold text-gray-600 uppercase tracking-widest">Main</p>
      {NAV_MAIN.map(item => (
        <a href={item.href} class={navClass(item.href, item.exact)}>
          <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon}/>
          </svg>
          {item.label}
        </a>
      ))}

      <div class="pt-4 pb-2">
        <p class="px-3 mb-2 text-xs font-semibold text-gray-600 uppercase tracking-widest">Account</p>
        {NAV_SECONDARY.map(item => (
          <a href={item.href} class={navClass(item.href, item.exact)}>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon}/>
            </svg>
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- Collab banner — toujours visible -->
    <CollabBanner partner="discord" />

    <!-- AdSense (Free / Basic only) -->
    {showAds && (
      <div class="px-3 pb-3" id="adsense-sidebar-wrap" style="display:none;">
        <div class="relative p-3 glass border border-white/8 rounded-xl overflow-hidden">
          <ins class="adsbygoogle adsense-sidebar"
            style="display:block;width:100%;min-width:160px;"
            data-ad-client="ca-pub-2203788383686517"
            data-ad-slot="2242281532"
            data-ad-format="rectangle"
            data-full-width-responsive="false"></ins>
          <a href="/dashboard/#"
            class="flex items-center gap-2 mt-2 pt-2 border-t border-white/8 text-xs text-gray-500 hover:text-neon-green transition-colors">
            <svg class="w-3 h-3 text-neon-green/60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Remove ads — Upgrade to Pro
          </a>
        </div>
      </div>
    )}

    <!-- User profile footer -->
    <div class="px-3 pb-4 pt-2 border-t border-white/10 shrink-0">
      <div class="flex items-center gap-3 p-2 rounded-xl hover:bg-white/5 transition-all cursor-pointer group" id="sidebar-user-btn">
        <div class="relative shrink-0">
          {avatarUrl ? (
            <img src={avatarUrl} alt={displayName}
              class="w-8 h-8 rounded-full object-cover border border-white/20" />
          ) : (
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center text-xs font-bold text-black">
              {initials}
            </div>
          )}
          <span class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 bg-neon-green rounded-full border-2 border-dark-900"></span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-semibold text-white truncate">{displayName}</p>
          <span class={`inline-flex items-center text-xs px-1.5 py-0 rounded-full border font-medium ${planColor}`}>
            {plan}
          </span>
        </div>
        <svg class="w-3.5 h-3.5 text-gray-600 group-hover:text-gray-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>

      <div id="sidebar-user-menu" class="hidden mt-1 p-1 glass-strong border border-white/10 rounded-xl shadow-2xl">
        <a href="/dashboard/settings"
          class="flex items-center gap-2.5 px-3 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Settings
        </a>
        {!isPaid && (
          <a href="/dashboard/#"
            class="flex items-center gap-2.5 px-3 py-2 text-sm text-neon-green hover:bg-neon-green/5 rounded-lg transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Upgrade to Pro
          </a>
        )}
        <div class="my-1 border-t border-white/10"></div>
        <a href="/api/auth/signout"
          class="flex items-center gap-2.5 px-3 py-2 text-sm text-red-400 hover:bg-red-500/5 rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Sign Out
        </a>
      </div>
    </div>

  </aside>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="flex-1 flex flex-col min-w-0">

  <!-- ===== TOP PROMO BANNER ===== -->
  {!isPaid && (
    <div id="promo-banner"
      style="position:relative;z-index:40;height:36px;overflow:hidden;flex-shrink:0;background:linear-gradient(90deg,rgba(0,255,157,0.06) 0%,rgba(0,0,0,0) 50%,rgba(0,255,157,0.06) 100%);border-bottom:1px solid rgba(0,255,157,0.12)"
    >
      <!-- Rotating messages track -->
      <div id="promo-track" style="display:flex;height:100%;align-items:center;justify-content:center;gap:0">
        <!-- Each message — JS will show one at a time -->
        <div class="promo-msg" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:10px;opacity:0;transform:translateY(8px);transition:opacity 0.5s ease,transform 0.5s ease">
          <span style="font-size:11px;font-weight:500;color:rgba(255,255,255,0.55)">
            ✦ Passe à Pro et débloque les <strong style="color:#fff;font-weight:700">wallpapers, polices custom</strong> et le <strong style="color:#fff;font-weight:700">mode Hero</strong>
          </span>
          <a href="/dashboard/billing"
            style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;background:#00ff9d;color:#000;border-radius:99px;font-size:11px;font-weight:800;font-family:'Cabinet Grotesk',system-ui,sans-serif;text-decoration:none;transition:all 0.2s;white-space:nowrap;flex-shrink:0"
            onmouseover="this.style.background='#20ffaa'" onmouseout="this.style.background='#00ff9d'"
          >
            <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Upgrader
          </a>
        </div>

        <div class="promo-msg" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:10px;opacity:0;transform:translateY(8px);transition:opacity 0.5s ease,transform 0.5s ease">
          <span style="font-size:11px;font-weight:500;color:rgba(255,255,255,0.55)">
            📊 Pro : analytics <strong style="color:#fff;font-weight:700">avancées</strong>, rétention, provenance et <strong style="color:#fff;font-weight:700">heatmaps</strong> — dès <strong style="color:#fff;font-weight:700">7€/mois</strong>
          </span>
          <a href="/dashboard/billing"
            style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;background:#00ff9d;color:#000;border-radius:99px;font-size:11px;font-weight:800;font-family:'Cabinet Grotesk',system-ui,sans-serif;text-decoration:none;transition:all 0.2s;white-space:nowrap;flex-shrink:0"
            onmouseover="this.style.background='#20ffaa'" onmouseout="this.style.background='#00ff9d'"
          >
            Voir les plans →
          </a>
        </div>

        <div class="promo-msg" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:10px;opacity:0;transform:translateY(8px);transition:opacity 0.5s ease,transform 0.5s ease">
          <span style="font-size:11px;font-weight:500;color:rgba(255,255,255,0.55)">
            🎨 <strong style="color:#fff;font-weight:700">35+ polices</strong>, dégradés, presets exclusifs et CSS personnalisé en Pro
          </span>
          <a href="/dashboard/appearance"
            style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border:1px solid rgba(0,255,157,0.35);color:#00ff9d;border-radius:99px;font-size:11px;font-weight:700;font-family:'Cabinet Grotesk',system-ui,sans-serif;text-decoration:none;transition:all 0.2s;white-space:nowrap;flex-shrink:0;background:rgba(0,255,157,0.07)"
            onmouseover="this.style.background='rgba(0,255,157,0.14)'" onmouseout="this.style.background='rgba(0,255,157,0.07)'"
          >
            Tester l'Aperçu
          </a>
        </div>

        <div class="promo-msg" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:10px;opacity:0;transform:translateY(8px);transition:opacity 0.5s ease,transform 0.5s ease">
          <span style="font-size:11px;font-weight:500;color:rgba(255,255,255,0.55)">
            🔗 Raccourcisseur de liens, planificateur social et <strong style="color:#fff;font-weight:700">intégrations</strong> débloqués en Creator
          </span>
          <a href="/dashboard/billing"
            style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;background:#00ff9d;color:#000;border-radius:99px;font-size:11px;font-weight:800;font-family:'Cabinet Grotesk',system-ui,sans-serif;text-decoration:none;transition:all 0.2s;white-space:nowrap;flex-shrink:0"
            onmouseover="this.style.background='#20ffaa'" onmouseout="this.style.background='#00ff9d'"
          >
            Passer Creator
          </a>
        </div>

        <div class="promo-msg" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:10px;opacity:0;transform:translateY(8px);transition:opacity 0.5s ease,transform 0.5s ease">
          <span style="font-size:11px;font-weight:500;color:rgba(255,255,255,0.55)">
            ⚡ <strong style="color:#fff;font-weight:700">Essai gratuit 7 jours</strong> — accès complet à toutes les fonctionnalités Pro, sans CB
          </span>
          <a href="/dashboard/billing"
            style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;background:linear-gradient(135deg,#00ff9d,#00cc7a);color:#000;border-radius:99px;font-size:11px;font-weight:800;font-family:'Cabinet Grotesk',system-ui,sans-serif;text-decoration:none;transition:all 0.2s;white-space:nowrap;flex-shrink:0;box-shadow:0 2px 10px rgba(0,255,157,0.25)"
            onmouseover="this.style.boxShadow='0 4px 16px rgba(0,255,157,0.4)'" onmouseout="this.style.boxShadow='0 2px 10px rgba(0,255,157,0.25)'"
          >
            Démarrer l'essai ✦
          </a>
        </div>
      </div>

      <!-- Progress dots -->
      <div id="promo-dots" style="position:absolute;bottom:4px;left:50%;transform:translateX(-50%);display:flex;gap:4px">
        <div class="pdot" style="width:14px;height:2px;border-radius:1px;background:#00ff9d;transition:all 0.3s ease"></div>
        <div class="pdot" style="width:4px;height:2px;border-radius:1px;background:rgba(255,255,255,0.2);transition:all 0.3s ease"></div>
        <div class="pdot" style="width:4px;height:2px;border-radius:1px;background:rgba(255,255,255,0.2);transition:all 0.3s ease"></div>
        <div class="pdot" style="width:4px;height:2px;border-radius:1px;background:rgba(255,255,255,0.2);transition:all 0.3s ease"></div>
        <div class="pdot" style="width:4px;height:2px;border-radius:1px;background:rgba(255,255,255,0.2);transition:all 0.3s ease"></div>
      </div>

      <!-- Dismiss -->
      <button id="promo-dismiss"
        style="position:absolute;right:10px;top:50%;transform:translateY(-50%);width:20px;height:20px;border-radius:6px;background:none;border:none;color:rgba(255,255,255,0.25);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:11px;transition:color 0.15s"
        onmouseover="this.style.color='rgba(255,255,255,0.6)'" onmouseout="this.style.color='rgba(255,255,255,0.25)'"
        aria-label="Fermer"
      >✕</button>
    </div>
  )}

    <!-- Top Bar -->
    <header class="h-14 lg:h-16 glass-strong border-b border-white/10 flex items-center justify-between px-4 lg:px-6 shrink-0 gap-3">

      <div class="flex items-center gap-3 lg:hidden">
        <button id="mobile-menu-btn" class="p-2 rounded-lg hover:bg-white/5 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">

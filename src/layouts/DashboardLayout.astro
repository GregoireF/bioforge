---
// src/layouts/DashboardLayout.astro — version stabilisée & fluide (2026-ready)
import CommandPalette from '@/components/features/CommandPalette.astro'
import OnboardingTour from '@/components/features/OnboardingTour.astro';
import UpgradeModal from '@/components/features/UpgradeModal.astro';
import { Image } from 'astro:assets';
import '@/styles/global.css';
import { withAuth } from '@/lib/auth/auth';
import SidebarNav from '@/components/dashboard/SidebarNav.astro';
import UserMenu from '@/components/dashboard/UserMenu.astro';
import { NAV_MAIN, NAV_SECONDARY } from '@/data/nav-dashboard';

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

// ── Auth & user data ─────────────────────────────────────────────────────────
let profile: any = null;
let plan = 'Free';
let isPaid = false;
let showAds = true;
let avatarUrl: string | null = null;
let displayName = 'User';
let initials = 'US';
let planColor = 'text-gray-400 bg-white/5 border-white/10';

const PLAN_COLORS: Record<string, string> = {
  Free:       'text-gray-400 bg-white/5 border-white/10',
  Basic:      'text-neon-blue bg-neon-blue/10 border-neon-blue/20',
  Pro:        'text-neon-green bg-neon-green/10 border-neon-green/20',
  Business:   'text-neon-purple bg-neon-purple/10 border-neon-purple/20',
  Enterprise: 'text-orange-400 bg-orange-400/10 border-orange-400/20',
};

try {
  const auth = await withAuth({ cookies: Astro.cookies, request: Astro.request });
  if (auth.success && auth.data?.profile) {
    profile = auth.data.profile;
    plan = profile.plan ?? 'Free';
    isPaid = ['Pro', 'Business', 'Enterprise'].includes(plan);
    showAds = !isPaid;
    avatarUrl = profile.avatar_url ?? null;
    displayName = profile.display_name || profile.username || 'User';
    initials = displayName.slice(0, 2).toUpperCase();
    planColor = PLAN_COLORS[plan] ?? PLAN_COLORS.Free;
  }
} catch (err) {
  console.error('[DashboardLayout] Auth error:', err);
}

const initialCollapsed = Astro.cookies.get('sidebar-collapsed')?.value === 'true';
---

<!doctype html>
<html lang="en" class="scroll-smooth antialiased">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BioForge</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preload" href="/logo.webp" as="image" />
  {showAds && (
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2203788383686517" crossorigin="anonymous"></script>
  )}
  <style is:global>
    @media (prefers-reduced-motion: reduce) {
      * { transition: none !important; animation: none !important; }
    }
    :focus-visible {
      outline: 2px solid #10b981;
      outline-offset: 2px;
      border-radius: 6px;
    }

    /* Transition fluide pour sidebar collapsible */
    #sidebar {
      transition: width 0.3s ease-in-out;
      overflow: hidden;
    }

    #sidebar > * {
      transition: opacity 0.2s ease 0.1s, transform 0.2s ease 0.1s;
    }

    #sidebar.lg\:w-16 > * {
      opacity: 0;
      transform: translateX(-10px);
      pointer-events: none;
    }
  </style>
</head>
<body class="bg-dark-900 text-white min-h-screen">

  <!-- Skip link -->
  <a href="#main-content" class="sr-only focus:not-sr-only fixed z-[100] top-4 left-4 bg-neon-green text-black px-5 py-3 rounded-xl font-bold shadow-xl">
    Skip to content
  </a>

  <div class="flex min-h-screen">

    <!-- Sidebar Desktop (collapsible) -->
    <aside
      id="sidebar"
      class:list={[
        "hidden lg:flex lg:flex-col lg:border-r lg:border-white/10 lg:glass-strong lg:transition-all lg:duration-300 lg:ease-in-out lg:overflow-hidden",
        initialCollapsed ? "lg:w-16 xl:w-20" : "lg:w-64 xl:w-72"
      ]}
      aria-label="Primary navigation sidebar"
    >
      <div class="h-16 flex items-center justify-between px-4 border-b border-white/10">
        <a href="/" class="flex items-center gap-3">
          <Image src="/logo.webp" alt="BioForge logo" width={32} height={32} class="rounded-lg" format="avif" quality={85} />
          {!initialCollapsed && <span class="font-bold tracking-tight">BioForge</span>}
        </a>
        <button
          id="sidebar-toggle"
          aria-label={initialCollapsed ? "Expand sidebar" : "Collapse sidebar"}
          class="p-2 rounded-lg hover:bg-white/10 transition"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={initialCollapsed ? "M13 5l7 7-7 7M5 5l7 7-7 7" : "M11 19l-7-7 7-7m-7 7h14"} />
          </svg>
        </button>
      </div>

      <div class="flex-1 px-3 py-6 overflow-y-auto">
        <SidebarNav items={NAV_MAIN} collapsed={initialCollapsed} currentPath={currentPath} />

        <div class="mt-8 pt-4 border-t border-white/10">
          <p class:list={["px-3 mb-2 text-xs uppercase tracking-wider text-gray-500 font-semibold", initialCollapsed && "sr-only"]}>Account</p>
          <SidebarNav
            items={NAV_SECONDARY}
            collapsed={initialCollapsed}
            currentPath={currentPath}
          />
        </div>
      </div>

      {showAds && (
        <div class="px-3 pb-4">
          <div class="p-3 glass border border-white/10 rounded-xl min-h-[100px] flex items-center justify-center text-gray-500 text-sm">
            <ins
              class="adsbygoogle"
              style="display:block; width:100%; height:100px;"
              data-ad-client="ca-pub-2203788383686517"
              data-ad-slot="2242281532"
              data-ad-format="auto"
              data-full-width-responsive="true"
            ></ins>
          </div>
        </div>
      )}

      <div class="p-3 border-t border-white/10">
        <UserMenu
          avatarUrl={avatarUrl}
          displayName={displayName}
          initials={initials}
          plan={plan}
          planColor={planColor}
          collapsed={initialCollapsed}
        />
      </div>
    </aside>

    <!-- Main content area -->
    <div class="flex-1 flex flex-col min-w-0">

      <!-- Topbar -->
      <header class="h-14 lg:h-16 glass-strong border-b border-white/10 px-4 lg:px-6 flex items-center justify-between shrink-0">
        <div class="flex items-center gap-4 lg:hidden">
          <button id="mobile-menu-btn" aria-label="Open navigation menu" class="p-2 rounded-lg hover:bg-white/10">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <span class="text-base font-semibold truncate max-w-[180px]">{title}</span>
        </div>

        <div class="hidden lg:flex items-center gap-3 text-sm text-gray-400">
          Dashboard {currentPath !== '/dashboard' && <>→ <span class="text-white font-medium">{title}</span></>}
        </div>

        <div class="flex items-center gap-3">
          <button id="command-palette-trigger" class="hidden lg:flex items-center gap-2 px-3 py-1.5 glass border border-white/10 rounded-lg hover:border-white/20 text-sm text-gray-400 hover:text-white transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="hidden xl:inline">Quick actions</span>
            <kbd class="hidden xl:inline px-2 py-1 text-xs bg-white/5 rounded border border-white/15">⌘K</kbd>
          </button>

          {!isPaid && (
            <a href="/upgrade" class="hidden lg:flex items-center gap-2 px-4 py-2 bg-neon-green/10 border border-neon-green/25 rounded-lg text-sm font-medium text-neon-green hover:bg-neon-green/20 transition">
              Upgrade
            </a>
          )}

          <UserMenu
            avatarUrl={avatarUrl}
            displayName={displayName}
            initials={initials}
            plan={plan}
            planColor={planColor}
            mobile={true}
            class="lg:hidden"
          />
        </div>
      </header>

      <!-- Page content -->
      <main id="main-content" tabindex="-1" class="flex-1 overflow-y-auto p-4 lg:p-6 xl:p-8 pb-24 lg:pb-8">
        <slot />
      </main>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-50 lg:hidden" role="dialog" aria-modal="true" aria-labelledby="mobile-menu-title">
    <div id="mobile-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="absolute inset-y-0 left-0 w-72 glass-strong border-r border-white/10 flex flex-col overflow-hidden">

      <div class="h-16 flex items-center justify-between px-5 border-b border-white/10 shrink-0">
        <div class="flex items-center gap-3">
          <Image src="/logo.webp" alt="BioForge logo" width={32} height={32} class="rounded-lg" />
          <span id="mobile-menu-title" class="font-bold">BioForge</span>
        </div>
        <button id="mobile-close" aria-label="Close menu" class="p-2 rounded-lg hover:bg-white/10">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <div class="flex-1 px-4 py-6 overflow-y-auto">
        <p class="px-3 mb-3 text-xs uppercase tracking-wider text-gray-500 font-semibold">Main</p>
        <SidebarNav items={NAV_MAIN} collapsed={false} currentPath={currentPath} />

        <div class="mt-8 pt-4 border-t border-white/10">
          <p class="px-3 mb-3 text-xs uppercase tracking-wider text-gray-500 font-semibold">Account</p>
          <SidebarNav items={NAV_SECONDARY} collapsed={false} currentPath={currentPath} />
        </div>
      </div>

      <div class="p-4 border-t border-white/10 shrink-0">
        <div class="flex items-center gap-3">
          {avatarUrl ? (
            <img src={avatarUrl} alt="" class="w-10 h-10 rounded-full object-cover border border-white/20" referrerpolicy="no-referrer" loading="lazy" />
          ) : (
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center text-sm font-bold text-black">
              {initials}
            </div>
          )}
          <div class="flex-1 min-w-0">
            <p class="font-semibold truncate">{displayName}</p>
            <span class:list={["text-xs px-2.5 py-0.5 rounded-full border font-medium", planColor]}>{plan}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Feature islands -->
  <CommandPalette client:visible />
  <OnboardingTour client:visible />
  <UpgradeModal client:visible />

<script is:inline>
  // Sidebar toggle – fluide et sans glitch
  const sidebar = document.getElementById('sidebar');
  const toggleBtn = document.getElementById('sidebar-toggle');

  let isCollapsed = sidebar?.classList.contains('lg:w-16') ?? false;

  toggleBtn?.addEventListener('click', () => {
    isCollapsed = !isCollapsed;

    sidebar?.classList.toggle('lg:w-16', isCollapsed);
    sidebar?.classList.toggle('lg:w-64', !isCollapsed);
    sidebar?.classList.toggle('xl:w-72', !isCollapsed);

    void sidebar?.offsetWidth; // force reflow pour transition

    document.cookie = `sidebar-collapsed=${isCollapsed}; path=/; max-age=31536000; samesite=lax`;
    localStorage.setItem('sidebar-collapsed', isCollapsed.toString());

    toggleBtn.setAttribute('aria-label', isCollapsed ? 'Expand sidebar' : 'Collapse sidebar');
  });

  // Mobile drawer
  const menu = document.getElementById('mobile-menu');
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });

  const closeDrawer = () => {
    menu?.classList.add('hidden');
    document.body.style.overflow = '';
  };

  document.getElementById('mobile-close')?.addEventListener('click', closeDrawer);
  document.getElementById('mobile-backdrop')?.addEventListener('click', closeDrawer);

  // Command palette
  document.getElementById('command-palette-trigger')?.addEventListener('click', () => {
    window.openCommandPalette?.();
  });

  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      window.openCommandPalette?.();
    }
  });

  // AdSense push – CORRIGÉ : utilisation de {showAds} pour injecter la variable Astro
  if ({showAds}) {
    setTimeout(() => {
      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      } catch (e) {
        console.warn('AdSense push failed', e);
      }
    }, 800);
  }
</script>
</body>
</html>
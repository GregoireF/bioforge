---
// src/layouts/DashboardLayout.astro - V4 with Command Palette & Onboarding

import CommandPalette from '@/components/features/CommandPalette.astro';
import OnboardingTour from '@/components/features/OnboardingTour.astro';
import UpgradeModal from '@/components/features/UpgradeModal.astro';
import '@/styles/global.css';
import { Image } from 'astro:assets';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - BioForge Dashboard</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body class="bg-dark-900 text-white min-h-screen">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden lg:flex lg:flex-shrink-0 lg:w-64 glass-strong border-r border-white/10">
      <div class="flex flex-col w-full">
        <!-- Logo -->
        <div class="flex items-center justify-between h-16 px-6 border-b border-white/10">
          <a href="https://bioforge.click/" class="flex items-center space-x-2">
            <Image src="/logo.webp" alt="BioForge Logo" width="40" height="40" />
            <span class="text-white font-bold text-lg">BioForge</span>
          </a>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
          <a 
            href="/dashboard" 
            class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span class="font-medium">Overview</span>
          </a>

          <a 
            href="/dashboard/blocks" 
            class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/blocks' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
            </svg>
            <span class="font-medium">Blocks</span>
          </a>

          <a 
            href="/dashboard/analytics" 
            class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/analytics' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            <span class="font-medium">Analytics</span>
          </a>

          <a 
            href="/dashboard/appearance" 
            class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/appearance' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
            <span class="font-medium">Appearance</span>
          </a>

          <a 
            href="/dashboard/settings" 
            class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/settings' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="font-medium">Settings</span>
          </a>
        </nav>

        <!-- Footer -->
        <div class="p-4 border-t border-white/10">
          <div class="flex items-center justify-between text-xs text-gray-500">
            <span>Press ⌘K for quick actions</span>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col min-w-0">
      <!-- Top Bar -->
      <header class="h-16 glass-strong border-b border-white/10 flex items-center justify-between px-4 lg:px-8">
        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg hover:bg-white/5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Page Title (mobile) -->
        <h1 class="lg:hidden text-lg font-semibold text-white">{title}</h1>

        <!-- Spacer -->
        <div class="flex-1 lg:hidden"></div>

        <!-- Right Side -->
        <div class="flex items-center space-x-2 lg:space-x-4">
          <!-- Command Palette Trigger -->
          <button 
            id="command-palette-trigger"
            class="hidden lg:flex items-center space-x-2 px-3 py-2 glass border border-white/10 rounded-lg hover:border-neon-green/30 transition-all"
          >
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <span class="text-sm text-gray-400">Quick actions</span>
            <kbd class="px-1.5 py-0.5 text-xs bg-white/5 rounded border border-white/10">⌘K</kbd>
          </button>

          <!-- User Menu -->
          <div class="relative">
            <button id="user-menu-btn" class="flex items-center space-x-2 p-2 rounded-lg hover:bg-white/5">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center text-sm font-bold">
                U
              </div>
            </button>

            <!-- Dropdown (hidden by default) -->
            <div id="user-menu" class="hidden absolute right-0 mt-2 w-48 glass-strong border border-white/10 rounded-xl shadow-2xl overflow-hidden z-50">
              <a href="/dashboard/settings" class="block px-4 py-3 text-sm text-gray-300 hover:bg-white/5 transition-colors">
                Settings
              </a>
              <a href="/api/auth/signout" class="block px-4 py-3 text-sm text-red-400 hover:bg-white/5 transition-colors border-t border-white/10">
                Sign Out
              </a>
            </div>
          </div>
        </div>
      </header>

      <!-- Page Content -->
      <main class="flex-1 overflow-y-auto p-4 lg:p-8">
        <slot />
      </main>
    </div>
  </div>

  <!-- Mobile Menu Overlay (hidden by default) -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-50 lg:hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="mobile-menu-backdrop"></div>
    <div class="absolute inset-y-0 left-0 w-64 glass-strong border-r border-white/10">
      <div class="flex flex-col h-full">
        <!-- Mobile Logo -->
        <div class="flex items-center justify-between h-16 px-6 border-b border-white/10">
          <a href="/dashboard" class="flex items-center space-x-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center">
              <span class="text-white font-bold text-lg">B</span>
            </div>
            <span class="text-white font-bold text-lg">BioForge</span>
          </a>
          <button id="mobile-menu-close" class="p-2 rounded-lg hover:bg-white/5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Mobile Navigation -->
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
          <!-- Same links as sidebar -->
          <a href="/dashboard" class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span class="font-medium">Overview</span>
          </a>
          <a href="/dashboard/blocks" class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/blocks' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
            </svg>
            <span class="font-medium">Blocks</span>
          </a>
          <a href="/dashboard/analytics" class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/analytics' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            <span class="font-medium">Analytics</span>
          </a>
          <a href="/dashboard/appearance" class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/appearance' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
            <span class="font-medium">Appearance</span>
          </a>
          <a href="/dashboard/settings" class={`flex items-center space-x-3 px-3 py-2.5 rounded-xl transition-all ${currentPath === '/dashboard/settings' ? 'bg-neon-green/10 text-neon-green border border-neon-green/30' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="font-medium">Settings</span>
          </a>
        </nav>
      </div>
    </div>
  </div>

  <!-- V4 Features -->
  <CommandPalette />
  <OnboardingTour />
  <UpgradeModal />

  <!-- Toast Container -->
  <div id="toast-container" class="fixed bottom-4 right-4 z-[9999] space-y-2"></div>

  <script>
    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');

    function openMobileMenu() {
      mobileMenu?.classList.remove('hidden');
    }

    function closeMobileMenu() {
      mobileMenu?.classList.add('hidden');
    }

    mobileMenuBtn?.addEventListener('click', openMobileMenu);
    mobileMenuClose?.addEventListener('click', closeMobileMenu);
    mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);

    // User menu toggle
    const userMenuBtn = document.getElementById('user-menu-btn');
    const userMenu = document.getElementById('user-menu');

    userMenuBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      userMenu?.classList.toggle('hidden');
    });

    // Close user menu when clicking outside
    document.addEventListener('click', () => {
      userMenu?.classList.add('hidden');
    });

    // Command Palette trigger
    const commandPaletteTrigger = document.getElementById('command-palette-trigger');
    commandPaletteTrigger?.addEventListener('click', () => {
      if (window.openCommandPalette) {
        window.openCommandPalette();
      }
    });
  </script>
</body>
</html>
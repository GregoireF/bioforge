      </div>
      <p class="text-sm text-gray-500">Données sur <span class="text-gray-300 font-medium">{days} jours</span>{summary.botViews > 0 && <span class="ml-2 text-xs text-yellow-500/70">· {summary.botViews} bots exclus</span>}</p>
    </div>
    <div class="flex items-center gap-2 self-start flex-wrap">
      <div class="flex items-center gap-0.5 p-1 rounded-xl border border-white/8 bg-white/3">

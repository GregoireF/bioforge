---
// src/layouts/DashboardLayout.astro — v5
// Auth-aware layout : nav centralisée, Carbon Ads (Free/Base), user menu riche,
// Billing + # dans la nav, bottom nav mobile, plan badge

import CommandPalette from '@/components/features/CommandPalette.astro';
import OnboardingTour from '@/components/features/OnboardingTour.astro';
import UpgradeModal from '@/components/features/UpgradeModal.astro';
import '@/styles/global.css';
import { Image } from 'astro:assets';
import { withAuth } from '@/lib/auth/auth';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

// ── Auth (best-effort — layout ne redirige pas, les pages s'en chargent) ──────
let profile: any   = null;
let planLimits: any = null;
try {
  const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
  if (authResult.success && authResult.data) {
    profile    = authResult.data.profile;
    planLimits = authResult.data.planLimits;
  }
} catch {}

// ── Plan helpers ───────────────────────────────────────────────────────────────
const PAID_PLANS   = ['Pro', 'Business', 'Enterprise'];
const plan         = profile?.plan ?? 'Free';
const isPaid       = PAID_PLANS.includes(plan);
const isBasicOrFree = !isPaid; // Carbon Ads shown for Free + Basic
const showAds      = isBasicOrFree;

const PLAN_COLORS: Record<string, string> = {
  Free:       'text-gray-400 bg-white/5 border-white/10',
  Basic:      'text-neon-blue bg-neon-blue/10 border-neon-blue/20',
  Pro:        'text-neon-green bg-neon-green/10 border-neon-green/20',
  Business:   'text-neon-purple bg-neon-purple/10 border-neon-purple/20',
  Enterprise: 'text-orange-400 bg-orange-400/10 border-orange-400/20',
};
const planColor = PLAN_COLORS[plan] ?? PLAN_COLORS.Free;

// ── Avatar fallback ────────────────────────────────────────────────────────────
const avatarUrl   = profile?.avatar_url ?? null;
const displayName = profile?.display_name || profile?.username || 'User';
const initials    = displayName.slice(0, 2).toUpperCase();

// ── Navigation items ───────────────────────────────────────────────────────────
// Single source of truth — rendered in both sidebar & mobile nav
const NAV_MAIN = [
  {
    href:  '/dashboard',
    label: 'Overview',
    exact: true,
    icon:  'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  },
  {
    href:  '/dashboard/blocks',
    label: 'Blocks',
    exact: false,
    icon:  'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
  },
  {
    href:  '/dashboard/analytics',
    label: 'Analytics',
    exact: false,
    icon:  'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
  {
    href:  '/dashboard/appearance',
    label: 'Appearance',
    exact: false,
    icon:  'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  },
];

const NAV_SECONDARY = [
  {
    href:  '/dashboard/#',
    label: 'Billing',
    exact: false,
    icon:  'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
  },
  {
    href:  '/dashboard/#',
    label: 'Roadmap',
    exact: false,
    icon:  'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  },
  {
    href:  '/dashboard/settings',
    label: 'Settings',
    exact: false,
    icon:  'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
];

// ── Nav active helper ──────────────────────────────────────────────────────────
function isActive(href: string, exact: boolean): boolean {
  return exact ? currentPath === href : currentPath.startsWith(href);
}
function navClass(href: string, exact: boolean): string {
  return isActive(href, exact)
    ? 'flex items-center gap-3 px-3 py-2.5 rounded-xl bg-neon-green/10 text-neon-green border border-neon-green/25 font-medium text-sm'
    : 'flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:text-white hover:bg-white/5 transition-all font-medium text-sm';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BioForge</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <!-- Google AdSense verification -->
  <meta name="google-adsense-account" content="ca-pub-2203788383686517" />
  <!-- AdSense script (chargé uniquement si showAds) -->
  {showAds && (
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2203788383686517" crossorigin="anonymous"></script>
  )}
</head>
<body class="bg-dark-900 text-white min-h-screen">

<div class="flex min-h-screen">

  <!-- ===== SIDEBAR (desktop) ===== -->
  <aside class="hidden lg:flex lg:flex-shrink-0 lg:w-60 xl:w-64 flex-col glass-strong border-r border-white/10">

    <!-- Logo -->
    <div class="flex items-center h-16 px-5 border-b border-white/10 shrink-0">
      <a href="https://bioforge.click/" class="flex items-center gap-2.5">
        <Image src="/logo.webp" alt="BioForge" width={28} height={28} class="rounded-lg" />
        <span class="text-white font-bold text-base tracking-tight">BioForge</span>
      </a>
    </div>

    <!-- Nav main -->
    <nav class="flex-1 px-3 py-5 space-y-0.5 overflow-y-auto">
      <p class="px-3 mb-2 text-xs font-semibold text-gray-600 uppercase tracking-widest">Main</p>
      {NAV_MAIN.map(item => (
        <a href={item.href} class={navClass(item.href, item.exact)}>
          <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon}/>
          </svg>
          {item.label}
        </a>
      ))}

      <div class="pt-4 pb-2">
        <p class="px-3 mb-2 text-xs font-semibold text-gray-600 uppercase tracking-widest">Account</p>
        {NAV_SECONDARY.map(item => (
          <a href={item.href} class={navClass(item.href, item.exact)}>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon}/>
            </svg>
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- AdSense (Free / Basic only) — collapses if ad blocked or not filled -->
    {showAds && (
      <div class="px-3 pb-3" id="adsense-sidebar-wrap" style="display:none;">
        <div class="relative p-3 glass border border-white/8 rounded-xl overflow-hidden">
          <ins class="adsbygoogle adsense-sidebar"
            style="display:block;width:100%;min-width:160px;"
            data-ad-client="ca-pub-2203788383686517"
            data-ad-slot="2242281532"
            data-ad-format="rectangle"
            data-full-width-responsive="false"></ins>
          <a href="/dashboard/#"
            class="flex items-center gap-2 mt-2 pt-2 border-t border-white/8 text-xs text-gray-500 hover:text-neon-green transition-colors">
            <svg class="w-3 h-3 text-neon-green/60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Remove ads — Upgrade to Pro
          </a>
        </div>
      </div>
    )}

    <!-- User profile footer -->
    <div class="px-3 pb-4 pt-2 border-t border-white/10 shrink-0">
      <div class="flex items-center gap-3 p-2 rounded-xl hover:bg-white/5 transition-all cursor-pointer group" id="sidebar-user-btn">
        <!-- Avatar -->
        <div class="relative shrink-0">
          {avatarUrl ? (
            <img src={avatarUrl} alt={displayName}
              class="w-8 h-8 rounded-full object-cover border border-white/20" />
          ) : (
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center text-xs font-bold text-black">
              {initials}
            </div>
          )}
          <span class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 bg-neon-green rounded-full border-2 border-dark-900"></span>
        </div>
        <!-- Name + plan -->
        <div class="flex-1 min-w-0">
          <p class="text-xs font-semibold text-white truncate">{displayName}</p>
          <span class={`inline-flex items-center text-xs px-1.5 py-0 rounded-full border font-medium ${planColor}`}>
            {plan}
          </span>
        </div>
        <!-- Chevron -->
        <svg class="w-3.5 h-3.5 text-gray-600 group-hover:text-gray-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>

      <!-- User dropdown -->
      <div id="sidebar-user-menu" class="hidden mt-1 p-1 glass-strong border border-white/10 rounded-xl shadow-2xl">
        <a href="/dashboard/settings"
          class="flex items-center gap-2.5 px-3 py-2 text-sm text-gray-300 hover:bg-white/5 hover:text-white rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Settings
        </a>
        {!isPaid && (
          <a href="/dashboard/#"
            class="flex items-center gap-2.5 px-3 py-2 text-sm text-neon-green hover:bg-neon-green/5 rounded-lg transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Upgrade to Pro
          </a>
        )}
        <div class="my-1 border-t border-white/10"></div>
        <a href="/api/auth/signout"
          class="flex items-center gap-2.5 px-3 py-2 text-sm text-red-400 hover:bg-red-500/5 rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Sign Out
        </a>
      </div>
    </div>

  </aside>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="flex-1 flex flex-col min-w-0">

    <!-- Top Bar -->
    <header class="h-14 lg:h-16 glass-strong border-b border-white/10 flex items-center justify-between px-4 lg:px-6 shrink-0 gap-3">

      <!-- Mobile: hamburger + logo -->
      <div class="flex items-center gap-3 lg:hidden">
        <button id="mobile-menu-btn" class="p-2 rounded-lg hover:bg-white/5 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <span class="text-sm font-semibold text-white">{title}</span>
      </div>

      <!-- Desktop: breadcrumb -->
      <div class="hidden lg:flex items-center gap-2 text-sm">
        <span class="text-gray-600">Dashboard</span>
        {currentPath !== '/dashboard' && (
          <>
            <svg class="w-3.5 h-3.5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="text-white font-medium">{title}</span>
          </>
        )}
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-2">

        <!-- Command palette trigger (desktop) -->
        <button id="command-palette-trigger"
          class="hidden lg:flex items-center gap-2 px-3 py-1.5 glass border border-white/10 rounded-lg hover:border-white/20 transition-all text-sm text-gray-500 hover:text-gray-300">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <span class="hidden xl:inline">Quick actions</span>
          <kbd class="hidden xl:inline px-1.5 py-0.5 text-xs bg-white/5 rounded border border-white/10 font-mono">⌘K</kbd>
        </button>

        <!-- View profile shortcut -->
        {profile?.username && (
          <a href={`/@${profile.username}`} target="_blank"
            class="hidden lg:flex items-center gap-1.5 px-3 py-1.5 glass border border-white/10 rounded-lg hover:border-white/20 transition-all text-xs text-gray-400 hover:text-white">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            View profile
          </a>
        )}

        <!-- Upgrade CTA (Free/Basic only, desktop) -->
        {!isPaid && (
          <a href="/dashboard/#"
            class="hidden lg:flex items-center gap-1.5 px-3 py-1.5 bg-neon-green/10 border border-neon-green/25 rounded-lg text-xs font-semibold text-neon-green hover:bg-neon-green/20 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Upgrade
          </a>
        )}

        <!-- User menu (topbar, mobile) -->
        <div class="relative lg:hidden">
          <button id="topbar-user-btn" class="p-1.5 rounded-full hover:bg-white/5 transition-colors">
            {avatarUrl ? (
              <img src={avatarUrl} alt={displayName} class="w-7 h-7 rounded-full object-cover" />
            ) : (
              <div class="w-7 h-7 rounded-full bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center text-xs font-bold text-black">
                {initials}
              </div>
            )}
          </button>
          <div id="topbar-user-menu" class="hidden absolute right-0 mt-2 w-48 glass-strong border border-white/10 rounded-xl shadow-2xl z-50 p-1">
            <a href="/dashboard/settings" class="flex items-center gap-2.5 px-3 py-2 text-sm text-gray-300 hover:bg-white/5 rounded-lg transition-all">Settings</a>
            {!isPaid && <a href="/dashboard/#" class="flex items-center gap-2.5 px-3 py-2 text-sm text-neon-green hover:bg-neon-green/5 rounded-lg transition-all">Upgrade to Pro</a>}
            <div class="my-1 border-t border-white/10"></div>
            <a href="/api/auth/signout" class="flex items-center gap-2.5 px-3 py-2 text-sm text-red-400 hover:bg-red-500/5 rounded-lg transition-all">Sign Out</a>
          </div>
        </div>

      </div>
    </header>

    <!-- Page content -->
    <main class="flex-1 overflow-y-auto p-4 lg:p-6 xl:p-8 pb-20 lg:pb-8">
      <slot />
    </main>

  </div>
</div>

<!-- ===== MOBILE DRAWER ===== -->
<div id="mobile-menu" class="hidden fixed inset-0 z-50 lg:hidden">
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/75 backdrop-blur-sm"></div>
  <div class="absolute inset-y-0 left-0 w-64 glass-strong border-r border-white/10 flex flex-col">

    <!-- Header -->
    <div class="flex items-center justify-between h-14 px-4 border-b border-white/10 shrink-0">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center">
          <span class="text-black font-bold text-sm">B</span>
        </div>
        <span class="text-white font-bold">BioForge</span>
      </div>
      <button id="mobile-menu-close" class="p-1.5 rounded-lg hover:bg-white/5 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <p class="px-3 mb-2 text-xs font-semibold text-gray-600 uppercase tracking-widest">Main</p>
      {NAV_MAIN.map(item => (
        <a href={item.href} class={navClass(item.href, item.exact)}>
          <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon}/>
          </svg>
          {item.label}
        </a>
      ))}
      <div class="pt-4 pb-2">
        <p class="px-3 mb-2 text-xs font-semibold text-gray-600 uppercase tracking-widest">Account</p>
        {NAV_SECONDARY.map(item => (
          <a href={item.href} class={navClass(item.href, item.exact)}>
            <svg class="w-4.5 h-4.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon}/>
            </svg>
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- Mobile ads — collapses if not filled -->
    {showAds && (
      <div class="px-3 pb-2" id="adsense-mobile-wrap" style="display:none;">
        <div class="p-3 glass border border-white/8 rounded-xl">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs text-gray-600">Sponsored</span>
            <a href="/dashboard/#" class="text-xs text-neon-green hover:underline">Remove ads</a>
          </div>
          <ins class="adsbygoogle adsense-mobile"
            style="display:block;width:100%;min-width:160px;"
            data-ad-client="ca-pub-2203788383686517"
            data-ad-slot="2242281532"
            data-ad-format="rectangle"
            data-full-width-responsive="false"></ins>
        </div>
      </div>
    )}

    <!-- User footer -->
    <div class="px-3 py-4 border-t border-white/10 shrink-0">
      <div class="flex items-center gap-3">
        {avatarUrl ? (
          <img src={avatarUrl} alt={displayName} class="w-8 h-8 rounded-full object-cover" />
        ) : (
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-neon-green to-neon-blue flex items-center justify-center text-xs font-bold text-black">{initials}</div>
        )}
        <div class="flex-1 min-w-0">
          <p class="text-xs font-semibold text-white truncate">{displayName}</p>
          <span class={`text-xs px-1.5 py-0 rounded-full border font-medium ${planColor}`}>{plan}</span>
        </div>
        <a href="/api/auth/signout" class="p-1.5 text-gray-500 hover:text-red-400 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</div>

<!-- ===== MOBILE BOTTOM NAV ===== -->
<nav class="fixed bottom-0 left-0 right-0 z-40 lg:hidden glass-strong border-t border-white/10 flex items-center justify-around px-2 h-16 safe-area-pb">
  {[...NAV_MAIN].slice(0, 4).map(item => {
    const active = isActive(item.href, item.exact);
    return (
      <a href={item.href}
        class={`flex flex-col items-center justify-center gap-0.5 px-3 py-1.5 rounded-xl transition-all min-w-0
          ${active ? 'text-neon-green' : 'text-gray-500 hover:text-gray-300'}`}>
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width={active ? '2' : '1.75'} d={item.icon}/>
        </svg>
        <span class="text-xs font-medium truncate">{item.label}</span>
      </a>
    );
  })}
  <!-- More button → opens drawer -->
  <button id="mobile-more-btn"
    class="flex flex-col items-center justify-center gap-0.5 px-3 py-1.5 rounded-xl text-gray-500 hover:text-gray-300 transition-all">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
    <span class="text-xs font-medium">More</span>
  </button>
</nav>

<!-- V4 Features -->
<CommandPalette />
<OnboardingTour />
<UpgradeModal />

<!-- Toast -->
<div id="toast-container" class="fixed bottom-20 right-4 lg:bottom-4 z-[9999] space-y-2"></div>

<style>
  /* AdSense — contenu minimum pour éviter le layout shift */
  .adsbygoogle { min-height: 100px; background: transparent; }
  /* Safe area for mobile bottom nav */
  .safe-area-pb { padding-bottom: env(safe-area-inset-bottom, 0); }
</style>

<script>
  // ── Mobile menu ──────────────────────────────────────────────────────────────
  const mobileMenu     = document.getElementById('mobile-menu');
  const mobileBackdrop = document.getElementById('mobile-menu-backdrop');

  function openMobile()  { mobileMenu?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closeMobile() { mobileMenu?.classList.add('hidden');    document.body.style.overflow = ''; }

  document.getElementById('mobile-menu-btn')?.addEventListener('click', openMobile);
  document.getElementById('mobile-more-btn')?.addEventListener('click', openMobile);
  document.getElementById('mobile-menu-close')?.addEventListener('click', closeMobile);
  mobileBackdrop?.addEventListener('click', closeMobile);

  // ── Sidebar user dropdown ────────────────────────────────────────────────────
  const sidebarUserBtn  = document.getElementById('sidebar-user-btn');
  const sidebarUserMenu = document.getElementById('sidebar-user-menu');

  sidebarUserBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    sidebarUserMenu?.classList.toggle('hidden');
  });

  // ── Topbar user dropdown (mobile) ────────────────────────────────────────────
  const topbarUserBtn  = document.getElementById('topbar-user-btn');
  const topbarUserMenu = document.getElementById('topbar-user-menu');

  topbarUserBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    topbarUserMenu?.classList.toggle('hidden');
    sidebarUserMenu?.classList.add('hidden');
  });

  // Close all dropdowns on outside click
  document.addEventListener('click', () => {
    sidebarUserMenu?.classList.add('hidden');
    topbarUserMenu?.classList.add('hidden');
  });

  // ── Command palette ──────────────────────────────────────────────────────────
  document.getElementById('command-palette-trigger')?.addEventListener('click', () => {
    window.openCommandPalette?.();
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      window.openCommandPalette?.();
    }
  });
</script>

<script>
  function initAdsense() {
    document.querySelectorAll('.adsbygoogle').forEach(function(ins) {
      if (ins.getAttribute('data-adsbygoogle-status')) return;
      var wrap = ins.closest('[id$="-wrap"]');
      var w = ins.closest('aside')?.offsetWidth || ins.parentElement?.offsetWidth || 0;
      if (w < 50) return;
      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
        // Show wrapper only after push succeeds (ad may still be blocked)
        if (wrap) {
          // MutationObserver: reveal wrapper only if AdSense fills the ins
          var obs = new MutationObserver(function() {
            if (ins.getAttribute('data-adsbygoogle-status') === 'done' && ins.offsetHeight > 10) {
              wrap.style.display = '';
              obs.disconnect();
            }
          });
          obs.observe(ins, { attributes: true, childList: true, subtree: true });
          // Fallback: hide after 4s if still empty
          setTimeout(function() {
            if (ins.offsetHeight <= 10) { wrap.style.display = 'none'; }
            obs.disconnect();
          }, 4000);
        }
      } catch(e) {}
    });
  }
  if (document.readyState === 'complete') {
    setTimeout(initAdsense, 400);
  } else {
    window.addEventListener('load', function() { setTimeout(initAdsense, 400); });
  }
</script>
</body>
</html>
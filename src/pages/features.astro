---
// src/pages/features.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL ?? 'https://bioforge.click';

const SEO = {
  title:       'Fonctionnalités — BioForge',
  description: 'Découvrez toutes les fonctionnalités BioForge : éditeur drag & drop, analytics temps réel, personnalisation avancée, sécurité et communauté.',
  url:         `${SITE_URL}/features`,
};

const categories = [
  {
    id:    'analytics',
    label: 'Analytics',
    color: '#38bdf8',
    title: 'Comprends ce qui performe',
    desc:  'Des données réelles, en temps réel. Pas juste un compteur de vues — un vrai outil de croissance.',
    features: [
      { name: 'Vues de page en temps réel',    desc: 'Chaque visite est enregistrée instantanément. Vois les pics de trafic au moment où ils arrivent.' },
      { name: 'Clics par bloc',                 desc: 'Sais exactement quel lien ou bloc performe. Optimise ton ordre et ton contenu en conséquence.' },
      { name: 'Sources de trafic',              desc: 'Instagram, TikTok, Twitter, direct — vois d\'où vient ton audience et double la mise.' },
      { name: 'Statistiques par période',       desc: 'Compare tes performances semaine par semaine, mois par mois. Mesure l\'impact de chaque publication.' },
      { name: 'Export CSV',                     desc: 'Exporte tes données pour les analyser dans ton outil préféré ou les présenter à des partenaires.' },
    ],
  },
  {
    id:    'editor',
    label: 'Éditeur',
    color: '#39ff8f',
    title: 'Construit ta page sans coder',
    desc:  'Un éditeur drag & drop pensé pour les créateurs, pas pour les développeurs.',
    features: [
      { name: 'Drag & drop intuitif',           desc: 'Réorganise tes blocs en quelques secondes. Ce que tu vois en édition est exactement ce que voient tes visiteurs.' },
      { name: '15+ types de blocs',             desc: 'Lien, titre, image, vidéo, formulaire, countdown, QR code, intégration réseaux sociaux — et bien plus.' },
      { name: 'Prévisualisation live',          desc: 'Vois les changements en temps réel sur desktop et mobile avant de publier.' },
      { name: 'Blocs actifs / inactifs',        desc: 'Active ou désactive des blocs temporairement sans les supprimer. Parfait pour les promos et annonces.' },
      { name: 'Ordre et priorité',              desc: 'Mets en avant ce qui compte. Change l\'ordre d\'un bloc en une seconde.' },
    ],
  },
  {
    id:    'design',
    label: 'Personnalisation',
    color: '#a78bfa',
    title: 'Un design qui te ressemble',
    desc:  'Ton profil doit refléter ton identité. Ici, rien n\'est générique.',
    features: [
      { name: 'Thèmes prédéfinis',              desc: 'Démarre vite avec des thèmes soigneusement designés, calibrés pour les créateurs gaming et lifestyle.' },
      { name: 'Couleurs & typographie custom',  desc: 'Choisis tes couleurs exactes, ta palette, ta police. Ta charte, pas celle de tout le monde.' },
      { name: 'Fond custom',                    desc: 'Couleur unie, gradient, image, vidéo — le fond de ta page est entièrement personnalisable.' },
      { name: 'CSS custom (Pro)',               desc: 'Tu veux aller plus loin ? Injecte ton propre CSS pour un contrôle total sur l\'apparence.' },
      { name: 'Domaine custom (Pro)',            desc: 'Connecte liens.toi.com en quelques minutes. SSL automatique inclus, aucun hébergeur nécessaire.' },
    ],
  },
  {
    id:    'community',
    label: 'Roadmap & Communauté',
    color: '#fb923c',
    title: 'Tu shapes le produit',
    desc:  'BioForge est construit avec ses utilisateurs. Ta voix compte vraiment.',
    features: [
      { name: 'Roadmap publique',               desc: 'Vois ce qui est planifié, en cours et livré. Aucune feature cachée derrière un NDA opaque.' },
      { name: 'Vote sur les features',          desc: 'Vote pour les fonctionnalités qui t\'importent. Les plus votées passent en priorité.' },
      { name: 'Suggestions directes',          desc: 'Propose tes propres idées. Notre équipe lit et répond à chaque suggestion.' },
      { name: 'Accès bêta (Pro+)',              desc: 'Les abonnés Pro testent les nouvelles features en avant-première avant le déploiement général.' },
      { name: 'Communauté Discord',             desc: 'Rejoins des centaines de créateurs, partage tes tips, reçois de l\'aide et influence le produit.' },
    ],
  },
  {
    id:    'security',
    label: 'Sécurité & Perf',
    color: '#f59e0b',
    title: 'Rapide, fiable, sécurisé',
    desc:  'Tes visiteurs n\'attendent pas. Tes données ne fuient pas.',
    features: [
      { name: 'Pages statiques ultra-rapides', desc: 'Les profils publics sont générés statiquement. Score PageSpeed 95+ sur mobile, Largest Contentful Paint < 1s.' },
      { name: 'SSL automatique',               desc: 'Tout est HTTPS par défaut. Certificat SSL émis et renouvelé automatiquement pour ton domaine custom.' },
      { name: 'Uptime 99.9%',                 desc: 'Infrastructure redondante hébergée en Europe. SLA garanti avec monitoring 24/7.' },
      { name: 'Conformité RGPD',              desc: 'Données hébergées en Europe (UE). Aucun cookie tiers sans consentement. Conformité totale avec le RGPD.' },
      { name: 'Authentification sécurisée',    desc: 'OAuth 2.0 via Google et Discord. Aucun mot de passe stocké. Magic link pour une connexion sans friction.' },
    ],
  },
] as const;
---

<BaseLayout title={SEO.title}>
  <Fragment slot="head">
    <meta name="description"        content={SEO.description} />
    <link rel="canonical"           href={SEO.url} />
    <meta property="og:title"       content={SEO.title} />
    <meta property="og:description" content={SEO.description} />
    <meta property="og:url"         content={SEO.url} />
  </Fragment>

  <Header />

  <main class="feat-main">

    <!-- Hero -->
    <section class="feat-hero">
      <div class="feat-bg" aria-hidden="true">
        <div class="fh-glow g1"></div>
        <div class="fh-glow g2"></div>
        <div class="fh-grid"></div>
      </div>
      <div class="feat-hero-inner">
        <div class="feat-badge">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
          Toutes les fonctionnalités
        </div>
        <h1 class="feat-hero-title">
          Tout ce dont tu as besoin<br>
          <span class="feat-accent">pour grandir</span>
        </h1>
        <p class="feat-hero-sub">Un outil pensé pour les créateurs gaming, streamers et artistes. Rien de superflu, tout ce qui compte.</p>

        <!-- Nav catégories -->
        <nav class="feat-nav" aria-label="Catégories de fonctionnalités">
          {categories.map(cat => (
            <a href={`#${cat.id}`} class="feat-nav-link" style={`--c:${cat.color}`}>
              {cat.label}
            </a>
          ))}
        </nav>
      </div>
    </section>

    <!-- Sections par catégorie -->
    {categories.map((cat, ci) => (
      <section id={cat.id} class={`feat-section${ci % 2 === 1 ? ' feat-section-alt' : ''}`} aria-labelledby={`cat-title-${cat.id}`}>
        <div class="feat-section-inner">

          <!-- Texte intro -->
          <div class="cat-intro feat-reveal" style={`--c:${cat.color}`}>
            <div class="cat-eyebrow" style={`color:${cat.color}; background:${cat.color}10; border-color:${cat.color}22`}>
              {cat.label}
            </div>
            <h2 id={`cat-title-${cat.id}`} class="cat-title">{cat.title}</h2>
            <p class="cat-desc">{cat.desc}</p>

            <a href="/signin" class="cat-cta" style={`color:${cat.color}; border-color:${cat.color}30; background:${cat.color}0e`}>
              Essayer gratuitement
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>

          <!-- Grille de features -->
          <div class="feat-grid">
            {cat.features.map((f, fi) => (
              <div class="feat-card feat-reveal" style={`--c:${cat.color}; animation-delay:${fi * 0.07}s`}>
                <div class="feat-card-dot" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={cat.color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <div>
                  <h3 class="feat-card-title">{f.name}</h3>
                  <p class="feat-card-desc">{f.desc}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </section>
    ))}

    <!-- CTA final -->
    <section class="feat-cta-section">
      <div class="feat-cta-box">
        <h2 class="feat-cta-title">
          Prêt à tout ça ?<br>
          <span class="feat-cta-accent">Commence maintenant.</span>
        </h2>
        <p class="feat-cta-sub">Gratuit pour démarrer. Aucune CB requise.</p>
        <div class="feat-cta-btns">
          <a href="/signin" class="feat-cta-primary">
            Créer ma page gratuitement
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
          <a href="/pricing" class="feat-cta-secondary">Voir les tarifs</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<script>
  // Reveal au scroll
  document.querySelectorAll('.feat-reveal').forEach(el =>
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) (e.target as HTMLElement).classList.add('revealed');
    }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }).observe(el)
  );

  // Smooth scroll pour les ancres du nav
  document.querySelectorAll('.feat-nav-link').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const id = (link as HTMLAnchorElement).getAttribute('href')!.slice(1);
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

<style>
  .feat-main { padding-top: 64px; }

  /* ── Hero ── */
  .feat-hero {
    position: relative; overflow: hidden;
    padding: 5rem 1.5rem 4rem; text-align: center;
  }
  .feat-bg { position: absolute; inset: 0; pointer-events: none; }
  .fh-glow { position: absolute; border-radius: 50%; filter: blur(100px); }
  .g1 { width: 500px; height: 400px; top: -20%; left: -10%; background: rgba(57,255,143,.07); }
  .g2 { width: 400px; height: 300px; bottom: 0; right: -5%; background: rgba(56,189,248,.055); }
  .fh-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(57,255,143,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(57,255,143,.035) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  .feat-hero-inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }

  .feat-badge {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .3rem .875rem;
    background: rgba(57,255,143,.08); border: 1px solid rgba(57,255,143,.2);
    border-radius: 99px; font-size: .72rem; font-weight: 700; color: #39ff8f;
    text-transform: uppercase; letter-spacing: .08em;
  }

  .feat-hero-title {
    font-family: 'Syne', sans-serif; font-weight: 800;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: #fff; letter-spacing: -.04em; line-height: 1.05;
  }
  .feat-accent {
    background: linear-gradient(90deg, #39ff8f, #38bdf8);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .feat-hero-sub { font-size: 1rem; color: rgba(255,255,255,.48); max-width: 500px; line-height: 1.65; }

  /* Nav catégories */
  .feat-nav {
    display: flex; flex-wrap: wrap; gap: .5rem; justify-content: center;
    margin-top: .5rem;
  }
  .feat-nav-link {
    padding: .35rem .875rem;
    background: color-mix(in srgb, var(--c) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 20%, transparent);
    border-radius: 99px; color: var(--c);
    font-size: .78rem; font-weight: 600; text-decoration: none;
    transition: all .15s;
  }
  .feat-nav-link:hover { background: color-mix(in srgb, var(--c) 18%, transparent); }

  /* ── Sections ── */
  .feat-section { padding: 5rem 1.5rem; }
  .feat-section-alt { background: rgba(255,255,255,.015); }

  .feat-section-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 2fr;
    gap: 4rem; align-items: start;
  }

  /* Reveal */
  .feat-reveal {
    opacity: 0; transform: translateY(18px);
    transition: opacity .5s ease, transform .5s ease;
    transition-delay: var(--delay, 0s);
  }
  .feat-reveal.revealed { opacity: 1; transform: none; }

  /* Intro colonne */
  .cat-intro { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: 90px; }

  .cat-eyebrow {
    display: inline-block; width: fit-content;
    padding: .3rem .875rem; border-radius: 99px; border: 1px solid;
    font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em;
  }

  .cat-title {
    font-family: 'Syne', sans-serif; font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800; color: #fff; letter-spacing: -.03em; line-height: 1.1;
  }
  .cat-desc { font-size: .875rem; color: rgba(255,255,255,.46); line-height: 1.7; }

  .cat-cta {
    display: inline-flex; align-items: center; gap: .4rem; width: fit-content;
    padding: .625rem 1.125rem; border-radius: .625rem; border: 1px solid;
    font-size: .8125rem; font-weight: 600; text-decoration: none; transition: all .15s;
  }
  .cat-cta:hover { filter: brightness(1.15); transform: translateY(-1px); }

  /* Grille features */
  .feat-grid { display: flex; flex-direction: column; gap: .875rem; }

  .feat-card {
    display: flex; align-items: flex-start; gap: 1rem;
    padding: 1.25rem;
    background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.07);
    border-radius: 1rem;
    transition: border-color .2s, background .2s, transform .2s;
  }
  .feat-card:hover {
    border-color: color-mix(in srgb, var(--c) 22%, transparent);
    background: rgba(255,255,255,.04);
    transform: translateX(4px);
  }

  .feat-card-dot {
    width: 32px; height: 32px; border-radius: .5rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb, var(--c) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 18%, transparent);
    margin-top: .1rem;
  }

  .feat-card-title { font-size: .9rem; font-weight: 700; color: #fff; margin-bottom: .3rem; }
  .feat-card-desc  { font-size: .8rem; color: rgba(255,255,255,.46); line-height: 1.65; }

  /* ── CTA final ── */
  .feat-cta-section { padding: 5rem 1.5rem; display: flex; justify-content: center; }
  .feat-cta-box {
    max-width: 560px; width: 100%; text-align: center;
    background: rgba(13,16,18,.75); border: 1px solid rgba(255,255,255,.08);
    border-radius: 2rem; padding: 3.5rem 2.5rem;
    backdrop-filter: blur(16px);
    box-shadow: 0 0 0 1px rgba(57,255,143,.04), 0 40px 80px rgba(0,0,0,.35);
  }
  .feat-cta-title {
    font-family: 'Syne', sans-serif; font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800; color: #fff; letter-spacing: -.04em; line-height: 1.1; margin-bottom: .75rem;
  }
  .feat-cta-accent {
    background: linear-gradient(90deg, #39ff8f, #b4ff6e);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .feat-cta-sub { font-size: .875rem; color: rgba(255,255,255,.4); margin-bottom: 1.75rem; }
  .feat-cta-btns { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }

  .feat-cta-primary {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .8125rem 1.5rem;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    color: #050c08; border-radius: .875rem; font-weight: 700; font-size: .9rem;
    text-decoration: none; transition: filter .15s, transform .15s;
    box-shadow: 0 4px 20px rgba(57,255,143,.2);
  }
  .feat-cta-primary:hover { filter: brightness(1.07); transform: translateY(-1px); }

  .feat-cta-secondary {
    display: inline-flex; align-items: center;
    padding: .8125rem 1.25rem;
    color: rgba(255,255,255,.55); border: 1px solid rgba(255,255,255,.12);
    border-radius: .875rem; font-size: .875rem; font-weight: 500;
    text-decoration: none; transition: all .15s;
  }
  .feat-cta-secondary:hover { color: #fff; border-color: rgba(255,255,255,.25); background: rgba(255,255,255,.04); }

  /* Responsive */
  @media (max-width: 900px) {
    .feat-section-inner { grid-template-columns: 1fr; gap: 2rem; }
    .cat-intro { position: static; }
  }
  @media (max-width: 480px) {
    .feat-section { padding: 3.5rem 1rem; }
    .feat-cta-box { padding: 2.5rem 1.5rem; }
  }
</style>
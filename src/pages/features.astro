---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/Button.astro';

const features = [
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
    title: 'Advanced Analytics',
    description: 'Track every click, view, and interaction in real-time. See what works and optimize for maximum growth.',
    details: [
      'Real-time click tracking',
      'Geographic insights',
      'Device & browser analytics',
      'Conversion funnels',
      'Export to CSV/PDF'
    ],
    color: 'neon-green'
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>',
    title: 'Full Customization',
    description: 'Make it truly yours with our powerful editor. No coding required, but full CSS access if you want it.',
    details: [
      '50+ professional themes',
      'Custom colors & fonts',
      'Upload your own images',
      'Custom CSS support',
      'Drag & drop builder'
    ],
    color: 'neon-purple'
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    title: 'Lightning Fast',
    description: 'Optimized for speed and performance. Your page loads instantly on any device, anywhere in the world.',
    details: [
      'Global CDN delivery',
      'Sub-second load times',
      'Optimized images',
      '99.9% uptime SLA',
      'Zero downtime deploys'
    ],
    color: 'neon-blue'
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>',
    title: 'Mobile Optimized',
    description: 'Perfect experience on every screen size. Tested on hundreds of devices to ensure flawless performance.',
    details: [
      'Responsive design',
      'Touch-optimized',
      'PWA support',
      'iOS & Android native feel',
      'Offline mode ready'
    ],
    color: 'neon-pink'
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>',
    title: 'Custom Domains',
    description: 'Use your own domain for ultimate brand consistency. Setup takes minutes with our guided wizard.',
    details: [
      'Custom domain support',
      'Free SSL certificates',
      'Auto-renewal',
      'DNS management',
      'Subdomain support'
    ],
    color: 'neon-orange'
  },
  {
    icon: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>',
    title: 'Powerful Integrations',
    description: 'Connect with all your favorite tools. From analytics to email marketing, we integrate with everything.',
    details: [
      'Google Analytics',
      'Facebook Pixel',
      'Mailchimp & ConvertKit',
      'Zapier integration',
      'Custom webhooks'
    ],
    color: 'neon-blue'
  }
];
---

<BaseLayout title="Features - BioForge | Everything You Need">
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden" data-scroll-section>
      <!-- Background -->
      <div class="absolute inset-0 bg-gradient-to-b from-dark-900 via-dark-800 to-dark-900"></div>
      <div class="absolute inset-0 opacity-5">
        <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-neon-green rounded-full blur-[150px] animate-pulse-slow"></div>
      </div>

      <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center reveal">
          <!-- Badge -->
          <div class="inline-flex items-center space-x-2 px-4 py-2 glass rounded-full text-sm text-neon-green mb-8">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span>Powerful Features</span>
          </div>

          <!-- Heading -->
          <h1 class="text-6xl sm:text-7xl lg:text-8xl font-display font-bold text-white leading-[0.95] mb-8">
            Everything You
            <span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-neon-green via-neon-blue to-neon-purple animate-gradient text-glow-green">
              Need & More
            </span>
          </h1>

          <p class="text-xl sm:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed mb-12">
            From advanced analytics to custom domains, BioForge has everything you need to create a professional link-in-bio that converts.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button 
              variant="primary" 
              size="lg" 
              href="/signup"
              class="magnetic glow-green group"
            >
              <span class="relative z-10">Start Free Trial</span>
              <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </Button>
            <Button 
              variant="outline" 
              size="lg" 
              href="/pricing"
              class="magnetic"
            >
              View Pricing
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
          {features.map((feature, index) => (
            <div class="reveal" style={`animation-delay: ${index * 0.1}s`}>
              <div class="glass-strong rounded-3xl p-8 border border-white/10 hover:border-neon-green/30 transition-all duration-500 h-full group">
                <!-- Icon -->
                <div class={`inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-${feature.color}/20 to-${feature.color}/10 border border-${feature.color}/30 text-${feature.color} mb-6 group-hover:scale-110 transition-transform`}>
                  <Fragment set:html={feature.icon} />
                </div>

                <!-- Title -->
                <h3 class="text-2xl font-display font-bold text-white mb-4 group-hover:text-neon-green transition-colors">
                  {feature.title}
                </h3>

                <!-- Description -->
                <p class="text-gray-400 mb-6 leading-relaxed">
                  {feature.description}
                </p>

                <!-- Details List -->
                <ul class="space-y-3">
                  {feature.details.map((detail) => (
                    <li class="flex items-center space-x-3 text-sm text-gray-400">
                      <svg class="w-5 h-5 text-neon-green flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      <span>{detail}</span>
                    </li>
                  ))}
                </ul>

                <!-- Hover Glow -->
                <div class="absolute inset-0 bg-gradient-to-br from-neon-green/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl pointer-events-none"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Comparison Section -->
    <section class="relative py-20 overflow-hidden" data-scroll-section>
      <div class="absolute inset-0 bg-gradient-to-b from-dark-800 to-dark-900"></div>
      
      <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <!-- Header -->
          <div class="text-center mb-16 reveal">
            <h2 class="text-5xl sm:text-6xl font-display font-bold text-white mb-6">
              Why Choose
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-green to-neon-blue text-glow-green">
                BioForge?
              </span>
            </h2>
            <p class="text-xl text-gray-400">
              See how we stack up against the competition
            </p>
          </div>

          <!-- Comparison Table -->
          <div class="glass-strong rounded-3xl p-8 border border-white/10 reveal overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left py-4 px-4 text-gray-400 font-medium">Feature</th>
                  <th class="py-4 px-4 text-neon-green font-semibold">BioForge</th>
                  <th class="py-4 px-4 text-gray-400 font-medium">Linktree</th>
                  <th class="py-4 px-4 text-gray-400 font-medium">Others</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10">
                <tr>
                  <td class="py-4 px-4 text-white">Custom Domains</td>
                  <td class="py-4 px-4 text-center">
                    <svg class="w-6 h-6 text-neon-green mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                  </td>
                  <td class="py-4 px-4 text-center text-gray-500">Pro Only</td>
                  <td class="py-4 px-4 text-center text-gray-500">Limited</td>
                </tr>
                <tr>
                  <td class="py-4 px-4 text-white">Advanced Analytics</td>
                  <td class="py-4 px-4 text-center">
                    <svg class="w-6 h-6 text-neon-green mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                  </td>
                  <td class="py-4 px-4 text-center text-gray-500">Basic</td>
                  <td class="py-4 px-4 text-center">
                    <svg class="w-6 h-6 text-red-500 mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                  </td>
                </tr>
                <tr>
                  <td class="py-4 px-4 text-white">Unlimited Links</td>
                  <td class="py-4 px-4 text-center">
                    <svg class="w-6 h-6 text-neon-green mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                  </td>
                  <td class="py-4 px-4 text-center">
                    <svg class="w-6 h-6 text-neon-green mx-auto" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                  </td>
                  <td class="py-4 px-4 text-center text-gray-500">Limited</td>
                </tr>
                <tr>
                  <td class="py-4 px-4 text-white">Price (yearly)</td>
                  <td class="py-4 px-4 text-center text-neon-green font-bold">$49</td>
                  <td class="py-4 px-4 text-center text-gray-400">$72</td>
                  <td class="py-4 px-4 text-center text-gray-400">$60+</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center glass-strong rounded-3xl p-12 border border-white/10 reveal">
          <h2 class="text-4xl sm:text-5xl font-display font-bold text-white mb-6">
            Ready to Get Started?
          </h2>
          <p class="text-xl text-gray-300 mb-8">
            Join 10K+ creators who've already leveled up their link-in-bio
          </p>
          <Button 
            variant="primary" 
            size="lg" 
            href="/signup"
            class="magnetic glow-green group text-lg px-10 py-5"
          >
            <span class="relative z-10">Start Free Trial</span>
            <svg class="w-6 h-6 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </Button>
          <p class="text-sm text-gray-500 mt-4">No credit card required • Free forever plan available</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
---
// src/pages/pricing.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const SITE_URL = import.meta.env.PUBLIC_SITE_URL ?? 'https://bioforge.click';

const SEO = {
  title:       'Tarifs — BioForge',
  description: 'Plans et tarifs BioForge. Gratuit pour démarrer, Creator à 4.99€/mois, Pro à 9.99€/mois. Aucune CB requise pour le plan gratuit.',
  url:         `${SITE_URL}/pricing`,
};

// ── Plans ─────────────────────────────────────────────────────────────────────
const plans = [
  {
    id:       'free',
    name:     'Free',
    color:    'rgba(255,255,255,0.55)',
    monthly:  0,
    annual:   0,
    desc:     'Pour découvrir sans engagement.',
    cta:      { label: 'Créer mon compte', href: '/signin', style: 'ghost' },
    features: [
      '5 blocs actifs',
      'URL bioforge.click/@toi',
      'Analytics basiques (7 jours)',
      'Thèmes prédéfinis',
      'Support communauté',
    ],
    limits: [
      'Domaine custom',
      'Analytics avancés',
      'Branding BioForge visible',
    ],
  },
  {
    id:       'creator',
    name:     'Creator',
    color:    '#38bdf8',
    monthly:  4.99,
    annual:   3.99,
    desc:     'Pour les créateurs qui débutent leur croissance.',
    cta:      { label: 'Commencer Creator', href: '/signin?plan=creator', style: 'blue' },
    features: [
      '20 blocs actifs',
      'URL bioforge.click/@toi',
      'Analytics 30 jours',
      'Thèmes prédéfinis + couleurs custom',
      'Suppression branding BioForge',
      'Support email prioritaire',
    ],
    limits: [
      'Domaine custom',
      'Analytics avancés (sources de trafic)',
      'Blocs premium (live stream, shop)',
    ],
  },
  {
    id:       'pro',
    name:     'Pro',
    color:    '#39ff8f',
    monthly:  9.99,
    annual:   7.99,
    popular:  true,
    desc:     'Le plan complet pour les créateurs sérieux.',
    cta:      { label: 'Commencer Pro', href: '/signin?plan=pro', style: 'green' },
    features: [
      'Blocs illimités',
      'Domaine custom (liens.toi.com)',
      'Analytics avancés (90 jours + sources)',
      'Tous les thèmes + CSS custom',
      'Tous les blocs premium',
      'Suppression branding BioForge',
      'Support email prioritaire',
      'Accès fonctionnalités bêta',
    ],
    limits: [],
  },
  {
    id:       'enterprise',
    name:     'Enterprise',
    color:    '#fb923c',
    monthly:  29.99,
    annual:   23.99,
    desc:     'Pour les agences et créateurs à fort volume.',
    cta:      { label: 'Nous contacter', href: '/contact?subject=enterprise', style: 'orange' },
    features: [
      'Tout le plan Pro',
      'Plusieurs profils (multi-compte)',
      'Analytics illimités (historique complet)',
      'API access',
      'Intégrations custom sur demande',
      'SLA uptime garanti',
      'Account manager dédié',
      'Onboarding personnalisé',
    ],
    limits: [],
  },
] as const;

// ── Tableau comparatif ────────────────────────────────────────────────────────
type PlanId = 'free' | 'creator' | 'pro' | 'enterprise';
type CellValue = boolean | string;

const compareRows: { label: string; cat: string; values: Record<PlanId, CellValue> }[] = [
  // Blocs
  { label: 'Blocs actifs',        cat: 'Éditeur',       values: { free: '5',          creator: '20',        pro: 'Illimités',  enterprise: 'Illimités' } },
  { label: 'Types de blocs',      cat: 'Éditeur',       values: { free: 'Standard',   creator: 'Standard',  pro: 'Tous',       enterprise: 'Tous' } },
  { label: 'Blocs premium',       cat: 'Éditeur',       values: { free: false,         creator: false,        pro: true,         enterprise: true } },
  { label: 'Drag & drop',         cat: 'Éditeur',       values: { free: true,          creator: true,         pro: true,         enterprise: true } },
  // Analytics
  { label: 'Vues & clics',        cat: 'Analytics',     values: { free: '7 jours',    creator: '30 jours',  pro: '90 jours',   enterprise: 'Illimités' } },
  { label: 'Sources de trafic',   cat: 'Analytics',     values: { free: false,         creator: false,        pro: true,         enterprise: true } },
  { label: 'Export CSV',          cat: 'Analytics',     values: { free: false,         creator: false,        pro: true,         enterprise: true } },
  { label: 'API analytics',       cat: 'Analytics',     values: { free: false,         creator: false,        pro: false,        enterprise: true } },
  // Personnalisation
  { label: 'Thèmes prédéfinis',   cat: 'Design',        values: { free: true,          creator: true,         pro: true,         enterprise: true } },
  { label: 'Couleurs custom',     cat: 'Design',        values: { free: false,         creator: true,         pro: true,         enterprise: true } },
  { label: 'CSS custom',          cat: 'Design',        values: { free: false,         creator: false,        pro: true,         enterprise: true } },
  { label: 'Domaine custom',      cat: 'Design',        values: { free: false,         creator: false,        pro: true,         enterprise: true } },
  { label: 'Suppression branding',cat: 'Design',        values: { free: false,         creator: true,         pro: true,         enterprise: true } },
  // Compte
  { label: 'Multi-profils',       cat: 'Compte',        values: { free: false,         creator: false,        pro: false,        enterprise: true } },
  { label: 'API access',          cat: 'Compte',        values: { free: false,         creator: false,        pro: false,        enterprise: true } },
  { label: 'Support',             cat: 'Compte',        values: { free: 'Communauté', creator: 'Email',      pro: 'Prioritaire',enterprise: 'Dédié' } },
];
---

<BaseLayout title={SEO.title}>
  <Fragment slot="head">
    <meta name="description"        content={SEO.description} />
    <link rel="canonical"           href={SEO.url} />
    <meta property="og:title"       content={SEO.title} />
    <meta property="og:description" content={SEO.description} />
    <meta property="og:url"         content={SEO.url} />
  </Fragment>

  <Header />

  <main class="pricing-main">

    <!-- Hero -->
    <section class="pr-hero">
      <div class="pr-bg" aria-hidden="true">
        <div class="pr-glow g1"></div>
        <div class="pr-glow g2"></div>
        <div class="pr-grid"></div>
      </div>
      <div class="pr-hero-inner">
        <div class="pr-badge">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          Tarifs simples et transparents
        </div>
        <h1 class="pr-hero-title">
          Le bon plan<br>
          <span class="pr-accent">pour chaque créateur</span>
        </h1>
        <p class="pr-hero-sub">Commence gratuitement. Passe au niveau supérieur quand tu es prêt. Aucune CB requise pour démarrer.</p>

        <!-- Toggle mensuel / annuel -->
        <div class="billing-toggle" role="group" aria-label="Période de facturation">
          <button id="toggle-monthly" class="toggle-btn active" aria-pressed="true">Mensuel</button>
          <button id="toggle-annual"  class="toggle-btn"        aria-pressed="false">
            Annuel
            <span class="toggle-save">-20%</span>
          </button>
        </div>
      </div>
    </section>

    <!-- Cards -->
    <section class="pr-cards-section" aria-label="Plans tarifaires">
      <div class="pr-cards">
        {plans.map((plan, i) => (
          <div
            class={`pr-card${plan.popular ? ' pr-card-popular' : ''}`}
            style={`--c:${plan.color}; animation-delay:${i*0.08}s`}
          >
            {plan.popular && (
              <div class="popular-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                Populaire
              </div>
            )}

            <div class="plan-top">
              <div class="plan-name" style={`color:${plan.color}`}>{plan.name}</div>
              <p class="plan-desc">{plan.desc}</p>
            </div>

            <div class="plan-price-wrap">
              {plan.monthly === 0 ? (
                <div class="plan-price">
                  <span class="price-amount">Gratuit</span>
                </div>
              ) : (
                <div class="plan-price">
                  <span class="price-currency">€</span>
                  <span class="price-amount" data-monthly={plan.monthly} data-annual={plan.annual}>
                    {plan.monthly}
                  </span>
                  <span class="price-period">/mois</span>
                </div>
              )}
              {plan.monthly > 0 && (
                <p class="price-annual-note hidden" id={`note-${plan.id}`}>
                  Facturé annuellement (€{(plan.annual * 12).toFixed(2)}/an)
                </p>
              )}
            </div>

            <a href={plan.cta.href} class={`plan-cta cta-${plan.cta.style}`}>
              {plan.cta.label}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>

            <ul class="plan-features" aria-label={`Fonctionnalités du plan ${plan.name}`}>
              {plan.features.map(f => (
                <li class="feat-item feat-ok">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#39ff8f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {f}
                </li>
              ))}
              {plan.limits.map(l => (
                <li class="feat-item feat-no">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                  </svg>
                  {l}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Tableau comparatif -->
    <section class="pr-compare" aria-labelledby="compare-title">
      <div class="pr-compare-inner">
        <h2 id="compare-title" class="compare-title">Comparaison détaillée</h2>
        <p class="compare-sub">Toutes les fonctionnalités, plan par plan.</p>

        <div class="compare-table-wrap">
          <table class="compare-table" role="table">
            <thead>
              <tr>
                <th scope="col" class="col-feature">Fonctionnalité</th>
                <th scope="col" class="col-plan">Free</th>
                <th scope="col" class="col-plan">Creator</th>
                <th scope="col" class="col-plan col-plan-pro">Pro</th>
                <th scope="col" class="col-plan">Enterprise</th>
              </tr>
            </thead>
            <tbody>
              {(() => {
                let lastCat = '';
                return compareRows.map(row => {
                  const catRow = row.cat !== lastCat ? (lastCat = row.cat, row.cat) : null;
                  return (
                    <>
                      {catRow && (
                        <tr class="cat-row">
                          <td colspan="5" class="cat-label">{catRow}</td>
                        </tr>
                      )}
                      <tr class="data-row">
                        <td class="feat-label">{row.label}</td>
                        {(['free','creator','pro','enterprise'] as PlanId[]).map(pid => (
                          <td class={`feat-val${pid === 'pro' ? ' col-pro-val' : ''}`}>
                            {typeof row.values[pid] === 'boolean' ? (
                              row.values[pid] ? (
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#39ff8f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-label="Inclus">
                                  <polyline points="20 6 9 17 4 12"/>
                                </svg>
                              ) : (
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="Non inclus">
                                  <line x1="18" y1="6" x2="6" y2="18"/>
                                  <line x1="6" y1="6" x2="18" y2="18"/>
                                </svg>
                              )
                            ) : (
                              <span>{row.values[pid]}</span>
                            )}
                          </td>
                        ))}
                      </tr>
                    </>
                  );
                });
              })()}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ pricing -->
    <section class="pr-faq" aria-labelledby="pr-faq-title">
      <div class="pr-faq-inner">
        <h2 id="pr-faq-title" class="pr-faq-title">Questions sur les tarifs</h2>

        {[
          { q: 'Puis-je changer de plan à tout moment ?', a: "Oui. Tu peux upgrader immédiatement — la différence est calculée au prorata. Pour downgrader, le changement s'applique à la fin de la période en cours." },
          { q: "Que se passe-t-il si j'annule ?", a: "Tu gardes l'accès au plan payant jusqu'à la fin de la période déjà payée. Ensuite tu repasses automatiquement au plan Free : ta page reste en ligne, tes données sont conservées." },
          { q: 'Le plan annuel est-il engageant ?', a: "Non. Tu peux annuler quand tu veux. Si tu annules un plan annuel, tu gardes l'accès jusqu'à la fin des 12 mois payés. Aucun remboursement partiel sauf cas exceptionnel." },
          { q: 'Y a-t-il une période d\'essai pour les plans payants ?', a: "Oui — 7 jours d'essai gratuit sur Creator et Pro, sans CB. Tu rentres tes infos de paiement seulement à la fin de la période d'essai." },
          { q: 'Quels modes de paiement acceptez-vous ?', a: "Carte bancaire (Visa, Mastercard, Amex) et SEPA (virement). Tout est géré de manière sécurisée via Stripe." },
        ].map((faq, i) => (
          <details class="pr-faq-item" style={`animation-delay:${i * 0.05}s`}>
            <summary class="pr-faq-q">
              <span>{faq.q}</span>
              <span class="pr-faq-chevron" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </span>
            </summary>
            <div class="pr-faq-a"><p>{faq.a}</p></div>
          </details>
        ))}
      </div>
    </section>

    <!-- Enterprise CTA -->
    <section class="pr-enterprise">
      <div class="pr-enterprise-inner">
        <div class="ent-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fb923c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
          </svg>
        </div>
        <div class="ent-text">
          <h2 class="ent-title">Besoin d'une solution sur-mesure ?</h2>
          <p class="ent-desc">Agences, labels, créateurs à fort volume — discutons de tes besoins spécifiques, volume de profils, intégrations custom et SLA.</p>
        </div>
        <a href="/contact?subject=enterprise" class="ent-cta">
          Contacter l'équipe
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<script>
  // ── Toggle mensuel / annuel ───────────────────────────────────────────────
  const btnMonthly = document.getElementById('toggle-monthly')!;
  const btnAnnual  = document.getElementById('toggle-annual')!;
  const prices     = document.querySelectorAll<HTMLElement>('.price-amount[data-monthly]');
  const notes      = document.querySelectorAll<HTMLElement>('[id^="note-"]');
  let isAnnual = false;

  function setMode(annual: boolean) {
    isAnnual = annual;
    btnMonthly.classList.toggle('active', !annual);
    btnAnnual.classList.toggle('active', annual);
    btnMonthly.setAttribute('aria-pressed', String(!annual));
    btnAnnual.setAttribute('aria-pressed',  String(annual));

    prices.forEach(el => {
      const v = annual
        ? parseFloat(el.dataset.annual!)
        : parseFloat(el.dataset.monthly!);
      el.textContent = v.toFixed(2).replace('.00','').replace(/\.(\d)$/, '.$10');
    });

    notes.forEach(el => el.classList.toggle('hidden', !annual));
  }

  btnMonthly.addEventListener('click', () => setMode(false));
  btnAnnual.addEventListener('click',  () => setMode(true));

  // ── FAQ accordion ─────────────────────────────────────────────────────────
  document.querySelectorAll('.pr-faq-item').forEach(item => {
    item.addEventListener('toggle', () => {
      if ((item as HTMLDetailsElement).open) {
        document.querySelectorAll('.pr-faq-item').forEach(o => {
          if (o !== item) (o as HTMLDetailsElement).open = false;
        });
      }
    });
  });

  // ── Reveal ────────────────────────────────────────────────────────────────
  document.querySelectorAll('.pr-card, .pr-faq-item, .pr-enterprise-inner, .compare-title').forEach(el =>
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) (e.target as HTMLElement).classList.add('revealed');
    }, { threshold: 0.1 }).observe(el)
  );
</script>

<style>
  .pricing-main { padding-top: 64px; }

  /* ── Hero ── */
  .pr-hero {
    position: relative; overflow: hidden;
    padding: 5rem 1.5rem 4rem; text-align: center;
  }
  .pr-bg { position: absolute; inset: 0; pointer-events: none; }
  .pr-glow { position: absolute; border-radius: 50%; filter: blur(100px); }
  .g1 { width: 500px; height: 400px; top: -20%; left: -10%; background: rgba(57,255,143,.07); }
  .g2 { width: 400px; height: 300px; bottom: 0; right: -5%; background: rgba(251,146,60,.055); }
  .pr-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(57,255,143,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(57,255,143,.035) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  .pr-hero-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }

  .pr-badge {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .3rem .875rem;
    background: rgba(57,255,143,.08); border: 1px solid rgba(57,255,143,.2);
    border-radius: 99px; font-size: .72rem; font-weight: 700; color: #39ff8f;
    text-transform: uppercase; letter-spacing: .08em;
  }

  .pr-hero-title {
    font-family: 'Syne', sans-serif; font-weight: 800;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: #fff; letter-spacing: -.04em; line-height: 1.05;
  }
  .pr-accent {
    background: linear-gradient(90deg, #39ff8f, #38bdf8);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .pr-hero-sub { font-size: 1rem; color: rgba(255,255,255,.48); max-width: 480px; line-height: 1.65; }

  /* Toggle */
  .billing-toggle {
    display: inline-flex; align-items: center; gap: 0;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    border-radius: .75rem; padding: 3px; margin-top: .5rem;
  }
  .toggle-btn {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .5rem 1.25rem; border: none; border-radius: .5rem;
    background: transparent; color: rgba(255,255,255,.45);
    font-size: .8375rem; font-weight: 600; cursor: pointer; transition: all .2s;
  }
  .toggle-btn.active { background: rgba(255,255,255,.1); color: #fff; }
  .toggle-save {
    font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
    background: rgba(57,255,143,.15); color: #39ff8f;
    border: 1px solid rgba(57,255,143,.25); border-radius: 99px;
    padding: .1rem .4rem;
  }

  /* ── Cards ── */
  .pr-cards-section { padding: 3rem 1.5rem; }
  .pr-cards {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;
  }

  .pr-card {
    position: relative; display: flex; flex-direction: column; gap: 1.25rem;
    padding: 1.75rem;
    background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.08);
    border-radius: 1.25rem;
    opacity: 0; transform: translateY(16px);
    transition: opacity .45s ease, transform .45s ease, border-color .2s, background .2s;
    transition-delay: var(--delay, 0s);
  }
  .pr-card.revealed { opacity: 1; transform: none; }
  .pr-card:hover { border-color: color-mix(in srgb, var(--c) 25%, transparent); background: rgba(255,255,255,.04); }

  .pr-card-popular {
    border-color: rgba(57,255,143,.25) !important;
    background: rgba(57,255,143,.04) !important;
    box-shadow: 0 0 0 1px rgba(57,255,143,.1), 0 24px 64px rgba(0,0,0,.3);
  }

  .popular-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    display: inline-flex; align-items: center; gap: .35rem;
    padding: .3rem .875rem;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    color: #050c08; font-size: .7rem; font-weight: 800; letter-spacing: .04em;
    text-transform: uppercase; border-radius: 99px;
    white-space: nowrap;
  }

  .plan-name { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 800; letter-spacing: -.01em; }
  .plan-desc { font-size: .775rem; color: rgba(255,255,255,.42); line-height: 1.5; margin-top: .25rem; }

  .plan-price { display: flex; align-items: baseline; gap: .15rem; }
  .price-currency { font-size: 1.25rem; font-weight: 700; color: rgba(255,255,255,.7); }
  .price-amount { font-family: 'Syne', sans-serif; font-size: 2.25rem; font-weight: 800; color: #fff; letter-spacing: -.04em; line-height: 1; }
  .price-period { font-size: .8rem; color: rgba(255,255,255,.38); margin-left: .1rem; }
  .price-annual-note { font-size: .7rem; color: rgba(255,255,255,.3); margin-top: .35rem; }
  .hidden { display: none; }

  /* CTA variants */
  .plan-cta {
    display: flex; align-items: center; justify-content: center; gap: .4rem;

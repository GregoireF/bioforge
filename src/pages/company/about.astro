---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout title="About Us - BioForge">
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden" data-scroll-section>
      <div class="absolute inset-0 bg-gradient-to-b from-dark-900 via-dark-800 to-dark-900"></div>
      <div class="absolute inset-0 opacity-5">
        <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-neon-purple rounded-full blur-[150px] animate-pulse-slow"></div>
      </div>

      <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center reveal">
          <!-- Badge -->
          <div class="inline-flex items-center space-x-2 px-4 py-2 glass rounded-full text-sm text-neon-purple mb-8">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/>
            </svg>
            <span>Our Story</span>
          </div>

          <h1 class="text-6xl sm:text-7xl lg:text-8xl font-display font-bold text-white leading-[0.95] mb-8">
            About
            <span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-neon-purple via-neon-pink to-neon-blue animate-gradient text-glow-purple">
              BioForge
            </span>
          </h1>

          <p class="text-xl sm:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
            We're on a mission to empower creators with the best link-in-bio platform on the planet.
          </p>
        </div>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-5xl mx-auto">
          <div class="glass-strong rounded-3xl p-12 border border-white/10 reveal">
            <div class="text-center mb-12">
              <h2 class="text-4xl sm:text-5xl font-display font-bold text-white mb-6">Our Mission</h2>
            </div>
            
            <p class="text-xl text-gray-300 leading-relaxed mb-6">
              BioForge was born from a simple frustration: existing link-in-bio tools were either too basic, too expensive, or just plain ugly. We knew creators deserved better.
            </p>
            
            <p class="text-xl text-gray-300 leading-relaxed mb-6">
              In 2024, we set out to build the link-in-bio platform we wished existed. One that's beautiful, powerful, and accessible to everyone—from aspiring creators to established influencers.
            </p>
            
            <p class="text-xl text-gray-300 leading-relaxed">
              Today, BioForge powers over 10,000 creator pages worldwide, helping them connect with their audience and grow their online presence. And we're just getting started.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-16 reveal">
            <h2 class="text-4xl sm:text-5xl font-display font-bold text-white mb-6">Our Values</h2>
            <p class="text-xl text-gray-400">The principles that guide everything we do</p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <!-- Value 1 -->
            <div class="glass-strong rounded-2xl p-8 border border-white/10 hover:border-neon-green/30 transition-all duration-300 reveal group">
              <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-neon-green/20 to-neon-green/10 border border-neon-green/30 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-white mb-4">Creator First</h3>
              <p class="text-gray-400">Every feature we build starts with one question: How does this help creators succeed?</p>
            </div>

            <!-- Value 2 -->
            <div class="glass-strong rounded-2xl p-8 border border-white/10 hover:border-neon-purple/30 transition-all duration-300 reveal group">
              <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-neon-purple/20 to-neon-purple/10 border border-neon-purple/30 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-white mb-4">Move Fast</h3>
              <p class="text-gray-400">We ship features quickly and iterate based on real user feedback. Speed is our advantage.</p>
            </div>

            <!-- Value 3 -->
            <div class="glass-strong rounded-2xl p-8 border border-white/10 hover:border-neon-blue/30 transition-all duration-300 reveal group">
              <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-neon-blue/20 to-neon-blue/10 border border-neon-blue/30 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-white mb-4">Design Matters</h3>
              <p class="text-gray-400">Beautiful, intuitive design isn't optional—it's essential to the creator experience.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <div class="glass-strong rounded-3xl p-12 border border-white/10 reveal">
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
              <div>
                <div class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-neon-green to-neon-blue mb-2">10K+</div>
                <div class="text-gray-400">Active Creators</div>
              </div>
              <div>
                <div class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-neon-purple to-neon-pink mb-2">50M+</div>
                <div class="text-gray-400">Monthly Clicks</div>
              </div>
              <div>
                <div class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-neon-blue to-neon-green mb-2">99.9%</div>
                <div class="text-gray-400">Uptime</div>
              </div>
              <div>
                <div class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-neon-pink to-neon-purple mb-2">4.9/5</div>
                <div class="text-gray-400">User Rating</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-16 reveal">
            <h2 class="text-4xl sm:text-5xl font-display font-bold text-white mb-6">Meet the Team</h2>
            <p class="text-xl text-gray-400">The people building the future of link-in-bio</p>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Team Member 1 -->
            <div class="text-center reveal group">
              <div class="mb-6 relative">
                <div class="w-48 h-48 mx-auto rounded-2xl bg-gradient-to-br from-neon-green/20 to-neon-blue/20 border border-white/10 group-hover:scale-105 transition-transform duration-300"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-1">Alex Johnson</h3>
              <p class="text-neon-green text-sm mb-2">Co-Founder & CEO</p>
              <p class="text-gray-400 text-sm">Ex-Google, Stanford CS</p>
            </div>

            <!-- Team Member 2 -->
            <div class="text-center reveal group">
              <div class="mb-6 relative">
                <div class="w-48 h-48 mx-auto rounded-2xl bg-gradient-to-br from-neon-purple/20 to-neon-pink/20 border border-white/10 group-hover:scale-105 transition-transform duration-300"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-1">Sarah Miller</h3>
              <p class="text-neon-purple text-sm mb-2">Co-Founder & CTO</p>
              <p class="text-gray-400 text-sm">Ex-Meta, MIT</p>
            </div>

            <!-- Team Member 3 -->
            <div class="text-center reveal group">
              <div class="mb-6 relative">
                <div class="w-48 h-48 mx-auto rounded-2xl bg-gradient-to-br from-neon-blue/20 to-neon-green/20 border border-white/10 group-hover:scale-105 transition-transform duration-300"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-1">Marcus Lee</h3>
              <p class="text-neon-blue text-sm mb-2">Head of Design</p>
              <p class="text-gray-400 text-sm">Ex-Airbnb, RISD</p>
            </div>

            <!-- Team Member 4 -->
            <div class="text-center reveal group">
              <div class="mb-6 relative">
                <div class="w-48 h-48 mx-auto rounded-2xl bg-gradient-to-br from-neon-pink/20 to-neon-purple/20 border border-white/10 group-hover:scale-105 transition-transform duration-300"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-1">Emma Davis</h3>
              <p class="text-neon-pink text-sm mb-2">Head of Growth</p>
              <p class="text-gray-400 text-sm">Ex-Stripe, Berkeley</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center glass-strong rounded-3xl p-12 border border-white/10 reveal">
          <h2 class="text-4xl sm:text-5xl font-display font-bold text-white mb-6">
            Join Us on This Journey
          </h2>
          <p class="text-xl text-gray-300 mb-8">
            Whether you're a creator or want to join our team, we'd love to hear from you.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button variant="primary" size="lg" href="/signup" class="glow-purple">
              Start Creating
            </Button>
            <Button variant="outline" size="lg" href="/careers">
              View Careers
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
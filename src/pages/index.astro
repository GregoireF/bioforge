---
// src/pages/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Hero from '@/components/landing/Hero.astro';
import SocialProofBar from '@/components/landing/SocialProofBar.astro';
import HowItWorks from '@/components/landing/HowItWorks.astro';
import LiveProfiles from '@/components/landing/LiveProfiles.astro';
import Testimonials from '@/components/landing/Testimonials.astro';
import FAQ from '@/components/landing/FAQ.astro';
import CTA from '@/components/landing/CTA.astro';
import Footer from '@/components/layout/Footer.astro';
import { createClient } from '@supabase/supabase-js';

export const prerender = false; // SSR — stats fraîches à chaque visite

const SITE_URL = import.meta.env.PUBLIC_SITE_URL ?? 'https://bioforge.click';

// ── Stats réelles depuis Supabase ─────────────────────────────────────────────
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

let stats = { total_profiles: 0, total_clicks: 0, total_views: 0 };
let liveProfiles: any[] = [];

try {
  const [statsRes, profilesRes] = await Promise.all([
    supabase.rpc('get_landing_stats'),
    supabase
      .from('profiles')
      .select('username, display_name, avatar_url, plan, is_verified')
      .eq('is_active', true)
      .is('deleted_at', null)
      .order('created_at', { ascending: false })
      .limit(14),
  ]);

  if (statsRes.data)    stats        = statsRes.data;
  if (profilesRes.data) liveProfiles = profilesRes.data;
} catch (e) {
  console.error('[index] stats fetch failed:', e);
}

// ── SEO ───────────────────────────────────────────────────────────────────────
const SEO = {
  title:       'BioForge — Forge ta présence en ligne',
  description: 'Crée ta page bio en quelques minutes. Analytics en temps réel, blocs personnalisés, domaine custom. Gratuit pour les créateurs, streamers et gamers.',
  url:         SITE_URL,
  image:       `${SITE_URL}/og.png`,
};

const appJsonLd = JSON.stringify({
  '@context':          'https://schema.org',
  '@type':             'SoftwareApplication',
  name:                'BioForge',
  url:                 SITE_URL,
  applicationCategory: 'BusinessApplication',
  operatingSystem:     'Web',
  inLanguage:          'fr-FR',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  description:         SEO.description,
});

const faqJsonLd = JSON.stringify({
  '@context':  'https://schema.org',
  '@type':     'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name:    'BioForge est-il gratuit ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oui. Le plan gratuit inclut 5 blocs, un domaine bioforge.click/@username et les analytics basiques. Les plans payants débloquent les blocs illimités, le domaine custom et les analytics avancés.' },
    },
    {
      '@type': 'Question',
      name:    'Puis-je utiliser mon propre domaine ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oui, avec le plan Pro. Tu connectes ton propre domaine (ex: links.toi.com) en quelques minutes depuis le dashboard.' },
    },
    {
      '@type': 'Question',
      name:    'Comment fonctionnent les analytics ?',
      acceptedAnswer: { '@type': 'Answer', text: 'BioForge enregistre chaque vue et chaque clic en temps réel. Depuis ton dashboard tu vois les vues, clics, taux de conversion et sources de trafic.' },
    },
  ],
});
---

<BaseLayout title={SEO.title}>
  <Fragment slot="head">
    <meta name="description"         content={SEO.description} />
    <link rel="canonical"            href={SEO.url} />
    <meta name="robots"              content="index, follow, max-image-preview:large" />
    <meta name="keywords"            content="link in bio, page bio, créateur, streamer, gamer, analytics, lien bio" />
    <meta name="author"              content="BioForge" />

    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={SEO.url} />
    <meta property="og:title"        content={SEO.title} />
    <meta property="og:description"  content={SEO.description} />
    <meta property="og:image"        content={SEO.image} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"       content="fr_FR" />
    <meta property="og:site_name"    content="BioForge" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={SEO.title} />
    <meta name="twitter:description" content={SEO.description} />
    <meta name="twitter:image"       content={SEO.image} />

    <script type="application/ld+json" set:html={appJsonLd} />
    <script type="application/ld+json" set:html={faqJsonLd} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </Fragment>

  <Header />

  <main id="main-content">
    <Hero profileCount={stats.total_profiles} />
    <SocialProofBar stats={stats} />
    <HowItWorks />
    <LiveProfiles profiles={liveProfiles} />
    <Testimonials />
    <FAQ />
    <CTA profileCount={stats.total_profiles} />
  </main>

  <Footer />
</BaseLayout>
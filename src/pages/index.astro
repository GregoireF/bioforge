---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import HowItWorks from '@/components/landing/HowItWorks.astro'
import Hero from '@/components/landing/Hero.astro';
import Testimonials from '@/components/landing/Testimonials.astro';
import CreatorsSection from '@/components/landing/CreatorsSection.astro';
import FAQ from '@/components/landing/FAQ.astro';
import CTA from '@/components/landing/CTA.astro';
import FloatingCTA from '@/components/landing/FloatingCTA.astro';
import Footer from '@/components/layout/Footer.astro';
---

<BaseLayout title="BioForge - Level Up Your Link-in-Bio">
  <Header />
  
  <main>
    <Hero />

    <HowItWorks />

    <Testimonials client:load />
    
    <CreatorsSection client:load />

    <FAQ client:load />

    <CTA client:load />

    <FloatingCTA client:load />
  </main>

  <Footer />
</BaseLayout>

<script type="module">
  import { CountUp } from 'countup.js';

  function initCountUps() {
    const counters = document.querySelectorAll('.count-up:not(.count-up-initialized)');
    if (!counters.length) return;

    // Fallback si IntersectionObserver n'existe pas
    if (!('IntersectionObserver' in window)) {
      counters.forEach((el) => startCount(el));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const el = entry.target;
          startCount(el);
          observer.unobserve(el);
        });
      },
      { threshold: 0.4, rootMargin: '0px 0px 100px 0px' }
    );

    counters.forEach((c) => observer.observe(c));
  }

  function startCount(el) {
    if (el.classList.contains('count-up-initialized')) return;

    const count = parseFloat(el.dataset.count ?? '0');
    const suffix = el.dataset.suffix ?? '';

    try {
      const countUp = new CountUp(el, count, {
        duration: 2,
        useEasing: true,
        suffix,
      });

      if (!countUp.error) {
        countUp.start();
      } else {
        el.textContent = count + suffix;
      }
    } catch (err) {
      console.error('CountUp error:', err);
      el.textContent = count + suffix;
    }

    el.classList.add('count-up-initialized');
  }

  // Load initial
  window.addEventListener('load', initCountUps);

  // Astro View Transitions support
  document.addEventListener('astro:after-swap', initCountUps);
</script>

<style>
  @keyframes blob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(20px, -50px) scale(1.1);
    }
    50% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    75% {
      transform: translate(50px, 50px) scale(1.05);
    }
  }

  .animate-blob {
    animation: blob 20s ease-in-out infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
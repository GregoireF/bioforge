---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const categories = [
  {
    name: 'Getting Started',
    icon: 'rocket',
    articles: [
      { title: 'How to create your first link', views: '12.5K' },
      { title: 'Setting up your profile', views: '8.2K' },
      { title: 'Customizing your page', views: '6.1K' },
    ]
  },
  {
    name: 'Links & Content',
    icon: 'link',
    articles: [
      { title: 'Adding and organizing links', views: '5.8K' },
      { title: 'Link scheduling and expiration', views: '4.2K' },
      { title: 'Embedding content', views: '3.9K' },
    ]
  },
  {
    name: 'Analytics',
    icon: 'chart',
    articles: [
      { title: 'Understanding your analytics', views: '7.3K' },
      { title: 'Tracking link performance', views: '5.1K' },
      { title: 'Exporting data', views: '2.8K' },
    ]
  },
  {
    name: 'Account & Billing',
    icon: 'settings',
    articles: [
      { title: 'Upgrading to Pro', views: '9.4K' },
      { title: 'Managing your subscription', views: '4.7K' },
      { title: 'Payment methods', views: '3.2K' },
    ]
  },
];
---

<BaseLayout title="Help Center - BioForge">
  <Header />
  
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-20 overflow-hidden" data-scroll-section>
      <div class="absolute inset-0 bg-gradient-to-b from-dark-900 via-dark-800 to-dark-900"></div>
      
      <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center reveal">
          <div class="inline-flex items-center space-x-2 px-4 py-2 glass rounded-full text-sm text-neon-blue mb-8">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
            </svg>
            <span>Help Center</span>
          </div>

          <h1 class="text-6xl sm:text-7xl font-display font-bold text-white leading-tight mb-8">
            How Can We
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-neon-blue via-neon-purple to-neon-pink text-glow-blue">
              Help?
            </span>
          </h1>

          <p class="text-xl text-gray-300 mb-12">
            Search our knowledge base or browse categories below
          </p>

          <!-- Search Bar -->
          <div class="relative max-w-2xl mx-auto">
            <input
              type="text"
              placeholder="Search for articles..."
              class="w-full px-6 py-4 pl-14 glass border border-white/10 rounded-2xl text-white placeholder-gray-500 focus:border-neon-blue/50 focus:outline-none focus:ring-2 focus:ring-neon-blue/20 transition-all"
            />
            <svg class="absolute left-5 top-1/2 transform -translate-y-1/2 w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
          {categories.map((category, index) => (
            <div class="glass-strong rounded-2xl p-6 border border-white/10 hover:border-neon-blue/30 transition-all reveal" style={`animation-delay: ${index * 0.1}s`}>
              <div class="flex items-center space-x-3 mb-6">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-neon-blue/20 to-neon-blue/10 border border-neon-blue/30 flex items-center justify-center">
                  {category.icon === 'rocket' && (
                    <svg class="w-6 h-6 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                  )}
                  {category.icon === 'link' && (
                    <svg class="w-6 h-6 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                    </svg>
                  )}
                  {category.icon === 'chart' && (
                    <svg class="w-6 h-6 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                  )}
                  {category.icon === 'settings' && (
                    <svg class="w-6 h-6 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                  )}
                </div>
                <h3 class="text-xl font-bold text-white">{category.name}</h3>
              </div>
              <ul class="space-y-3">
                {category.articles.map((article) => (
                  <li>
                    <a href="#" class="flex items-center justify-between p-3 glass rounded-xl border border-transparent hover:border-neon-blue/30 transition-all group">
                      <span class="text-gray-300 group-hover:text-white transition-colors">{article.title}</span>
                      <span class="text-xs text-gray-500">{article.views}</span>
                    </a>
                  </li>
                ))}
              </ul>
              <a href="#" class="inline-flex items-center space-x-2 text-neon-blue hover:text-neon-green transition-colors mt-4 text-sm font-medium">
                <span>View all articles</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Support -->
    <section class="relative py-20" data-scroll-section>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center glass-strong rounded-3xl p-12 border border-white/10 reveal">
          <h2 class="text-4xl font-display font-bold text-white mb-4">
            Still Need Help?
          </h2>
          <p class="text-xl text-gray-300 mb-8">
            Can't find what you're looking for? Get in touch with our support team.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center space-x-2 px-6 py-3 bg-gradient-to-r from-neon-blue to-neon-purple text-white font-semibold rounded-xl hover:opacity-90 transition-all glow-blue">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
              <span>Email Support</span>
            </a>
            <a href="#" class="inline-flex items-center justify-center space-x-2 px-6 py-3 glass border border-white/10 text-white font-semibold rounded-xl hover:border-neon-blue/30 transition-all">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"/>
                <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"/>
              </svg>
              <span>Live Chat</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
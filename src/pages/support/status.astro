---
// src/pages/status.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createSupabaseServer } from '@/lib/supabase/server';

const supabase = createSupabaseServer({
  request: Astro.request,
  cookies: Astro.cookies,
});

// ==================== FETCH ====================
const [{ data: services }, { data: incidents }] = await Promise.all([
  supabase
    .from('service_status')
    .select('*')
    .order('name'),
  supabase
    .from('incidents')
    .select(`*, incident_updates(*)`)
    .order('created_at', { ascending: false })
    .limit(20),
]);

// ==================== HELPERS ====================
type Status = 'operational' | 'degraded' | 'partial_outage' | 'major_outage' | 'maintenance';
type Impact = 'none' | 'minor' | 'major' | 'critical';
type IncidentStatus = 'investigating' | 'identified' | 'monitoring' | 'resolved';

const STATUS_CONFIG: Record<Status, { label: string; color: string; dot: string; bg: string; border: string }> = {
  operational:   { label: 'Operational',    color: 'text-neon-green',  dot: 'bg-neon-green',  bg: 'bg-neon-green/10',  border: 'border-neon-green/20'  },
  degraded:      { label: 'Degraded',       color: 'text-yellow-400',  dot: 'bg-yellow-400',  bg: 'bg-yellow-400/10',  border: 'border-yellow-400/20'  },
  partial_outage:{ label: 'Partial Outage', color: 'text-orange-400',  dot: 'bg-orange-400',  bg: 'bg-orange-400/10',  border: 'border-orange-400/20'  },
  major_outage:  { label: 'Major Outage',   color: 'text-red-400',     dot: 'bg-red-400',     bg: 'bg-red-400/10',     border: 'border-red-400/20'     },
  maintenance:   { label: 'Maintenance',    color: 'text-neon-blue',   dot: 'bg-neon-blue',   bg: 'bg-neon-blue/10',   border: 'border-neon-blue/20'   },
};

const INCIDENT_STATUS_CONFIG: Record<IncidentStatus, { label: string; color: string }> = {
  investigating: { label: 'Investigating', color: 'text-red-400'     },
  identified:    { label: 'Identified',    color: 'text-orange-400'  },
  monitoring:    { label: 'Monitoring',    color: 'text-yellow-400'  },
  resolved:      { label: 'Resolved',      color: 'text-neon-green'  },
};

const IMPACT_CONFIG: Record<Impact, { label: string; color: string; bg: string }> = {
  none:     { label: 'No Impact',       color: 'text-gray-400',   bg: 'bg-gray-400/10'   },
  minor:    { label: 'Minor Impact',    color: 'text-yellow-400', bg: 'bg-yellow-400/10' },
  major:    { label: 'Major Impact',    color: 'text-orange-400', bg: 'bg-orange-400/10' },
  critical: { label: 'Critical Impact', color: 'text-red-400',    bg: 'bg-red-400/10'    },
};

// Statut global = pire statut parmi les services
const STATUS_RANK: Record<Status, number> = {
  operational: 0, maintenance: 1, degraded: 2, partial_outage: 3, major_outage: 4,
};
const worstStatus: Status = (services ?? []).reduce<Status>((worst, s) => {
  const st = s.status as Status;
  return STATUS_RANK[st] > STATUS_RANK[worst] ? st : worst;
}, 'operational');

const OVERALL_CONFIG = {
  operational:    { label: 'All Systems Operational',  bg: 'bg-neon-green/10',  border: 'border-neon-green/25',  text: 'text-neon-green',  icon: 'M5 13l4 4L19 7' },
  maintenance:    { label: 'Scheduled Maintenance',    bg: 'bg-neon-blue/10',   border: 'border-neon-blue/25',   text: 'text-neon-blue',   icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
  degraded:       { label: 'Degraded Performance',     bg: 'bg-yellow-400/10',  border: 'border-yellow-400/25',  text: 'text-yellow-400',  icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' },
  partial_outage: { label: 'Partial System Outage',    bg: 'bg-orange-400/10',  border: 'border-orange-400/25',  text: 'text-orange-400',  icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' },
  major_outage:   { label: 'Major System Outage',      bg: 'bg-red-500/10',     border: 'border-red-500/25',     text: 'text-red-400',     icon: 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z' },
};
const overall = OVERALL_CONFIG[worstStatus];

// Incidents actifs (non résolus)
const activeIncidents  = (incidents ?? []).filter(i => i.status !== 'resolved');
const resolvedIncidents = (incidents ?? []).filter(i => i.status === 'resolved').slice(0, 10);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit', timeZone: 'UTC' }) + ' UTC';
}

function timeAgo(d: string) {
  const diff = Date.now() - new Date(d).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 60)   return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24)   return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}
---

<BaseLayout
  title="System Status"
  description="Real-time status of BioForge services — Dashboard, public profiles and database."
  noindex={false}
>

  <div class="min-h-screen bg-[#0a0a0f]">

    <!-- ═══════ NAV ═══════ -->
    <nav class="border-b border-white/5 backdrop-blur-xl sticky top-0 z-40 bg-[#0a0a0f]/80">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group">
          <svg class="w-7 h-7 text-neon-green" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L2 7L12 12L22 7L12 2Z"  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 17L12 22L22 17"            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 12L12 17L22 12"            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-display font-semibold text-white tracking-wide text-sm">BioForge</span>
        </a>
        <span class="text-xs text-gray-500 font-mono">status.bioforge.click</span>
      </div>
    </nav>

    <div class="max-w-4xl mx-auto px-6 py-12 space-y-10">

      <!-- ═══════ OVERALL BANNER ═══════ -->
      <div class={`flex items-center gap-4 p-6 rounded-2xl border ${overall.bg} ${overall.border}`}>
        <div class={`w-12 h-12 rounded-xl ${overall.bg} border ${overall.border} flex items-center justify-center shrink-0`}>
          <svg class={`w-6 h-6 ${overall.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={overall.icon}/>
          </svg>
        </div>
        <div>
          <h1 class={`text-xl font-display font-semibold ${overall.text}`}>{overall.label}</h1>
          <p class="text-sm text-gray-400 mt-0.5">Last updated: <span id="last-updated" class="text-gray-300">{new Date().toUTCString().replace('GMT', 'UTC')}</span></p>
        </div>
        <div class="ml-auto shrink-0">
          {worstStatus === 'operational' && (
            <div class="relative flex items-center justify-center w-3 h-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-green opacity-60"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-neon-green"></span>
            </div>
          )}
        </div>
      </div>

      <!-- ═══════ SERVICES ═══════ -->
      <section>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Services</h2>
        <div class="divide-y divide-white/5 glass rounded-2xl overflow-hidden border border-white/8">
          {(services ?? []).map(service => {
            const cfg = STATUS_CONFIG[service.status as Status] ?? STATUS_CONFIG.operational;
            return (
              <div class="flex items-center justify-between px-5 py-4 hover:bg-white/[0.02] transition-colors">
                <div class="flex items-center gap-3">
                  <div class={`w-2 h-2 rounded-full ${cfg.dot} shrink-0`}
                    style={service.status === 'operational' ? 'box-shadow: 0 0 6px rgba(0,255,157,0.7)' : ''}>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-white">{service.name}</p>
                    {service.description && <p class="text-xs text-gray-500 mt-0.5">{service.description}</p>}
                  </div>
                </div>
                <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${cfg.bg} ${cfg.color} border ${cfg.border}`}>
                  {cfg.label}
                </span>
              </div>
            );
          })}
        </div>
      </section>

      <!-- ═══════ ACTIVE INCIDENTS ═══════ -->
      {activeIncidents.length > 0 && (
        <section>
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Active Incidents</h2>
          <div class="space-y-4">
            {activeIncidents.map(incident => {
              const impactCfg  = IMPACT_CONFIG[incident.impact as Impact] ?? IMPACT_CONFIG.minor;
              const statusCfg  = INCIDENT_STATUS_CONFIG[incident.status as IncidentStatus];
              const updates    = [...(incident.incident_updates ?? [])].sort((a, b) =>
                new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
              );
              return (
                <div class="glass rounded-2xl border border-red-500/20 p-5 space-y-4">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${impactCfg.bg} ${impactCfg.color}`}>
                          {impactCfg.label}
                        </span>
                        <span class={`text-xs font-semibold ${statusCfg.color}`}>{statusCfg.label}</span>
                      </div>
                      <h3 class="text-white font-semibold text-sm">{incident.title}</h3>
                      {incident.services?.length > 0 && (
                        <p class="text-xs text-gray-500 mt-1">
                          Affected: {incident.services.join(', ')}
                        </p>
                      )}
                    </div>
                    <span class="text-xs text-gray-600 shrink-0">{timeAgo(incident.created_at)}</span>
                  </div>

                  <!-- Timeline updates -->
                  {updates.length > 0 && (
                    <div class="relative pl-4 space-y-4 border-l border-white/10">
                      {updates.map((update, i) => {
                        const uCfg = INCIDENT_STATUS_CONFIG[update.status as IncidentStatus];
                        return (
                          <div class="relative">
                            <div class={`absolute -left-[1.35rem] top-1 w-2.5 h-2.5 rounded-full border-2 border-[#0a0a0f] ${
                              i === 0 ? 'bg-neon-green' : 'bg-gray-600'
                            }`}></div>
                            <div class="flex items-baseline justify-between gap-4 mb-0.5">
                              <span class={`text-xs font-semibold ${uCfg.color}`}>{uCfg.label}</span>
                              <span class="text-xs text-gray-600 shrink-0">{formatDate(update.created_at)}</span>
                            </div>
                            <p class="text-sm text-gray-300 leading-relaxed">{update.message}</p>
                          </div>
                        );
                      })}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </section>
      )}

      <!-- ═══════ INCIDENT HISTORY ═══════ -->
      <section>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Incident History</h2>

        {resolvedIncidents.length === 0 ? (
          <div class="text-center py-12 glass rounded-2xl border border-white/5">
            <svg class="w-8 h-8 text-neon-green mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-sm text-gray-400">No incidents in the past 30 days</p>
          </div>
        ) : (
          <div class="space-y-3">
            {resolvedIncidents.map(incident => {
              const impactCfg = IMPACT_CONFIG[incident.impact as Impact] ?? IMPACT_CONFIG.minor;
              const updates   = [...(incident.incident_updates ?? [])].sort((a, b) =>
                new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
              );
              return (
                <details class="glass rounded-xl border border-white/8 group">
                  <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-white/[0.02] transition-colors">
                    <div class="flex items-center gap-3">
                      <svg class="w-4 h-4 text-neon-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <span class="text-sm text-white font-medium">{incident.title}</span>
                      <span class={`text-xs px-2 py-0.5 rounded-full ${impactCfg.bg} ${impactCfg.color}`}>
                        {impactCfg.label}
                      </span>
                    </div>
                    <div class="flex items-center gap-3 shrink-0">
                      <span class="text-xs text-gray-600">{formatDate(incident.created_at)}</span>
                      <svg class="w-4 h-4 text-gray-600 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </div>
                  </summary>

                  {updates.length > 0 && (
                    <div class="px-5 pb-5 pt-1">
                      <div class="relative pl-4 space-y-4 border-l border-white/10">
                        {updates.map((update, i) => {
                          const uCfg = INCIDENT_STATUS_CONFIG[update.status as IncidentStatus];
                          return (
                            <div class="relative">
                              <div class={`absolute -left-[1.35rem] top-1 w-2.5 h-2.5 rounded-full border-2 border-[#0a0a0f] ${
                                i === 0 ? 'bg-neon-green' : 'bg-gray-700'
                              }`}></div>
                              <div class="flex items-baseline justify-between gap-4 mb-0.5">
                                <span class={`text-xs font-semibold ${uCfg.color}`}>{uCfg.label}</span>
                                <span class="text-xs text-gray-600 shrink-0">{formatDate(update.created_at)}</span>
                              </div>
                              <p class="text-sm text-gray-400 leading-relaxed">{update.message}</p>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  )}
                </details>
              );
            })}
          </div>
        )}
      </section>

      <!-- ═══════ FOOTER ═══════ -->
      <footer class="pt-6 border-t border-white/5 flex items-center justify-between text-xs text-gray-600">
        <span>© {new Date().getFullYear()} BioForge</span>
        <a href="/" class="hover:text-gray-400 transition-colors">← Back to BioForge</a>
      </footer>

    </div>
  </div>

</BaseLayout>

<style>
  details > summary::-webkit-details-marker { display: none; }
</style>
---
// src/pages/dashboard/settings.astro - IMPROVED with more features

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import Input from '@/components/ui/Input.astro';
import Badge from '@/components/ui/Badge.astro';
import Alert from '@/components/ui/Alert.astro';
import { withAuth } from '@/lib/auth/auth';

// ==================== AUTH CHECK ====================

const authResult = await withAuth({
  cookies: Astro.cookies,
  request: Astro.request,
});

if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}

const { user, profile, planLimits } = authResult.data;
---

<DashboardLayout title="Settings">
  <!-- Header -->
  <div class="mb-6">
    <h2 class="text-lg lg:text-xl font-semibold text-white mb-1">Settings</h2>
    <p class="text-sm text-gray-400">Manage your account and preferences</p>
  </div>

  <!-- Profile Settings -->
  <Card title="Profile Information" description="Update your public profile" class="mb-6">
    <form id="profile-form" class="space-y-4">
      <!-- Display Name -->
      <div>
        <label for="display_name" class="block text-sm font-medium text-gray-300 mb-2">
          Display Name
          <span class="text-red-400 ml-1">*</span>
        </label>
        <Input
          type="text"
          id="display_name"
          name="display_name"
          value={profile.display_name || ''}
          placeholder="John Doe"
          required
        />
      </div>

      <!-- Username -->
      <div>
        <label for="username" class="block text-sm font-medium text-gray-300 mb-2">
          Username
          <span class="text-red-400 ml-1">*</span>
          <span class="text-gray-500 text-xs ml-2">https://bioforge.click/@{profile.username}</span>
        </label>
        <div class="flex items-center space-x-2">
          <Input
            type="text"
            id="username"
            name="username"
            value={profile.username}
            placeholder="johndoe"
            required
            pattern="[a-z0-9_]+"
            minlength="3"
            maxlength="24"
            class="flex-1"
          />
          <button
            type="button"
            id="check-username-btn"
            class="px-4 py-3 glass border border-white/10 rounded-xl text-sm text-white hover:bg-white/5 transition-all"
          >
            Check
          </button>
        </div>
        <p class="text-xs text-gray-500 mt-1.5">
          3-24 characters. Lowercase letters, numbers and underscores only.
        </p>
        <div id="username-feedback" class="mt-2 text-sm hidden"></div>
      </div>

      <!-- Bio -->
      <div>
        <label for="bio" class="block text-sm font-medium text-gray-300 mb-2">
          Bio
          <span class="text-gray-500 text-xs ml-2">Optional</span>
        </label>
        <textarea
          id="bio"
          name="bio"
          rows="4"
          maxlength="500"
          class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-green/50 focus:outline-none focus:ring-2 focus:ring-neon-green/20 resize-none"
          placeholder="Tell people about yourself..."
        >{profile.bio || ''}</textarea>
        <div class="flex items-center justify-between mt-1.5">
          <p class="text-xs text-gray-500">
            <span id="bio-count">0</span>/500 characters
          </p>
          <button
            type="button"
            id="bio-suggestions-btn"
            class="text-xs text-neon-green hover:underline"
          >
            Need inspiration?
          </button>
        </div>
      </div>

      <!-- Avatar URL -->
      <div>
        <label for="avatar_url" class="block text-sm font-medium text-gray-300 mb-2">
          Avatar URL
          <span class="text-gray-500 text-xs ml-2">Optional</span>
        </label>
        <div class="flex items-center space-x-3">
          {profile.avatar_url && (
            <img 
              id="avatar-preview"
              src={profile.avatar_url} 
              alt="Avatar" 
              class="w-12 h-12 rounded-full object-cover border-2 border-neon-green/30"
            />
          )}
          <Input
            type="url"
            id="avatar_url"
            name="avatar_url"
            value={profile.avatar_url || ''}
            placeholder="https://example.com/avatar.jpg"
            class="flex-1"
          />
        </div>
        <p class="text-xs text-gray-500 mt-1.5">
          Paste a link to your profile picture. We recommend 400x400px minimum.
        </p>
      </div>

      <!-- Email (readonly) -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-2">
          Email
        </label>
        <Input
          type="email"
          value={user.email}
          readonly
          class="opacity-50 cursor-not-allowed"
        />
        <p class="text-xs text-gray-500 mt-1.5">
          Email cannot be changed here. Contact support if you need to update it.
        </p>
      </div>

      <div class="flex items-center space-x-3 pt-2">
        <Button type="submit" variant="primary" id="save-profile-btn" class="flex-1 sm:flex-none">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          Save Changes
        </Button>
        <Button type="button" variant="ghost" href="/dashboard">
          Cancel
        </Button>
      </div>
    </form>
  </Card>

  <!-- Current Plan -->
  <Card title="Current Plan" description="Your subscription details" class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <div class="flex items-center space-x-2 mb-2">
          <Badge variant={profile.plan === 'Free' ? 'default' : 'premium'} size="md">
            {profile.plan}
          </Badge>
          {profile.plan === 'Free' && (
            <span class="text-xs text-gray-500">Free forever</span>
          )}
        </div>
        <p class="text-sm text-gray-400">
          {planLimits.max_blocks_total === -1 ? 'Unlimited' : planLimits.max_blocks_total} blocks maximum
        </p>
      </div>
      {profile.plan === 'Free' && (
        <Button variant="secondary" href="/pricing">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
          Upgrade Plan
        </Button>
      )}
    </div>

    <!-- Plan Features -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-4 pt-4 border-t border-white/10">
      <div class="flex items-center space-x-2 text-sm text-gray-300">
        <svg class="w-4 h-4 text-neon-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span>{planLimits.max_blocks_total === -1 ? 'Unlimited' : planLimits.max_blocks_total} blocks</span>
      </div>
      <div class="flex items-center space-x-2 text-sm text-gray-300">
        <svg class="w-4 h-4 text-neon-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span>Basic analytics</span>
      </div>
      <div class="flex items-center space-x-2 text-sm text-gray-300">
        <svg class="w-4 h-4 text-neon-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span>Custom themes</span>
      </div>
      <div class="flex items-center space-x-2 text-sm text-gray-300">
        <svg class="w-4 h-4 text-neon-green flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span>Email support</span>
      </div>
    </div>
  </Card>

  <!-- Public Profile Link -->
  <Card title="Public Profile" description="Share your page" class="mb-6">
    <div class="space-y-3">
      <div class="flex items-center space-x-3">
        <Input
          type="text"
          value={`https://bioforge.click/@${profile.username}`}
          readonly
          id="profile-url"
          class="flex-1"
        />
        <Button variant="secondary" id="copy-url-btn">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </Button>
        <Button variant="secondary" href={`/@${profile.username}`} target="_blank">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </Button>
      </div>
      
      <!-- Social Share Buttons -->
      <div class="flex items-center space-x-2 pt-2">
        <span class="text-xs text-gray-500">Share on:</span>
        <button 
          id="share-twitter"
          class="p-2 glass rounded-lg hover:bg-white/5 transition-all"
          title="Share on Twitter"
        >
          <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
          </svg>
        </button>
        <button 
          id="share-facebook"
          class="p-2 glass rounded-lg hover:bg-white/5 transition-all"
          title="Share on Facebook"
        >
          <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
        </button>
        <button 
          id="share-linkedin"
          class="p-2 glass rounded-lg hover:bg-white/5 transition-all"
          title="Share on LinkedIn"
        >
          <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z"/>
          </svg>
        </button>
      </div>
    </div>
  </Card>

  <!-- Account Status -->
  <Card title="Account Information" description="Account details" class="mb-6">
    <div class="space-y-3">
      <div class="flex items-center justify-between py-2">
        <span class="text-sm text-gray-400">Email</span>
        <span class="text-sm text-white">{user.email}</span>
      </div>
      <div class="flex items-center justify-between py-2 border-t border-white/5">
        <span class="text-sm text-gray-400">Account Status</span>
        <Badge variant={profile.is_active ? 'success' : 'default'} size="sm">
          {profile.is_active ? 'Active' : 'Inactive'}
        </Badge>
      </div>
      <div class="flex items-center justify-between py-2 border-t border-white/5">
        <span class="text-sm text-gray-400">Member Since</span>
        <span class="text-sm text-white">
          {new Date(profile.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
      </div>
      <div class="flex items-center justify-between py-2 border-t border-white/5">
        <span class="text-sm text-gray-400">Last Updated</span>
        <span class="text-sm text-white">
          {new Date(profile.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </span>
      </div>
    </div>
  </Card>

  <!-- Preferences -->
  <Card title="Preferences" description="Customize your experience" class="mb-6">
    <div class="space-y-4">
      <label class="flex items-center justify-between p-3 glass rounded-lg cursor-pointer hover:bg-white/5 transition-all">
        <div>
          <div class="text-white font-medium">Email Notifications</div>
          <div class="text-xs text-gray-400">Receive weekly analytics reports</div>
        </div>
        <input type="checkbox" id="email_notifications" class="toggle" checked />
      </label>

      <label class="flex items-center justify-between p-3 glass rounded-lg cursor-pointer hover:bg-white/5 transition-all">
        <div>
          <div class="text-white font-medium">Marketing Emails</div>
          <div class="text-xs text-gray-400">Updates and tips to grow your audience</div>
        </div>
        <input type="checkbox" id="marketing_emails" class="toggle" />
      </label>

      <label class="flex items-center justify-between p-3 glass rounded-lg cursor-pointer hover:bg-white/5 transition-all">
        <div>
          <div class="text-white font-medium">Profile Public</div>
          <div class="text-xs text-gray-400">Make your profile visible to search engines</div>
        </div>
        <input type="checkbox" id="profile_public" class="toggle" checked />
      </label>
    </div>
  </Card>

  <!-- Danger Zone -->
  <Card title="Danger Zone" description="Irreversible actions" class="border-red-500/30">
    <Alert variant="danger" title="Delete Account">
      <p class="mb-4">Once you delete your account, there is no going back. This will permanently delete:</p>
      <ul class="list-disc list-inside mb-4 text-sm space-y-1">
        <li>Your profile and username</li>
        <li>All your blocks and content</li>
        <li>All your analytics data</li>
        <li>Your subscription (if any)</li>
      </ul>
      <Button variant="danger" id="delete-account-btn">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete My Account
      </Button>
    </Alert>
  </Card>

  <script>
    import { toast } from '@/lib/utils/toast';

    // ==================== BIO COUNTER ====================
    const bioTextarea = document.getElementById('bio') as HTMLTextAreaElement;
    const bioCount = document.getElementById('bio-count');

    function updateBioCount() {
      if (bioTextarea && bioCount) {
        bioCount.textContent = bioTextarea.value.length.toString();
      }
    }

    bioTextarea?.addEventListener('input', updateBioCount);
    updateBioCount();

    // ==================== BIO SUGGESTIONS ====================
    const bioSuggestionsBtn = document.getElementById('bio-suggestions-btn');
    const suggestions = [
      "✨ Creating magic on the internet",
      "🚀 Building the future, one link at a time",
      "💡 Sharing ideas that matter",
      "🎨 Digital creator & storyteller",
      "🌍 Making connections worldwide",
      "📸 Capturing moments, sharing stories",
      "🎯 Helping you reach your goals",
      "💻 Tech enthusiast & problem solver"
    ];

    bioSuggestionsBtn?.addEventListener('click', () => {
      const random = suggestions[Math.floor(Math.random() * suggestions.length)];
      if (bioTextarea) {
        bioTextarea.value = random;
        updateBioCount();
        toast.info('Bio suggestion added! Feel free to edit it.');
      }
    });

    // ==================== AVATAR PREVIEW ====================
    const avatarInput = document.getElementById('avatar_url') as HTMLInputElement;
    const avatarPreview = document.getElementById('avatar-preview') as HTMLImageElement;

    avatarInput?.addEventListener('input', () => {
      const url = avatarInput.value;
      if (url && avatarPreview) {
        avatarPreview.src = url;
        avatarPreview.onerror = () => {
          toast.error('Invalid image URL');
        };
      }
    });

    // ==================== CHECK USERNAME ====================
    const checkUsernameBtn = document.getElementById('check-username-btn');
    const usernameInput = document.getElementById('username') as HTMLInputElement;
    const usernameFeedback = document.getElementById('username-feedback');

    checkUsernameBtn?.addEventListener('click', async () => {
      const username = usernameInput?.value;
      if (!username) {
        toast.error('Please enter a username');
        return;
      }

      // Validate format
      if (!/^[a-z0-9_]{3,24}$/.test(username)) {
        toast.error('Invalid username format');
        return;
      }

      try {
        // TODO: Add API endpoint to check username availability
        toast.info('Checking username...');
        // For now, just show success
        setTimeout(() => {
          toast.success('Username is available!');
        }, 500);
      } catch (error) {
        toast.error('Failed to check username');
      }
    });

    // ==================== PROFILE FORM ====================
    const profileForm = document.getElementById('profile-form');

    profileForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      console.log('[FORM SUBMIT] Début');

      const formData = new FormData(e.target as HTMLFormElement);
      const data = {
        display_name: formData.get('display_name') as string,
        username: formData.get('username') as string,
        bio: formData.get('bio') as string || null,
        avatar_url: formData.get('avatar_url') as string || null,
      };

      console.log('[FORM DATA]', data);               // ← log ce qui est envoyé
      console.log('[JSON envoyé]', JSON.stringify(data));

      try {
        const response = await fetch('https://bioforge-three.vercel.app/api/profile', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        console.log('[RESPONSE STATUS]', response.status);

        const result = await response.json();
        console.log('[RESPONSE BODY]', result);

        if (!response.ok) {
          throw new Error(result.error || 'Failed to update profile');
        }

        toast.success('Profile updated successfully!');
        setTimeout(() => window.location.reload(), 1000);
      } catch (error) {
        console.error('[FETCH ERROR]', error);
        toast.error(error instanceof Error ? error.message : 'Failed to update profile');
      }
    });

    // ==================== COPY URL ====================
    const copyUrlBtn = document.getElementById('copy-url-btn');
    const profileUrl = document.getElementById('profile-url') as HTMLInputElement;

    copyUrlBtn?.addEventListener('click', async () => {
      if (profileUrl) {
        try {
          await navigator.clipboard.writeText(profileUrl.value);
          toast.success('URL copied to clipboard!');
        } catch (error) {
          profileUrl.select();
          document.execCommand('copy');
          toast.success('URL copied!');
        }
      }
    });

    // ==================== SOCIAL SHARE ====================
    const shareTwitter = document.getElementById('share-twitter');
    const shareFacebook = document.getElementById('share-facebook');
    const shareLinkedIn = document.getElementById('share-linkedin');

    const profileUrlValue = profileUrl?.value || '';
    const shareText = 'Check out my profile!';

    shareTwitter?.addEventListener('click', () => {
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(profileUrlValue)}`, '_blank');
    });

    shareFacebook?.addEventListener('click', () => {
      window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(profileUrlValue)}`, '_blank');
    });

    shareLinkedIn?.addEventListener('click', () => {
      window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(profileUrlValue)}`, '_blank');
    });

    // ==================== DELETE ACCOUNT ====================
    const deleteBtn = document.getElementById('delete-account-btn');

    deleteBtn?.addEventListener('click', async () => {
      const confirmed = confirm(
        'Are you sure you want to delete your account?\n\n' +
        'This will permanently delete:\n' +
        '- Your profile\n' +
        '- All your blocks\n' +
        '- All your analytics data\n\n' +
        'This action CANNOT be undone!'
      );

      if (!confirmed) return;

      const doubleConfirm = confirm(
        'FINAL WARNING: This will permanently delete everything.\n\n' +
        'Are you ABSOLUTELY sure?'
      );

      if (!doubleConfirm) return;

      try {
        const response = await fetch('https://bioforge-three.vercel.app/api/profile/delete', {
          method: 'POST'
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Failed to delete account');
        }

        toast.success('Account deleted. Goodbye!');
        
        // Redirect to home
        setTimeout(() => {
          window.location.href = '/';
        }, 2000);
      } catch (error) {
        toast.error(error instanceof Error ? error.message : 'Failed to delete account');
      }
    });
  </script>
</DashboardLayout>
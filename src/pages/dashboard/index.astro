            <div class="group p-3 rounded-xl transition-all cursor-default" style="border:1px solid rgba(255,255,255,0.05)">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-base leading-none">{medals[i] ?? `#${i + 1}`}</span>
                <p class="text-xs font-semibold text-white truncate flex-1">{block.title || 'Sans titre'}</p>
                <span class="text-xs font-bold tabular-nums shrink-0" style={`color:${barColors[i] ?? '#fff'}`}>
                  {clicks.toLocaleString('fr-FR')}
                </span>
              </div>
              <div class="h-1 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.06)">
                <div class="h-full rounded-full transition-all duration-700" style={`width:${pct}%;background:${barColors[i] ?? '#fff'}`}></div>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
 
  <!-- Share + Geo -->
  <div class="flex flex-col gap-4">
 
    <!-- Share card -->

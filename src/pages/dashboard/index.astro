  <!-- ===== RECENT BLOCKS + TOP PERFORMING + ACTIVITY ===== -->
  <div class="grid lg:grid-cols-3 gap-6">

    <!-- Recent Blocks -->
    <div class="glass border border-white/10 rounded-2xl p-5">
      <div class="flex items-center justify-between mb-4">
        <div>

      </div>
      <a href="/dashboard/analytics" class="text-xs text-gray-500 hover:text-neon-purple transition-colors">Rapport →</a>
    </div>
    {topBlocks.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-8 text-center">
        <div class="text-3xl mb-3">🎯</div>
        <p class="text-xs text-gray-500">Aucun clic enregistré</p>
        <p class="text-xs text-gray-600 mt-1">Partage ton profil pour collecter des données</p>
      </div>
    ) : (
      <div class="space-y-2.5">
        {topBlocks.slice(0, 5).map((block: any, i: number) => {
          const maxClicks = safeNum(topBlocks[0]?.clicks, 1);
          const clicks    = safeNum(block.clicks);
          const pct = Math.round((clicks / maxClicks) * 100);
          const medals = ['🥇', '🥈', '🥉'];
          const barColors = ['#00ff9d', '#bf00ff', '#00d4ff', '#fb923c', '#f87171'];

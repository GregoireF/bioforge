    <h3 class="text-white font-bold text-lg mb-2">Analytics avancées</h3>
    <p class="text-sm text-gray-400 mb-6 leading-relaxed">Accède à 30j, 90j et à l'historique complet pour comprendre ta croissance.</p>
    <div class="space-y-2 mb-6 text-left">
      {['Historique 30j & 90j', 'Analyse des tendances', 'Performance détaillée par bloc', 'Export CSV'].map(f => (
        <div class="flex items-center gap-2 text-sm text-gray-300">
          <svg class="w-4 h-4 text-neon-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
          </svg>
          {f}
        </div>
      ))}
    </div>
    <a href="/dashboard/billing" class="block w-full py-3 rounded-xl text-sm font-bold mb-3 transition-all hover:opacity-90"
      style="background:#00ff9d;color:#000">Passer à Pro →</a>
    <button id="paywall-close" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">Plus tard</button>
  </div>

</DashboardLayout>

<style>
  .stat-card { transition: transform 0.2s ease; }
  .stat-card:hover { transform: translateY(-2px); }
  .period-btn.active { background: rgba(255,255,255,0.1); color: white; }
  .ds-btn.active { background: rgba(255,255,255,0.1); color: white; }
  #paywall-modal.open { display: flex; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
 
<script>
  const bridge = document.getElementById('server-data');
  const { chartLabels, chartViews, chartClicks, sparkViews, sparkClicks, sparkRate, isPaid, profileUrl, todayViews } =
    JSON.parse(bridge?.dataset.bridge ?? '{}');
 
  // ── Sparklines ────────────────────────────────────────────────────────────────
  function drawSparkline(svgEl, values, color) {
    if (!svgEl || !values?.length) return;
    const W = 80, H = 24, pad = 2;
    const max = Math.max(...values, 1), min = Math.min(...values, 0);
    const range = max - min || 1;
    const pts = values.map((v, i) => {
      const x = pad + (i / Math.max(values.length - 1, 1)) * (W - pad * 2);
      const y = H - pad - ((v - min) / range) * (H - pad * 2);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    });
    const gid = 'g' + color.replace(/[^a-z0-9]/gi, '');
    const area = `${pts[0].split(',')[0]},${H} ${pts.join(' ')} ${pts[pts.length-1].split(',')[0]},${H}`;
    svgEl.innerHTML = `
      <defs>
        <linearGradient id="${gid}" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${color}" stop-opacity="0.35"/>
          <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <polygon points="${area}" fill="url(#${gid})"/>
      <polyline points="${pts.join(' ')}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="${pts[pts.length-1].split(',')[0]}" cy="${pts[pts.length-1].split(',')[1]}" r="2" fill="${color}"/>
    `;
  }
  requestAnimationFrame(() => {
    document.querySelectorAll('svg[data-values]').forEach(svg => {
      drawSparkline(svg, JSON.parse(svg.dataset.values ?? '[]'), svg.dataset.color ?? '#fff');
    });
  });
 
  // ── Today badge ───────────────────────────────────────────────────────────────
  const badge = document.getElementById('today-badge');
  if (badge && todayViews !== undefined) {
    badge.classList.remove('hidden');
    badge.classList.add('inline-flex');
  }
 
  // ── Chart ─────────────────────────────────────────────────────────────────────
  let chartInstance = null;
  let currentDs = 'both';
 
  function buildChart(labels, views, clicks, ds) {
    const ctx = document.getElementById('growth-chart');
    if (!ctx || typeof Chart === 'undefined') return;
    chartInstance?.destroy();
    const datasets = [];
    if (ds === 'both' || ds === 'views')  datasets.push({ label: 'Vues',  data: views,  borderColor: '#00ff9d', backgroundColor: 'rgba(0,255,157,0.07)', tension: 0.4, fill: true, borderWidth: 2, pointRadius: 2, pointHoverRadius: 5, pointBackgroundColor: '#00ff9d' });
    if (ds === 'both' || ds === 'clicks') datasets.push({ label: 'Clics', data: clicks, borderColor: '#bf00ff', backgroundColor: 'rgba(191,0,255,0.07)', tension: 0.4, fill: true, borderWidth: 2, pointRadius: 2, pointHoverRadius: 5, pointBackgroundColor: '#bf00ff' });
    chartInstance = new Chart(ctx, {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { labels: { color: '#6b7280', font: { size: 11 }, boxWidth: 8, usePointStyle: true } },
          tooltip: {
            backgroundColor: '#0d1014', borderColor: 'rgba(255,255,255,0.1)', borderWidth: 1,
            titleColor: '#fff', bodyColor: '#9ca3af', padding: 10,
            callbacks: { label: c => ` ${c.dataset.label}: ${c.parsed.y.toLocaleString('fr-FR')}` }
          }
        },
        scales: {
          y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#4b5563', font: { size: 10 }, maxTicksLimit: 5 }, border: { display: false } },
          x: { grid: { display: false }, ticks: { color: '#4b5563', font: { size: 10 }, maxTicksLimit: 7 }, border: { display: false } },
        }
      }
    });
  }
 
  function initChart() {
    if (!document.getElementById('growth-chart') || !chartLabels?.length) return;
    if (typeof Chart === 'undefined') { setTimeout(initChart, 100); return; }
    const obs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { buildChart(chartLabels, chartViews, chartClicks, currentDs); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(document.getElementById('growth-chart'));
  }
  initChart();
  window.addEventListener('load', initChart, { once: true });
 
  // Dataset toggle
  document.querySelectorAll('.ds-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.ds-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentDs = btn.dataset.ds;
      if (chartInstance) buildChart(chartInstance.data.labels, chartViews, chartClicks, currentDs);
    });
  });
 
  // Period selector
  document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const days = parseInt(btn.dataset.days);
      const free = btn.dataset.free === 'true';
      if (!free && !isPaid) { document.getElementById('paywall-modal')?.classList.add('open'); return; }
      document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (days === 7) { buildChart(chartLabels, chartViews, chartClicks, currentDs); return; }
      fetch(`/api/analytics/summary?days=${days}`)
        .then(r => r.ok ? r.json() : Promise.reject())
        .then(d => {
          const labels = (d.profileStats ?? []).map(s => new Date(s.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }));
          const views  = (d.profileStats ?? []).map(s => s.views ?? 0);
          const cmap   = new Map();
          (d.blockStats ?? []).forEach(bs => cmap.set(bs.date, (cmap.get(bs.date) ?? 0) + (bs.clicks ?? 0)));
          buildChart(labels, views, (d.profileStats ?? []).map(s => cmap.get(s.date) ?? 0), currentDs);
        }).catch(() => {});
    });
  });
  document.querySelector('.period-btn[data-days="7"]')?.classList.add('active');
 
  // ── Paywall ───────────────────────────────────────────────────────────────────
  const modal = document.getElementById('paywall-modal');
  document.getElementById('paywall-backdrop')?.addEventListener('click', () => modal?.classList.remove('open'));
  document.getElementById('paywall-close')?.addEventListener('click',    () => modal?.classList.remove('open'));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') modal?.classList.remove('open'); });
 
  // ── Copy URL ──────────────────────────────────────────────────────────────────
  function copyUrl(btn) {
    const url = btn?.dataset?.url;
    if (!url) return;
    navigator.clipboard.writeText(url).then(() => {
      const label = btn.querySelector('#copy-label, span');
      const icon  = btn.querySelector('#copy-icon, svg');
      if (label) label.textContent = 'Copié !';
      if (icon)  icon.style.color = '#00ff9d';
      btn.style.borderColor = 'rgba(0,255,157,0.4)';
      btn.style.color = '#00ff9d';
      setTimeout(() => {
        if (label) label.textContent = 'Copier';
        if (icon)  icon.style.color = '';
        btn.style.borderColor = '';
        btn.style.color = '';
      }, 2000);
    });
  }
  document.getElementById('copy-url-btn')?.addEventListener('click', function() { copyUrl(this); });
  document.getElementById('share-copy')?.addEventListener('click', function() { copyUrl(this); });
 
  // ── QR Code (mini canvas — sans lib externe) ──────────────────────────────────
  // Version simplifiée: juste afficher l'URL en QR via API publique si disponible
  // ou un placeholder stylé
  (function() {
    const canvas = document.getElementById('qr-canvas');
    if (!canvas || !profileUrl) return;
    const ctx2 = canvas.getContext('2d');
    if (!ctx2) return;
    // Placeholder graphique tant qu'on n'a pas de lib QR
    ctx2.fillStyle = '#0a0a0a';
    ctx2.fillRect(0, 0, 52, 52);
    // Grid décorative
    ctx2.fillStyle = '#00ff9d';
    const cells = 7;
    const cell  = 52 / cells;
    // Pattern QR simplifié (finder patterns)
    [[0,0],[0,4],[4,0]].forEach(([r,c]) => {
      for (let y = r; y < r+3; y++) for (let x = c; x < c+3; x++) {
        if (y === r || y === r+2 || x === c || x === c+2)
          ctx2.fillRect(x*cell+1, y*cell+1, cell-2, cell-2);
      }
    });
    // Data cells random seed from URL
    let seed = [...(profileUrl)].reduce((a,c) => a + c.charCodeAt(0), 0);
    for (let y = 0; y < cells; y++) for (let x = 0; x < cells; x++) {
      seed = (seed * 1664525 + 1013904223) & 0xffffffff;
      if ((seed >>> 0) % 3 === 0 && !(x < 3 && y < 3) && !(x > 3 && y < 3) && !(x < 3 && y > 3))
        ctx2.fillRect(x*cell+1, y*cell+1, cell-2, cell-2);
    }
  })();
</script>
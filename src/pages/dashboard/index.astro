  </div>
 
  <!-- Profile Optimizer -->
  <div class="rounded-2xl p-5 flex flex-col" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08)">
    <h3 class="text-sm font-semibold text-white mb-0.5">Optimise ton profil</h3>
    <p class="text-xs text-gray-500 mb-4">Actions concrètes pour plus de clics</p>
 
    <!-- Score visual -->
    <div class="flex items-center gap-4 mb-5 p-3 rounded-xl" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06)">
      <div class="relative w-14 h-14 shrink-0">
        <svg class="w-14 h-14 -rotate-90" viewBox="0 0 56 56">
          <circle cx="28" cy="28" r="22" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="5"/>
          <circle cx="28" cy="28" r="22" fill="none"
            stroke={profileScore >= 80 ? '#00ff9d' : profileScore >= 50 ? '#fbbf24' : '#f87171'}
            stroke-width="5" stroke-linecap="round"
            stroke-dasharray={`${(profileScore / 100) * 138} 138`}/>
        </svg>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-xs font-bold text-white">{profileScore}</span>
        </div>
      </div>
      <div>
        <p class="text-xs text-gray-400">Score profil</p>
        <p class="text-sm font-bold" style={`color:${profileScore >= 80 ? '#00ff9d' : profileScore >= 50 ? '#fbbf24' : '#f87171'}`}>
          {profileScore >= 80 ? 'Excellent 🏆' : profileScore >= 60 ? 'Bon niveau 👍' : profileScore >= 40 ? 'En cours 📈' : 'À compléter ⚡'}
        </p>
      </div>
    </div>
 
    <!-- Recommendations list -->
    <div class="flex-1 space-y-2 overflow-auto" style="max-height:220px">
      {completionChecks.map(c => (
        <a href={c.href}
          class={`flex items-center gap-3 p-2.5 rounded-xl transition-all text-xs
            ${c.done
              ? 'opacity-50 cursor-default pointer-events-none'
              : 'hover:border-neon-green/30 hover:bg-white/5'}`}
          style={`border:1px solid ${c.done ? 'rgba(255,255,255,0.05)' : 'rgba(255,255,255,0.08)'}`}>
          <div class={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 border

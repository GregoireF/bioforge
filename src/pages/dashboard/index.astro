      </div>
      {blocks.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-10 text-center">
          <p class="text-xs text-gray-500 mb-3">No blocks yet</p>
          <a href="/dashboard/blocks" class="text-xs text-neon-green hover:underline">Add your first block →</a>
        </div>
      ) : (
        <div class="space-y-2">
          {[...blocks]
            .sort((a: any, b: any) => new Date(b.created_at ?? 0).getTime() - new Date(a.created_at ?? 0).getTime())
            .slice(0, 5)
            .map((block: any) => {
              const typeIcon = { link: '🔗', heading: '📝', image: '🖼️', video: '🎥', social: '🌐', spacer: '—' } as const;
              return (
                <a href="/dashboard/blocks"
                  class="flex items-center gap-3 p-3 rounded-xl border border-white/5 hover:border-neon-green/25 hover:bg-white/5 transition-all group">
                  <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-sm shrink-0">
                    {typeIcon[block.type] ?? '📌'}

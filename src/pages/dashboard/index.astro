          <span class={`flex-1 font-medium text-gray-300 truncate ${c.done ? 'line-through' : ''}`}>{c.label}</span>
          <span class="text-[10px] font-bold shrink-0" style="color:rgba(0,255,157,0.7)">+{c.weight}pts</span>

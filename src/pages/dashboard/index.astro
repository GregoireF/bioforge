      <h3 class="text-xs font-semibold text-neon-green uppercase tracking-widest mb-3">Partage ton profil</h3>
      {profileUrl ? (
        <div>
          <div class="flex items-center gap-2 mb-3">
            <!-- Mini QR placeholder — généré par JS -->
            <canvas id="qr-canvas" width="52" height="52" class="rounded-lg shrink-0" style="border:1px solid rgba(255,255,255,0.1)"></canvas>
            <div class="min-w-0">
              <p class="text-xs text-gray-400 font-mono truncate">{profileUrl}</p>
              <p class="text-xs text-gray-600 mt-0.5">Scanne ou copie le lien</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button id="share-copy"
              class="flex-1 flex items-center justify-center gap-1.5 py-2 rounded-lg text-xs font-semibold transition-all"
              style="background:rgba(0,255,157,0.12);border:1px solid rgba(0,255,157,0.25);color:#00ff9d"
              data-url={profileUrl}>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Copier
            </button>
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(profileUrl)}&text=Mon+profil+BioForge`} target="_blank" rel="noopener"
              class="flex items-center justify-center w-8 h-8 rounded-lg transition-all hover:opacity-80"
              style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1)" title="Partager sur X">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href={`https://wa.me/?text=${encodeURIComponent('Mon profil BioForge : ' + profileUrl)}`} target="_blank" rel="noopener"
              class="flex items-center justify-center w-8 h-8 rounded-lg transition-all hover:opacity-80"
              style="background:rgba(37,211,102,0.12);border:1px solid rgba(37,211,102,0.25)" title="WhatsApp">
              <svg class="w-3.5 h-3.5" fill="#25D166" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12.004 2C6.477 2 2 6.477 2 12.004c0 1.765.46 3.467 1.32 4.962L2 22l5.198-1.288A10.006 10.006 0 0012.004 22C17.523 22 22 17.523 22 12.004 22 6.477 17.523 2 12.004 2zm0 18.18a8.18 8.18 0 01-4.172-1.141l-.299-.177-3.087.766.778-3.018-.194-.31A8.182 8.182 0 1112.004 20.18z"/></svg>
            </a>
          </div>
        </div>
      ) : (
        <p class="text-xs text-gray-500">Configure ton pseudo dans les settings pour obtenir ton lien.</p>
      )}
    </div>
 
    <!-- Geo top countries -->
    <div class="flex-1 rounded-2xl p-4" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08)">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Top pays</h3>
      {topCountries.length === 0 ? (
        <p class="text-xs text-gray-600 text-center py-4">Pas encore de données géo</p>
      ) : (
        <div class="space-y-2">
          {topCountries.slice(0, 4).map((c: any) => {
            const pct = Math.round((safeNum(c.views) / safeNum(topCountries[0]?.views, 1)) * 100);
            return (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="flex items-center gap-1.5 text-xs text-gray-300">
                    <span>{flagEmoji(c.country)}</span>
                    <span>{c.country || 'Inconnu'}</span>
                  </span>
                  <span class="text-xs font-semibold text-white tabular-nums">{safeNum(c.views).toLocaleString('fr-FR')}</span>
                </div>
                <div class="h-1 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.06)">
                  <div class="h-full rounded-full" style={`width:${pct}%;background:rgba(0,212,255,0.6)`}></div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </div>
 
  <!-- Activity / Notifications feed -->
  <div class="rounded-2xl p-5" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08)">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-white">Activité récente</h3>
      <span class="text-xs text-gray-600">Événements</span>
    </div>
 
    {/* Notifications réelles en priorité */}
    {notifs.length > 0 ? (
      <div class="relative">
        <div class="absolute left-4 top-2 bottom-2 w-px" style="background:rgba(255,255,255,0.07)"></div>
        <div class="space-y-4 pl-9">
          {notifs.slice(0, 6).map((n: any) => {
            const ICON_BG: Record<string, string> = {
              welcome:         'rgba(0,255,157,0.15)',
              roadmap_shipped: 'rgba(0,255,157,0.15)',
              visit_milestone: 'rgba(56,189,248,0.15)',
              click_milestone: 'rgba(251,146,60,0.15)',
              suggestion_ok:   'rgba(0,255,157,0.15)',
              upgrade_success: 'rgba(167,139,250,0.15)',
            };
            const bg = ICON_BG[n.type] ?? 'rgba(255,255,255,0.08)';
            const timeAgo = (() => {
              const diff = (Date.now() - new Date(n.created_at).getTime()) / 1000;
              if (diff < 3600)  return Math.floor(diff / 60) + ' min';
              if (diff < 86400) return Math.floor(diff / 3600) + 'h';
              return Math.floor(diff / 86400) + 'j';
            })();
            return (
              <div class="relative flex items-start gap-2.5">
                <div class="absolute -left-5 top-0.5 w-7 h-7 rounded-lg flex items-center justify-center text-sm shrink-0"
                  style={`background:${bg};border:1px solid ${bg}`}>
                  {n.icon ?? '✦'}
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-xs font-semibold text-white leading-snug">{n.title}</p>
                  {n.body && <p class="text-xs text-gray-500 mt-0.5 leading-relaxed line-clamp-2">{n.body}</p>}
                  <p class="text-xs text-gray-600 mt-1">Il y a {timeAgo}</p>
                </div>
                {!n.is_read && (
                  <div class="w-1.5 h-1.5 rounded-full bg-neon-green shrink-0 mt-1.5"></div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    ) : (
      /* Fallback: events statiques depuis les données */
      <div class="relative">
        <div class="absolute left-4 top-2 bottom-2 w-px" style="background:rgba(255,255,255,0.07)"></div>
        <div class="space-y-4 pl-9">
          {[
            ...[...blocks]
              .sort((a: any, b: any) => new Date(b.created_at ?? 0).getTime() - new Date(a.created_at ?? 0).getTime())
              .slice(0, 2)
              .map((b: any) => ({
                icon: '🔗', color: '#00ff9d',
                text: `Bloc <strong>${escHtml(b.title || b.type)}</strong> ajouté`,
                time: b.created_at ? new Date(b.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }) : '',
              })),
            ...(analytics.summary.totalViews > 0 ? [{
              icon: '👁️', color: '#38bdf8',
              text: `<strong>${analytics.summary.totalViews.toLocaleString('fr-FR')} vues</strong> sur 7 jours`,
              time: 'cette semaine',
            }] : []),
            { icon: '✦', color: '#bf00ff', text: 'Profil BioForge créé', time: profile?.created_at ? new Date((profile as any).created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }) : '' },
          ].filter(e => e.time).map(e => (
            <div class="relative">
              <div class="absolute -left-5 top-0.5 w-7 h-7 rounded-lg flex items-center justify-center text-sm"
                style={`background:${e.color}18;border:1px solid ${e.color}25`}>
                {e.icon}
              </div>
              <p class="text-xs text-gray-300 leading-relaxed" set:html={e.text}></p>
              <p class="text-xs text-gray-600 mt-0.5">{e.time}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</div>
 

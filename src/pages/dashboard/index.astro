            {f}
          </div>
        ))}
      </div>
      <a href="/pricing" class="block w-full py-3 bg-neon-green text-black font-bold rounded-xl hover:bg-neon-green/90 active:scale-[0.98] transition-all text-sm mb-3">
        Upgrade Plan →
      </a>
      <button id="paywall-close" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">Maybe later</button>
    </div>
  </div>

</DashboardLayout>

<style>
  .stat-card { transition: transform 0.2s ease; }
  .stat-card:hover { transform: translateY(-2px); }
  .period-btn.active { background: rgba(255,255,255,0.08); color: white; }
  #paywall-modal.open { display: flex; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
  const bridge = document.getElementById('server-data');
  const { chartLabels, chartViews, chartClicks, isPaid } =
    JSON.parse(bridge?.dataset.bridge ?? '{}');

  // ==================== SPARKLINES ====================
  function drawSparkline(svgEl, values, color) {
    if (!svgEl || !values?.length) return;
    const W = 80, H = 24, pad = 2;
    const max = Math.max(...values, 1);
    const min = Math.min(...values, 0);
    const range = max - min || 1;
    const pts = values.map((v, i) => {
      const x = pad + (i / (values.length - 1)) * (W - pad * 2);
      const y = H - pad - ((v - min) / range) * (H - pad * 2);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    });
    const first = pts[0], last = pts[pts.length - 1];
    const area  = `${first.split(',')[0]},${H} ${pts.join(' ')} ${last.split(',')[0]},${H}`;
    const gid   = color.replace('#', 'sg');
    svgEl.innerHTML = `
      <defs>
        <linearGradient id="${gid}" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${color}" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <polygon points="${area}" fill="url(#${gid})"/>
      <polyline points="${pts.join(' ')}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    `;
  }

  requestAnimationFrame(() => {
    document.querySelectorAll('svg[data-values]').forEach(svg => {
      drawSparkline(svg, JSON.parse(svg.dataset.values ?? '[]'), svg.dataset.color ?? '#fff');
    });
  });

  // ==================== CHART ====================
  let chartInstance = null;

  function buildChart(labels, views, clicks) {
    const ctx = document.getElementById('growth-chart');
    if (!ctx || typeof Chart === 'undefined') return;
    chartInstance?.destroy();
    chartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          { label: 'Views',  data: views,  borderColor: '#00ff9d', backgroundColor: 'rgba(0,255,157,0.08)',  tension: 0.4, fill: true, borderWidth: 2, pointRadius: 3, pointHoverRadius: 6, pointBackgroundColor: '#00ff9d' },
          { label: 'Clicks', data: clicks, borderColor: '#bf00ff', backgroundColor: 'rgba(191,0,255,0.08)', tension: 0.4, fill: true, borderWidth: 2, pointRadius: 3, pointHoverRadius: 6, pointBackgroundColor: '#bf00ff' },
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { labels: { color: '#6b7280', font: { size: 11 }, boxWidth: 10, usePointStyle: true } },
          tooltip: {
            backgroundColor: '#111', borderColor: 'rgba(255,255,255,0.1)', borderWidth: 1,
            titleColor: '#fff', bodyColor: '#9ca3af', padding: 10,
            callbacks: { label: (c) => ` ${c.dataset.label}: ${c.parsed.y.toLocaleString('fr-FR')}` }
          }
        },
        scales: {
          y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#4b5563', font: { size: 10 }, maxTicksLimit: 5 }, border: { display: false } },
          x: { grid: { display: false }, ticks: { color: '#4b5563', font: { size: 10 }, maxTicksLimit: 7 }, border: { display: false } },
        }
      }
    });
  }

  // FIX: wait for Chart.js CDN to finish loading before calling buildChart
  function initChart() {
    const chartCanvas = document.getElementById('growth-chart');
    if (!chartCanvas || !chartLabels?.length) return;
    if (typeof Chart === 'undefined') {
      // CDN not ready yet — retry after a tick
      setTimeout(initChart, 100);
      return;
    }
    const obs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) { buildChart(chartLabels, chartViews, chartClicks); obs.disconnect(); }
    }, { threshold: 0.1 });
    obs.observe(chartCanvas);
  }

  // Try immediately, then also on window load as fallback
  initChart();
  window.addEventListener('load', initChart, { once: true });

  // ==================== PERIOD TABS ====================
  document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const days = parseInt(btn.dataset.days);
      const free = btn.dataset.free === 'true';
      if (!free && !isPaid) { document.getElementById('paywall-modal')?.classList.add('open'); return; }
      document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (days === 7) { buildChart(chartLabels, chartViews, chartClicks); return; }
      fetch(`/api/analytics/summary?days=${days}`)
        .then(r => r.ok ? r.json() : Promise.reject(r.status))
        .then(data => {
          const labels = (data.profileStats ?? []).map(s => new Date(s.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }));
          const views  = (data.profileStats ?? []).map(s => s.views ?? 0);
          const cmap   = new Map();
          (data.blockStats ?? []).forEach(bs => cmap.set(bs.date, (cmap.get(bs.date) ?? 0) + (bs.clicks ?? 0)));
          buildChart(labels, views, (data.profileStats ?? []).map(s => cmap.get(s.date) ?? 0));
        })
        .catch(() => {});
    });
  });
  document.querySelector('.period-btn[data-days="7"]')?.classList.add('active');

  // ==================== PAYWALL ====================
  const modal = document.getElementById('paywall-modal');
  document.getElementById('paywall-backdrop')?.addEventListener('click', () => modal?.classList.remove('open'));
  document.getElementById('paywall-close')?.addEventListener('click',    () => modal?.classList.remove('open'));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') modal?.classList.remove('open'); });

  // ==================== ONBOARDING ====================
  const ONBOARDING_KEY  = 'onboarding_dismissed_v1';
  const onboardingCard  = document.getElementById('onboarding-card');
  if (localStorage.getItem(ONBOARDING_KEY) === '1') onboardingCard?.remove();
  document.getElementById('dismiss-onboarding')?.addEventListener('click', () => {
    onboardingCard?.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
    setTimeout(() => onboardingCard?.remove(), 300);
    localStorage.setItem(ONBOARDING_KEY, '1');
  });
</script>
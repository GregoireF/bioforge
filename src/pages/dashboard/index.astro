                    <p class="text-xs text-gray-600 mt-0.5 flex items-center gap-1">
                      <span class={`inline-block w-1.5 h-1.5 rounded-full ${block.active ? 'bg-neon-green' : 'bg-gray-600'}`}></span>
                      {block.type} · {block.active ? 'Active' : 'Inactive'}

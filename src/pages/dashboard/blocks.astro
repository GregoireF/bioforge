  const FI = 'field-input'; // class shorthand
  const DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];

  function fi(extra = '') { return `class="field-input${extra ? ' '+extra : ''}"` }
  function fgroup(label: string, required: boolean, opt: boolean, content: string, hint = '') {
    return `<div class="field-group">
      <label class="field-label">${label}${required ? ' <span class="field-required">*</span>' : ''}${opt ? ' <span class="field-opt">optional</span>' : ''}</label>
      ${content}
      ${hint ? `<p class="field-hint">${hint}</p>` : ''}
    </div>`;
  }

  function normalizeSchedule(raw: any[]): {day: string; slots: string[]}[] {
    return raw.map((s: any) => ({
      day:   s.day,
      slots: Array.isArray(s.slots) && s.slots.length ? s.slots : [s.time ?? '20:00'],
    }));
  }

  function buildScheduleWidget(existing: any[]) {
    const normalized = normalizeSchedule(existing);
    return `<div id="schedule-rows" style="display:flex;flex-direction:column;gap:10px">${DAYS.map(day => {
      const found  = normalized.find(s => s.day === day);
      const active = !!found;
      const slots  = found?.slots ?? ['20:00'];
      return `<div class="sch-day-block" data-day="${day}">
        <div style="display:flex;align-items:flex-start;gap:12px">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;width:105px;flex-shrink:0;margin-top:8px">
            <input type="checkbox" class="sch-day-cb" data-day="${day}" ${active ? 'checked' : ''} style="width:15px;height:15px;accent-color:#00ff9d;border-radius:4px" />
            <span style="font-size:13px;color:rgba(255,255,255,.7)">${day}</span>
          </label>
          <div style="flex:1;display:flex;flex-direction:column;gap:6px;${!active ? 'opacity:.3;pointer-events:none' : ''}" id="sch-slots-${day.toLowerCase()}">
            ${slots.map((t: string, i: number) => `
              <div class="sch-slot-row" style="display:flex;align-items:center;gap:7px" data-day="${day}">
                <input type="time" class="sch-time-input" data-day="${day}" value="${t}" />
                ${slots.length > 1 ? `<button type="button" class="rm-slot icon-btn" data-day="${day}" style="opacity:.5"><svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>` : '<span style="width:30px"></span>'}
              </div>`).join('')}
            <button type="button" class="add-slot" data-day="${day}" style="font-size:11.5px;color:#00ff9d;background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;gap:5px;${!active ? 'display:none' : ''}">
              <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
              Add slot
            </button>
          </div>
        </div>
      </div>`;
    }).join('')}</div>`;
  }


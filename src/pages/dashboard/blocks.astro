  async function handleKitClick(kitId: string) {
    const kit = STREAMER_KITS.find(k => k.id === kitId);
    if (!kit) return;
    if (!confirm(`Add the "${kit.label}" kit? This will create ${kit.blocks.length} blocks.`)) return;
    let added = 0;
    for (const bd of kit.blocks) {
      if (blockLimit !== -1 && (blockCount + added) >= blockLimit) { toast.error(`Limit reached after ${added} blocks.`); break; }
      try {
        const data = await apiCall('/api/blocks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ type: bd.type, title: bd.title, config: bd.config }) });
        blocks.push({ id: data.id, ...bd, active: true, created_at: new Date().toISOString(), clicks: 0, is_pinned: false });
        added++;
      } catch {}
    }
    renderBlocks();
    toast.success(`${added} blocks added!`);
  }


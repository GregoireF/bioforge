---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PlanLimitIndicator from '@/components/features/PlanLimitIndicator.astro';
import { getBlocks } from '@/lib/supabase/queries';
import { getAnalyticsSummary } from '@/lib/db/queries.server';
import type { Block } from '@/lib/db';
 
// ── Auth depuis locals — le middleware a déjà validé ─────────────────────────
const user    = Astro.locals.user
const supabase = Astro.locals.supabase
 
if (!user) return Astro.redirect('/signin?error=auth_failed')
 
// ── Profil depuis supabase (locals.supabase est le client SSR authentifié) ───
const { data: profileData } = await supabase
  .from('profiles')
  .select('id, username, plan')
  .eq('id', user.id)
  .single()
 
const profile    = profileData
const planLimits = profile?.plan
  ? await supabase.from('plan_limits').select('*').eq('plan', profile.plan).single().then(r => r.data)
  : null
 
function escapeHtml(val: unknown): string {
  return String(val ?? '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}
function safeNum(val: unknown): number {
  const n = Number(val); return isFinite(n) ? n : 0;
}
 
const safeProfileId = profile?.id?.trim() ?? '';
 
const [blocksResult, analyticsResult] = await Promise.all([
  safeProfileId ? getBlocks(supabase, safeProfileId) : Promise.resolve({ success: false, data: [] }),
  safeProfileId ? getAnalyticsSummary(supabase, safeProfileId, 7) : Promise.resolve({ success: false, data: null }),
]);
 
const rawBlocks = (blocksResult.success ? (blocksResult.value ?? blocksResult.data) : []) as Block[];
const blocks    = rawBlocks.filter(b => !b.deleted_at);
 
const analyticsData = analyticsResult.success ? (analyticsResult.value ?? analyticsResult.data) : null;
const topBlocks     = analyticsData?.topBlocks ?? [];
const totalViews    = analyticsData?.totalViews ?? analyticsData?.summary?.totalViews ?? 0;
 
const clicksMap = new Map<string, number>();
topBlocks.forEach((b: { id: string; clicks: number }) => clicksMap.set(b.id, safeNum(b.clicks)));
 
const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
 
const safeBridgeBlocks = blocks
  .filter(b => UUID_RE.test(String(b.id ?? '')))
  .map(b => ({
    id:         String(b.id),
    type:       escapeHtml(b.type),
    title:      escapeHtml(b.title),
    active:     Boolean(b.active),
    position:   safeNum(b.position),
    created_at: escapeHtml(b.created_at),
    clicks:     clicksMap.get(b.id) ?? 0,
    is_pinned:  Boolean((b as Record<string, unknown>).is_pinned ?? (b.config as Record<string, unknown>)?.is_pinned),
    config: {
      url:               escapeHtml((b.config as Record<string, unknown>)?.url),
      icon_url:          escapeHtml((b.config as Record<string, unknown>)?.icon_url),
      show_from:         escapeHtml((b.config as Record<string, unknown>)?.show_from),
      show_until:        escapeHtml((b.config as Record<string, unknown>)?.show_until),
      target_date:       escapeHtml((b.config as Record<string, unknown>)?.target_date),
      goal_amount:       safeNum((b.config as Record<string, unknown>)?.goal_amount),
      current_amount:    safeNum((b.config as Record<string, unknown>)?.current_amount),
      donation_platform: escapeHtml((b.config as Record<string, unknown>)?.donation_platform),
      height:            safeNum((b.config as Record<string, unknown>)?.height),
      schedule:          Array.isArray((b.config as Record<string, unknown>)?.schedule) ? (b.config as Record<string, unknown>).schedule : [],
      links: Array.isArray((b.config as Record<string, unknown>)?.links)
        ? ((b.config as Record<string, unknown>).links as {url: string}[]).map(l => ({ url: escapeHtml(l?.url) }))
        : [],
      content:    escapeHtml((b.config as Record<string, unknown>)?.content),
      align:      ['left','center','right'].includes((b.config as Record<string, unknown>)?.align as string) ? (b.config as Record<string, unknown>).align : 'center',
      text_size:  ['sm','md','lg'].includes((b.config as Record<string, unknown>)?.text_size as string) ? (b.config as Record<string, unknown>).text_size : 'md',
      badge:        escapeHtml((b.config as Record<string, unknown>)?.badge),
      badge_preset: escapeHtml((b.config as Record<string, unknown>)?.badge_preset),
      message:      escapeHtml((b.config as Record<string, unknown>)?.message),
      url_label:    escapeHtml((b.config as Record<string, unknown>)?.url_label),
      image_url: escapeHtml((b.config as Record<string, unknown>)?.image_url),
      price:     escapeHtml((b.config as Record<string, unknown>)?.price),
      currency:  escapeHtml((b.config as Record<string, unknown>)?.currency),
      cta_label: escapeHtml((b.config as Record<string, unknown>)?.cta_label),
      question:       escapeHtml((b.config as Record<string, unknown>)?.question),
      options:        Array.isArray((b.config as Record<string, unknown>)?.options) ? ((b.config as Record<string, unknown>).options as {text: string; votes: number}[]).map(o => ({ text: escapeHtml(o?.text), votes: safeNum(o?.votes) })) : [],
      allow_multiple: Boolean((b.config as Record<string, unknown>)?.allow_multiple),
      channel:         escapeHtml((b.config as Record<string, unknown>)?.channel),
      show_chat:       Boolean((b.config as Record<string, unknown>)?.show_chat),
      offline_message: escapeHtml((b.config as Record<string, unknown>)?.offline_message),
      provider:        escapeHtml((b.config as Record<string, unknown>)?.provider),
      action_url:      escapeHtml((b.config as Record<string, unknown>)?.action_url),
      nl_placeholder:  escapeHtml((b.config as Record<string, unknown>)?.nl_placeholder),
      nl_cta:          escapeHtml((b.config as Record<string, unknown>)?.nl_cta),
      nl_success:      escapeHtml((b.config as Record<string, unknown>)?.nl_success),
      first_name: escapeHtml((b.config as Record<string, unknown>)?.first_name),
      last_name:  escapeHtml((b.config as Record<string, unknown>)?.last_name),
      email:      escapeHtml((b.config as Record<string, unknown>)?.email),
      phone:      escapeHtml((b.config as Record<string, unknown>)?.phone),
      website:    escapeHtml((b.config as Record<string, unknown>)?.website),
      company:    escapeHtml((b.config as Record<string, unknown>)?.company),
      role:       escapeHtml((b.config as Record<string, unknown>)?.role),
      items: Array.isArray((b.config as Record<string, unknown>)?.items)
        ? ((b.config as Record<string, unknown>).items as {title: string; price: string; image_url: string; url: string; currency: string}[]).slice(0,3).map(it => ({
            title:     escapeHtml(it?.title),
            price:     escapeHtml(it?.price),
            image_url: escapeHtml(it?.image_url),
            url:       escapeHtml(it?.url),
            currency:  escapeHtml(it?.currency),
          }))
        : [],
    },
  }));
 
const blockCount  = blocks.length;
const blockLimit  = planLimits?.max_blocks_total ?? 15;
const canAddBlock = blockLimit === -1 || blockCount < blockLimit;
const isNearLimit = blockLimit !== -1 && blockCount >= blockLimit * 0.8 && blockCount < blockLimit;
const blocksError = blocksResult.success ? null : 'Failed to load blocks';
 
const bridge = JSON.stringify({
  blocks: safeBridgeBlocks, blockCount, blockLimit, canAddBlock,
  profileId: escapeHtml(safeProfileId),
  username:  escapeHtml(profile?.username ?? ''),
  totalViews,
});
 
const BLOCK_TYPES = [
  { type: 'link',      emoji: '🔗', label: 'Link',        desc: 'Clickable link button'   },
  { type: 'social',    emoji: '👥', label: 'Social',      desc: 'Social icon grid'         },
  { type: 'heading',   emoji: '📝', label: 'Heading',     desc: 'Section title'            },
  { type: 'spacer',    emoji: '—',  label: 'Spacer',      desc: 'Blank space'              },
  { type: 'image',     emoji: '🖼️', label: 'Image',       desc: 'Display an image'         },
  { type: 'video',     emoji: '🎥', label: 'Video',       desc: 'Embed YouTube / Vimeo'    },
  { type: 'countdown',   emoji: '⏱️', label: 'Countdown',    desc: 'Next stream timer'        },
  { type: 'schedule',    emoji: '📅', label: 'Schedule',     desc: 'Weekly stream schedule'   },
  { type: 'donation',    emoji: '💸', label: 'Donation',     desc: 'Ko-fi / Patreon CTA'      },
  { type: 'embed',       emoji: '🎵', label: 'Music Embed',  desc: 'Spotify / SoundCloud'     },
  { type: 'text',        emoji: '📄', label: 'Text',         desc: 'Paragraph / description'  },
  { type: 'banner',      emoji: '📢', label: 'Banner',       desc: 'LIVE / NEW announcement'  },
  { type: 'product',     emoji: '🛍️', label: 'Product',      desc: 'Product card with price'  },
  { type: 'poll',        emoji: '📊', label: 'Poll',         desc: 'Interactive vote options' },
  { type: 'twitch_live', emoji: '🟣', label: 'Twitch Live',  desc: 'Channel embed + badge'    },
  { type: 'newsletter',  emoji: '📧', label: 'Newsletter',   desc: 'Email capture form'       },
  { type: 'vcard',       emoji: '👤', label: 'vCard',        desc: 'Download my contact'      },
  { type: 'merch_grid',  emoji: '🛒', label: 'Merch Grid',   desc: 'Grid of products / items' },
];
---

<DashboardLayout title="Blocks">

  <div id="server-data" class="hidden" data-bridge={bridge}></div>

  <!-- ===== HEADER ===== -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-widest mb-1">Content</p>
      <h2 class="text-xl font-semibold text-white tracking-tight">Blocks</h2>
      <p class="text-sm text-gray-400 mt-0.5">Build and manage your profile page</p>
    </div>
    <div class="flex items-center gap-2">
      <div id="bulk-bar" class="hidden items-center gap-2">
        <span id="bulk-count" class="text-xs text-gray-400 font-medium px-2">0 selected</span>
        <button id="bulk-toggle-btn"
          class="px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-300 hover:text-white hover:border-white/25 transition-all">
          Toggle
        </button>
        <button id="bulk-delete-btn"
          class="flex items-center gap-1.5 px-3 py-2 glass border border-red-500/20 rounded-xl text-xs text-red-400 hover:border-red-500/40 hover:bg-red-500/5 transition-all">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        </button>
        <button id="bulk-cancel-btn" class="px-3 py-2 text-xs text-gray-500 hover:text-white transition-colors">Cancel</button>
      </div>
      <button id="preview-toggle-btn"
        class="hidden lg:flex items-center gap-2 px-4 py-2.5 glass border border-white/10 rounded-xl text-sm font-medium text-gray-400 hover:text-white hover:border-white/25 transition-all"
        title="Aperçu du profil">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        </svg>
        Aperçu
      </button>
      <button id="add-block-btn"
        class={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all active:scale-[0.98]
          ${canAddBlock ? 'bg-neon-green text-black hover:bg-neon-green/90' : 'glass border border-white/10 text-gray-400 cursor-not-allowed opacity-60'}`}
        title="N">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        {canAddBlock ? 'Add Block' : 'Upgrade to Add More'}
      </button>
    </div>
  </div>

  <div class="mb-5">
    <PlanLimitIndicator current={blockCount} limit={blockLimit} feature="Blocks" showUpgrade={true} />
  </div>

  {isNearLimit && (
    <div class="mb-5 flex items-center gap-3 p-4 glass border border-yellow-400/20 rounded-xl">
      <svg class="w-4 h-4 text-yellow-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <p class="text-sm text-yellow-300">Using {blockCount} of {blockLimit} blocks.
        <a href="/pricing" class="underline ml-1">Upgrade for more →</a>
      </p>
    </div>
  )}
  {!canAddBlock && blockLimit !== -1 && (
    <div class="mb-5 flex items-center gap-3 p-4 glass border border-red-500/20 rounded-xl">
      <p class="text-sm text-red-300">Block limit reached ({blockLimit}).
        <a href="/pricing" class="underline ml-1">Upgrade →</a>
      </p>
    </div>
  )}
  {blocksError && (
    <div class="mb-5 flex items-center gap-3 p-4 glass border border-red-500/20 rounded-xl">
      <p class="text-sm text-red-300">{blocksError}</p>
      <button onclick="location.reload()" class="ml-auto text-xs text-red-400 underline">Retry</button>
    </div>
  )}

  <!-- ===== QUICK-ADD URL BAR ===== -->
  <div class="mb-5">
    <div id="quick-add-bar"
      class="flex items-center gap-3 px-4 py-3 glass border border-white/10 rounded-xl focus-within:border-neon-green/40 transition-colors">
      <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      <input type="url" id="quick-add-input" placeholder="Paste a URL to instantly add a link…"
        class="flex-1 bg-transparent text-white text-sm placeholder-gray-600 focus:outline-none min-w-0" />
      <div id="quick-detect-zone" class="hidden items-center gap-2 shrink-0">
        <span id="quick-plat-icon" class="text-lg leading-none"></span>
        <span id="quick-plat-label" class="text-xs font-semibold text-neon-green whitespace-nowrap"></span>
        <button id="quick-add-confirm"
          class="px-3 py-1.5 bg-neon-green text-black text-xs font-bold rounded-lg hover:bg-neon-green/90 active:scale-95 transition-all">
          Add
        </button>
        <button id="quick-add-cancel" class="text-gray-600 hover:text-gray-300 transition-colors p-0.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- ===== STREAMER KIT ===== -->
  <div class="mb-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <span class="text-base">🎮</span>
        <p class="text-sm font-semibold text-white">Streamer Kit</p>
        <span class="text-xs px-2 py-0.5 rounded-full bg-neon-green/15 text-neon-green border border-neon-green/25 font-medium">Quick Start</span>
      </div>
      <button id="kit-toggle-btn" class="text-xs text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1">
        <span id="kit-toggle-label">Afficher</span>
        <svg id="kit-chevron" class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    </div>
    <div id="kit-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3"></div>
  </div>

  <!-- ===== SEARCH + FILTER ===== -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <div class="relative flex-1">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
      </svg>
      <input type="text" id="search-input" placeholder="Search blocks…"
        class="w-full pl-9 pr-4 py-2.5 glass border border-white/10 rounded-xl text-white text-sm placeholder-gray-600 focus:border-neon-green/40 focus:outline-none transition-colors" />
    </div>
    <div class="flex items-center gap-2 overflow-x-auto pb-0.5 scrollbar-none">
      <button class="filter-btn active shrink-0 px-3 py-2 rounded-xl text-xs font-medium transition-all" data-filter="all">All</button>
      {BLOCK_TYPES.map(t => (
        <button class="filter-btn shrink-0 px-3 py-2 rounded-xl text-xs font-medium transition-all" data-filter={t.type}>
          {t.emoji} {t.label}
        </button>
      ))}
    </div>
  </div>

  <!-- ===== BLOCKS LIST ===== -->
  <div id="blocks-container">
    {blocks.length === 0 ? (
      <div id="empty-state" class="flex flex-col items-center justify-center py-20 text-center">
        <div class="w-20 h-20 rounded-2xl bg-neon-green/10 border border-neon-green/20 flex items-center justify-center mx-auto mb-5">
          <svg class="w-9 h-9 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">No blocks yet</h3>
        <p class="text-sm text-gray-400 mb-6 max-w-xs">Paste a URL above, use a Streamer Kit template, or click Add Block to get started.</p>
        {canAddBlock && (
          <button id="empty-add-btn"
            class="flex items-center gap-2 px-6 py-3 bg-neon-green text-black text-sm font-semibold rounded-xl hover:bg-neon-green/90 active:scale-[0.98] transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Add Your First Block
          </button>
        )}
        <p class="text-xs text-gray-600 mt-4">Tip: <kbd class="px-1.5 py-0.5 glass rounded text-gray-400 font-mono text-xs">N</kbd> ajouter · <kbd class="px-1.5 py-0.5 glass rounded text-gray-400 font-mono text-xs">P</kbd> aperçu</p>
      </div>
    ) : (
      <div class="space-y-2" id="sortable-blocks"></div>
    )}
    <div id="no-results" class="hidden flex-col items-center justify-center py-16 text-center">
      <p class="text-sm text-gray-500 mb-2">No blocks match your search</p>
      <button id="clear-search-btn" class="text-xs text-neon-green hover:underline">Clear filters</button>
    </div>
  </div>

    <div id="no-results" class="hidden flex-col items-center justify-center py-16 text-center">
      <p class="text-sm text-gray-500 mb-2">No blocks match your search</p>
      <button id="clear-search-btn" class="text-xs text-neon-green hover:underline">Clear filters</button>
    </div>
  </div>

  <!-- ===== ARCHIVED BLOCKS SECTION ===== -->
  <div id="archive-section" class="hidden mt-8">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8m-9 4v4m4-4v4"/>
        </svg>
        <p class="text-sm font-semibold text-gray-400">Corbeille</p>
        <span id="archive-count" class="text-xs px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-gray-500 font-medium"></span>
      </div>
      <button id="archive-clear-btn" class="text-xs text-red-400 hover:text-red-300 transition-colors">Vider la corbeille</button>
    </div>
    <div id="archive-list" class="space-y-2"></div>
  </div>

  <!-- ===== PREVIEW PANEL (desktop, fixed right) ===== -->
  <div id="preview-panel"
    class="hidden lg:hidden fixed top-0 right-0 h-screen w-[340px] z-40 border-l border-white/8 flex flex-col"
    style="background: #09090b;">
    <div class="flex items-center justify-between px-4 py-3 border-b border-white/8 shrink-0">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-neon-green animate-pulse"></span>
        <span class="text-xs font-semibold text-white">Aperçu live</span>
      </div>
      <div class="flex items-center gap-2">
        <button id="preview-refresh-btn"
          class="p-1.5 rounded-lg text-gray-500 hover:text-white hover:bg-white/8 transition-all"
          title="Actualiser">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </button>
        <button id="preview-open-btn"
          class="p-1.5 rounded-lg text-gray-500 hover:text-white hover:bg-white/8 transition-all"
          title="Ouvrir dans un onglet">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </button>
        <button id="preview-close-btn"
          class="p-1.5 rounded-lg text-gray-500 hover:text-white hover:bg-white/8 transition-all">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
    <!-- Phone frame -->
    <div class="flex-1 flex items-start justify-center pt-6 pb-4 overflow-hidden">
      <div class="relative" style="width: 220px;">
        <!-- Phone outline -->
        <div class="absolute inset-0 rounded-[2rem] border-2 border-white/15 pointer-events-none z-10"
          style="box-shadow: 0 0 0 6px rgba(255,255,255,0.03); margin: -4px;"></div>
        <!-- Notch -->
        <div class="absolute top-2 left-1/2 -translate-x-1/2 w-16 h-4 rounded-full bg-black z-20"></div>
        <iframe id="preview-iframe"
          src=""
          class="w-full rounded-[2rem] border-0 overflow-hidden"
          style="height: 440px; pointer-events: none;"
          loading="lazy"
          sandbox="allow-scripts allow-same-origin"></iframe>
      </div>
    </div>
    <div class="shrink-0 px-4 py-2 border-t border-white/5 text-center">
      <p id="preview-url-label" class="text-xs text-gray-600 font-mono truncate"></p>
    </div>
  </div>
  <div id="type-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div id="type-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative glass border border-white/10 rounded-2xl w-full max-w-2xl shadow-2xl max-h-[88vh] overflow-hidden flex flex-col">

      <!-- Modal header -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-white/8 shrink-0">
        <h3 class="text-white font-semibold text-base">Ajouter un block</h3>
        <button id="type-close" class="text-gray-500 hover:text-white transition-colors p-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Search bar -->
      <div class="px-5 py-3 border-b border-white/8 shrink-0">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
          </svg>
          <input type="text" id="type-search" placeholder="Colle ou recherche un lien, une plateforme…"
            class="w-full pl-9 pr-4 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white text-sm placeholder-gray-600 focus:border-neon-green/40 focus:outline-none transition-colors" />
        </div>
      </div>

      <!-- Body: sidebar + content -->
      <div class="flex flex-1 min-h-0 overflow-hidden">
        <!-- Left sidebar -->
        <nav class="w-40 shrink-0 border-r border-white/8 py-2 overflow-y-auto scrollbar-none bg-black/20">
          <!-- populated by JS -->
          <div id="type-nav"></div>
        </nav>

        <!-- Right panel -->
        <div class="flex-1 overflow-y-auto scrollbar-none p-4" id="type-panel">
          <!-- populated by JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- ===== EDIT MODAL ===== -->
  <div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div id="edit-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative glass border border-white/10 rounded-2xl p-6 w-full max-w-md shadow-2xl max-h-[92vh] overflow-y-auto scrollbar-none">
      <div class="flex items-center justify-between mb-5">
        <h3 class="text-white font-semibold" id="modal-title">Add Block</h3>
        <button id="edit-close" class="text-gray-500 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="block-form" class="space-y-4" novalidate>
        <input type="hidden" id="block-id" />
        <input type="hidden" id="block-type" />
        <div id="form-fields" class="space-y-4"></div>

        <!-- Scheduled visibility (all types except spacer) -->
        <div id="schedule-visibility-section" class="hidden">
          <div class="border-t border-white/10 pt-4">
            <button type="button" id="visibility-toggle"
              class="w-full flex items-center justify-between text-sm text-gray-400 hover:text-white transition-colors">
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Visibilité planifiée
                <span class="text-xs px-1.5 py-0.5 rounded bg-white/5 text-gray-500">optionnel</span>
              </span>
              <svg id="vis-chevron" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id="visibility-panel" class="hidden mt-3 space-y-3">
              <p class="text-xs text-gray-600">Laisser vide pour toujours afficher.</p>
              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1.5">
                  <label class="text-xs font-medium text-gray-400">Afficher à partir de</label>
                  <input type="datetime-local" id="field-show-from"
                    class="w-full px-3 py-2 glass border border-white/10 rounded-xl text-white text-sm focus:border-neon-green/50 focus:outline-none transition-colors" />
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-medium text-gray-400">Masquer après</label>
                  <input type="datetime-local" id="field-show-until"
                    class="w-full px-3 py-2 glass border border-white/10 rounded-xl text-white text-sm focus:border-neon-green/50 focus:outline-none transition-colors" />
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex gap-3 pt-1">
          <button type="submit" id="submit-btn"
            class="flex-1 flex items-center justify-center gap-2 py-2.5 bg-neon-green text-black text-sm font-semibold rounded-xl hover:bg-neon-green/90 active:scale-[0.98] transition-all disabled:opacity-50 disabled:pointer-events-none">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span id="submit-text">Save Block</span>
          </button>
          <button type="button" id="cancel-btn"
            class="px-5 py-2.5 glass border border-white/10 rounded-xl text-sm text-gray-300 hover:text-white transition-all">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

</DashboardLayout>


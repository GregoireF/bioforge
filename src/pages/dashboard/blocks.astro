    const fields = document.getElementById('form-fields')!;
    fields.innerHTML = fieldHtml[type] ?? `<div style="padding:16px 0;text-align:center;font-size:13px;color:rgba(255,255,255,.3)">Type "${type}" not supported.</div>`;

    const visSec = document.getElementById('schedule-visibility-section');
    if (visSec) visSec.style.display = type === 'spacer' ? 'none' : '';
    const showFrom  = document.getElementById('field-show-from')  as HTMLInputElement | null;
    const showUntil = document.getElementById('field-show-until') as HTMLInputElement | null;
    if (showFrom  && block?.config?.show_from)  showFrom.value  = block.config.show_from.slice(0,16);
    if (showUntil && block?.config?.show_until) showUntil.value = block.config.show_until.slice(0,16);

    openModal('edit-modal');
    if (type === 'link') setTimeout(attachOgFetch, 50);
    setTimeout(() => (fields.querySelector('input:not([type="checkbox"]):not([type="time"]):not([type="hidden"]),textarea') as HTMLElement|null)?.focus(), 100);

    // Donation platform buttons
    if (type === 'donation') {
      document.querySelectorAll('.don-plat-btn, #don-platform-grid .plat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.plat!;
          (document.getElementById('field-donation-platform') as HTMLInputElement).value = id;
          document.querySelectorAll('#don-platform-grid .plat-btn').forEach(b => b.classList.toggle('active', b===btn));
        });
      });
    }

    // Schedule
    if (type === 'schedule') {
      function refreshSlotRemoveBtns(day: string) {
        const cont = document.getElementById(`sch-slots-${day.toLowerCase()}`);
        if (!cont) return;
        const rows = cont.querySelectorAll('.sch-slot-row');
        rows.forEach(row => {
          const btn = row.querySelector('.rm-slot') as HTMLElement|null;
          if (btn) btn.style.opacity = rows.length > 1 ? '.5' : '0';
        });
      }
      document.querySelectorAll('.sch-day-cb').forEach((cb: any) => {
        cb.addEventListener('change', () => {
          const day = cb.dataset.day as string;
          const cont = document.getElementById(`sch-slots-${day.toLowerCase()}`);
          const addBtn = cont?.querySelector('.add-slot') as HTMLElement|null;
          if (!cont) return;
          const off = !cb.checked;
          cont.style.opacity = off ? '.3' : '1';
          cont.style.pointerEvents = off ? 'none' : '';
          if (addBtn) addBtn.style.display = off ? 'none' : '';
        });
      });
      document.querySelectorAll('.add-slot').forEach(btn => {
        btn.addEventListener('click', () => {
          const day = (btn as HTMLElement).dataset.day!;
          const cont = document.getElementById(`sch-slots-${day.toLowerCase()}`);
          if (!cont) return;
          const row = document.createElement('div');
          row.className = 'sch-slot-row'; row.style.cssText = 'display:flex;align-items:center;gap:7px'; row.dataset.day = day;
          row.innerHTML = `<input type="time" class="sch-time-input" data-day="${day}" value="20:00" /><button type="button" class="rm-slot icon-btn" data-day="${day}" style="opacity:.5"><svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>`;
          row.querySelector('.rm-slot')?.addEventListener('click', () => { row.remove(); refreshSlotRemoveBtns(day); });
          cont.insertBefore(row, btn);
          refreshSlotRemoveBtns(day);
          (row.querySelector('input') as HTMLElement)?.focus();
        });
      });
      document.querySelectorAll('.rm-slot').forEach(btn => {
        btn.addEventListener('click', () => {
          const day = (btn as HTMLElement).dataset.day!;
          btn.closest('.sch-slot-row')?.remove();
          refreshSlotRemoveBtns(day);
        });
      });
      DAYS.forEach((day: string) => refreshSlotRemoveBtns(day));
    }

    // Visibility toggle
    document.getElementById('visibility-toggle')?.addEventListener('click', () => {
      const panel = document.getElementById('visibility-panel');
      const chev  = document.getElementById('vis-chevron');
      if (!panel) return;
      const hidden = panel.style.display === 'none' || panel.style.display === '';
      panel.style.display = hidden ? '' : 'none';
      if (chev) chev.style.transform = hidden ? 'rotate(180deg)' : '';
    });

    // Icon preview
    const iconInput = document.getElementById('field-icon-url') as HTMLInputElement|null;
    const iconWrap  = document.getElementById('icon-preview-wrap');
    if (iconInput && iconWrap) {
      const emptyIcon = `<svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`;
      iconInput.addEventListener('input', () => {
        const u = iconInput.value.trim();
        iconWrap.innerHTML = u ? `<img src="${u}" style="width:100%;height:100%;object-fit:cover" onerror="this.parentElement.innerHTML='${emptyIcon.replace(/'/g,"\\'")}'"/>` : emptyIcon;
      });
      const urlField = document.getElementById('field-url') as HTMLInputElement|null;
      urlField?.addEventListener('blur', () => {
        if (iconInput.value) return;
        const plat = detectPlatform(urlField.value.trim());
        if (plat?.defaultIcon) { iconInput.value = plat.defaultIcon; iconWrap.innerHTML = `<img src="${plat.defaultIcon}" style="width:100%;height:100%;object-fit:cover" />`; }
      });
    }

    // Merch grid
    if (type === 'merch_grid') {
      const SYM: Record<string,string> = { EUR:'€', USD:'$', GBP:'£' };
      document.querySelectorAll('.merch-img').forEach(inp => {
        const pid = (inp as HTMLElement).dataset.previewId;
        if (!pid) return;
        const preview = document.getElementById(pid);
        if (!preview) return;
        inp.addEventListener('input', () => {
          const u = (inp as HTMLInputElement).value.trim();
          preview.innerHTML = u ? `<img src="${u}" style="width:100%;height:100%;object-fit:cover" />` : `<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`;
        });
      });
      document.querySelectorAll('.merch-currency').forEach(sel => {
        sel.addEventListener('change', () => {
          const row = sel.closest('.merch-item');
          const sym = row?.querySelector('.merch-currency-symbol');
          if (sym) sym.textContent = SYM[(sel as HTMLSelectElement).value] ?? '€';
        });
      });
    }

    // Banner presets
    if (type === 'banner') {
      const badgeInput  = document.getElementById('field-banner-badge')  as HTMLInputElement|null;
      const presetInput = document.getElementById('field-banner-preset') as HTMLInputElement|null;
      document.querySelectorAll('.banner-preset-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const p = (btn as HTMLElement).dataset.preset!;
          if (badgeInput) badgeInput.value = p; if (presetInput) presetInput.value = p;
          document.querySelectorAll('.banner-preset-btn').forEach(b => b.classList.toggle('active', b===btn));
        });
      });
    }

    // Newsletter provider
    if (type === 'newsletter') {
      document.querySelectorAll('#nl-provider-grid .plat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const p = (btn as HTMLElement).dataset.prov!;
          (document.getElementById('field-nl-provider') as HTMLInputElement).value = p;
          document.querySelectorAll('#nl-provider-grid .plat-btn').forEach(b => b.classList.toggle('active', b===btn));
        });
      });
    }

    // Poll
    if (type === 'poll') {
      function updatePollRemoveBtns() {
        document.querySelectorAll('.poll-option-row').forEach((row,i) => {
          const btn = row.querySelector('.rm-poll-option') as HTMLElement;
          if (btn) { btn.style.opacity = i<2 ? '0' : '1'; btn.style.pointerEvents = i<2 ? 'none' : ''; }
        });
      }
      function attachPollRemove() {
        document.querySelectorAll('.rm-poll-option').forEach(btn => {
          btn.addEventListener('click', () => {
            btn.closest('.poll-option-row')?.remove();
            document.querySelectorAll('.poll-option-row').forEach((row,i) => {
              const sp = row.querySelector('.poll-num') as HTMLElement;
              if (sp) sp.textContent = `${i+1}.`;
            });
            updatePollRemoveBtns();
          });
        });
      }
      document.getElementById('add-poll-option')?.addEventListener('click', () => {
        const list = document.getElementById('poll-options-list');
        if (!list || list.querySelectorAll('.poll-option-row').length >= 4) return;
        const count = list.querySelectorAll('.poll-option-row').length;
        const row = document.createElement('div');
        row.className = 'poll-option-row';
        row.innerHTML = `<span class="poll-num">${count+1}.</span><input type="text" class="poll-opt-input field-input" value="" maxlength="80" placeholder="Option ${count+1}" style="flex:1" /><input type="hidden" class="poll-opt-votes" value="0" /><button type="button" class="rm-poll-option icon-btn"><svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>`;
        list.appendChild(row);
        updatePollRemoveBtns();
        attachPollRemove();
      });
      attachPollRemove();
      updatePollRemoveBtns();
    }
  }

  document.getElementById('block-form')?.addEventListener('submit', async (e: any) => {
    e.preventDefault();
    if (isSaving) return;
    const type    = (document.getElementById('block-type') as HTMLInputElement).value;
    const blockId = (document.getElementById('block-id')   as HTMLInputElement).value ?? '';
    const submitBtn  = document.getElementById('submit-btn');
    const submitText = document.getElementById('submit-text')!;

    let title: string | null = null;
    let config: any = {};

    const titleEl   = document.getElementById('field-title')    as HTMLInputElement|null;
    const urlEl     = document.getElementById('field-url')      as HTMLInputElement|null;
    const linksEl   = document.getElementById('field-links')    as HTMLTextAreaElement|null;
    const iconUrlEl = document.getElementById('field-icon-url') as HTMLInputElement|null;
    const showFrom  = (document.getElementById('field-show-from')  as HTMLInputElement|null)?.value?.trim() || null;
    const showUntil = (document.getElementById('field-show-until') as HTMLInputElement|null)?.value?.trim() || null;
    const vis = (k: string, v: any) => v ? { [k]: v } : {};

    switch (type) {
      case 'link': {
        title = titleEl?.value?.trim() ?? null; const url = urlEl?.value?.trim() ?? ''; const ico = iconUrlEl?.value?.trim() ?? '';
        if (!title) { toast.error('Title is required'); return; }
        if (!url || !url.startsWith('http')) { toast.error('Valid URL required'); return; }
        config = { url, ...(ico ? { icon_url: ico } : {}), ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'heading': title = titleEl?.value?.trim() ?? null; if (!title) { toast.error('Text is required'); return; } break;
      case 'spacer':  break;
      case 'image': {
        const u = urlEl?.value?.trim() ?? ''; if (!u||!u.startsWith('http')) { toast.error('Valid image URL required'); return; }
        title = titleEl?.value?.trim()||null; config = { url:u, ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'video': {
        const u = urlEl?.value?.trim() ?? ''; if (!u||!u.startsWith('http')) { toast.error('Valid video URL required'); return; }
        title = titleEl?.value?.trim()||null; config = { url:u, ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'social': {
        title = titleEl?.value?.trim()||null;
        const links = (linksEl?.value?.trim()??'').split('\n').map(u=>u.trim()).filter(u=>u.startsWith('http')).map(u=>({url:u}));
        if (!links.length) { toast.error('At least one valid URL required'); return; }
        config = { links, ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'countdown': {
        title = titleEl?.value?.trim()??null; const d = (document.getElementById('field-countdown-date') as HTMLInputElement)?.value;
        if (!title) { toast.error('Label is required'); return; } if (!d) { toast.error('Target date required'); return; }
        config = { target_date:d, label:title }; break;
      }
      case 'schedule': {
        title = titleEl?.value?.trim()||'Stream schedule';
        const scheduleMap = new Map<string,string[]>();
        document.querySelectorAll('.sch-day-cb').forEach((cb: any) => {
          if (!cb.checked) return;
          const day = cb.dataset.day as string;
          const times = Array.from(document.querySelectorAll(`.sch-time-input[data-day="${day}"]`)).map(el=>(el as HTMLInputElement).value).filter(Boolean);
          scheduleMap.set(day, times.length?times:['20:00']);
        });
        if (!scheduleMap.size) { toast.error('Check at least one day'); return; }
        config = { schedule: Array.from(scheduleMap.entries()).map(([day,slots])=>({day,slots})) }; break;
      }
      case 'donation': {
        title = titleEl?.value?.trim()??null; const u = urlEl?.value?.trim()??'';
        const plat = (document.getElementById('field-donation-platform') as HTMLInputElement)?.value||'other';
        const goal = parseFloat((document.getElementById('field-goal') as HTMLInputElement)?.value||'0')||0;
        const cur  = parseFloat((document.getElementById('field-current') as HTMLInputElement)?.value||'0')||0;
        if (!title) { toast.error('Title is required'); return; } if (!u||!u.startsWith('http')) { toast.error('Donation URL is required'); return; }
        config = { url:u, donation_platform:plat, goal_amount:goal, current_amount:cur }; break;
      }
      case 'embed': {
        title = titleEl?.value?.trim()||null; const u = urlEl?.value?.trim()??'';
        const h = parseInt((document.getElementById('field-embed-height') as HTMLInputElement)?.value||'152');
        if (!u||!u.startsWith('http')) { toast.error('Valid URL required'); return; }
        config = { url:u, height:Math.min(500,Math.max(80,h||152)) }; break;
      }
      case 'text': {
        const content = (document.getElementById('field-text-content') as HTMLTextAreaElement)?.value?.trim()??'';
        if (!content) { toast.error('Content is required'); return; }
        title = titleEl?.value?.trim()||null;
        config = { content, align:(document.getElementById('field-text-align') as HTMLSelectElement)?.value||'center', text_size:(document.getElementById('field-text-size') as HTMLSelectElement)?.value||'md', ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'banner': {
        title = titleEl?.value?.trim()??null;
        const badge    = (document.getElementById('field-banner-badge')  as HTMLInputElement)?.value?.trim()||'LIVE';
        const preset   = (document.getElementById('field-banner-preset') as HTMLInputElement)?.value||'LIVE';
        const url      = urlEl?.value?.trim()||null;
        const urlLabel = (document.getElementById('field-banner-cta') as HTMLInputElement)?.value?.trim()||null;
        if (!title) { toast.error('Message is required'); return; }
        config = { badge, badge_preset:preset, message:title, ...(url?{url}:{}), ...(urlLabel?{url_label:urlLabel}:{}), ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'product': {
        title = titleEl?.value?.trim()??null; const url = urlEl?.value?.trim()??'';
        const imageUrl = (document.getElementById('field-product-image')    as HTMLInputElement)?.value?.trim()||null;
        const price    = (document.getElementById('field-product-price')    as HTMLInputElement)?.value?.trim()||null;
        const currency = (document.getElementById('field-product-currency') as HTMLSelectElement)?.value||'EUR';
        const cta      = (document.getElementById('field-product-cta')      as HTMLInputElement)?.value?.trim()||'Buy now →';
        if (!title) { toast.error('Product name is required'); return; } if (!url||!url.startsWith('http')) { toast.error('Valid product URL required'); return; }
        config = { url, ...(imageUrl?{image_url:imageUrl}:{}), ...(price?{price}:{}), currency, cta_label:cta, ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'poll': {
        title = titleEl?.value?.trim()??null; if (!title) { toast.error('Question is required'); return; }
        const optInputs = document.querySelectorAll('.poll-opt-input') as NodeListOf<HTMLInputElement>;
        const optVotes  = document.querySelectorAll('.poll-opt-votes') as NodeListOf<HTMLInputElement>;
        const options   = Array.from(optInputs).map((inp,i)=>({text:inp.value.trim(),votes:parseInt(optVotes[i]?.value||'0')||0})).filter(o=>o.text);
        if (options.length<2) { toast.error('At least 2 valid options required'); return; }
        config = { question:title, options, allow_multiple:(document.getElementById('field-allow-multiple') as HTMLInputElement)?.checked??false }; break;
      }
      case 'twitch_live': {
        const channel = (document.getElementById('field-twitch-channel') as HTMLInputElement)?.value?.trim().toLowerCase()??'';
        if (!channel) { toast.error('Twitch channel name is required'); return; }
        const showChat = (document.getElementById('field-twitch-chat') as HTMLInputElement)?.checked??false;
        title = titleEl?.value?.trim()||null;
        config = { channel, show_chat:showChat, ...(title?{offline_message:title}:{}) };
        title = title||channel; break;
      }
      case 'newsletter': {
        title = titleEl?.value?.trim()??null; const actionUrl = urlEl?.value?.trim()??'';
        const provider    = (document.getElementById('field-nl-provider')    as HTMLInputElement)?.value||'custom';
        const placeholder = (document.getElementById('field-nl-placeholder') as HTMLInputElement)?.value?.trim()||'your@email.com';
        const nlCta       = (document.getElementById('field-nl-cta')         as HTMLInputElement)?.value?.trim()||'Subscribe';
        const nlSuccess   = (document.getElementById('field-nl-success')     as HTMLInputElement)?.value?.trim()||'Thanks!';
        if (!title) { toast.error('Title is required'); return; } if (!actionUrl||!actionUrl.startsWith('http')) { toast.error('Action URL is required'); return; }
        config = { provider, action_url:actionUrl, url:actionUrl, nl_placeholder:placeholder, nl_cta:nlCta, nl_success:nlSuccess, ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      case 'vcard': {
        title = titleEl?.value?.trim()??null;
        const firstName = (document.getElementById('field-vcard-firstname') as HTMLInputElement)?.value?.trim()??'';
        const lastName  = (document.getElementById('field-vcard-lastname')  as HTMLInputElement)?.value?.trim()??'';
        const email     = (document.getElementById('field-vcard-email')     as HTMLInputElement)?.value?.trim()||null;
        const phone     = (document.getElementById('field-vcard-phone')     as HTMLInputElement)?.value?.trim()||null;
        const website   = (document.getElementById('field-vcard-website')   as HTMLInputElement)?.value?.trim()||null;
        const company   = (document.getElementById('field-vcard-company')   as HTMLInputElement)?.value?.trim()||null;
        const role      = (document.getElementById('field-vcard-role')      as HTMLInputElement)?.value?.trim()||null;
        if (!firstName) { toast.error('First name is required'); return; } if (!title) { toast.error('Button title is required'); return; }
        config = { first_name:firstName, last_name:lastName, ...(email?{email}:{}), ...(phone?{phone}:{}), ...(website?{website}:{}), ...(company?{company}:{}), ...(role?{role}:{}) }; break;
      }
      case 'merch_grid': {
        title = titleEl?.value?.trim()||null;
        const items: any[] = [];
        document.querySelectorAll('.merch-item').forEach(row => {
          const t  = (row.querySelector('.merch-title')    as HTMLInputElement)?.value?.trim();
          const u  = (row.querySelector('.merch-url')      as HTMLInputElement)?.value?.trim();
          const im = (row.querySelector('.merch-img')      as HTMLInputElement)?.value?.trim();
          const pr = (row.querySelector('.merch-price')    as HTMLInputElement)?.value?.trim();
          const cu = (row.querySelector('.merch-currency') as HTMLSelectElement)?.value||'EUR';
          if (t&&u&&u.startsWith('http')) items.push({title:t,url:u,...(im?{image_url:im}:{}),...(pr?{price:pr}:{}),currency:cu});
        });
        if (!items.length) { toast.error('At least one valid item required'); return; }
        config = { items, ...vis('show_from',showFrom), ...vis('show_until',showUntil) }; break;
      }
      default: toast.error(`Unknown type: ${type}`); return;
    }

    isSaving = true; submitBtn?.setAttribute('disabled','');
    submitText.textContent = blockId ? 'Saving…' : 'Saving…';

    try {
      const data = await apiCall(blockId ? `/api/blocks/${blockId}` : '/api/blocks', {
        method: blockId ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, title: title??null, config }),
      });
      if (blockId) {
        const idx = blocks.findIndex((b: any) => b.id === blockId);
        if (idx !== -1) blocks[idx] = { ...blocks[idx], title, config, ...data };
      } else {
        blocks.push({ id:data.id, type, title, config, active:true, is_pinned:false, created_at:new Date().toISOString(), clicks:0, ...data });
      }
      closeModal('edit-modal');
      renderBlocks();
      schedulePreviewRefresh();
      toast.success(blockId ? 'Block updated!' : 'Block added!');
    } catch (err: any) {
      toast.error(err.message?.includes('limit') ? 'Block limit reached!' : (err.message || 'Failed to save'));
    } finally {
      isSaving = false; submitBtn?.removeAttribute('disabled');
      submitText.textContent = blockId ? 'Update Block' : 'Save Block';
    }
  });

  function handleEditBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (block) openEditModal(block.type, block, null);
  }

  async function handleDuplicateBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block || !canAddBlock) { if (!canAddBlock) toast.error('Block limit reached!'); return; }
    try {
      const data = await apiCall('/api/blocks', { method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ type:block.type, title:block.title?`${block.title} (copy)`:null, config:block.config }) });
      blocks.push({ ...block, id:data.id, title:block.title?`${block.title} (copy)`:null, created_at:new Date().toISOString(), clicks:0, is_pinned:false });
      renderBlocks();
      toast.success('Block duplicated!');
    } catch (err: any) { toast.error(err.message || 'Failed to duplicate'); }
  }

  async function handleDeleteBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block) return;
    try {
      await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active:false }) });
      blocks = blocks.filter((b: any) => b.id !== id);
      archivedBlocks.unshift({ ...block });
      selectedIds.delete(id);
      renderBlocks(); renderArchive();
      toast.success('Block archived — restore from trash');
    } catch (err: any) { toast.error(err.message || 'Failed to archive'); }
  }

  document.addEventListener('keydown', (e: any) => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if (tag==='INPUT'||tag==='TEXTAREA'||(document.activeElement as HTMLElement)?.contentEditable==='true') return;
    if (e.key==='n'||e.key==='N') { e.preventDefault(); openTypeModal(); }
    if (e.key==='Escape') { closeModal('type-modal'); closeModal('edit-modal'); }
  });

  renderBlocks();
</script>
---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PlanLimitIndicator from '@/components/features/PlanLimitIndicator.astro';
import { getBlocks } from '@/lib/db/queries/blocks';
import { getAnalyticsSummary } from '@/lib/db/queries/analytics';
import type { Block } from '@/lib/db';

const user     = Astro.locals.user
const supabase = Astro.locals.supabase

if (!user) return Astro.redirect('/signin?error=auth_failed')

const { data: profileData } = await supabase
  .from('profiles')
  .select('id, username, plan')
  .eq('id', user.id)
  .single()

const profile    = profileData
const planLimits = profile?.plan
  ? await supabase.from('plan_limits').select('*').eq('plan', profile.plan).single().then(r => r.data)
  : null

function escapeHtml(val: unknown): string {
  return String(val ?? '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}
function safeNum(val: unknown): number {
  const n = Number(val); return isFinite(n) ? n : 0;
}

const safeProfileId = profile?.id?.trim() ?? '';

const [blocksResult, analyticsResult] = await Promise.all([
  safeProfileId ? getBlocks(supabase, safeProfileId) : Promise.resolve({ success: false, data: [] }),
  safeProfileId ? getAnalyticsSummary(supabase, safeProfileId, 7) : Promise.resolve({ success: false, data: null }),
]);

const rawBlocks = (blocksResult.success ? (blocksResult.value ?? blocksResult.data) : []) as Block[];
const blocks    = rawBlocks.filter(b => !b.deleted_at);

const analyticsData = analyticsResult.success ? (analyticsResult.value ?? analyticsResult.data) : null;
const topBlocks     = analyticsData?.topBlocks ?? [];
const totalViews    = analyticsData?.totalViews ?? analyticsData?.summary?.totalViews ?? 0;

const clicksMap = new Map<string, number>();
topBlocks.forEach((b: { id: string; clicks: number }) => clicksMap.set(b.id, safeNum(b.clicks)));

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

const safeBridgeBlocks = blocks
  .filter(b => UUID_RE.test(String(b.id ?? '')))
  .map(b => ({
    id:         String(b.id),
    type:       escapeHtml(b.type),
    title:      escapeHtml(b.title),
    active:     Boolean(b.active),
    position:   safeNum(b.position),
    created_at: escapeHtml(b.created_at),
    clicks:     clicksMap.get(b.id) ?? 0,
    is_pinned:  Boolean((b as Record<string, unknown>).is_pinned ?? (b.config as Record<string, unknown>)?.is_pinned),
    config: {
      url:               escapeHtml((b.config as Record<string, unknown>)?.url),
      icon_url:          escapeHtml((b.config as Record<string, unknown>)?.icon_url),
      show_from:         escapeHtml((b.config as Record<string, unknown>)?.show_from),
      show_until:        escapeHtml((b.config as Record<string, unknown>)?.show_until),
      target_date:       escapeHtml((b.config as Record<string, unknown>)?.target_date),
      goal_amount:       safeNum((b.config as Record<string, unknown>)?.goal_amount),
      current_amount:    safeNum((b.config as Record<string, unknown>)?.current_amount),
      donation_platform: escapeHtml((b.config as Record<string, unknown>)?.donation_platform),
      height:            safeNum((b.config as Record<string, unknown>)?.height),
      schedule:          Array.isArray((b.config as Record<string, unknown>)?.schedule) ? (b.config as Record<string, unknown>).schedule : [],
      links: Array.isArray((b.config as Record<string, unknown>)?.links)
        ? ((b.config as Record<string, unknown>).links as {url: string}[]).map(l => ({ url: escapeHtml(l?.url) }))
        : [],
      content:    escapeHtml((b.config as Record<string, unknown>)?.content),
      align:      ['left','center','right'].includes((b.config as Record<string, unknown>)?.align as string) ? (b.config as Record<string, unknown>).align : 'center',
      text_size:  ['sm','md','lg'].includes((b.config as Record<string, unknown>)?.text_size as string) ? (b.config as Record<string, unknown>).text_size : 'md',
      badge:        escapeHtml((b.config as Record<string, unknown>)?.badge),
      badge_preset: escapeHtml((b.config as Record<string, unknown>)?.badge_preset),
      message:      escapeHtml((b.config as Record<string, unknown>)?.message),
      url_label:    escapeHtml((b.config as Record<string, unknown>)?.url_label),
      image_url: escapeHtml((b.config as Record<string, unknown>)?.image_url),
      price:     escapeHtml((b.config as Record<string, unknown>)?.price),
      currency:  escapeHtml((b.config as Record<string, unknown>)?.currency),
      cta_label: escapeHtml((b.config as Record<string, unknown>)?.cta_label),
      question:       escapeHtml((b.config as Record<string, unknown>)?.question),
      options:        Array.isArray((b.config as Record<string, unknown>)?.options) ? ((b.config as Record<string, unknown>).options as {text: string; votes: number}[]).map(o => ({ text: escapeHtml(o?.text), votes: safeNum(o?.votes) })) : [],
      allow_multiple: Boolean((b.config as Record<string, unknown>)?.allow_multiple),
      channel:         escapeHtml((b.config as Record<string, unknown>)?.channel),
      show_chat:       Boolean((b.config as Record<string, unknown>)?.show_chat),
      offline_message: escapeHtml((b.config as Record<string, unknown>)?.offline_message),
      provider:        escapeHtml((b.config as Record<string, unknown>)?.provider),
      action_url:      escapeHtml((b.config as Record<string, unknown>)?.action_url),
      nl_placeholder:  escapeHtml((b.config as Record<string, unknown>)?.nl_placeholder),
      nl_cta:          escapeHtml((b.config as Record<string, unknown>)?.nl_cta),
      nl_success:      escapeHtml((b.config as Record<string, unknown>)?.nl_success),
      first_name: escapeHtml((b.config as Record<string, unknown>)?.first_name),
      last_name:  escapeHtml((b.config as Record<string, unknown>)?.last_name),
      email:      escapeHtml((b.config as Record<string, unknown>)?.email),
      phone:      escapeHtml((b.config as Record<string, unknown>)?.phone),
      website:    escapeHtml((b.config as Record<string, unknown>)?.website),
      company:    escapeHtml((b.config as Record<string, unknown>)?.company),
      role:       escapeHtml((b.config as Record<string, unknown>)?.role),
      items: Array.isArray((b.config as Record<string, unknown>)?.items)
        ? ((b.config as Record<string, unknown>).items as {title: string; price: string; image_url: string; url: string; currency: string}[]).slice(0,3).map(it => ({
            title:     escapeHtml(it?.title),
            price:     escapeHtml(it?.price),
            image_url: escapeHtml(it?.image_url),
            url:       escapeHtml(it?.url),
            currency:  escapeHtml(it?.currency),
          }))
        : [],
    },
  }));

const blockCount  = blocks.length;
const blockLimit  = planLimits?.max_blocks_total ?? 15;
const canAddBlock = blockLimit === -1 || blockCount < blockLimit;
const isNearLimit = blockLimit !== -1 && blockCount >= blockLimit * 0.8 && blockCount < blockLimit;
const blocksError = blocksResult.success ? null : 'Failed to load blocks';

const bridge = JSON.stringify({
  blocks: safeBridgeBlocks, blockCount, blockLimit, canAddBlock,
  profileId: escapeHtml(safeProfileId),
  username:  escapeHtml(profile?.username ?? ''),
  totalViews,
});

const BLOCK_TYPES = [
  { type: 'link',        emoji: '🔗', label: 'Link',        desc: 'Clickable link button'   },
  { type: 'social',      emoji: '👥', label: 'Social',      desc: 'Social icon grid'         },
  { type: 'heading',     emoji: '📝', label: 'Heading',     desc: 'Section title'            },
  { type: 'spacer',      emoji: '—',  label: 'Spacer',      desc: 'Blank space'              },
  { type: 'image',       emoji: '🖼️', label: 'Image',       desc: 'Display an image'         },
  { type: 'video',       emoji: '🎥', label: 'Video',       desc: 'Embed YouTube / Vimeo'    },
  { type: 'countdown',   emoji: '⏱️', label: 'Countdown',   desc: 'Next stream timer'        },
  { type: 'schedule',    emoji: '📅', label: 'Schedule',    desc: 'Weekly stream schedule'   },
  { type: 'donation',    emoji: '💸', label: 'Donation',    desc: 'Ko-fi / Patreon CTA'      },
  { type: 'embed',       emoji: '🎵', label: 'Music Embed', desc: 'Spotify / SoundCloud'     },
  { type: 'text',        emoji: '📄', label: 'Text',        desc: 'Paragraph / description'  },
  { type: 'banner',      emoji: '📢', label: 'Banner',      desc: 'LIVE / NEW announcement'  },
  { type: 'product',     emoji: '🛍️', label: 'Product',     desc: 'Product card with price'  },
  { type: 'poll',        emoji: '📊', label: 'Poll',        desc: 'Interactive vote options' },
  { type: 'twitch_live', emoji: '🟣', label: 'Twitch Live', desc: 'Channel embed + badge'    },
  { type: 'newsletter',  emoji: '📧', label: 'Newsletter',  desc: 'Email capture form'       },
  { type: 'vcard',       emoji: '👤', label: 'vCard',       desc: 'Download my contact'      },
  { type: 'merch_grid',  emoji: '🛒', label: 'Merch Grid',  desc: 'Grid of products / items' },
];
---
<DashboardLayout title="Blocks">

  <div id="server-data" style="display:none" data-bridge={bridge}></div>

  <!-- ===== HEADER ===== -->
  <div class="page-header">
    <div class="page-header-left">
      <p class="page-eyebrow">Content</p>
      <h2 class="page-title">Blocks</h2>
      <p class="page-subtitle">Build and manage your profile page</p>
    </div>
    <div class="page-header-right">
      <div id="bulk-bar" class="bulk-bar" style="display:none">
        <span id="bulk-count" class="bulk-count">0 selected</span>
        <button id="bulk-toggle-btn" class="btn btn-ghost btn-sm">Toggle</button>
        <button id="bulk-delete-btn" class="btn btn-danger btn-sm">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete
        </button>
        <button id="bulk-cancel-btn" class="btn-link">Cancel</button>
      </div>
      <button id="add-block-btn"
        class={`btn ${canAddBlock ? 'btn-primary' : 'btn-ghost btn-disabled'}`}
        title="N">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        {canAddBlock ? 'Add Block' : 'Upgrade to Add More'}
      </button>
    </div>
  </div>

  <!-- ===== PLAN LIMIT ===== -->
  <div class="plan-bar-wrap">
    <PlanLimitIndicator current={blockCount} limit={blockLimit} feature="Blocks" showUpgrade={true} />
  </div>

  {isNearLimit && (
    <div class="alert alert-warning">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <span>Using {blockCount} of {blockLimit} blocks. <a href="/dashboard/billing">Upgrade for more →</a></span>
    </div>
  )}
  {!canAddBlock && blockLimit !== -1 && (
    <div class="alert alert-danger">
      <span>Block limit reached ({blockLimit}). <a href="/dashboard/billing">Upgrade →</a></span>
    </div>
  )}
  {blocksError && (
    <div class="alert alert-danger">
      <span>{blocksError}</span>
      <button onclick="location.reload()" class="btn-link ml-auto">Retry</button>
    </div>
  )}

  <!-- ===== QUICK-ADD URL BAR ===== -->
  <div class="quick-add-bar" id="quick-add-bar">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="quick-add-icon"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
    <input type="url" id="quick-add-input" placeholder="Paste a URL to instantly add a link…" class="quick-add-input" />
    <div id="quick-detect-zone" class="quick-detect-zone" style="display:none">
      <span id="quick-plat-icon" class="quick-plat-icon"></span>
      <span id="quick-plat-label" class="quick-plat-label"></span>
      <button id="quick-add-confirm" class="btn btn-primary btn-xs">Add</button>
      <button id="quick-add-cancel" class="icon-btn">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- ===== STREAMER KIT ===== -->
  <div class="section-box kit-section">
    <div class="kit-header">
      <div class="kit-header-left">
        <span class="kit-emoji">🎮</span>
        <span class="kit-title">Streamer Kit</span>
        <span class="badge badge-green">Quick Start</span>
      </div>
      <button id="kit-toggle-btn" class="btn-link btn-sm">
        <span id="kit-toggle-label">Show</span>
        <svg id="kit-chevron" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="transition:transform .2s"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
    </div>
    <div id="kit-grid" class="kit-grid" style="display:none"></div>
  </div>

  <!-- ===== SEARCH + FILTER ===== -->
  <div class="search-filter-row">
    <div class="search-wrap">
      <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="search-icon"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
      <input type="text" id="search-input" placeholder="Search blocks…" class="search-input" />
    </div>
    <div class="filter-tabs" id="filter-tabs">
      <button class="filter-tab active" data-filter="all">All</button>
      {BLOCK_TYPES.map(t => (
        <button class="filter-tab" data-filter={t.type}>{t.emoji} {t.label}</button>
      ))}
    </div>
  </div>

  <!-- ===== MAIN LAYOUT ===== -->
  <div id="blocks-main-layout" class="blocks-main-layout">

    <div id="blocks-content" class="blocks-content">

      <!-- BLOCKS LIST -->
      <div id="blocks-container">
        {blocks.length === 0 ? (
          <div id="empty-state" class="empty-state">
            <div class="empty-icon-wrap">
              <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
            </div>
            <h3 class="empty-title">No blocks yet</h3>
            <p class="empty-sub">Paste a URL above, use a Streamer Kit template, or click Add Block to get started.</p>
            {canAddBlock && (
              <button id="empty-add-btn" class="btn btn-primary">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                Add Your First Block
              </button>
            )}
            <p class="empty-tip">Tip: <kbd>N</kbd> to add · <kbd>P</kbd> preview</p>
          </div>
        ) : (
          <div class="sortable-list" id="sortable-blocks"></div>
        )}
        <div id="no-results" class="no-results" style="display:none">
          <p>No blocks match your search</p>
          <button id="clear-search-btn" class="btn-link">Clear filters</button>
        </div>
      </div>

      <!-- ARCHIVED BLOCKS -->
      <div id="archive-section" class="archive-section" style="display:none">
        <div class="archive-header">
          <div class="archive-header-left">
            <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8m-9 4v4m4-4v4"/></svg>
            <span class="archive-label">Trash</span>
            <span id="archive-count" class="badge badge-neutral"></span>
          </div>
          <button id="archive-clear-btn" class="btn-link btn-danger-link">Empty trash</button>
        </div>
        <div id="archive-list" class="archive-list"></div>
      </div>

    </div>

    <!-- ===== LIVE PREVIEW (desktop ≥1280px) ===== -->
    <div id="preview-panel-inline" class="preview-panel">
      <div class="preview-panel-inner">
        <div class="preview-panel-head">
          <div class="preview-live-dot">
            <span class="live-pulse"></span>
            <span class="preview-live-label">Live preview</span>
          </div>
          <div class="preview-panel-actions">
            <button id="preview-refresh-btn" class="icon-btn" title="Refresh">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </button>
            <button id="preview-open-btn" class="icon-btn" title="Open in tab">
              <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </button>
          </div>
        </div>
        <div class="preview-iframe-wrap">
          <iframe id="preview-iframe" src="" class="preview-iframe" loading="lazy" sandbox="allow-scripts allow-same-origin"></iframe>
        </div>
        <div class="preview-panel-foot">
          <p id="preview-url-label" class="preview-url-label"></p>
        </div>
      </div>
    </div>

  </div>

  <!-- ===== TYPE MODAL ===== -->
  <div id="type-modal" class="modal-overlay" style="display:none">
    <div id="type-backdrop" class="modal-backdrop"></div>
    <div class="modal-box modal-wide">
      <div class="modal-head">
        <h3 class="modal-title">Add a block</h3>
        <button id="type-close" class="icon-btn">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="modal-search-row">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="search-icon"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
        <input type="text" id="type-search" placeholder="Search or paste a URL…" class="search-input" />
      </div>
      <div class="modal-body">
        <nav class="type-nav" id="type-nav"></nav>
        <div class="type-panel" id="type-panel"></div>
      </div>
    </div>
  </div>

  <!-- ===== EDIT MODAL ===== -->
  <div id="edit-modal" class="modal-overlay" style="display:none">
    <div id="edit-backdrop" class="modal-backdrop"></div>
    <div class="modal-box modal-narrow">
      <div class="modal-head">
        <h3 class="modal-title" id="modal-title">Add Block</h3>
        <button id="edit-close" class="icon-btn">
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="block-form" class="modal-form" novalidate>
        <input type="hidden" id="block-id" />
        <input type="hidden" id="block-type" />
        <div id="form-fields" class="form-fields"></div>
        <div id="schedule-visibility-section">
          <div class="visibility-section">
            <button type="button" id="visibility-toggle" class="visibility-toggle-btn">
              <span class="vis-toggle-left">
                <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Scheduled visibility
                <span class="badge badge-neutral">optional</span>
              </span>
              <svg id="vis-chevron" width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="transition:transform .2s"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="visibility-panel" style="display:none">
              <p class="field-hint">Leave empty to always show.</p>
              <div class="grid-2">
                <div class="field-group">
                  <label class="field-label">Show from</label>
                  <input type="datetime-local" id="field-show-from" class="field-input" />
                </div>
                <div class="field-group">
                  <label class="field-label">Hide after</label>
                  <input type="datetime-local" id="field-show-until" class="field-input" />
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-actions">
          <button type="submit" id="submit-btn" class="btn btn-primary btn-full">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span id="submit-text">Save Block</span>
          </button>
          <button type="button" id="cancel-btn" class="btn btn-ghost">Cancel</button>
        </div>
      </form>
    </div>
  </div>

</DashboardLayout>

<style>
  /* ── Design tokens ── */
  :root {
    --green:       #00ff9d;
    --green-dim:   rgba(0,255,157,0.12);
    --green-glow:  rgba(0,255,157,0.25);
    --surface-0:   #0a0a0f;
    --surface-1:   #111118;
    --surface-2:   rgba(255,255,255,0.04);
    --surface-3:   rgba(255,255,255,0.07);
    --border:      rgba(255,255,255,0.09);
    --border-hover:rgba(255,255,255,0.16);
    --text-0:      #ffffff;
    --text-1:      rgba(255,255,255,0.75);
    --text-2:      rgba(255,255,255,0.42);
    --text-3:      rgba(255,255,255,0.22);
    --red:         #ff4d6a;
    --red-dim:     rgba(255,77,106,0.12);
    --yellow:      #fbbf24;
    --yellow-dim:  rgba(251,191,36,0.12);
    --radius-sm:   8px;
    --radius-md:   12px;
    --radius-lg:   16px;
    --radius-xl:   20px;
  }

  /* ── Reset noise ── */
  *, *::before, *::after { box-sizing: border-box; }

  /* ── Page header ── */
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .page-eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-2);
    margin: 0 0 4px;
  }
  .page-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-0);
    margin: 0 0 3px;
    letter-spacing: -.02em;
  }
  .page-subtitle {
    font-size: 13px;
    color: var(--text-2);
    margin: 0;
  }
  .page-header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all .15s ease;
    white-space: nowrap;
    text-decoration: none;
  }
  .btn:active { transform: scale(.97); }
  .btn-primary {
    background: var(--green);
    color: #000;
  }
  .btn-primary:hover { background: #1affb0; box-shadow: 0 0 20px var(--green-glow); }
  .btn-ghost {
    background: var(--surface-2);
    color: var(--text-1);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover { background: var(--surface-3); border-color: var(--border-hover); color: var(--text-0); }
  .btn-danger {
    background: var(--red-dim);
    color: var(--red);
    border: 1px solid rgba(255,77,106,0.25);
  }
  .btn-danger:hover { background: rgba(255,77,106,0.18); }
  .btn-disabled { opacity: .5; cursor: not-allowed; pointer-events: none; }
  .btn-sm { padding: 7px 13px; font-size: 12px; }
  .btn-xs { padding: 5px 11px; font-size: 11px; font-weight: 700; }
  .btn-full { width: 100%; justify-content: center; padding: 12px; font-size: 14px; }
  .btn-link { background: none; border: none; cursor: pointer; color: var(--text-2); font-size: 12px; font-weight: 500; padding: 4px 0; transition: color .15s; }
  .btn-link:hover { color: var(--text-0); }
  .btn-danger-link { color: var(--red); }
  .btn-danger-link:hover { color: #ff6b82; }
  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-sm);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    transition: all .15s;
    flex-shrink: 0;
  }
  .icon-btn:hover { background: var(--surface-3); color: var(--text-0); }

  /* ── Badges ── */
  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 99px;
    font-size: 10px;
    font-weight: 600;
    border: 1px solid transparent;
  }
  .badge-green  { background: var(--green-dim); color: var(--green); border-color: var(--green-glow); }
  .badge-neutral { background: var(--surface-3); color: var(--text-2); border-color: var(--border); }

  /* ── Alerts ── */
  .alert {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-radius: var(--radius-md);
    font-size: 13px;
    margin-bottom: 12px;
    border: 1px solid transparent;
  }
  .alert a { text-decoration: underline; margin-left: 4px; }
  .alert-warning { background: var(--yellow-dim); border-color: rgba(251,191,36,0.2); color: #f0c048; }
  .alert-warning a { color: #f0c048; }
  .alert-danger  { background: var(--red-dim);    border-color: rgba(255,77,106,0.2);  color: #ff8096; }
  .alert-danger a { color: #ff8096; }

  /* ── Plan bar ── */
  .plan-bar-wrap { margin-bottom: 14px; }

  /* ── Quick-add ── */
  .quick-add-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 16px;
    transition: border-color .2s;
  }
  .quick-add-bar:focus-within { border-color: var(--green-glow); }
  .quick-add-icon { color: var(--text-3); flex-shrink: 0; }
  .quick-add-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--text-0);
    font-size: 13px;
    min-width: 0;
  }
  .quick-add-input::placeholder { color: var(--text-3); }
  .quick-detect-zone {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .quick-plat-icon { font-size: 16px; line-height: 1; }
  .quick-plat-label { font-size: 12px; font-weight: 700; color: var(--green); white-space: nowrap; }

  /* ── Section box ── */
  .section-box {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px;
    margin-bottom: 16px;
  }
  .kit-section { margin-bottom: 16px; }
  .kit-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .kit-header-left { display: flex; align-items: center; gap: 8px; }
  .kit-emoji { font-size: 16px; line-height: 1; }
  .kit-title { font-size: 14px; font-weight: 600; color: var(--text-0); }
  .kit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
    margin-top: 14px;
  }
  .kit-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 14px;
    cursor: pointer;
    text-align: left;
    transition: all .15s;
  }
  .kit-card:hover { border-color: var(--border-hover); background: var(--surface-3); transform: translateY(-1px); }
  .kit-card-emoji { font-size: 22px; line-height: 1; margin-bottom: 8px; display: block; }
  .kit-card-name { font-size: 13px; font-weight: 600; color: var(--text-0); margin-bottom: 3px; }
  .kit-card-desc { font-size: 11px; color: var(--text-2); margin-bottom: 10px; }
  .kit-card-cta { font-size: 11px; font-weight: 700; display: flex; align-items: center; gap: 5px; }

  /* ── Search + Filter ── */
  .search-filter-row {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 180px;
  }
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-3);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 9px 14px 9px 36px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-0);
    font-size: 13px;
    outline: none;
    transition: border-color .2s;
  }
  .search-input:focus { border-color: var(--green-glow); }
  .search-input::placeholder { color: var(--text-3); }
  .filter-tabs {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 2px;
    flex-shrink: 0;
    max-width: 100%;
  }
  .filter-tabs::-webkit-scrollbar { display: none; }
  .filter-tab {
    padding: 7px 12px;
    border-radius: var(--radius-sm);
    font-size: 11.5px;
    font-weight: 500;
    border: 1px solid transparent;
    background: none;
    color: var(--text-2);
    cursor: pointer;
    transition: all .15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .filter-tab:hover { color: var(--text-0); background: var(--surface-3); }
  .filter-tab.active { color: var(--text-0); background: var(--surface-3); border-color: var(--border-hover); }

  /* ── Main layout ── */
  .blocks-main-layout {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .blocks-content { flex: 1; min-width: 0; }

  /* ── Block cards ── */
  .sortable-list { display: flex; flex-direction: column; gap: 5px; }

  .bc {
    position: relative;
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 10px 13px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color .15s, background .15s;
    min-height: 54px;
    user-select: none;
  }
  .bc:hover { border-color: var(--border-hover); background: var(--surface-3); }
  .bc--selected { border-color: var(--green-glow) !important; background: rgba(0,255,157,0.03) !important; }
  .bc--pinned { border-color: rgba(251,191,36,0.3) !important; }
  .bc.sortable-ghost { opacity: .35; }
  .bc.sortable-drag { box-shadow: 0 16px 40px rgba(0,0,0,.55); transform: rotate(.6deg); z-index: 999; }

  /* pin bar at top */
  .bc-pintab {
    position: absolute;
    top: -1px;
    left: 14px;
    width: 2px;
    height: 7px;
    background: var(--yellow);
    border-radius: 0 0 2px 2px;
  }

  /* checkbox */
  .bc-check { opacity: 0; flex-shrink: 0; transition: opacity .15s; }
  .bc-check--vis, .bc:hover .bc-check { opacity: 1; }
  .bc-check input {
    width: 15px;
    height: 15px;
    accent-color: var(--green);
    cursor: pointer;
    border-radius: 4px;
  }

  /* drag handle */
  .bc-drag {
    color: var(--text-3);
    cursor: grab;
    flex-shrink: 0;
    padding: 2px;
    transition: color .15s;
    display: flex;
    align-items: center;
  }
  .bc-drag:hover { color: var(--text-1); }
  .bc-drag:active { cursor: grabbing; }

  /* icon */
  .bc-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--surface-3);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    overflow: hidden;
  }
  .bc-icon img { width: 100%; height: 100%; object-fit: cover; }

  /* body */
  .bc-body { flex: 1; min-width: 0; }
  .bc-row1 { display: flex; align-items: center; gap: 5px; overflow: hidden; }
  .bc-type-badge {
    font-size: 9.5px;
    padding: 2px 6px;
    border-radius: 99px;
    font-weight: 600;
    border: 1px solid var(--border);
    background: var(--surface-3);
    color: var(--text-2);
    flex-shrink: 0;
    letter-spacing: .01em;
  }
  .bc-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-0);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: default;
  }
  .bc-notitle { font-size: 13px; color: var(--text-3); font-style: italic; }
  .bc-pin, .bc-sched { font-size: 11px; flex-shrink: 0; }
  .bc-new {
    font-size: 9.5px;
    padding: 1.5px 6px;
    border-radius: 99px;
    background: var(--green-dim);
    color: var(--green);
    border: 1px solid var(--green-glow);
    font-weight: 700;
    flex-shrink: 0;
  }
  .bc-sub {
    font-size: 11px;
    color: var(--text-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }

  /* clicks */
  .bc-clicks {
    font-size: 11px;
    color: var(--text-2);
    white-space: nowrap;
    flex-shrink: 0;
    font-feature-settings: 'tnum';
  }

  /* status dot */
  .bc-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: background .2s;
  }
  .bc-dot--on  { background: #22c55e; box-shadow: 0 0 6px rgba(34,197,94,.4); }
  .bc-dot--off { background: var(--text-3); }

  /* toggle */
  .bc-toggle-wrap { flex-shrink: 0; cursor: pointer; position: relative; display: inline-flex; }
  .bc-toggle-wrap input { position: absolute; opacity: 0; width: 0; height: 0; }
  .bc-toggle-track {
    width: 36px;
    height: 20px;
    background: var(--surface-3);
    border-radius: 99px;
    border: 1px solid var(--border);
    position: relative;
    transition: all .2s;
  }
  .bc-toggle-wrap input:checked ~ .bc-toggle-track {
    background: rgba(0,255,157,.2);
    border-color: rgba(0,255,157,.35);
  }
  .bc-toggle-thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--text-2);
    transition: all .2s;
  }
  .bc-toggle-wrap input:checked ~ .bc-toggle-track .bc-toggle-thumb {
    transform: translateX(16px);
    background: var(--green);
  }

  /* copy / menu buttons */
  .bc-copy, .bc-menu-btn {
    opacity: 0;
    width: 26px;
    height: 26px;
    border-radius: var(--radius-sm);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .15s;
    flex-shrink: 0;
  }
  .bc:hover .bc-copy,
  .bc:hover .bc-menu-btn { opacity: 1; }
  .bc-copy:hover, .bc-menu-btn:hover { background: var(--surface-3); color: var(--text-0); }

  /* dropdown menu */
  .bc-menu-wrap { position: relative; flex-shrink: 0; }
  .bc-dropdown {
    position: absolute;
    right: 0;
    top: calc(100% + 4px);
    width: 168px;
    background: rgba(10,10,18,0.97);
    border: 1px solid var(--border-hover);
    border-radius: var(--radius-md);
    padding: 4px;
    z-index: 50;
    box-shadow: 0 16px 40px rgba(0,0,0,.6);
    backdrop-filter: blur(20px);
  }
  .bc-menu-item {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 10px;
    font-size: 13px;
    color: var(--text-1);
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-align: left;
    transition: all .12s;
  }
  .bc-menu-item:hover { background: var(--surface-3); color: var(--text-0); }
  .bc-menu-item svg { color: var(--text-2); flex-shrink: 0; }
  .bc-menu-item--danger { color: var(--red); }
  .bc-menu-item--danger:hover { background: var(--red-dim); }
  .bc-menu-divider { height: 1px; background: var(--border); margin: 4px 0; }

  /* Type badge colors */
  .badge-countdown  { background: rgba(251,191,36,.1);   color: #d4a012; border-color: rgba(251,191,36,.25); }
  .badge-schedule   { background: rgba(99,179,237,.1);   color: #4fa0d0; border-color: rgba(99,179,237,.25); }
  .badge-donation   { background: rgba(248,113,113,.1);  color: #e05050; border-color: rgba(248,113,113,.25); }
  .badge-embed      { background: rgba(167,139,250,.1);  color: #9a6ee0; border-color: rgba(167,139,250,.25); }
  .badge-text       { background: rgba(148,163,184,.08); color: #8090a0; border-color: rgba(148,163,184,.2); }
  .badge-banner     { background: rgba(251,113,133,.1);  color: #d05070; border-color: rgba(251,113,133,.25); }
  .badge-product    { background: rgba(52,211,153,.1);   color: #20a070; border-color: rgba(52,211,153,.25); }
  .badge-poll       { background: rgba(56,189,248,.1);   color: #1e96d2; border-color: rgba(56,189,248,.25); }
  .badge-twitch     { background: rgba(145,70,255,.12);  color: #a064ff; border-color: rgba(145,70,255,.3); }
  .badge-newsletter { background: rgba(251,191,36,.08);  color: #b48c10; border-color: rgba(251,191,36,.2); }
  .badge-vcard      { background: rgba(99,179,237,.08);  color: #468cc8; border-color: rgba(99,179,237,.2); }
  .badge-merch      { background: rgba(248,113,113,.08); color: #b44646; border-color: rgba(248,113,113,.2); }

  /* ── Empty / no-results ── */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 72px 24px;
    text-align: center;
  }
  .empty-icon-wrap {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-xl);
    background: var(--green-dim);
    border: 1px solid var(--green-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    margin-bottom: 18px;
  }
  .empty-title { font-size: 18px; font-weight: 700; color: var(--text-0); margin: 0 0 8px; }
  .empty-sub   { font-size: 13px; color: var(--text-2); margin: 0 0 22px; max-width: 300px; line-height: 1.5; }
  .empty-tip   { font-size: 12px; color: var(--text-3); margin-top: 14px; }
  .empty-tip kbd {
    padding: 2px 6px;
    background: var(--surface-3);
    border: 1px solid var(--border);
    border-radius: 5px;
    font-family: monospace;
    font-size: 11px;
    color: var(--text-1);
  }
  .no-results {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48px 0;
    gap: 8px;
    color: var(--text-2);
    font-size: 13px;
  }

  /* ── Archive ── */
  .archive-section { margin-top: 28px; }
  .archive-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .archive-header-left {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--text-2);
    font-size: 13px;
    font-weight: 600;
  }
  .archive-label { font-size: 13px; font-weight: 600; color: var(--text-2); }
  .archive-list { display: flex; flex-direction: column; gap: 6px; }
  .archive-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    opacity: .55;
    transition: opacity .15s;
  }
  .archive-card:hover { opacity: 1; }

  /* ── Preview panel ── */
  .preview-panel {
    width: 240px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    display: none;
  }
  @media (min-width: 1280px) { .preview-panel { display: block; } }
  .preview-panel-inner {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }
  .preview-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
  }
  .preview-live-dot { display: flex; align-items: center; gap: 7px; }
  .live-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.2)} }
  .preview-live-label { font-size: 12px; font-weight: 600; color: var(--text-0); }
  .preview-panel-actions { display: flex; gap: 2px; }
  .preview-iframe-wrap { padding: 8px; }
  .preview-iframe {
    width: 100%;
    height: 420px;
    border: none;
    border-radius: var(--radius-md);
    pointer-events: none;
    display: block;
    background: var(--surface-0);
  }
  .preview-panel-foot {
    padding: 8px 12px;
    border-top: 1px solid var(--border);
  }
  .preview-url-label {
    font-size: 10.5px;
    color: var(--text-3);
    font-family: monospace;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  /* ── Bulk bar ── */
  .bulk-bar {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .bulk-count { font-size: 11.5px; font-weight: 600; color: var(--text-2); }

  /* ── Modals ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .modal-overlay.open { display: flex !important; }
  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.72);
    backdrop-filter: blur(8px);
  }
  .modal-box {
    position: relative;
    background: rgba(12,12,20,0.98);
    border: 1px solid var(--border-hover);
    border-radius: var(--radius-xl);
    box-shadow: 0 32px 80px rgba(0,0,0,.7);
    display: flex;
    flex-direction: column;
    max-height: 92vh;
    overflow: hidden;
    animation: modal-in .18s ease;
  }
  @keyframes modal-in { from{opacity:0;transform:scale(.97) translateY(6px)} to{opacity:1;transform:scale(1) translateY(0)} }
  .modal-wide  { width: 100%; max-width: 660px; }
  .modal-narrow{ width: 100%; max-width: 440px; overflow-y: auto; scrollbar-width: none; }
  .modal-narrow::-webkit-scrollbar { display: none; }
  .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px 16px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .modal-title { font-size: 15px; font-weight: 700; color: var(--text-0); margin: 0; }
  .modal-search-row {
    padding: 12px 16px;

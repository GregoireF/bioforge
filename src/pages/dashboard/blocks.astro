  .merch-item-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 13px;
    background: var(--surface-3);
    border-bottom: 1px solid var(--border);
  }
  .merch-item-label { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-2); }
  .merch-item-body { padding: 12px; display: flex; flex-direction: column; gap: 8px; }
  .merch-img-preview {
    width: 46px;
    height: 46px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface-3);
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-3);
  }
  .merch-img-preview img { width: 100%; height: 100%; object-fit: cover; }
  .price-row { display: flex; gap: 7px; align-items: stretch; }
  .price-input-wrap { position: relative; flex: 1; }
  .price-symbol {
    position: absolute;
    left: 11px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 13px;
    font-weight: 700;
    color: var(--green);
    pointer-events: none;
  }
  .price-input { padding-left: 26px !important; }

  /* banner presets */
  .banner-presets { display: flex; gap: 6px; flex-wrap: wrap; }
  .banner-preset-btn {
    padding: 5px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: none;
    color: var(--text-2);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .06em;
    cursor: pointer;
    transition: all .12s;
  }
  .banner-preset-btn:hover { border-color: var(--border-hover); color: var(--text-0); }
  .banner-preset-btn.active { border-color: var(--green-glow); background: var(--green-dim); color: var(--text-0); }

  /* info box */
  .info-box {
    padding: 10px 13px;
    background: rgba(251,191,36,.06);
    border: 1px solid rgba(251,191,36,.2);
    border-radius: var(--radius-md);
    font-size: 12px;
    color: rgba(251,191,36,.8);
    line-height: 1.5;
  }

  /* OG loader */
  #og-loading { transition: opacity .2s; }

  /* Inline title edit */
  .block-title-editable[contenteditable="true"] {
    outline: none;
    border-bottom: 1px solid var(--green-glow);
    padding-bottom: 1px;
    cursor: text;
    min-width: 40px;
  }

  /* Scrollbar utility */
  .no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
  .no-scrollbar::-webkit-scrollbar { display: none; }

  /* Preview refresh animation */
  @keyframes spin-anim { from{transform:rotate(0)} to{transform:rotate(360deg)} }
  .preview-loading svg { animation: spin-anim .7s linear infinite; }

  /* Responsive tweaks */
  @media (max-width: 640px) {
    .page-header { flex-direction: column; }
    .search-filter-row { flex-direction: column; }
    .filter-tabs { max-width: 100%; }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>

<script>
  import { toast } from '@/lib/utils/toast';

  const raw = JSON.parse(document.getElementById('server-data')?.dataset.bridge ?? '{}');
  let { blocks, blockCount, blockLimit, canAddBlock, profileId, username, totalViews } = raw;
  const profileUrl = username ? `/@${username}` : null;

  let selectedIds: Set<string> = new Set();
  let activeFilter = 'all';
  let searchQuery  = '';
  let isSaving     = false;
  let sortable: any = null;

  async function apiCall(url: string, options: RequestInit = {}) {
    const res  = await fetch(url, options);
    const json = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(json.error?.message ?? json.error ?? `HTTP ${res.status}`);
    return json.data ?? json;
  }

  const PLATFORMS = [
    { id: 'twitch',         label: 'Twitch',        icon: '🟣', match: ['twitch.tv'],                       defaultIcon: 'https://bioforge.click/social/twitch.png'         },
    { id: 'youtube',        label: 'YouTube',        icon: '🔴', match: ['youtube.com','youtu.be'],           defaultIcon: 'https://bioforge.click/social/youtube.png'        },
    { id: 'tiktok',         label: 'TikTok',         icon: '⬛', match: ['tiktok.com'],                       defaultIcon: 'https://bioforge.click/social/tiktok.png'         },
    { id: 'instagram',      label: 'Instagram',      icon: '📸', match: ['instagram.com'],                    defaultIcon: 'https://bioforge.click/social/instagram.png'      },
    { id: 'twitter',        label: 'X / Twitter',    icon: '🐦', match: ['twitter.com','x.com'],              defaultIcon: 'https://bioforge.click/social/x.png'              },
    { id: 'discord',        label: 'Discord',        icon: '💬', match: ['discord.com','discord.gg'],         defaultIcon: 'https://bioforge.click/social/discord.png'        },
    { id: 'kick',           label: 'Kick',           icon: '🟢', match: ['kick.com'],                         defaultIcon: 'https://bioforge.click/social/kick.png'           },
    { id: 'spotify',        label: 'Spotify',        icon: '🎵', match: ['spotify.com','open.spotify.com'],   defaultIcon: 'https://bioforge.click/social/spotify.png'        },
    { id: 'github',         label: 'GitHub',         icon: '🐙', match: ['github.com'],                       defaultIcon: 'https://bioforge.click/social/github.png'         },
    { id: 'linkedin',       label: 'LinkedIn',       icon: '💼', match: ['linkedin.com'],                     defaultIcon: 'https://www.linkedin.com/favicon.ico'             },
    { id: 'patreon',        label: 'Patreon',        icon: '🎁', match: ['patreon.com'],                      defaultIcon: 'https://c5.patreon.com/external/favicon/favicon.ico' },
    { id: 'kofi',           label: 'Ko-fi',          icon: '☕', match: ['ko-fi.com'],                        defaultIcon: 'https://storage.ko-fi.com/cdn/nav-logo-stroke.png' },
    { id: 'streamlabs',     label: 'Streamlabs',     icon: '🎛️', match: ['streamlabs.com','streamlabs.link'], defaultIcon: 'https://bioforge.click/social/streamlabs.png'     },
    { id: 'streamelements', label: 'StreamElements', icon: '⚡', match: ['streamelements.com'],               defaultIcon: 'https://bioforge.click/social/streamelements.png'  },
    { id: 'throne',         label: 'Throne',         icon: '👑', match: ['throne.com'],                       defaultIcon: 'https://bioforge.click/social/throne.png'         },
    { id: 'snapchat',       label: 'Snapchat',       icon: '👻', match: ['snapchat.com'],                     defaultIcon: 'https://bioforge.click/social/snapchat.png'       },
    { id: 'facebook',       label: 'Facebook',       icon: '📘', match: ['facebook.com'],                     defaultIcon: 'https://bioforge.click/social/facebook.png'       },
  ];

  function detectPlatform(url: string) {
    try { const l = url.toLowerCase(); return PLATFORMS.find(p => p.match.some(m => l.includes(m))) ?? null; }
    catch { return null; }
  }

  function getDefaultTitle(url: string, platform: any): string {
    if (!platform) return '';
    try {
      const parts = new URL(url).pathname.split('/').filter(Boolean);
      return parts[0] ? `${platform.label} — @${parts[0]}` : platform.label;
    } catch { return platform.label; }
  }

  const BLOCK_EMOJI: Record<string, string> = {
    link:'🔗', heading:'📝', spacer:'—', image:'🖼️', video:'🎥',
    social:'👥', countdown:'⏱️', schedule:'📅', donation:'💸', embed:'🎵',
    text:'📄', banner:'📢', product:'🛍️', poll:'📊',
    twitch_live:'🟣', newsletter:'📧', vcard:'👤', merch_grid:'🛒',
  };
  const TYPE_BADGE_CLASS: Record<string, string> = {
    countdown:'badge-countdown', schedule:'badge-schedule',
    donation:'badge-donation',   embed:'badge-embed',
    text:'badge-text',           banner:'badge-banner',     product:'badge-product',
    poll:'badge-poll',           twitch_live:'badge-twitch', newsletter:'badge-newsletter',
    vcard:'badge-vcard',         merch_grid:'badge-merch',
  };

  function isNew(createdAt: string): boolean {
    return !!createdAt && Date.now() - new Date(createdAt).getTime() < 86_400_000;
  }
  function isScheduled(block: any): boolean {
    return !!(block.config?.show_from || block.config?.show_until);
  }
  function getFiltered() {
    return blocks.filter((b: any) => {
      const matchType   = activeFilter === 'all' || b.type === activeFilter;
      const matchSearch = !searchQuery || b.title?.toLowerCase().includes(searchQuery) || b.type.includes(searchQuery);
      return matchType && matchSearch;
    });
  }

  // ── Archive ───────────────────────────────────────────────────────────────
  let archivedBlocks: any[] = [];

  function renderArchive() {
    const section = document.getElementById('archive-section');
    const list    = document.getElementById('archive-list');
    const count   = document.getElementById('archive-count');
    if (!section || !list) return;
    if (!archivedBlocks.length) { section.style.display = 'none'; return; }
    section.style.display = '';
    if (count) count.textContent = String(archivedBlocks.length);
    list.innerHTML = archivedBlocks.map(b => `
      <div class="archive-card" data-id="${b.id}">
        <span style="font-size:18px;flex-shrink:0">${BLOCK_EMOJI[b.type] ?? '📌'}</span>
        <div style="flex:1;min-width:0">
          <p style="font-size:13px;font-weight:500;color:rgba(255,255,255,.65);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin:0">${b.title || b.type}</p>
          <p style="font-size:11px;color:rgba(255,255,255,.3);margin:0">${b.type}</p>
        </div>
        <button class="btn btn-ghost btn-sm archive-restore-btn" data-id="${b.id}">Restore</button>
        <button class="icon-btn archive-perm-delete-btn" data-id="${b.id}" title="Delete permanently">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>`).join('');
    list.querySelectorAll('.archive-restore-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id!;
        const b  = archivedBlocks.find((x: any) => x.id === id);
        if (!b) return;
        try {
          await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active: false }) });
          archivedBlocks = archivedBlocks.filter((x: any) => x.id !== id);
          blocks.push({ ...b, active: false });
          renderBlocks(); renderArchive();
          toast.success('Block restored!');
        } catch { toast.error('Restore failed'); }
      });
    });
    list.querySelectorAll('.archive-perm-delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id!;
        if (!confirm('Delete permanently?')) return;
        try {
          await apiCall(`/api/blocks/${id}`, { method:'DELETE' });
          archivedBlocks = archivedBlocks.filter((x: any) => x.id !== id);
          renderArchive();
          toast.success('Deleted permanently');
        } catch { toast.error('Delete failed'); }
      });
    });
  }

  document.getElementById('archive-clear-btn')?.addEventListener('click', async () => {
    if (!archivedBlocks.length) return;
    if (!confirm(`Delete ${archivedBlocks.length} archived block(s) permanently?`)) return;
    try {
      await Promise.all(archivedBlocks.map(b => apiCall(`/api/blocks/${b.id}`, { method:'DELETE' })));
      archivedBlocks = [];
      renderArchive();
      toast.success('Trash emptied');
    } catch { toast.error('Failed'); }
  });

  // ── Preview ───────────────────────────────────────────────────────────────
  const previewIframe  = document.getElementById('preview-iframe') as HTMLIFrameElement | null;
  const previewUrlLbl  = document.getElementById('preview-url-label');
  let previewDebounce: ReturnType<typeof setTimeout> | null = null;

  function loadPreview() {
    if (!previewIframe || !profileUrl) return;
    const btn = document.getElementById('preview-refresh-btn');
    btn?.classList.add('preview-loading');
    previewIframe.src = profileUrl + '?preview=1&t=' + Date.now();
    previewIframe.onload = () => btn?.classList.remove('preview-loading');
    if (previewUrlLbl) previewUrlLbl.textContent = `bioforge.click${profileUrl}`;
  }
  function schedulePreviewRefresh() {
    if (!profileUrl) return;
    if (previewDebounce) clearTimeout(previewDebounce);
    previewDebounce = setTimeout(loadPreview, 1200);
  }

  document.getElementById('preview-refresh-btn')?.addEventListener('click', loadPreview);
  document.getElementById('preview-open-btn')?.addEventListener('click', () => {
    if (profileUrl) window.open(profileUrl, '_blank');
  });
  if (profileUrl && window.innerWidth >= 1280) setTimeout(loadPreview, 500);

  // ── OG fetch ──────────────────────────────────────────────────────────────
  let ogFetchController: AbortController | null = null;

  async function fetchOgMeta(url: string): Promise<{ title: string; image: string } | null> {
    try {
      ogFetchController?.abort();
      ogFetchController = new AbortController();
      const res = await fetch(`https://api.microlink.io/?url=${encodeURIComponent(url)}&screenshot=false`, { signal: ogFetchController.signal });
      const json = await res.json();
      if (json.status !== 'success') return null;
      return { title: json.data?.title ?? '', image: json.data?.image?.url ?? json.data?.logo?.url ?? '' };
    } catch { return null; }
  }

  function showOgLoader(show: boolean) {
    const el = document.getElementById('og-loading');
    if (el) el.style.opacity = show ? '1' : '0';
  }

  function attachOgFetch() {
    const urlField   = document.getElementById('field-url')      as HTMLInputElement | null;
    const titleField = document.getElementById('field-title')    as HTMLInputElement | null;
    const iconField  = document.getElementById('field-icon-url') as HTMLInputElement | null;
    const iconWrap   = document.getElementById('icon-preview-wrap');
    if (!urlField) return;
    let ogTimer: ReturnType<typeof setTimeout> | null = null;
    urlField.addEventListener('input', () => {
      const val = urlField.value.trim();
      if (!val.startsWith('http')) return;
      if (ogTimer) clearTimeout(ogTimer);
      ogTimer = setTimeout(async () => {
        showOgLoader(true);
        const meta = await fetchOgMeta(val);
        showOgLoader(false);
        if (!meta) return;
        if (titleField && !titleField.value) titleField.value = meta.title;
        if (iconField && !iconField.value && meta.image) {
          iconField.value = meta.image;
          if (iconWrap) iconWrap.innerHTML = `<img src="${meta.image}" style="width:100%;height:100%;object-fit:cover" />`;
        }
      }, 700);
    });
  }

  // ── Inline title edit ─────────────────────────────────────────────────────
  function attachInlineEdit() {
    document.querySelectorAll('.block-title-editable').forEach(el => {
      el.addEventListener('dblclick', () => {
        (el as HTMLElement).contentEditable = 'true';
        (el as HTMLElement).focus();
        const range = document.createRange();
        range.selectNodeContents(el);
        const sel = window.getSelection();
        sel?.removeAllRanges(); sel?.addRange(range);
      });
      el.addEventListener('blur', async () => {
        if ((el as HTMLElement).contentEditable !== 'true') return;
        (el as HTMLElement).contentEditable = 'false';
        const newTitle = (el as HTMLElement).textContent?.trim() || null;
        const id = (el as HTMLElement).dataset.id!;
        if (!newTitle || !id) return;
        try {
          await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ title: newTitle }) });
          const b = blocks.find((b: any) => b.id === id);
          if (b) b.title = newTitle;
          toast.success('Title updated');
          schedulePreviewRefresh();
        } catch { toast.error('Failed to rename'); renderBlocks(); }
      });
      el.addEventListener('keydown', (e: any) => {
        if (e.key === 'Enter') { e.preventDefault(); (el as HTMLElement).blur(); }
        if (e.key === 'Escape') {
          (el as HTMLElement).contentEditable = 'false';
          const b = blocks.find((b: any) => b.id === (el as HTMLElement).dataset.id);
          if (b) (el as HTMLElement).textContent = b.title || '';
        }
      });
    });
  }

  function attachCopyBtns() {
    document.querySelectorAll('.block-copy-btn').forEach(btn => {
      btn.addEventListener('click', async (e: any) => {
        e.stopPropagation();
        const url = (btn as HTMLElement).dataset.url!;
        await navigator.clipboard.writeText(url).catch(() => {});
        const orig = (btn as HTMLElement).innerHTML;
        (btn as HTMLElement).innerHTML = `<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
        setTimeout(() => { (btn as HTMLElement).innerHTML = orig; }, 1500);
        toast.success('URL copied!');
      });
    });
  }

  // ── renderBlocks ──────────────────────────────────────────────────────────
  function renderBlocks() {
    const container  = document.getElementById('sortable-blocks');
    const noResults  = document.getElementById('no-results');
    const emptyState = document.getElementById('empty-state');
    if (!container) return;

    const filtered  = getFiltered();
    const hasSearch = searchQuery || activeFilter !== 'all';

    if (blocks.length === 0) {
      container.innerHTML = '';
      if (emptyState) emptyState.style.display = '';
      if (noResults)  noResults.style.display  = 'none';
      return;
    }
    if (emptyState) emptyState.style.display = 'none';
    if (filtered.length === 0 && hasSearch) {
      container.innerHTML = '';
      if (noResults) noResults.style.display = '';
      return;
    }
    if (noResults) noResults.style.display = 'none';

    const sorted = [...filtered].sort((a: any, b: any) => (b.is_pinned ? 1 : 0) - (a.is_pinned ? 1 : 0));

    container.innerHTML = sorted.map((block: any) => {
      const isSelected = selectedIds.has(block.id);
      const clicks     = block.clicks ?? 0;
      const isPinned   = block.is_pinned ?? false;
      const iconUrl    = block.config?.icon_url || '';
      const platform   = block.type === 'link' ? detectPlatform(block.config?.url || '') : null;
      const badgeCls   = TYPE_BADGE_CLASS[block.type] ?? '';

      const iconHtml = iconUrl
        ? `<div class="bc-icon"><img src="${iconUrl}" loading="lazy" onerror="this.parentElement.innerHTML='<span>${BLOCK_EMOJI[block.type] ?? '📌'}</span>'" /></div>`
        : platform
          ? `<div class="bc-icon"><span>${platform.icon}</span></div>`
          : `<div class="bc-icon"><span>${BLOCK_EMOJI[block.type] ?? '📌'}</span></div>`;

      let subInfo = '';
      if (block.type === 'link' && block.config?.url) {
        try { subInfo = new URL(block.config.url).hostname.replace('www.', ''); } catch { subInfo = block.config.url.slice(0,40); }
      } else if (block.type === 'donation' && block.config?.goal_amount > 0) {
        const pct = Math.min(100, Math.round((block.config.current_amount / block.config.goal_amount) * 100));
        subInfo = `${block.config.current_amount ?? 0}/${block.config.goal_amount}€ · ${pct}%`;
      } else if (block.type === 'countdown' && block.config?.target_date) {
        const diff = new Date(block.config.target_date).getTime() - Date.now();
        subInfo = diff > 0 ? `in ${Math.floor(diff/86400000)}d ${Math.floor((diff%86400000)/3600000)}h` : 'Expired';
      } else if (block.type === 'schedule' && block.config?.schedule?.length) {
        subInfo = block.config.schedule.slice(0,3).map((s: any) => s.day?.slice(0,3)).join(', ');
      } else if (block.type === 'poll' && block.config?.options?.length) {
        const total = block.config.options.reduce((s: number, o: any) => s + (o.votes ?? 0), 0);
        subInfo = `${block.config.options.length} options · ${total} votes`;
      } else if (block.type === 'twitch_live' && block.config?.channel) {
        subInfo = `twitch.tv/${block.config.channel}`;
      } else if (block.type === 'embed' && block.config?.url) {
        try { subInfo = new URL(block.config.url).hostname.replace('www.',''); } catch { subInfo = 'embed'; }
      } else if (block.type === 'text' && block.config?.content) {
        subInfo = block.config.content.slice(0, 45) + (block.config.content.length > 45 ? '…' : '');
      } else if (block.type === 'social') {
        subInfo = `${block.config?.links?.length ?? 0} links`;
      } else if (block.type === 'product' && block.config?.price) {
        subInfo = `${block.config.price} ${block.config.currency || '€'}`;
      } else if (block.type === 'merch_grid' && block.config?.items?.length) {
        subInfo = `${block.config.items.length} item${block.config.items.length > 1 ? 's' : ''}`;
      } else if (block.type === 'newsletter') {
        subInfo = block.config?.provider || 'custom';
      } else if (block.type === 'vcard') {
        subInfo = [block.config?.first_name, block.config?.last_name].filter(Boolean).join(' ');
      } else if (block.type === 'banner') {
        subInfo = (block.config?.badge || block.config?.badge_preset || 'LIVE').toUpperCase();
      }

      const clicksHtml = clicks > 0 ? `<span class="bc-clicks">${clicks >= 1000 ? (clicks/1000).toFixed(1)+'k' : clicks} clicks</span>` : '';
      const pinHtml    = isPinned ? '<span class="bc-pin" title="Pinned">📌</span>' : '';
      const newHtml    = isNew(block.created_at) ? '<span class="bc-new">New</span>' : '';
      const schedHtml  = isScheduled(block) ? '<span class="bc-sched" title="Scheduled">⏰</span>' : '';

      return `
        <div class="bc ${isSelected ? 'bc--selected' : ''} ${isPinned ? 'bc--pinned' : ''}" data-id="${block.id}" data-type="${block.type}">
          ${isPinned ? '<div class="bc-pintab"></div>' : ''}

          <div class="bc-check ${selectedIds.size > 0 ? 'bc-check--vis' : ''}">
            <input type="checkbox" ${isSelected ? 'checked' : ''} class="block-select" data-id="${block.id}" />
          </div>

          <div class="bc-drag drag-handle touch-none" title="Drag to reorder">
            <svg width="10" height="14" fill="none" viewBox="0 0 10 14">
              <circle cx="3" cy="3"  r="1.5" fill="currentColor"/>
              <circle cx="7" cy="3"  r="1.5" fill="currentColor"/>
              <circle cx="3" cy="7"  r="1.5" fill="currentColor"/>
              <circle cx="7" cy="7"  r="1.5" fill="currentColor"/>
              <circle cx="3" cy="11" r="1.5" fill="currentColor"/>
              <circle cx="7" cy="11" r="1.5" fill="currentColor"/>
            </svg>
          </div>

          ${iconHtml}

          <div class="bc-body">
            <div class="bc-row1">
              <span class="bc-type-badge ${badgeCls}">${block.type}</span>
              ${block.title
                ? `<span class="block-title-editable bc-title" data-id="${block.id}" title="Double-click to rename">${block.title}</span>`
                : `<span class="bc-notitle">Untitled</span>`}
              ${pinHtml}${newHtml}${schedHtml}
            </div>
            ${subInfo ? `<div class="bc-sub">${subInfo}</div>` : ''}
          </div>

          ${clicksHtml}

          <span class="bc-dot ${block.active ? 'bc-dot--on' : 'bc-dot--off'}" title="${block.active ? 'Active' : 'Inactive'}"></span>

          <label class="bc-toggle-wrap" title="${block.active ? 'Deactivate' : 'Activate'}">
            <input type="checkbox" ${block.active ? 'checked' : ''} class="block-toggle" data-id="${block.id}" style="position:absolute;opacity:0;width:0;height:0" />
            <div class="bc-toggle-track"><div class="bc-toggle-thumb"></div></div>
          </label>

          ${block.type === 'link' && block.config?.url
            ? `<button class="block-copy-btn bc-copy" data-url="${block.config.url}" title="Copy URL">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.1-1.1m-.757-4.9a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              </button>`
            : `<span style="width:26px;flex-shrink:0"></span>`}

          <div class="bc-menu-wrap">
            <button class="block-menu-btn bc-menu-btn" data-id="${block.id}" aria-label="Options">
              <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="5" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="12" cy="19" r="1.8"/>
              </svg>
            </button>
            <div class="bc-dropdown" data-id="${block.id}" style="display:none">
              <button class="bc-menu-item block-edit-btn" data-id="${block.id}">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Edit
              </button>
              <button class="bc-menu-item block-pin-btn" data-id="${block.id}" data-pinned="${isPinned}">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                ${isPinned ? 'Unpin' : 'Pin to top'}
              </button>
              <button class="bc-menu-item block-duplicate-btn" data-id="${block.id}">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                Duplicate
              </button>
              <div class="bc-menu-divider"></div>
              <button class="bc-menu-item bc-menu-item--danger block-delete-btn" data-id="${block.id}">
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Delete
              </button>
            </div>
          </div>
        </div>`;
    }).join('');

    attachCardListeners();
    attachInlineEdit();
    attachCopyBtns();
    initSortable();
    updateBulkBar();
    schedulePreviewRefresh();
  }

  document.addEventListener('click', (e: any) => {
    if (!e.target.closest('.bc-menu-wrap')) {
      document.querySelectorAll('.bc-dropdown').forEach(d => (d as HTMLElement).style.display = 'none');
    }
  });

  function attachCardListeners() {
    document.querySelectorAll('.block-toggle').forEach(toggle => {
      toggle.addEventListener('change', async (e: any) => {
        const id = e.target.dataset.id; const active = e.target.checked;
        try {
          await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active }) });
          const b = blocks.find((b: any) => b.id === id);
          if (b) { b.active = active; }
          const card = document.querySelector(`.bc[data-id="${id}"]`);
          const dot  = card?.querySelector('.bc-dot');
          if (dot) { dot.classList.toggle('bc-dot--on', active); dot.classList.toggle('bc-dot--off', !active); }
          toast.success(active ? 'Block activated' : 'Block deactivated');
        } catch { e.target.checked = !active; toast.error('Failed to update'); }
      });
    });
    document.querySelectorAll('.block-select').forEach(cb => {
      cb.addEventListener('change', (e: any) => {
        const id = e.target.dataset.id;
        e.target.checked ? selectedIds.add(id) : selectedIds.delete(id);
        document.querySelector(`.bc[data-id="${id}"]`)?.classList.toggle('bc--selected', e.target.checked);
        updateBulkBar();
      });
    });
    document.querySelectorAll('.block-menu-btn').forEach(btn => {
      btn.addEventListener('click', (e: any) => {
        e.stopPropagation();
        document.querySelectorAll('.bc-dropdown').forEach(d => (d as HTMLElement).style.display = 'none');
        const id = (btn as HTMLElement).dataset.id;
        const drop = document.querySelector(`.bc-dropdown[data-id="${id}"]`) as HTMLElement | null;
        if (drop) drop.style.display = drop.style.display === 'none' ? '' : 'none';
      });
    });
    document.querySelectorAll('.block-edit-btn').forEach(btn =>
      btn.addEventListener('click', () => handleEditBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-pin-btn').forEach(btn =>
      btn.addEventListener('click', () => handlePinBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-duplicate-btn').forEach(btn =>
      btn.addEventListener('click', () => handleDuplicateBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-delete-btn').forEach(btn =>
      btn.addEventListener('click', () => handleDeleteBlock((btn as HTMLElement).dataset.id!)));
  }

  async function handlePinBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block) return;
    const newPinned = !block.is_pinned;
    try {
      await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ is_pinned: newPinned }) });
      block.is_pinned = newPinned;
      renderBlocks();
      toast.success(newPinned ? '📌 Block pinned' : 'Block unpinned');
    } catch { toast.error('Failed to update pin'); }
  }

  function initSortable() {
    const container = document.getElementById('sortable-blocks');
    if (!container) return;
    if (!(window as any).Sortable) { setTimeout(initSortable, 30); return; }
    sortable?.destroy();
    sortable = new (window as any).Sortable(container, {
      animation: 200, handle: '.drag-handle',
      ghostClass: 'sortable-ghost', dragClass: 'sortable-drag',
      onEnd: async () => {
        const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
        const visibleIds = Array.from(container.children)
          .map((el: any) => el.dataset.id)
          .filter((id: any) => id && UUID_RE.test(id));
        if (!visibleIds.length) return;
        let blockIds: string[];
        if (activeFilter === 'all' && !searchQuery) {
          blockIds = visibleIds;
        } else {
          const vs = new Set(visibleIds);
          blockIds = [...visibleIds, ...blocks.filter((b: any) => !vs.has(b.id)).map((b: any) => b.id)];
        }
        try {
          await apiCall('/api/blocks/reorder', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ blockIds }) });
          blocks = blockIds.map((id: string) => blocks.find((b: any) => b.id === id)).filter(Boolean);
          toast.success('Order saved');
        } catch { toast.error('Failed to save order'); renderBlocks(); }
      },
    });
  }

  function updateBulkBar() {
    const bar = document.getElementById('bulk-bar');
    const cnt = document.getElementById('bulk-count');
    if (!bar || !cnt) return;
    bar.style.display = selectedIds.size > 0 ? 'flex' : 'none';
    cnt.textContent = `${selectedIds.size} selected`;
    document.querySelectorAll('.bc-check').forEach(el => {
      el.classList.toggle('bc-check--vis', selectedIds.size > 0);
    });
  }

  document.getElementById('bulk-cancel-btn')?.addEventListener('click', () => { selectedIds.clear(); renderBlocks(); });
  document.getElementById('bulk-toggle-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    const newActive = !ids.every(id => blocks.find((b: any) => b.id === id)?.active);
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active: newActive }) })));
      ids.forEach(id => { const b = blocks.find((b: any) => b.id === id); if (b) b.active = newActive; });
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} ${newActive ? 'activated' : 'deactivated'}`);
    } catch { toast.error('Bulk toggle failed'); }
  });
  document.getElementById('bulk-delete-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    if (!confirm(`Delete ${ids.length} block${ids.length > 1 ? 's' : ''}?`)) return;
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, { method:'DELETE' })));
      blocks = blocks.filter((b: any) => !ids.includes(b.id));
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} deleted`);
    } catch { toast.error('Bulk delete failed'); }
  });

  document.getElementById('search-input')?.addEventListener('input', (e: any) => {
    searchQuery = e.target.value.toLowerCase().trim(); renderBlocks();
  });
  document.querySelectorAll('.filter-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = (btn as HTMLElement).dataset.filter!;
      document.querySelectorAll('.filter-tab').forEach(b => b.classList.toggle('active', b === btn));
      renderBlocks();
    });
  });
  document.getElementById('clear-search-btn')?.addEventListener('click', () => {
    searchQuery = ''; activeFilter = 'all';
    (document.getElementById('search-input') as HTMLInputElement).value = '';
    document.querySelectorAll('.filter-tab').forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.filter === 'all'));
    renderBlocks();
  });

  // ── Quick-add ─────────────────────────────────────────────────────────────
  const quickInput  = document.getElementById('quick-add-input') as HTMLInputElement;
  const detectZone  = document.getElementById('quick-detect-zone')!;
  const platIconEl  = document.getElementById('quick-plat-icon')!;
  const platLabelEl = document.getElementById('quick-plat-label')!;
  let quickUrl = ''; let quickPlat: any = null;

  quickInput?.addEventListener('input', () => {
    const val = quickInput.value.trim();
    if (val.startsWith('http')) {
      quickUrl = val; quickPlat = detectPlatform(val);
      platIconEl.textContent  = quickPlat?.icon  ?? '🔗';
      platLabelEl.textContent = quickPlat?.label ?? 'Link detected';
      detectZone.style.display = 'flex';
    } else if (val.length > 1) {
      quickInput.value = '';
      detectZone.style.display = 'none';
      openTypeModal();
      setTimeout(() => {
        const searchEl = document.getElementById('type-search') as HTMLInputElement;
        if (searchEl) { searchEl.value = val; searchEl.dispatchEvent(new Event('input')); }
      }, 50);
    } else {
      detectZone.style.display = 'none';
    }
  });
  quickInput?.addEventListener('paste', () => setTimeout(() => quickInput.dispatchEvent(new Event('input')), 0));

  document.getElementById('quick-add-confirm')?.addEventListener('click', async () => {
    if (!quickUrl || !canAddBlock) { if (!canAddBlock) toast.error('Block limit reached!'); return; }
    const title   = getDefaultTitle(quickUrl, quickPlat);
    const iconUrl = quickPlat?.defaultIcon ?? '';
    try {
      const data = await apiCall('/api/blocks', { method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ type:'link', title, config:{ url: quickUrl, ...(iconUrl ? { icon_url: iconUrl } : {}) } }) });
      blocks.push({ id: data.id, type:'link', title, config:{ url: quickUrl, icon_url: iconUrl }, active:true, created_at: new Date().toISOString(), clicks:0, is_pinned:false });
      renderBlocks();
      toast.success(`${quickPlat?.label ?? 'Link'} added!`);
      quickInput.value = '';
      detectZone.style.display = 'none';
    } catch (err: any) { toast.error(err.message || 'Failed to add'); }
  });
  document.getElementById('quick-add-cancel')?.addEventListener('click', () => {
    quickInput.value = '';
    detectZone.style.display = 'none';
  });

  // ── Modals ────────────────────────────────────────────────────────────────
  function openModal(id: string)  {
    const el = document.getElementById(id);
    if (el) { el.style.display = 'flex'; el.classList.add('open'); }
  }
  function closeModal(id: string) {
    const el = document.getElementById(id);
    if (el) { el.style.display = 'none'; el.classList.remove('open'); }
  }

  document.getElementById('type-backdrop')?.addEventListener('click', () => closeModal('type-modal'));
  document.getElementById('edit-backdrop')?.addEventListener('click', () => closeModal('edit-modal'));
  document.getElementById('type-close')?.addEventListener('click',    () => closeModal('type-modal'));
  document.getElementById('edit-close')?.addEventListener('click',    () => closeModal('edit-modal'));
  document.getElementById('cancel-btn')?.addEventListener('click',    () => closeModal('edit-modal'));

  // ── Streamer kits ─────────────────────────────────────────────────────────
  const STREAMER_KITS = [
    { id:'gaming', label:'Gaming', emoji:'🎮', desc:'Twitch · Discord · Countdown · Ko-fi', color:'#7c3aed', blocks:[
      { type:'link',      title:'Live on Twitch',   config:{ url:'https://twitch.tv/',    icon_url:'https://bioforge.click/social/twitch.png'   } },
      { type:'link',      title:'Join my Discord',  config:{ url:'https://discord.gg/',   icon_url:'https://bioforge.click/social/discord.png'  } },
      { type:'countdown', title:'Next stream',      config:{ target_date:'', label:'Next stream in' } },
      { type:'schedule',  title:'Stream schedule',  config:{ schedule:[] } },
      { type:'donation',  title:'Support me ☕',    config:{ donation_platform:'kofi', url:'https://ko-fi.com/', goal_amount:0 } },
    ]},
    { id:'irl', label:'IRL', emoji:'📱', desc:'Instagram · TikTok · Patreon', color:'#ec4899', blocks:[
      { type:'link',     title:'My Instagram',  config:{ url:'https://instagram.com/', icon_url:'https://bioforge.click/social/instagram.png' } },
      { type:'link',     title:'My TikTok',     config:{ url:'https://tiktok.com/',    icon_url:'https://bioforge.click/social/tiktok.png'    } },
      { type:'social',   title:'My socials',    config:{ links:[] } },

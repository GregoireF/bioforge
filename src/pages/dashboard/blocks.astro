  quickInput?.addEventListener('input', () => {
    const val = quickInput.value.trim();
    if (val.startsWith('http')) {
      quickUrl = val; quickPlat = detectPlatform(val);
      platIconEl.textContent  = quickPlat?.icon  ?? '🔗';
      platLabelEl.textContent = quickPlat?.label ?? 'Link détecté';
      detectZone.classList.remove('hidden'); detectZone.classList.add('flex');
    } else if (val.length > 1) {

          <input type="email" id="field-vcard-email" value="${val('email')}" placeholder="alex@example.com" class="${IC}" /></div>
        <div class="space-y-1.5"><label class="text-sm font-medium text-gray-300">Téléphone</label>
          <input type="tel" id="field-vcard-phone" value="${val('phone')}" placeholder="+33 6 00 00 00 00" class="${IC}" /></div>
        <div class="space-y-1.5"><label class="text-sm font-medium text-gray-300">Site web</label>
          <input type="url" id="field-vcard-website" value="${val('website')}" placeholder="https://bioforge.click/@monpseudo" class="${IC}" /></div>
        <div class="grid grid-cols-2 gap-3">
          <div class="space-y-1.5"><label class="text-sm font-medium text-gray-300">Entreprise / Orga</label>
            <input type="text" id="field-vcard-company" value="${val('company')}" maxlength="80" class="${IC}" /></div>
          <div class="space-y-1.5"><label class="text-sm font-medium text-gray-300">Rôle / Poste</label>
            <input type="text" id="field-vcard-role" value="${val('role')}" maxlength="80" placeholder="Streamer / Creator" class="${IC}" /></div>
        </div>`,

      merch_grid: `
        <div class="space-y-1.5"><label class="text-sm font-medium text-gray-300">Titre de section <span class="text-gray-500 text-xs">optionnel</span></label>
          <input type="text" id="field-title" value="${titleVal || 'Mon Merch'}" maxlength="80" placeholder="Mon Merch" class="${IC}" /></div>
        <div class="space-y-3" id="merch-items-list">
          ${(block?.config?.items?.length ? block.config.items : [{},{},{}]).slice(0,3).map((it: any, i: number) => `
            <div class="merch-item rounded-xl overflow-hidden border border-white/10 bg-white/3" data-i="${i}">
              <!-- Header article -->
              <div class="flex items-center justify-between px-3 py-2 bg-white/5 border-b border-white/8">
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Article ${i+1}</span>
                <span class="text-xs text-gray-600">Optionnel si vide</span>
              </div>
              <div class="p-3 space-y-2">
                <!-- Nom + URL côte à côte -->
                <div class="grid grid-cols-1 gap-2">
                  <input type="text" class="merch-title ${IC}" value="${it.title || ''}" placeholder="Nom du produit" maxlength="80" />
                  <input type="url" class="merch-url ${IC}" value="${it.url || ''}" placeholder="https://throne.com/..." />
                </div>
                <!-- Image URL avec preview -->
                <div class="flex items-center gap-2">
                  <div class="shrink-0 w-12 h-12 rounded-lg overflow-hidden border border-white/15 bg-white/5 flex items-center justify-center" id="merch-img-preview-${i}">
                    ${it.image_url
                      ? `<img src="${it.image_url}" class="w-full h-full object-cover" />`
                      : `<svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`
                    }
                  </div>
                  <input type="url" class="merch-img ${IC} flex-1" value="${it.image_url || ''}" placeholder="URL image (optionnel)" data-preview-id="merch-img-preview-${i}" />
                </div>
                <!-- Prix avec symbole visuel -->
                <div class="flex gap-2 items-stretch">
                  <div class="relative flex-1">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-bold text-neon-green pointer-events-none select-none merch-currency-symbol">${it.currency === 'USD' ? '$' : it.currency === 'GBP' ? '£' : '€'}</span>
                    <input type="text" class="merch-price w-full pl-8 pr-4 py-3 glass border border-white/10 rounded-xl text-white text-sm placeholder-gray-500 focus:border-neon-green/50 focus:outline-none focus:ring-1 focus:ring-neon-green/20 transition-colors" value="${it.price || ''}" placeholder="24.90" />
                  </div>
                  <select class="merch-currency px-3 py-3 glass border border-white/10 rounded-xl text-white text-sm bg-transparent focus:border-neon-green/50 focus:outline-none transition-colors w-24 shrink-0" style="background: rgba(255,255,255,0.05);">
                    ${['EUR','USD','GBP'].map(c => `<option value="${c}" style="background:#1a1a2e;color:#fff;" ${(it.currency||'EUR')===c?'selected':''}>${c}</option>`).join('')}
                  </select>
                </div>
              </div>
            </div>`).join('')}
        </div>
        <p class="text-xs text-gray-600">Les articles sans nom ou URL sont ignorés. Max 3 articles.</p>`,
    };

    const fields = document.getElementById('form-fields')!;
    fields.innerHTML = fieldHtml[type] ?? `<div class="py-4 text-center text-sm text-gray-500">Type "${type}" non supporté.</div>`;

    // Visibility section visibility
    document.getElementById('schedule-visibility-section')!.classList.toggle('hidden', type === 'spacer');
    const showFrom  = document.getElementById('field-show-from')  as HTMLInputElement | null;
    const showUntil = document.getElementById('field-show-until') as HTMLInputElement | null;
    if (showFrom  && block?.config?.show_from)  showFrom.value  = block.config.show_from.slice(0,16);
    if (showUntil && block?.config?.show_until) showUntil.value = block.config.show_until.slice(0,16);

    openModal('edit-modal');
    if (type === 'link') setTimeout(attachOgFetch, 50);
    setTimeout(() => (fields.querySelector('input:not([type="checkbox"]):not([type="time"]):not([type="hidden"]), textarea') as HTMLElement|null)?.focus(), 100);

    // Donation platform pills
    if (type === 'donation') {
      document.querySelectorAll('.don-plat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.plat!;
          (document.getElementById('field-donation-platform') as HTMLInputElement).value = id;
          document.querySelectorAll('.don-plat-btn').forEach(b => {
            b.classList.toggle('border-neon-green/50', b === btn);
            b.classList.toggle('bg-neon-green/5', b === btn);
            b.classList.toggle('text-white', b === btn);
            b.classList.toggle('border-white/10', b !== btn);
            b.classList.toggle('text-gray-400', b !== btn);
          });
        });
      });
    }

    // Schedule day checkboxes + multi-slot management
    if (type === 'schedule') {
      function refreshSlotRemoveBtns(day: string) {
        const container = document.getElementById(`sch-slots-${day.toLowerCase()}`);
        if (!container) return;
        const rows = container.querySelectorAll('.sch-slot-row');
        rows.forEach(row => {
          const rmBtn = row.querySelector('.rm-slot') as HTMLElement | null;
          if (rmBtn) rmBtn.style.display = rows.length > 1 ? '' : 'none';
        });
      }

      document.querySelectorAll('.sch-day-cb').forEach((cb: any) => {
        cb.addEventListener('change', () => {
          const day       = cb.dataset.day as string;
          const container = document.getElementById(`sch-slots-${day.toLowerCase()}`);
          const addBtn    = container?.querySelector('.add-slot') as HTMLElement | null;
          if (!container) return;
          const active = cb.checked;
          container.classList.toggle('opacity-30',        !active);
          container.classList.toggle('pointer-events-none', !active);
          if (addBtn) addBtn.classList.toggle('hidden', !active);
        });
      });

      document.querySelectorAll('.add-slot').forEach(btn => {
        btn.addEventListener('click', () => {
          const day       = (btn as HTMLElement).dataset.day!;
          const container = document.getElementById(`sch-slots-${day.toLowerCase()}`);
          if (!container) return;
          const addBtnEl  = container.querySelector('.add-slot');
          const row       = document.createElement('div');
          row.className   = 'sch-slot-row flex items-center gap-2';
          row.dataset.day = day;
          row.innerHTML   = `
            <input type="time" class="sch-time-input px-3 py-1.5 glass border border-white/10 rounded-lg text-white text-sm focus:border-neon-green/40 focus:outline-none transition-colors w-28"
              data-day="${day}" value="20:00" />
            <button type="button" class="rm-slot text-gray-600 hover:text-red-400 transition-colors shrink-0" data-day="${day}">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>`;
          row.querySelector('.rm-slot')?.addEventListener('click', () => {
            row.remove();
            refreshSlotRemoveBtns(day);
          });
          container.insertBefore(row, addBtnEl);
          refreshSlotRemoveBtns(day);
          (row.querySelector('input') as HTMLElement)?.focus();
        });
      });

      document.querySelectorAll('.rm-slot').forEach(btn => {
        btn.addEventListener('click', () => {
          const day = (btn as HTMLElement).dataset.day!;
          btn.closest('.sch-slot-row')?.remove();
          refreshSlotRemoveBtns(day);
        });
      });

      // Init remove button visibility
      DAYS_FR.forEach((day: string) => refreshSlotRemoveBtns(day));
    }

    // Visibility accordion
    document.getElementById('visibility-toggle')?.addEventListener('click', () => {
      const panel = document.getElementById('visibility-panel');
      panel?.classList.toggle('hidden');
      const ch = document.getElementById('vis-chevron');
      if (ch) ch.style.transform = panel?.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });

    // Icon live preview
    const iconInput = document.getElementById('field-icon-url') as HTMLInputElement | null;
    const iconWrap  = document.getElementById('icon-preview-wrap');
    if (iconInput && iconWrap) {
      const empty = `<svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`;
      iconInput.addEventListener('input', () => {
        const u = iconInput.value.trim();
        iconWrap.innerHTML = u ? `<img src="${u}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='${empty.replace(/'/g,"\\'")}'"/>` : empty;
      });
      const urlField = document.getElementById('field-url') as HTMLInputElement | null;
      urlField?.addEventListener('blur', () => {
        if (iconInput.value) return;
        const plat = detectPlatform(urlField.value.trim());
        if (plat?.defaultIcon) { iconInput.value = plat.defaultIcon; iconWrap.innerHTML = `<img src="${plat.defaultIcon}" class="w-full h-full object-cover" />`; }
      });
    }

    // MerchGrid: image preview live + currency symbol update
    if (type === 'merch_grid') {
      const CURRENCY_SYMBOLS = { EUR: '€', USD: '$', GBP: '£' };
      const emptyImgSvg = '<svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>';
      document.querySelectorAll('.merch-img').forEach(inp => {
        const input     = inp;
        const previewId = input.dataset.previewId;
        if (!previewId) return;
        const preview = document.getElementById(previewId);
        if (!preview) return;
        input.addEventListener('input', () => {
          const u = input.value.trim();
          preview.innerHTML = u
            ? `<img src="${u}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML=this.dataset.empty" data-empty="${emptyImgSvg.replace(/"/g, '&quot;')}" />`
            : emptyImgSvg;
        });
      });
      document.querySelectorAll('.merch-currency').forEach(sel => {
        sel.addEventListener('change', () => {
          const row    = sel.closest('.merch-item');
          const symbol = row?.querySelector('.merch-currency-symbol');
          if (symbol) symbol.textContent = CURRENCY_SYMBOLS[sel.value] ?? '€';
        });
      });
    }

    // Banner preset pills
    if (type === 'banner') {
      const badgeInput  = document.getElementById('field-banner-badge')  as HTMLInputElement | null;
      const presetInput = document.getElementById('field-banner-preset') as HTMLInputElement | null;
      document.querySelectorAll('.banner-preset-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const p = (btn as HTMLElement).dataset.preset!;
          if (badgeInput)  badgeInput.value  = p;
          if (presetInput) presetInput.value = p;
          document.querySelectorAll('.banner-preset-btn').forEach(b => {
            b.classList.toggle('border-neon-green/50', b === btn);
            b.classList.toggle('bg-neon-green/10',    b === btn);
            b.classList.toggle('text-white',           b === btn);
            b.classList.toggle('border-white/15',      b !== btn);
            b.classList.toggle('text-gray-500',        b !== btn);
          });
        });
      });
    }

    // Newsletter provider pills
    if (type === 'newsletter') {
      document.querySelectorAll('.nl-plat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const p = (btn as HTMLElement).dataset.prov!;
          (document.getElementById('field-nl-provider') as HTMLInputElement).value = p;
          document.querySelectorAll('.nl-plat-btn').forEach(b => {
            b.classList.toggle('border-neon-green/50', b === btn);
            b.classList.toggle('bg-neon-green/5',      b === btn);
            b.classList.toggle('text-white',            b === btn);
            b.classList.toggle('border-white/10',       b !== btn);
            b.classList.toggle('text-gray-400',         b !== btn);
          });
        });
      });
    }

    // Poll options: add / remove
    if (type === 'poll') {
      function updatePollRemoveBtns() {
        const rows = document.querySelectorAll('.poll-option-row');
        rows.forEach((row, i) => {
          const btn = row.querySelector('.rm-poll-option') as HTMLElement;
          if (btn) { btn.classList.toggle('opacity-0', i < 2); btn.classList.toggle('pointer-events-none', i < 2); }
        });
      }
      document.getElementById('add-poll-option')?.addEventListener('click', () => {
        const list = document.getElementById('poll-options-list');
        if (!list) return;
        const count = list.querySelectorAll('.poll-option-row').length;
        if (count >= 4) return;
        const row = document.createElement('div');
        row.className = `flex items-center gap-2 poll-option-row`;
        row.innerHTML = `
          <span class="text-xs text-gray-600 w-4 shrink-0">${count+1}.</span>
          <input type="text" class="poll-opt-input ${IC} flex-1" value="" maxlength="80" placeholder="Option ${count+1}" />
          <input type="hidden" class="poll-opt-votes" value="0" />
          <button type="button" class="rm-poll-option text-gray-600 hover:text-red-400 transition-colors shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>`;
        list.appendChild(row);
        updatePollRemoveBtns();
        attachPollRemove();
      });
      function attachPollRemove() {
        document.querySelectorAll('.rm-poll-option').forEach(btn => {
          btn.addEventListener('click', () => {
            btn.closest('.poll-option-row')?.remove();
            // Renumber
            document.querySelectorAll('.poll-option-row').forEach((row, i) => {
              const sp = row.querySelector('span') as HTMLElement;
              if (sp) sp.textContent = `${i+1}.`;
            });
            updatePollRemoveBtns();
          });
        });
      }
      attachPollRemove();
      updatePollRemoveBtns();
    }
  }

  // ── Form submit ────────────────────────────────────────────────────────────
  document.getElementById('block-form')?.addEventListener('submit', async (e: any) => {
    e.preventDefault();
    if (isSaving) return;
    const type    = (document.getElementById('block-type') as HTMLInputElement).value;
    const blockId = (document.getElementById('block-id')   as HTMLInputElement).value ?? '';
    const submitBtn  = document.getElementById('submit-btn');
    const submitText = document.getElementById('submit-text')!;

    let title: string | null = null;
    let config: any = {};

    const titleEl   = document.getElementById('field-title')    as HTMLInputElement | null;
    const urlEl     = document.getElementById('field-url')      as HTMLInputElement | null;
    const linksEl   = document.getElementById('field-links')    as HTMLTextAreaElement | null;
    const iconUrlEl = document.getElementById('field-icon-url') as HTMLInputElement | null;
    const showFrom  = (document.getElementById('field-show-from')  as HTMLInputElement | null)?.value?.trim() || null;
    const showUntil = (document.getElementById('field-show-until') as HTMLInputElement | null)?.value?.trim() || null;
    const vis       = (k: string, v: any) => v ? { [k]: v } : {};

    switch (type) {
      case 'link': {
        title = titleEl?.value?.trim() ?? null;
        const url = urlEl?.value?.trim() ?? '';
        const ico = iconUrlEl?.value?.trim() ?? '';
        if (!title) { toast.error('Le titre est requis'); return; }
        if (!url || !url.startsWith('http')) { toast.error('URL valide requise'); return; }
        if (ico && !ico.startsWith('http')) { toast.error("L'icône doit commencer par https://"); return; }
        config = { url, ...(ico ? { icon_url: ico } : {}), ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'heading':
        title = titleEl?.value?.trim() ?? null;
        if (!title) { toast.error('Le texte est requis'); return; }
        break;
      case 'spacer': break;
      case 'image': {
        const u = urlEl?.value?.trim() ?? '';
        if (!u || !u.startsWith('http')) { toast.error('URL image valide requise'); return; }
        title = titleEl?.value?.trim() || null;
        config = { url: u, ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'video': {
        const u = urlEl?.value?.trim() ?? '';
        if (!u || !u.startsWith('http')) { toast.error('URL vidéo valide requise'); return; }
        title = titleEl?.value?.trim() || null;
        config = { url: u, ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'social': {
        title = titleEl?.value?.trim() || null;
        const links = (linksEl?.value?.trim() ?? '').split('\n').map(u => u.trim()).filter(u => u.startsWith('http')).map(u => ({ url: u }));
        if (!links.length) { toast.error('Au moins un URL valide requis'); return; }
        config = { links, ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'countdown': {
        title = titleEl?.value?.trim() ?? null;
        const d = (document.getElementById('field-countdown-date') as HTMLInputElement)?.value;
        if (!title) { toast.error('Le label est requis'); return; }
        if (!d)     { toast.error('La date cible est requise'); return; }
        config = { target_date: d, label: title };
        break;
      }
      case 'schedule': {
        title = titleEl?.value?.trim() || 'Planning stream';
        const scheduleMap = new Map<string, string[]>();
        document.querySelectorAll('.sch-day-cb').forEach((cb: any) => {
          if (!cb.checked) return;
          const day   = cb.dataset.day as string;
          const times = Array.from(document.querySelectorAll(`.sch-time-input[data-day="${day}"]`))
            .map(el => (el as HTMLInputElement).value)
            .filter(Boolean);
          scheduleMap.set(day, times.length ? times : ['20:00']);
        });
        if (!scheduleMap.size) { toast.error('Coche au moins un jour'); return; }
        config = { schedule: Array.from(scheduleMap.entries()).map(([day, slots]) => ({ day, slots })) };
        break;
      }
      case 'donation': {
        title = titleEl?.value?.trim() ?? null;
        const u    = urlEl?.value?.trim() ?? '';
        const plat = (document.getElementById('field-donation-platform') as HTMLInputElement)?.value || 'other';
        const goal = parseFloat((document.getElementById('field-goal')    as HTMLInputElement)?.value || '0') || 0;
        const cur  = parseFloat((document.getElementById('field-current') as HTMLInputElement)?.value || '0') || 0;
        if (!title) { toast.error('Le titre est requis'); return; }
        if (!u || !u.startsWith('http')) { toast.error("L'URL de don est requise"); return; }
        config = { url: u, donation_platform: plat, goal_amount: goal, current_amount: cur };
        break;
      }
      case 'embed': {
        title = titleEl?.value?.trim() || null;
        const u = urlEl?.value?.trim() ?? '';
        const h = parseInt((document.getElementById('field-embed-height') as HTMLInputElement)?.value || '152');
        if (!u || !u.startsWith('http')) { toast.error('URL valide requise'); return; }
        config = { url: u, height: Math.min(500, Math.max(80, h || 152)) };
        break;
      }
      case 'text': {
        const content = (document.getElementById('field-text-content') as HTMLTextAreaElement)?.value?.trim() ?? '';
        if (!content) { toast.error('Le contenu est requis'); return; }
        title = titleEl?.value?.trim() || null;
        const align    = (document.getElementById('field-text-align') as HTMLSelectElement)?.value || 'center';
        const textSize = (document.getElementById('field-text-size')  as HTMLSelectElement)?.value || 'md';
        config = { content, align, text_size: textSize, ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'banner': {
        title = titleEl?.value?.trim() ?? null;
        const badge    = (document.getElementById('field-banner-badge')  as HTMLInputElement)?.value?.trim() || 'LIVE';
        const preset   = (document.getElementById('field-banner-preset') as HTMLInputElement)?.value || 'LIVE';
        const url      = urlEl?.value?.trim() || null;
        const urlLabel = (document.getElementById('field-banner-cta') as HTMLInputElement)?.value?.trim() || null;
        if (!title) { toast.error('Le message est requis'); return; }
        config = { badge, badge_preset: preset, message: title, ...(url ? { url } : {}), ...(urlLabel ? { url_label: urlLabel } : {}), ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'product': {
        title = titleEl?.value?.trim() ?? null;
        const url      = urlEl?.value?.trim() ?? '';
        const imageUrl = (document.getElementById('field-product-image')    as HTMLInputElement)?.value?.trim() || null;
        const price    = (document.getElementById('field-product-price')    as HTMLInputElement)?.value?.trim() || null;
        const currency = (document.getElementById('field-product-currency') as HTMLSelectElement)?.value || 'EUR';
        const cta      = (document.getElementById('field-product-cta')      as HTMLInputElement)?.value?.trim() || 'Acheter →';
        if (!title) { toast.error('Le nom du produit est requis'); return; }
        if (!url || !url.startsWith('http')) { toast.error('URL produit valide requise'); return; }
        config = { url, ...(imageUrl ? { image_url: imageUrl } : {}), ...(price ? { price } : {}), currency, cta_label: cta, ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'poll': {
        title = titleEl?.value?.trim() ?? null;
        if (!title) { toast.error('La question est requise'); return; }
        const optInputs = document.querySelectorAll('.poll-opt-input') as NodeListOf<HTMLInputElement>;
        const optVotes  = document.querySelectorAll('.poll-opt-votes') as NodeListOf<HTMLInputElement>;
        const options   = Array.from(optInputs).map((inp, i) => ({
          text:  inp.value.trim(),
          votes: parseInt(optVotes[i]?.value || '0') || 0,
        })).filter(o => o.text);
        if (options.length < 2) { toast.error('Au moins 2 options valides requises'); return; }
        const allowMultiple = (document.getElementById('field-allow-multiple') as HTMLInputElement)?.checked ?? false;
        config = { question: title, options, allow_multiple: allowMultiple };
        break;
      }
      case 'twitch_live': {
        const channel = (document.getElementById('field-twitch-channel') as HTMLInputElement)?.value?.trim().toLowerCase() ?? '';
        if (!channel) { toast.error('Le nom de chaîne Twitch est requis'); return; }
        const showChat = (document.getElementById('field-twitch-chat') as HTMLInputElement)?.checked ?? false;
        title = titleEl?.value?.trim() || null;
        config = { channel, show_chat: showChat, ...(title ? { offline_message: title } : {}) };
        title = title || channel;
        break;
      }
      case 'newsletter': {
        title = titleEl?.value?.trim() ?? null;
        const actionUrl   = urlEl?.value?.trim() ?? '';
        const provider    = (document.getElementById('field-nl-provider')    as HTMLInputElement)?.value || 'custom';
        const placeholder = (document.getElementById('field-nl-placeholder') as HTMLInputElement)?.value?.trim() || 'ton@email.com';
        const nlCta       = (document.getElementById('field-nl-cta')         as HTMLInputElement)?.value?.trim() || "S'abonner";
        const nlSuccess   = (document.getElementById('field-nl-success')     as HTMLInputElement)?.value?.trim() || 'Merci !';
        if (!title) { toast.error('Le titre est requis'); return; }
        if (!actionUrl || !actionUrl.startsWith('http')) { toast.error("L'URL d'action est requise"); return; }
        config = { provider, action_url: actionUrl, url: actionUrl, nl_placeholder: placeholder, nl_cta: nlCta, nl_success: nlSuccess, ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      case 'vcard': {
        title = titleEl?.value?.trim() ?? null;
        const firstName = (document.getElementById('field-vcard-firstname') as HTMLInputElement)?.value?.trim() ?? '';
        const lastName  = (document.getElementById('field-vcard-lastname')  as HTMLInputElement)?.value?.trim() ?? '';
        const email     = (document.getElementById('field-vcard-email')     as HTMLInputElement)?.value?.trim() || null;
        const phone     = (document.getElementById('field-vcard-phone')     as HTMLInputElement)?.value?.trim() || null;
        const website   = (document.getElementById('field-vcard-website')   as HTMLInputElement)?.value?.trim() || null;
        const company   = (document.getElementById('field-vcard-company')   as HTMLInputElement)?.value?.trim() || null;
        const role      = (document.getElementById('field-vcard-role')      as HTMLInputElement)?.value?.trim() || null;
        if (!firstName) { toast.error('Le prénom est requis'); return; }
        if (!title)     { toast.error('Le titre du bouton est requis'); return; }
        config = { first_name: firstName, last_name: lastName, ...(email?{email}:{}), ...(phone?{phone}:{}), ...(website?{website}:{}), ...(company?{company}:{}), ...(role?{role}:{}) };
        break;
      }
      case 'merch_grid': {
        title = titleEl?.value?.trim() || null;
        const items: any[] = [];
        document.querySelectorAll('.merch-item').forEach(row => {
          const t  = (row.querySelector('.merch-title')    as HTMLInputElement)?.value?.trim();
          const u  = (row.querySelector('.merch-url')      as HTMLInputElement)?.value?.trim();
          const im = (row.querySelector('.merch-img')      as HTMLInputElement)?.value?.trim();
          const pr = (row.querySelector('.merch-price')    as HTMLInputElement)?.value?.trim();
          const cu = (row.querySelector('.merch-currency') as HTMLSelectElement)?.value || 'EUR';
          if (t && u && u.startsWith('http')) items.push({ title:t, url:u, ...(im?{image_url:im}:{}), ...(pr?{price:pr}:{}), currency:cu });
        });
        if (!items.length) { toast.error('Au moins un article valide requis'); return; }
        config = { items, ...vis('show_from', showFrom), ...vis('show_until', showUntil) };
        break;
      }
      default: toast.error(`Type inconnu: ${type}`); return;
    }

    isSaving = true;
    submitBtn?.setAttribute('disabled','');
    submitText.textContent = blockId ? 'Modification…' : 'Sauvegarde…';

    try {
      const data = await apiCall(blockId ? `/api/blocks/${blockId}` : '/api/blocks', {
        method: blockId ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, title: title ?? null, config }),
      });
      if (blockId) {
        const idx = blocks.findIndex((b: any) => b.id === blockId);
        if (idx !== -1) blocks[idx] = { ...blocks[idx], title, config, ...data };
      } else {
        blocks.push({ id: data.id, type, title, config, active: true, is_pinned: false, created_at: new Date().toISOString(), clicks: 0, ...data });
      }
      closeModal('edit-modal');
      renderBlocks();
      schedulePreviewRefresh();
      toast.success(blockId ? 'Block modifié !' : 'Block ajouté !');
    } catch (err: any) {
      toast.error(err.message?.includes('limit') ? 'Block limit reached!' : (err.message || 'Failed to save'));
    } finally {
      isSaving = false;
      submitBtn?.removeAttribute('disabled');
      submitText.textContent = blockId ? 'Update Block' : 'Save Block';
    }
  });

  function handleEditBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (block) openEditModal(block.type, block, null);
  }

  async function handleDuplicateBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block || !canAddBlock) { if (!canAddBlock) toast.error('Block limit reached!'); return; }
    try {
      const data = await apiCall('/api/blocks', { method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ type: block.type, title: block.title ? `${block.title} (copy)` : null, config: block.config }) });
      blocks.push({ ...block, id: data.id, title: block.title ? `${block.title} (copy)` : null, created_at: new Date().toISOString(), clicks: 0, is_pinned: false });
      renderBlocks();
      toast.success('Block dupliqué !');
    } catch (err: any) { toast.error(err.message || 'Failed to duplicate'); }
  }

  async function handleDeleteBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block) return;
    // Soft delete → archive (keep in DB as inactive, remove from UI)
    try {
      await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active: false }) });
      blocks = blocks.filter((b: any) => b.id !== id);
      archivedBlocks.unshift({ ...block });
      selectedIds.delete(id);
      renderBlocks(); renderArchive();
      toast.success('Block archivé — restaurable depuis la corbeille');
    } catch (err: any) { toast.error(err.message || 'Failed to archive'); }
  }

  document.addEventListener('keydown', (e: any) => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || (document.activeElement as HTMLElement)?.contentEditable === 'true') return;
    if (e.key === 'n' || e.key === 'N') { e.preventDefault(); openTypeModal(); }
    if (e.key === 'p' || e.key === 'P') { e.preventDefault(); previewOpen ? closePreview() : openPreview(); }
    if (e.key === 'Escape') { closeModal('type-modal'); closeModal('edit-modal'); closePreview(); }
  });

  renderBlocks();
</script>
  // ── Form ──────────────────────────────────────────────────────────────────
  const IC = 'w-full px-4 py-3 glass border border-white/10 rounded-xl text-white text-sm placeholder-gray-600 focus:border-neon-green/50 focus:outline-none focus:ring-1 focus:ring-neon-green/20 transition-colors';
  const DAYS_FR = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'];

  // Normalise old format {day,time} → new format {day,slots:[]}
  function normalizeSchedule(raw: any[]): {day: string; slots: string[]}[] {
    return raw.map((s: any) => ({
      day:   s.day,
      slots: Array.isArray(s.slots) && s.slots.length ? s.slots : [s.time ?? '20:00'],
    }));
  }

  function buildScheduleWidget(existing: any[]) {
    const normalized = normalizeSchedule(existing);
    const slotInput = (day: string, val: string, idx: number, canRemove: boolean) =>
      `<div class="sch-slot-row flex items-center gap-2" data-day="${day}" data-idx="${idx}">
        <input type="time" class="sch-time-input px-3 py-1.5 glass border border-white/10 rounded-lg text-white text-sm focus:border-neon-green/40 focus:outline-none transition-colors w-28"
          data-day="${day}" value="${val}" />
        ${canRemove ? `<button type="button" class="rm-slot text-gray-600 hover:text-red-400 transition-colors shrink-0" data-day="${day}">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>` : `<span class="w-5 shrink-0"></span>`}
      </div>`;

    return `<div id="schedule-rows" class="space-y-3">${DAYS_FR.map(day => {
      const found = normalized.find(s => s.day === day);
      const active = !!found;
      const slots  = found?.slots ?? ['20:00'];
      return `<div class="sch-day-block" data-day="${day}">
        <div class="flex items-start gap-3">
          <label class="flex items-center gap-2 cursor-pointer w-28 shrink-0 mt-2">
            <input type="checkbox" class="sch-day-cb w-4 h-4 rounded accent-neon-green" data-day="${day}" ${active ? 'checked' : ''} />
            <span class="text-sm text-gray-300">${day}</span>
          </label>
          <div class="flex-1 space-y-1.5 ${!active ? 'opacity-30 pointer-events-none' : ''}" id="sch-slots-${day.toLowerCase()}">
            ${slots.map((t: string, i: number) => slotInput(day, t, i, slots.length > 1)).join('')}
            <button type="button" class="add-slot text-xs text-neon-green hover:text-neon-green/70 transition-colors flex items-center gap-1 ${!active ? 'hidden' : ''}" data-day="${day}">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Ajouter un créneau
            </button>
          </div>
        </div>
      </div>`;
    }).join('')}</div>`;
  }


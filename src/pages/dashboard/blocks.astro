              </button>
              <div
                class="block-menu-dropdown hidden absolute right-0 top-full mt-1 w-40 rounded-xl shadow-2xl z-30 py-1 border border-white/10 overflow-hidden"
                data-id="${block.id}">
                <button class="block-edit-btn w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors text-left" data-id="${block.id}">
                  <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                  Edit
                </button>
                <button class="block-duplicate-btn w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors text-left" data-id="${block.id}">
                  <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                  </svg>
                  Duplicate
                </button>
                <div class="my-1 border-t border-white/10"></div>
                <button class="block-delete-btn w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm text-red-400 hover:bg-red-500/5 transition-colors text-left" data-id="${block.id}">
                  <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                  Delete
                </button>
              </div>
            </div>
          </div>
        </div>
      `;
    }).join('');

    attachCardListeners();
    initSortable();
    updateBulkBar();
  }

  document.addEventListener('click', () => {
    document.querySelectorAll('.block-menu-dropdown').forEach(d => d.classList.add('hidden'));
  });

  function attachCardListeners() {
    document.querySelectorAll('.block-toggle').forEach(toggle => {
      toggle.addEventListener('change', async (e: any) => {
        const id = e.target.dataset.id;
        const active = e.target.checked;
        try {
          await apiCall(`/api/blocks/${id}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ active }),
          });
          const b = blocks.find((b: any) => b.id === id);
          if (b) b.active = active;
          toast.success(active ? 'Block activated' : 'Block deactivated');
        } catch {
          e.target.checked = !active;
          toast.error('Failed to update block');
        }
      });
    });

    document.querySelectorAll('.block-select').forEach(cb => {
      cb.addEventListener('change', (e: any) => {
        const id = e.target.dataset.id;
        e.target.checked ? selectedIds.add(id) : selectedIds.delete(id);
        document.querySelector(`.block-card[data-id="${id}"]`)?.classList.toggle('selected', e.target.checked);
        updateBulkBar();
      });
    });

    document.querySelectorAll('.block-menu-btn').forEach(btn => {
      btn.addEventListener('click', (e: any) => {
        e.stopPropagation();
        document.querySelectorAll('.block-menu-dropdown').forEach(d => d.classList.add('hidden'));
        const id = (btn as HTMLElement).dataset.id;
        document.querySelector(`.block-menu-dropdown[data-id="${id}"]`)?.classList.toggle('hidden');
      });
    });

    document.querySelectorAll('.block-edit-btn').forEach(btn => {
      btn.addEventListener('click', () => handleEditBlock((btn as HTMLElement).dataset.id!));
    });
    document.querySelectorAll('.block-duplicate-btn').forEach(btn => {
      btn.addEventListener('click', () => handleDuplicateBlock((btn as HTMLElement).dataset.id!));
    });
    document.querySelectorAll('.block-delete-btn').forEach(btn => {
      btn.addEventListener('click', () => handleDeleteBlock((btn as HTMLElement).dataset.id!));
    });
  }

  // ── Sortable ──────────────────────────────────────────────────────────────
  function initSortable() {
    const container = document.getElementById('sortable-blocks');
    if (!container) return;
    sortable?.destroy();
    sortable = new (window as any).Sortable(container, {
      animation: 200,
      handle: '.drag-handle',
      ghostClass: 'sortable-ghost',
      dragClass: 'sortable-drag',
      onEnd: async () => {
        const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

        // IDs visibles dans le DOM après le drag (peut être filtré)
        const visibleIds = Array.from(container.children)
          .map((el: any) => el.dataset.id)
          .filter((id: any) => id && UUID_RE.test(id));

        if (!visibleIds.length) return;

        // ─── FIX 2 : reorder stable sous filtre ───────────────────────────
        // Si un filtre est actif, container.children ne contient qu'un sous-ensemble.
        // On reconstruit l'ordre complet : blocs visibles (nouvel ordre) + blocs cachés (ordre conservé).
        let blockIds: string[];
        if (activeFilter === 'all' && !searchQuery) {
          // Pas de filtre : visibleIds = ordre complet
          blockIds = visibleIds;
        } else {
          // Filtre actif : les blocs non-filtrés gardent leur position relative,
          // on les insère après les blocs filtrés (ou on peut les interleaver selon UX souhaitée).
          const visibleSet  = new Set(visibleIds);
          const hiddenIds   = blocks
            .filter((b: any) => !visibleSet.has(b.id))
            .map((b: any) => b.id);
          blockIds = [...visibleIds, ...hiddenIds];
        }

        try {
          await apiCall('/api/blocks/reorder', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ blockIds }),
          });
          // Mettre à jour l'ordre local
          blocks = blockIds
            .map((id: string) => blocks.find((b: any) => b.id === id))
            .filter(Boolean);
          toast.success('Order saved');
        } catch {
          toast.error('Failed to save order');
          renderBlocks();
        }
      },
    });
  }

  function updateBulkBar() {
    const bar   = document.getElementById('bulk-bar');
    const count = document.getElementById('bulk-count');
    if (!bar || !count) return;
    if (selectedIds.size > 0) {
      bar.classList.remove('hidden'); bar.classList.add('flex');
      count.textContent = `${selectedIds.size} selected`;
    } else {
      bar.classList.add('hidden'); bar.classList.remove('flex');
    }
  }

  document.getElementById('bulk-cancel-btn')?.addEventListener('click', () => { selectedIds.clear(); renderBlocks(); });

  document.getElementById('bulk-toggle-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    const newActive = !ids.every(id => blocks.find((b: any) => b.id === id)?.active);
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ active: newActive }),
      })));
      ids.forEach(id => { const b = blocks.find((b: any) => b.id === id); if (b) b.active = newActive; });
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} ${newActive ? 'activated' : 'deactivated'}`);
    } catch { toast.error('Bulk toggle failed'); }
  });

  document.getElementById('bulk-delete-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    if (!confirm(`Delete ${ids.length} block${ids.length > 1 ? 's' : ''}? This cannot be undone.`)) return;
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, { method: 'DELETE' })));
      blocks = blocks.filter((b: any) => !ids.includes(b.id));
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} deleted`);
    } catch { toast.error('Bulk delete failed'); }
  });

  document.getElementById('search-input')?.addEventListener('input', (e: any) => {
    searchQuery = e.target.value.toLowerCase().trim(); renderBlocks();
  });

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = (btn as HTMLElement).dataset.filter!;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b === btn));
      renderBlocks();
    });
  });

  document.getElementById('clear-search-btn')?.addEventListener('click', () => {
    searchQuery = ''; activeFilter = 'all';
    (document.getElementById('search-input') as HTMLInputElement).value = '';
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.filter === 'all'));
    renderBlocks();
  });

  // ── Quick-add URL ─────────────────────────────────────────────────────────
  const quickInput  = document.getElementById('quick-add-input') as HTMLInputElement;
  const detectZone  = document.getElementById('quick-detect-zone')!;
  const platIconEl  = document.getElementById('quick-plat-icon')!;
  const platLabelEl = document.getElementById('quick-plat-label')!;
  let quickUrl = ''; let quickPlat: any = null;

  quickInput?.addEventListener('input', () => {
    const val = quickInput.value.trim();
    if (val.startsWith('http')) {
      quickUrl = val; quickPlat = detectPlatform(val);
      platIconEl.textContent  = quickPlat?.icon  ?? '🔗';
      platLabelEl.textContent = quickPlat?.label ?? 'Link detected';
      detectZone.classList.remove('hidden'); detectZone.classList.add('flex');
    } else {
      detectZone.classList.add('hidden'); detectZone.classList.remove('flex');
    }
  });
  quickInput?.addEventListener('paste', () => setTimeout(() => quickInput.dispatchEvent(new Event('input')), 0));

  document.getElementById('quick-add-confirm')?.addEventListener('click', async () => {
    if (!quickUrl) return;
    if (!canAddBlock) { toast.error('Block limit reached!'); return; }
    const title = getDefaultTitle(quickUrl, quickPlat);
    const iconUrl = quickPlat?.defaultIcon ?? '';
    try {
      // FIX 1 : apiCall unwrap data.id correctement
      const data = await apiCall('/api/blocks', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'link', title, config: { url: quickUrl, ...(iconUrl ? { icon_url: iconUrl } : {}) } }),
      });
      blocks.push({ id: data.id, type: 'link', title, config: { url: quickUrl, icon_url: iconUrl }, active: true, created_at: new Date().toISOString(), clicks: 0 });
      renderBlocks();
      toast.success(`${quickPlat?.label ?? 'Link'} added!`);
      quickInput.value = '';
      detectZone.classList.add('hidden'); detectZone.classList.remove('flex');
    } catch (err: any) { toast.error(err.message || 'Failed to add'); }
  });

  document.getElementById('quick-add-cancel')?.addEventListener('click', () => {
    quickInput.value = '';
    detectZone.classList.add('hidden'); detectZone.classList.remove('flex');
  });

  // ── Modals ────────────────────────────────────────────────────────────────
  function openModal(id: string)  { document.getElementById(id)?.classList.add('open'); }
  function closeModal(id: string) { document.getElementById(id)?.classList.remove('open'); }

  document.getElementById('type-backdrop')?.addEventListener('click', () => closeModal('type-modal'));
  document.getElementById('edit-backdrop')?.addEventListener('click', () => closeModal('edit-modal'));
  document.getElementById('type-close')?.addEventListener('click',    () => closeModal('type-modal'));
  document.getElementById('edit-close')?.addEventListener('click',    () => closeModal('edit-modal'));
  document.getElementById('cancel-btn')?.addEventListener('click',    () => closeModal('edit-modal'));

  function openTypeModal() {
    if (!canAddBlock) { toast.error('Block limit reached. Upgrade your plan!'); return; }
    const grid = document.getElementById('platform-grid')!;
    grid.innerHTML = PLATFORMS.slice(0, 8).map(p => `
      <button class="plat-btn flex flex-col items-center gap-1.5 p-2.5 glass border border-white/10 rounded-xl hover:border-neon-green/30 hover:bg-white/5 transition-all group"
        data-pid="${p.id}">
        <span class="text-xl leading-none">${p.icon}</span>
        <span class="text-xs text-gray-400 group-hover:text-white transition-colors truncate w-full text-center">${p.label}</span>
      </button>
    `).join('');
    grid.querySelectorAll('.plat-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const plat = PLATFORMS.find(p => p.id === (btn as HTMLElement).dataset.pid)!;
        closeModal('type-modal');
        openEditModal('link', null, plat);
      });
    });
    openModal('type-modal');
  }

  document.getElementById('add-block-btn')?.addEventListener('click', openTypeModal);
  document.getElementById('empty-add-btn')?.addEventListener('click', openTypeModal);
  document.querySelectorAll('.block-type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      closeModal('type-modal');
      openEditModal((btn as HTMLElement).dataset.type!, null, null);
    });
  });

  // ── Form ──────────────────────────────────────────────────────────────────
  const IC = 'w-full px-4 py-3 glass border border-white/10 rounded-xl text-white text-sm placeholder-gray-600 focus:border-neon-green/50 focus:outline-none focus:ring-1 focus:ring-neon-green/20 transition-colors';

  function openEditModal(type: string, block: any = null, suggestedPlat: any = null) {
    (document.getElementById('modal-title')!).textContent     = block ? `Edit ${type}` : `Add ${type}`;
    (document.getElementById('submit-text')!).textContent     = block ? 'Update Block' : 'Save Block';
    (document.getElementById('block-id')   as HTMLInputElement).value = block?.id ?? '';
    (document.getElementById('block-type') as HTMLInputElement).value = type;

    const val      = (key: string) => (block?.config?.[key] ?? '') as string;
    const titleVal = block?.title ?? (suggestedPlat?.label ?? '');
    const iconVal  = block?.config?.icon_url ?? (suggestedPlat?.defaultIcon ?? '');
    const urlVal   = block?.config?.url ?? '';

    const iconWidget = `
      <div class="space-y-1.5">
        <label class="text-sm font-medium text-gray-300 flex items-center gap-1.5">
          Icon <span class="text-xs text-gray-500 font-normal">optional — shown as circle</span>
        </label>
        <div class="flex items-center gap-3">
          <div id="icon-preview-wrap"
            class="shrink-0 w-12 h-12 rounded-full overflow-hidden border-2 border-white/10 bg-white/5 flex items-center justify-center transition-all">
            ${iconVal
              ? `<img src="${iconVal}" class="w-full h-full object-cover" />`
              : `<svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`}
          </div>
          <input type="url" id="field-icon-url" value="${iconVal}" placeholder="https://example.com/icon.png" class="${IC} flex-1" />
        </div>
        <p class="text-xs text-gray-600">Square image recommended (1:1).</p>
      </div>`;

    // ─── FIX 1 : champs image/video/spacer maintenant complets ────────────
    // L'ancien code n'avait pas de field-title pour image/video → config mal construite.
    const fieldHtml: Record<string, string> = {
      link: `
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Title <span class="text-red-400">*</span></label>
          <input type="text" id="field-title" value="${titleVal}" required maxlength="100" placeholder="My Twitch" class="${IC}" />
        </div>
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">URL <span class="text-red-400">*</span></label>
          <input type="url" id="field-url" value="${urlVal}" required placeholder="https://twitch.tv/username" class="${IC}" />
        </div>
        ${iconWidget}`,

      heading: `
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Heading Text <span class="text-red-400">*</span></label>
          <input type="text" id="field-title" value="${titleVal}" required maxlength="100" placeholder="My Social Links" class="${IC}" />
        </div>`,

      // spacer : aucun champ, le submit envoie juste type="spacer"
      spacer: `
        <div class="py-6 flex flex-col items-center gap-3 text-center">
          <div class="text-3xl">—</div>
          <p class="text-sm text-gray-400">A spacer adds blank space between blocks.</p>
          <p class="text-xs text-gray-600">No configuration needed.</p>
        </div>`,

      image: `
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Image URL <span class="text-red-400">*</span></label>
          <input type="url" id="field-url" value="${val('url')}" required placeholder="https://example.com/image.jpg" class="${IC}" />
        </div>
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Caption <span class="text-gray-500 font-normal text-xs ml-1">optional</span></label>
          <input type="text" id="field-title" value="${titleVal}" maxlength="100" placeholder="My photo" class="${IC}" />
        </div>`,

      video: `
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Video URL <span class="text-red-400">*</span></label>
          <input type="url" id="field-url" value="${val('url')}" required placeholder="https://youtube.com/watch?v=…" class="${IC}" />
          <p class="text-xs text-gray-600">Supports YouTube, Vimeo, TikTok</p>
        </div>
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Title <span class="text-gray-500 font-normal text-xs ml-1">optional</span></label>
          <input type="text" id="field-title" value="${titleVal}" maxlength="100" placeholder="Watch my latest video" class="${IC}" />
        </div>`,

      social: `
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Title <span class="text-gray-500 font-normal text-xs ml-1">Optional</span></label>
          <input type="text" id="field-title" value="${titleVal}" maxlength="60" placeholder="Follow Me" class="${IC}" />
        </div>
        <div class="space-y-1.5">
          <label class="text-sm font-medium text-gray-300">Social URLs <span class="text-red-400">*</span></label>
          <textarea id="field-links" rows="3" required placeholder="https://twitter.com/user&#10;https://instagram.com/user" class="${IC} resize-none">${block?.config?.links?.map((l: any) => l.url || l).join('\n') ?? ''}</textarea>
          <p class="text-xs text-gray-600">One URL per line</p>
        </div>`,
    };

    const fields = document.getElementById('form-fields')!;
    fields.innerHTML = fieldHtml[type] ?? `<div class="py-4 text-center text-sm text-gray-500">Type "${type}" not yet supported.</div>`;
    openModal('edit-modal');
    setTimeout(() => (fields.querySelector('input, textarea') as HTMLElement | null)?.focus(), 100);

    // Live icon preview
    const iconInput = document.getElementById('field-icon-url') as HTMLInputElement | null;
    const iconWrap  = document.getElementById('icon-preview-wrap');
    if (iconInput && iconWrap) {
      const emptyIcon = `<svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`;
      iconInput.addEventListener('input', () => {
        const u = iconInput.value.trim();
        iconWrap.innerHTML = u
          ? `<img src="${u}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='${emptyIcon.replace(/'/g, "\\'")}'" />`
          : emptyIcon;
      });
      const urlField = document.getElementById('field-url') as HTMLInputElement | null;
      urlField?.addEventListener('blur', () => {
        if (iconInput.value) return;
        const u = urlField.value.trim();
        if (!u) return;
        const plat = detectPlatform(u);
        if (plat?.defaultIcon) {
          iconInput.value = plat.defaultIcon;
          iconWrap.innerHTML = `<img src="${plat.defaultIcon}" class="w-full h-full object-cover" />`;
        }
      });
    }
  }

  // ── Form submit ───────────────────────────────────────────────────────────
  document.getElementById('block-form')?.addEventListener('submit', async (e: any) => {
    e.preventDefault();
    if (isSaving) return;

    const type    = (document.getElementById('block-type') as HTMLInputElement).value;
    const blockId = (document.getElementById('block-id')   as HTMLInputElement).value ?? '';
    const submitBtn  = document.getElementById('submit-btn');
    const submitText = document.getElementById('submit-text')!;

    let title: string | null = null;
    let config: any = {};

    const titleEl   = document.getElementById('field-title')    as HTMLInputElement | null;
    const urlEl     = document.getElementById('field-url')      as HTMLInputElement | null;
    const linksEl   = document.getElementById('field-links')    as HTMLTextAreaElement | null;
    const iconUrlEl = document.getElementById('field-icon-url') as HTMLInputElement | null;

    switch (type) {
      case 'link': {
        title = titleEl?.value?.trim() ?? null;
        const url     = urlEl?.value?.trim() ?? '';
        const iconUrl = iconUrlEl?.value?.trim() ?? '';
        if (!title)                                  { toast.error('Title is required'); return; }
        if (!url || !url.startsWith('http'))         { toast.error('Valid URL required'); return; }
        if (iconUrl && !iconUrl.startsWith('http'))  { toast.error('Icon URL must start with https://'); return; }
        config = { url, ...(iconUrl ? { icon_url: iconUrl } : {}) };
        break;
      }
      case 'heading':
        title = titleEl?.value?.trim() ?? null;
        if (!title) { toast.error('Heading text is required'); return; }
        break;
      case 'spacer':
        // Aucun champ requis — type seul suffit
        break;
      case 'image': {
        const u = urlEl?.value?.trim() ?? '';
        if (!u || !u.startsWith('http')) { toast.error('Valid image URL required'); return; }
        title  = titleEl?.value?.trim() || null;
        config = { url: u };
        break;
      }
      case 'video': {
        const u = urlEl?.value?.trim() ?? '';
        if (!u || !u.startsWith('http')) { toast.error('Valid video URL required'); return; }
        title  = titleEl?.value?.trim() || null;
        config = { url: u };
        break;
      }
      case 'social': {
        title = titleEl?.value?.trim() || null;
        const raw   = linksEl?.value?.trim() ?? '';
        const links = raw.split('\n').map(u => u.trim()).filter(u => u.startsWith('http')).map(u => ({ url: u }));
        if (!links.length) { toast.error('At least one valid URL required'); return; }
        config = { links };
        break;
      }
      default:
        toast.error(`Unknown block type: ${type}`); return;
    }

    isSaving = true;
    submitBtn?.setAttribute('disabled', '');
    submitText.textContent = blockId ? 'Updating…' : 'Saving…';

    try {
      // FIX 1 + 4 : apiCall unwrap { success, data } → data.id est valide
      const data = await apiCall(blockId ? `/api/blocks/${blockId}` : '/api/blocks', {
        method:  blockId ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ type, title: title ?? null, config }),
      });

      if (blockId) {
        const idx = blocks.findIndex((b: any) => b.id === blockId);
        if (idx !== -1) blocks[idx] = { ...blocks[idx], title, config, ...data };
      } else {
        // FIX 4 : le block apparaît immédiatement sans refresh
        blocks.push({
          id:         data.id,     // ← maintenant correctement défini
          type,
          title,
          config,
          active:     true,
          created_at: new Date().toISOString(),
          clicks:     0,
          ...data,
        });
      }

      closeModal('edit-modal');
      renderBlocks();
      toast.success(blockId ? 'Block updated!' : 'Block added!');
    } catch (err: any) {
      if (err.message?.includes('403') || err.message?.includes('limit')) {
        toast.error('Block limit reached!');
      } else {
        toast.error(err.message || 'Failed to save block');
      }
    } finally {
      isSaving = false;
      submitBtn?.removeAttribute('disabled');
      submitText.textContent = blockId ? 'Update Block' : 'Save Block';
    }
  });

  function handleEditBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (block) openEditModal(block.type, block, null);
  }

  async function handleDuplicateBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block) return;
    if (!canAddBlock) { toast.error('Block limit reached!'); return; }
    try {
      const data = await apiCall('/api/blocks', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: block.type, title: block.title ? `${block.title} (copy)` : null, config: block.config }),
      });
      blocks.push({ ...block, id: data.id, title: block.title ? `${block.title} (copy)` : null, created_at: new Date().toISOString(), clicks: 0 });
      renderBlocks();
      toast.success('Block duplicated!');
    } catch (err: any) { toast.error(err.message || 'Failed to duplicate'); }
  }

  async function handleDeleteBlock(id: string) {
    if (!confirm('Delete this block? This cannot be undone.')) return;
    try {
      // FIX 3 : hard delete — l'API fait maintenant un DELETE Supabase direct
      await apiCall(`/api/blocks/${id}`, { method: 'DELETE' });
      blocks = blocks.filter((b: any) => b.id !== id);
      selectedIds.delete(id);
      renderBlocks();
      toast.success('Block deleted');
    } catch (err: any) { toast.error(err.message || 'Failed to delete'); }
  }

  document.addEventListener('keydown', (e: any) => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;
    if (e.key === 'n' || e.key === 'N') { e.preventDefault(); openTypeModal(); }
    if (e.key === 'Escape') { closeModal('type-modal'); closeModal('edit-modal'); }
  });

  renderBlocks();
</script>
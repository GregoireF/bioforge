  function renderTypeModal() {
    const nav   = document.getElementById('type-nav')!;
    const panel = document.getElementById('type-panel')!;

    // Sidebar nav
    nav.innerHTML = TYPE_CATEGORIES.map(cat => `
      <button class="type-nav-btn w-full flex items-center gap-2 px-3 py-2.5 text-sm font-medium transition-all text-left rounded-lg mx-1 my-0.5
        ${cat.id === activeCatId ? 'bg-white/10 text-white' : 'text-gray-400 hover:text-white hover:bg-white/5'}"
        data-cat="${cat.id}" style="width: calc(100% - 8px);">
        ${cat.label}
      </button>`).join('');
    nav.querySelectorAll('.type-nav-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCatId = (btn as HTMLElement).dataset.cat!;
        typeSearch  = '';
        const inp = document.getElementById('type-search') as HTMLInputElement;
        if (inp) inp.value = '';
        renderTypeModal();
      });
    });

    // Panel content
    const cat = TYPE_CATEGORIES.find(c => c.id === activeCatId)!;
    let items = cat.items;

    // Search filter
    if (typeSearch) {
      const q = typeSearch.toLowerCase();
      items = TYPE_CATEGORIES.flatMap(c => c.items).filter(item => {
        if (item.kind === 'platform') {
          const p = PLATFORMS.find(p => p.id === item.id);
          return p?.label.toLowerCase().includes(q) || p?.id.includes(q);
        }
        return (item as any).label?.toLowerCase().includes(q) || (item as any).type?.includes(q);
      });
      // Deduplicate
      const seen = new Set<string>();
      items = items.filter(item => {
        const key = item.kind === 'platform' ? `plat:${item.id}` : `block:${(item as any).type}`;
        if (seen.has(key)) return false;
        seen.add(key); return true;
      });
    }

    if (!items.length) {
      panel.innerHTML = `<div class="flex flex-col items-center justify-center py-12 text-center"><p class="text-sm text-gray-500">Aucun résultat pour "${typeSearch}"</p></div>`;
      return;
    }

    // Group into platforms vs blocks
    const platforms = items.filter(i => i.kind === 'platform');
    const blockItems = items.filter(i => i.kind === 'block');

    let html = '';

    if (platforms.length) {
      html += `<div class="mb-5">
        <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-3 px-1">Plateformes</p>

---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PlanLimitIndicator from '@/components/features/PlanLimitIndicator.astro';
import { withAuth } from '@/lib/auth/auth';
import { getBlocks } from '@/lib/supabase/queries';
import { getAnalyticsSummary } from '@/lib/db/queries.server';
import { createServerClient } from '@supabase/ssr';
import { parse } from 'cookie';

const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}
const { user, profile, planLimits } = authResult.data;

function escapeHtml(val: unknown): string {
  return String(val ?? '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}
function safeNum(val: unknown): number {
  const n = Number(val); return isFinite(n) ? n : 0;
}

const cookies = parse(Astro.request.headers.get('cookie') ?? '');
const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL!,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY!,
  { cookies: { get: k => cookies[k], set: () => {}, remove: () => {} } }
);

const safeProfileId = profile?.id?.trim() ?? '';

const [blocksResult, analyticsResult] = await Promise.all([
  safeProfileId ? getBlocks(safeProfileId) : Promise.resolve({ success: false, data: [] }),
  safeProfileId ? getAnalyticsSummary(supabase, safeProfileId, 7) : Promise.resolve({ success: false, data: null }),
]);

const rawBlocks  = (blocksResult.success ? blocksResult.data : []) ?? [];
const blocks     = rawBlocks.filter((b: any) => !b.deleted_at);
const topBlocks  = analyticsResult.success ? (analyticsResult.data?.topBlocks ?? []) : [];
const totalViews = analyticsResult.success ? (analyticsResult.data?.totalViews ?? 0) : 0;

const clicksMap = new Map<string, number>();
topBlocks.forEach((b: any) => clicksMap.set(b.id, safeNum(b.clicks)));

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

const safeBridgeBlocks = blocks
  .filter((b: any) => UUID_RE.test(String(b.id ?? '')))
  .map((b: any) => ({
    id:         String(b.id),
    type:       escapeHtml(b.type),
    title:      escapeHtml(b.title),
    active:     Boolean(b.active),
    position:   safeNum(b.position),
    created_at: escapeHtml(b.created_at),
    clicks:     clicksMap.get(b.id) ?? 0,
    is_pinned:  Boolean(b.is_pinned ?? b.config?.is_pinned),
    config: {
      url:               escapeHtml(b.config?.url),
      icon_url:          escapeHtml(b.config?.icon_url),
      show_from:         escapeHtml(b.config?.show_from),
      show_until:        escapeHtml(b.config?.show_until),
      target_date:       escapeHtml(b.config?.target_date),
      goal_amount:       safeNum(b.config?.goal_amount),
      current_amount:    safeNum(b.config?.current_amount),
      donation_platform: escapeHtml(b.config?.donation_platform),
      height:            safeNum(b.config?.height),
      schedule:          Array.isArray(b.config?.schedule) ? b.config.schedule : [],
      links: Array.isArray(b.config?.links)
        ? b.config.links.map((l: any) => ({ url: escapeHtml(l?.url ?? l) }))
        : [],
    },
  }));

const blockCount  = blocks.length;
const blockLimit  = planLimits?.max_blocks_total ?? 15;
const canAddBlock = blockLimit === -1 || blockCount < blockLimit;
const isNearLimit = blockLimit !== -1 && blockCount >= blockLimit * 0.8 && blockCount < blockLimit;
const blocksError = blocksResult.success ? null : (blocksResult.error?.message ?? 'Failed to load blocks');

const bridge = JSON.stringify({
  blocks: safeBridgeBlocks, blockCount, blockLimit, canAddBlock,
  profileId: escapeHtml(safeProfileId),
  totalViews,
});

// All block types incl. new streamer types
const BLOCK_TYPES = [
  { type: 'link',      emoji: '🔗', label: 'Link',        desc: 'Clickable link button'   },
  { type: 'social',    emoji: '👥', label: 'Social',      desc: 'Social icon grid'         },
  { type: 'heading',   emoji: '📝', label: 'Heading',     desc: 'Section title'            },
  { type: 'spacer',    emoji: '—',  label: 'Spacer',      desc: 'Blank space'              },
  { type: 'image',     emoji: '🖼️', label: 'Image',       desc: 'Display an image'         },
  { type: 'video',     emoji: '🎥', label: 'Video',       desc: 'Embed YouTube / Vimeo'    },
  { type: 'countdown', emoji: '⏱️', label: 'Countdown',   desc: 'Next stream timer'        },
  { type: 'schedule',  emoji: '📅', label: 'Schedule',    desc: 'Weekly stream schedule'   },
  { type: 'donation',  emoji: '💸', label: 'Donation',    desc: 'Ko-fi / Patreon CTA'      },
  { type: 'embed',     emoji: '🎵', label: 'Music Embed', desc: 'Spotify / SoundCloud'     },
];
---

<DashboardLayout title="Blocks">

  <div id="server-data" class="hidden" data-bridge={bridge}></div>

  <!-- ===== HEADER ===== -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <p class="text-xs font-medium text-gray-500 uppercase tracking-widest mb-1">Content</p>
      <h2 class="text-xl font-semibold text-white tracking-tight">Blocks</h2>
      <p class="text-sm text-gray-400 mt-0.5">Build and manage your profile page</p>
    </div>
    <div class="flex items-center gap-2">
      <div id="bulk-bar" class="hidden items-center gap-2">
        <span id="bulk-count" class="text-xs text-gray-400 font-medium px-2">0 selected</span>
        <button id="bulk-toggle-btn"
          class="px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-300 hover:text-white hover:border-white/25 transition-all">
          Toggle
        </button>
        <button id="bulk-delete-btn"
          class="flex items-center gap-1.5 px-3 py-2 glass border border-red-500/20 rounded-xl text-xs text-red-400 hover:border-red-500/40 hover:bg-red-500/5 transition-all">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        </button>
        <button id="bulk-cancel-btn" class="px-3 py-2 text-xs text-gray-500 hover:text-white transition-colors">Cancel</button>
      </div>
      <button id="add-block-btn"
        class={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all active:scale-[0.98]
          ${canAddBlock ? 'bg-neon-green text-black hover:bg-neon-green/90' : 'glass border border-white/10 text-gray-400 cursor-not-allowed opacity-60'}`}
        title="N">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        {canAddBlock ? 'Add Block' : 'Upgrade to Add More'}
      </button>
    </div>
  </div>

  <div class="mb-5">
    <PlanLimitIndicator current={blockCount} limit={blockLimit} feature="Blocks" showUpgrade={true} />
  </div>

  {isNearLimit && (
    <div class="mb-5 flex items-center gap-3 p-4 glass border border-yellow-400/20 rounded-xl">
      <svg class="w-4 h-4 text-yellow-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <p class="text-sm text-yellow-300">Using {blockCount} of {blockLimit} blocks.
        <a href="/pricing" class="underline ml-1">Upgrade for more →</a>
      </p>
    </div>
  )}
  {!canAddBlock && blockLimit !== -1 && (
    <div class="mb-5 flex items-center gap-3 p-4 glass border border-red-500/20 rounded-xl">
      <p class="text-sm text-red-300">Block limit reached ({blockLimit}).
        <a href="/pricing" class="underline ml-1">Upgrade →</a>
      </p>
    </div>
  )}
  {blocksError && (
    <div class="mb-5 flex items-center gap-3 p-4 glass border border-red-500/20 rounded-xl">
      <p class="text-sm text-red-300">{blocksError}</p>
      <button onclick="location.reload()" class="ml-auto text-xs text-red-400 underline">Retry</button>
    </div>
  )}

  <!-- ===== QUICK-ADD URL BAR ===== -->
  <div class="mb-5">
    <div id="quick-add-bar"
      class="flex items-center gap-3 px-4 py-3 glass border border-white/10 rounded-xl focus-within:border-neon-green/40 transition-colors">
      <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      <input type="url" id="quick-add-input" placeholder="Paste a URL to instantly add a link…"
        class="flex-1 bg-transparent text-white text-sm placeholder-gray-600 focus:outline-none min-w-0" />
      <div id="quick-detect-zone" class="hidden items-center gap-2 shrink-0">
        <span id="quick-plat-icon" class="text-lg leading-none"></span>
        <span id="quick-plat-label" class="text-xs font-semibold text-neon-green whitespace-nowrap"></span>
        <button id="quick-add-confirm"
          class="px-3 py-1.5 bg-neon-green text-black text-xs font-bold rounded-lg hover:bg-neon-green/90 active:scale-95 transition-all">
          Add
        </button>
        <button id="quick-add-cancel" class="text-gray-600 hover:text-gray-300 transition-colors p-0.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- ===== STREAMER KIT ===== -->
  <div class="mb-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <span class="text-base">🎮</span>
        <p class="text-sm font-semibold text-white">Streamer Kit</p>
        <span class="text-xs px-2 py-0.5 rounded-full bg-neon-green/15 text-neon-green border border-neon-green/25 font-medium">Quick Start</span>
      </div>
      <button id="kit-toggle-btn" class="text-xs text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1">
        <span id="kit-toggle-label">Afficher</span>
        <svg id="kit-chevron" class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    </div>
    <div id="kit-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3"></div>
  </div>

  <!-- ===== SEARCH + FILTER ===== -->
  <div class="flex flex-col sm:flex-row gap-3 mb-5">
    <div class="relative flex-1">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
      </svg>
      <input type="text" id="search-input" placeholder="Search blocks…"
        class="w-full pl-9 pr-4 py-2.5 glass border border-white/10 rounded-xl text-white text-sm placeholder-gray-600 focus:border-neon-green/40 focus:outline-none transition-colors" />
    </div>
    <div class="flex items-center gap-2 overflow-x-auto pb-0.5 scrollbar-none">
      <button class="filter-btn active shrink-0 px-3 py-2 rounded-xl text-xs font-medium transition-all" data-filter="all">All</button>
      {BLOCK_TYPES.map(t => (
        <button class="filter-btn shrink-0 px-3 py-2 rounded-xl text-xs font-medium transition-all" data-filter={t.type}>
          {t.emoji} {t.label}
        </button>
      ))}
    </div>
  </div>

  <!-- ===== BLOCKS LIST ===== -->
  <div id="blocks-container">
    {blocks.length === 0 ? (
      <div id="empty-state" class="flex flex-col items-center justify-center py-20 text-center">
        <div class="w-20 h-20 rounded-2xl bg-neon-green/10 border border-neon-green/20 flex items-center justify-center mx-auto mb-5">
          <svg class="w-9 h-9 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">No blocks yet</h3>
        <p class="text-sm text-gray-400 mb-6 max-w-xs">Paste a URL above, use a Streamer Kit template, or click Add Block to get started.</p>
        {canAddBlock && (
          <button id="empty-add-btn"
            class="flex items-center gap-2 px-6 py-3 bg-neon-green text-black text-sm font-semibold rounded-xl hover:bg-neon-green/90 active:scale-[0.98] transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Add Your First Block
          </button>
        )}
        <p class="text-xs text-gray-600 mt-4">Tip: press <kbd class="px-1.5 py-0.5 glass rounded text-gray-400 font-mono text-xs">N</kbd> to add a block</p>
      </div>
    ) : (
      <div class="space-y-2" id="sortable-blocks"></div>
    )}
    <div id="no-results" class="hidden flex-col items-center justify-center py-16 text-center">
      <p class="text-sm text-gray-500 mb-2">No blocks match your search</p>
      <button id="clear-search-btn" class="text-xs text-neon-green hover:underline">Clear filters</button>
    </div>
  </div>

  <!-- ===== TYPE SELECTION MODAL — Linktree-style ===== -->
  <div id="type-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div id="type-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative glass border border-white/10 rounded-2xl w-full max-w-2xl shadow-2xl max-h-[88vh] overflow-hidden flex flex-col">

      <!-- Modal header -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-white/8 shrink-0">
        <h3 class="text-white font-semibold text-base">Ajouter un block</h3>
        <button id="type-close" class="text-gray-500 hover:text-white transition-colors p-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Search bar -->
      <div class="px-5 py-3 border-b border-white/8 shrink-0">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
          </svg>
          <input type="text" id="type-search" placeholder="Colle ou recherche un lien, une plateforme…"
            class="w-full pl-9 pr-4 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white text-sm placeholder-gray-600 focus:border-neon-green/40 focus:outline-none transition-colors" />
        </div>
      </div>

      <!-- Body: sidebar + content -->
      <div class="flex flex-1 min-h-0 overflow-hidden">
        <!-- Left sidebar -->
        <nav class="w-40 shrink-0 border-r border-white/8 py-2 overflow-y-auto scrollbar-none bg-black/20">
          <!-- populated by JS -->
          <div id="type-nav"></div>
        </nav>

        <!-- Right panel -->
        <div class="flex-1 overflow-y-auto scrollbar-none p-4" id="type-panel">
          <!-- populated by JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- ===== EDIT MODAL ===== -->
  <div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div id="edit-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative glass border border-white/10 rounded-2xl p-6 w-full max-w-md shadow-2xl max-h-[92vh] overflow-y-auto scrollbar-none">
      <div class="flex items-center justify-between mb-5">
        <h3 class="text-white font-semibold" id="modal-title">Add Block</h3>
        <button id="edit-close" class="text-gray-500 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="block-form" class="space-y-4" novalidate>
        <input type="hidden" id="block-id" />
        <input type="hidden" id="block-type" />
        <div id="form-fields" class="space-y-4"></div>

        <!-- Scheduled visibility (all types except spacer) -->
        <div id="schedule-visibility-section" class="hidden">
          <div class="border-t border-white/10 pt-4">
            <button type="button" id="visibility-toggle"
              class="w-full flex items-center justify-between text-sm text-gray-400 hover:text-white transition-colors">
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Visibilité planifiée
                <span class="text-xs px-1.5 py-0.5 rounded bg-white/5 text-gray-500">optionnel</span>
              </span>
              <svg id="vis-chevron" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id="visibility-panel" class="hidden mt-3 space-y-3">
              <p class="text-xs text-gray-600">Laisser vide pour toujours afficher.</p>
              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1.5">
                  <label class="text-xs font-medium text-gray-400">Afficher à partir de</label>
                  <input type="datetime-local" id="field-show-from"
                    class="w-full px-3 py-2 glass border border-white/10 rounded-xl text-white text-sm focus:border-neon-green/50 focus:outline-none transition-colors" />
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-medium text-gray-400">Masquer après</label>
                  <input type="datetime-local" id="field-show-until"
                    class="w-full px-3 py-2 glass border border-white/10 rounded-xl text-white text-sm focus:border-neon-green/50 focus:outline-none transition-colors" />
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex gap-3 pt-1">
          <button type="submit" id="submit-btn"
            class="flex-1 flex items-center justify-center gap-2 py-2.5 bg-neon-green text-black text-sm font-semibold rounded-xl hover:bg-neon-green/90 active:scale-[0.98] transition-all disabled:opacity-50 disabled:pointer-events-none">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span id="submit-text">Save Block</span>
          </button>
          <button type="button" id="cancel-btn"
            class="px-5 py-2.5 glass border border-white/10 rounded-xl text-sm text-gray-300 hover:text-white transition-all">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

</DashboardLayout>

<style>
  .filter-btn { color: rgb(107 114 128); border: 1px solid transparent; background: transparent; }
  .filter-btn:hover { color: white; background: rgba(255,255,255,0.05); }
  .filter-btn.active { color: white; background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); }
  #type-modal.open, #edit-modal.open { display: flex; }
  .block-card { transition: transform 0.15s ease, box-shadow 0.15s ease; }
  .block-card.selected { border-color: rgba(0,255,157,0.4) !important; background: rgba(0,255,157,0.03); }
  .block-card.pinned-card { border-color: rgba(251,191,36,0.35) !important; }
  .block-card.sortable-ghost { opacity: 0.4; }
  .block-card.sortable-drag  { box-shadow: 0 20px 60px rgba(0,0,0,0.5); transform: rotate(1deg); }
  .block-menu-dropdown { backdrop-filter: blur(16px); background: rgba(12,12,18,0.96); }
  .scrollbar-none { scrollbar-width: none; -ms-overflow-style: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }
  /* New type badges */
  .badge-countdown { background: rgba(251,191,36,0.12); color: rgb(251,191,36); border-color: rgba(251,191,36,0.3); }
  .badge-schedule  { background: rgba(99,179,237,0.12); color: rgb(99,179,237); border-color: rgba(99,179,237,0.3); }
  .badge-donation  { background: rgba(248,113,113,0.12); color: rgb(248,113,113); border-color: rgba(248,113,113,0.3); }
  .badge-embed     { background: rgba(167,139,250,0.12); color: rgb(167,139,250); border-color: rgba(167,139,250,0.3); }
  .badge-scheduled { background: rgba(251,191,36,0.08); color: rgba(251,191,36,0.8); border-color: rgba(251,191,36,0.2); }
  /* Progress bar */
  .progress-bar { background: linear-gradient(90deg, #00ff9d, #00e88a); border-radius: 99px; }
  /* Pin tab */
  .pin-tab { position: absolute; top: -1px; left: 14px; width: 2px; height: 8px; background: rgb(251,191,36); border-radius: 0 0 2px 2px; }
  /* Kit card */
  .kit-card { transition: transform 0.15s ease, border-color 0.15s ease; }
  .kit-card:hover { transform: translateY(-2px); }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>

<script>
  import { toast } from '@/lib/utils/toast';

  // ── Bridge ────────────────────────────────────────────────────────────────
  const raw = JSON.parse(document.getElementById('server-data')?.dataset.bridge ?? '{}');
  let { blocks, blockCount, blockLimit, canAddBlock, profileId, totalViews } = raw;

  // ── State ─────────────────────────────────────────────────────────────────
  let selectedIds: Set<string> = new Set();
  let activeFilter = 'all';
  let searchQuery  = '';
  let isSaving     = false;
  let sortable: any = null;

  // ── Central API helper ────────────────────────────────────────────────────
  async function apiCall(url: string, options: RequestInit = {}) {
    const res  = await fetch(url, options);
    const json = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(json.error?.message ?? json.error ?? `HTTP ${res.status}`);
    return json.data ?? json;
  }

  // ── Platform registry ─────────────────────────────────────────────────────
  const PLATFORMS = [
    { id: 'twitch',         label: 'Twitch',         icon: '🟣', match: ['twitch.tv'],                       defaultIcon: 'https://bioforge.click/social/twitch.png'        },
    { id: 'youtube',        label: 'YouTube',         icon: '🔴', match: ['youtube.com','youtu.be'],           defaultIcon: 'https://bioforge.click/social/youtube.png'       },
    { id: 'tiktok',         label: 'TikTok',          icon: '⬛', match: ['tiktok.com'],                       defaultIcon: 'https://bioforge.click/social/tiktok.png'        },
    { id: 'instagram',      label: 'Instagram',       icon: '📸', match: ['instagram.com'],                    defaultIcon: 'https://bioforge.click/social/instagram.png'     },
    { id: 'twitter',        label: 'X / Twitter',     icon: '🐦', match: ['twitter.com','x.com'],              defaultIcon: 'https://bioforge.click/social/x.png'             },
    { id: 'discord',        label: 'Discord',         icon: '💬', match: ['discord.com','discord.gg'],         defaultIcon: 'https://bioforge.click/social/discord.png'       },
    { id: 'kick',           label: 'Kick',            icon: '🟢', match: ['kick.com'],                         defaultIcon: 'https://bioforge.click/social/kick.png'          },
    { id: 'spotify',        label: 'Spotify',         icon: '🎵', match: ['spotify.com','open.spotify.com'],   defaultIcon: 'https://bioforge.click/social/spotify.png'       },
    { id: 'github',         label: 'GitHub',          icon: '🐙', match: ['github.com'],                       defaultIcon: 'https://bioforge.click/social/github.png'        },
    { id: 'linkedin',       label: 'LinkedIn',        icon: '💼', match: ['linkedin.com'],                     defaultIcon: 'https://www.linkedin.com/favicon.ico'            },
    { id: 'patreon',        label: 'Patreon',         icon: '🎁', match: ['patreon.com'],                      defaultIcon: 'https://c5.patreon.com/external/favicon/favicon.ico' },
    { id: 'kofi',           label: 'Ko-fi',           icon: '☕', match: ['ko-fi.com'],                        defaultIcon: 'https://storage.ko-fi.com/cdn/nav-logo-stroke.png' },
    { id: 'streamlabs',     label: 'Streamlabs',      icon: '🎛️', match: ['streamlabs.com','streamlabs.link'], defaultIcon: 'https://bioforge.click/social/streamlabs.png'    },
    { id: 'streamelements', label: 'StreamElements',  icon: '⚡', match: ['streamelements.com'],               defaultIcon: 'https://bioforge.click/social/streamelements.png' },
    { id: 'throne',         label: 'Throne',          icon: '👑', match: ['throne.com'],                       defaultIcon: 'https://bioforge.click/social/throne.png'        },
    { id: 'snapchat',       label: 'Snapchat',        icon: '👻', match: ['snapchat.com'],                     defaultIcon: 'https://bioforge.click/social/snapchat.png'      },
    { id: 'facebook',       label: 'Facebook',        icon: '📘', match: ['facebook.com'],                     defaultIcon: 'https://bioforge.click/social/facebook.png'      },
  ];

  function detectPlatform(url: string) {
    try { const l = url.toLowerCase(); return PLATFORMS.find(p => p.match.some(m => l.includes(m))) ?? null; }
    catch { return null; }
  }

  function getDefaultTitle(url: string, platform: any): string {
    if (!platform) return '';
    try {
      const parts = new URL(url).pathname.split('/').filter(Boolean);
      return parts[0] ? `${platform.label} — @${parts[0]}` : platform.label;
    } catch { return platform.label; }
  }

  const BLOCK_EMOJI: Record<string, string> = {
    link:'🔗', heading:'📝', spacer:'—', image:'🖼️', video:'🎥',
    social:'👥', countdown:'⏱️', schedule:'📅', donation:'💸', embed:'🎵',
  };
  const TYPE_BADGE: Record<string, string> = {
    countdown:'badge-countdown', schedule:'badge-schedule',
    donation:'badge-donation',   embed:'badge-embed',
  };

  function isNew(createdAt: string): boolean {
    return !!createdAt && Date.now() - new Date(createdAt).getTime() < 86_400_000;
  }
  function isScheduled(block: any): boolean {
    return !!(block.config?.show_from || block.config?.show_until);
  }

  function getFiltered() {
    return blocks.filter((b: any) => {
      const matchType   = activeFilter === 'all' || b.type === activeFilter;
      const matchSearch = !searchQuery || b.title?.toLowerCase().includes(searchQuery) || b.type.includes(searchQuery);
      return matchType && matchSearch;
    });
  }

  // ── Streamer Kit ──────────────────────────────────────────────────────────
  const STREAMER_KITS = [
    {
      id: 'gaming', label: '🎮 Gaming', desc: 'Twitch · Discord · Countdown · Ko-fi', color: '#7c3aed',
      blocks: [
        { type: 'link',      title: 'Live sur Twitch',    config: { url: 'https://twitch.tv/', icon_url: 'https://bioforge.click/social/twitch.png' } },
        { type: 'link',      title: 'Rejoins le Discord', config: { url: 'https://discord.gg/', icon_url: 'https://bioforge.click/social/discord.png' } },
        { type: 'countdown', title: 'Prochain stream',    config: { target_date: '', label: 'Prochain stream dans' } },
        { type: 'schedule',  title: 'Planning stream',    config: { schedule: [] } },
        { type: 'donation',  title: 'Soutiens-moi ☕',   config: { donation_platform: 'kofi', url: 'https://ko-fi.com/', goal_amount: 0 } },
      ],
    },
    {
      id: 'irl', label: '📱 IRL / Lifestyle', desc: 'Instagram · TikTok · Patreon', color: '#ec4899',
      blocks: [
        { type: 'link',     title: 'Mon Instagram', config: { url: 'https://instagram.com/', icon_url: 'https://bioforge.click/social/instagram.png' } },
        { type: 'link',     title: 'Mon TikTok',    config: { url: 'https://tiktok.com/',    icon_url: 'https://bioforge.click/social/tiktok.png' } },
        { type: 'social',   title: 'Mes réseaux',   config: { links: [] } },
        { type: 'donation', title: 'Me soutenir',   config: { donation_platform: 'patreon', url: 'https://patreon.com/', goal_amount: 0 } },
      ],
    },
    {
      id: 'music', label: '🎵 Music / DJ', desc: 'Spotify embed · SoundCloud · Merch', color: '#10b981',
      blocks: [
        { type: 'embed',  title: 'Ma playlist Spotify', config: { url: 'https://open.spotify.com/playlist/', height: 152 } },
        { type: 'link',   title: 'Mon SoundCloud',      config: { url: 'https://soundcloud.com/', icon_url: '' } },
        { type: 'link',   title: 'Achète mon merch 👑', config: { url: 'https://throne.com/', icon_url: 'https://bioforge.click/social/throne.png' } },
        { type: 'social', title: 'Mes réseaux',         config: { links: [] } },
      ],
    },
    {
      id: 'art', label: '🎨 Art / Creator', desc: 'Portfolio · Ko-fi · Commissions', color: '#f59e0b',
      blocks: [
        { type: 'link',     title: 'Mon Portfolio',     config: { url: 'https://', icon_url: '' } },
        { type: 'donation', title: 'Commissions ✦ Ouvertes', config: { donation_platform: 'kofi', url: 'https://ko-fi.com/', goal_amount: 0 } },
        { type: 'link',     title: 'Voir mes œuvres',   config: { url: 'https://instagram.com/', icon_url: 'https://bioforge.click/social/instagram.png' } },
        { type: 'social',   title: 'Mes réseaux',       config: { links: [] } },
      ],
    },
  ];

  function renderStreamerKit() {
    const grid = document.getElementById('kit-grid');
    if (!grid) return;
    grid.innerHTML = STREAMER_KITS.map(kit => `
      <button class="kit-card group text-left glass border border-white/10 rounded-2xl p-4 hover:border-white/20 w-full"
        style="" data-kit="${kit.id}">
        <div class="flex items-start justify-between mb-3">
          <div class="text-2xl leading-none">${kit.label.split(' ')[0]}</div>
          <span class="text-xs px-2 py-0.5 rounded-full border font-medium"
            style="background:${kit.color}18;color:${kit.color};border-color:${kit.color}30">
            ${kit.blocks.length} blocks
          </span>
        </div>
        <p class="text-sm font-semibold text-white mb-1">${kit.label.split(' ').slice(1).join(' ')}</p>
        <p class="text-xs text-gray-500 mb-4">${kit.desc}</p>
        <div class="flex items-center gap-1.5 text-xs font-semibold transition-all group-hover:gap-2"
          style="color:${kit.color};opacity:0.8">
          Utiliser ce kit
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </div>
      </button>
    `).join('');
    grid.querySelectorAll('[data-kit]').forEach(btn => {
      btn.addEventListener('click', () => handleKitClick((btn as HTMLElement).dataset.kit!));
    });
  }

  async function handleKitClick(kitId: string) {
    const kit = STREAMER_KITS.find(k => k.id === kitId);
    if (!kit) return;
    if (!confirm(`Ajouter le kit "${kit.label}" ? Cela va créer ${kit.blocks.length} blocks sur ton profil.`)) return;
    let added = 0;
    for (const bd of kit.blocks) {
      if (blockLimit !== -1 && (blockCount + added) >= blockLimit) {
        toast.error(`Limite atteinte après ${added} blocks. Upgrade pour plus !`);
        break;
      }
      try {
        const data = await apiCall('/api/blocks', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: bd.type, title: bd.title, config: bd.config }),
        });
        blocks.push({ id: data.id, ...bd, active: true, created_at: new Date().toISOString(), clicks: 0, is_pinned: false });
        added++;
      } catch {}
    }
    renderBlocks();
    toast.success(`${added} blocks ajoutés depuis le kit ${kit.label} !`);
  }

  // Kit toggle
  let kitVisible = false;
  document.getElementById('kit-toggle-btn')?.addEventListener('click', () => {
    kitVisible = !kitVisible;
    const grid    = document.getElementById('kit-grid')!;
    const lbl     = document.getElementById('kit-toggle-label')!;
    const chev    = document.getElementById('kit-chevron')!;
    grid.classList.toggle('hidden', !kitVisible);
    lbl.textContent = kitVisible ? 'Masquer' : 'Afficher';
    chev.style.transform = kitVisible ? 'rotate(180deg)' : '';
    if (kitVisible) renderStreamerKit();
  });

  // ── Render blocks ─────────────────────────────────────────────────────────
  function renderBlocks() {
    const container  = document.getElementById('sortable-blocks');
    const noResults  = document.getElementById('no-results');
    const emptyState = document.getElementById('empty-state');
    if (!container) return;

    const filtered  = getFiltered();
    const hasSearch = searchQuery || activeFilter !== 'all';

    if (blocks.length === 0) {
      container.innerHTML = '';
      emptyState?.classList.remove('hidden');
      noResults?.classList.add('hidden');
      return;
    }
    emptyState?.classList.add('hidden');

    if (filtered.length === 0 && hasSearch) {
      container.innerHTML = '';
      noResults?.classList.remove('hidden');
      return;
    }
    noResults?.classList.add('hidden');

    // Pinned first
    const sorted = [...filtered].sort((a: any, b: any) => (b.is_pinned ? 1 : 0) - (a.is_pinned ? 1 : 0));

    container.innerHTML = sorted.map((block: any) => {
      const isSelected = selectedIds.has(block.id);
      const clicks     = block.clicks ?? 0;
      const newBadge   = isNew(block.created_at);
      const scheduled  = isScheduled(block);
      const isPinned   = block.is_pinned ?? false;
      const iconUrl    = block.config?.icon_url || '';
      const platform   = block.type === 'link' ? detectPlatform(block.config?.url || '') : null;
      const typeBadge  = TYPE_BADGE[block.type] ?? '';
      const ctr        = (totalViews > 0 && clicks > 0) ? ((clicks / totalViews) * 100).toFixed(1) : null;

      const iconHtml = iconUrl
        ? `<div class="shrink-0 w-9 h-9 rounded-full overflow-hidden border border-white/10 bg-white/5">
             <img src="${iconUrl}" class="w-full h-full object-cover" loading="lazy"
               onerror="this.parentElement.innerHTML='<span class=\\'flex items-center justify-center w-full h-full text-base\\'>${BLOCK_EMOJI[block.type] ?? '📌'}</span>'" />
           </div>`
        : platform
          ? `<div class="shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-lg bg-white/5 border border-white/10">${platform.icon}</div>`
          : `<div class="shrink-0 w-9 h-9 flex items-center justify-center text-xl">${BLOCK_EMOJI[block.type] ?? '📌'}</div>`;

      // Block-type-specific extra info
      let extraHtml = '';
      if (block.type === 'donation' && block.config?.goal_amount > 0) {
        const pct = Math.min(100, Math.round((block.config.current_amount / block.config.goal_amount) * 100));
        extraHtml = `
          <div class="mt-2 pl-7">
            <div class="flex items-center justify-between text-xs text-gray-500 mb-1.5">
              <span>${block.config.current_amount ?? 0} / ${block.config.goal_amount} €</span>
              <span class="font-semibold text-neon-green">${pct}%</span>
            </div>
            <div class="h-1.5 w-full rounded-full bg-white/5">
              <div class="progress-bar h-full" style="width:${pct}%"></div>
            </div>
          </div>`;
      } else if (block.type === 'countdown' && block.config?.target_date) {
        const diff  = new Date(block.config.target_date).getTime() - Date.now();
        const text  = diff > 0
          ? `dans ${Math.floor(diff/86400000)}j ${Math.floor((diff%86400000)/3600000)}h`
          : 'Terminé';
        extraHtml = `<div class="mt-1 pl-7 text-xs ${diff > 0 ? 'text-yellow-400/70' : 'text-gray-500'}">⏱ ${text}</div>`;
      } else if (block.type === 'schedule' && block.config?.schedule?.length) {
        const days = block.config.schedule.map((s: any) => `${s.day?.slice(0,3)} ${s.time}`).join(' · ');
        extraHtml = `<div class="mt-1 pl-7 text-xs text-blue-400/70">📅 ${days}</div>`;
      } else if (block.type === 'embed' && block.config?.url) {
        const domain = (() => { try { return new URL(block.config.url).hostname.replace('www.',''); } catch { return ''; } })();
        extraHtml = `<div class="mt-1 pl-7 text-xs text-purple-400/70">🎵 ${domain}</div>`;
      }

      return `
        <div class="block-card group relative glass border border-white/10 rounded-2xl p-4 transition-all hover:border-white/20
          ${isSelected ? 'selected' : ''} ${isPinned ? 'pinned-card' : ''}"
          data-id="${block.id}" data-type="${block.type}">
          ${isPinned ? '<div class="pin-tab"></div>' : ''}
          <div class="absolute top-4 left-4 z-10 ${selectedIds.size > 0 ? '' : 'opacity-0 group-hover:opacity-100'} transition-opacity">
            <input type="checkbox" ${isSelected ? 'checked' : ''}
              class="block-select w-4 h-4 rounded accent-neon-green cursor-pointer" data-id="${block.id}" />
          </div>
          <div class="flex items-center gap-3 pl-7">
            <div class="drag-handle cursor-grab active:cursor-grabbing text-gray-600 hover:text-gray-400 transition-colors shrink-0 touch-none">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
              </svg>
            </div>
            ${iconHtml}
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5 flex-wrap mb-0.5">
                <span class="text-xs px-2 py-0.5 rounded-full border font-medium capitalize ${typeBadge || 'bg-white/5 border-white/10 text-gray-400'}">${block.type}</span>
                ${block.title
                  ? `<span class="text-sm font-semibold text-white truncate max-w-[160px]">${block.title}</span>`
                  : `<span class="text-sm text-gray-600 italic">No title</span>`}
                ${isPinned   ? '<span title="Épinglé" class="text-xs leading-none">📌</span>' : ''}
                ${newBadge   ? '<span class="text-xs px-1.5 py-0.5 rounded-full bg-neon-green/15 text-neon-green font-medium border border-neon-green/25">New</span>' : ''}
                ${scheduled  ? '<span class="text-xs px-1.5 py-0.5 rounded-full border badge-scheduled font-medium">⏰ Planifié</span>' : ''}
                ${platform   ? `<span class="text-xs px-1.5 py-0.5 rounded-full bg-white/5 text-gray-500 border border-white/10">${platform.label}</span>` : ''}
              </div>
              <div class="flex items-center gap-3 text-xs">
                <span class="${block.active ? 'text-neon-green' : 'text-gray-600'} flex items-center gap-1">
                  <span class="w-1.5 h-1.5 rounded-full ${block.active ? 'bg-neon-green' : 'bg-gray-600'}"></span>
                  ${block.active ? 'Active' : 'Inactive'}
                </span>
                ${clicks > 0 ? `
                  <span class="flex items-center gap-1 text-blue-400">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/>
                    </svg>
                    ${clicks.toLocaleString('fr-FR')} clicks${ctr ? ` <span class="text-gray-500">(${ctr}%)</span>` : ''}
                  </span>` : ''}
              </div>
            </div>
            <label class="relative inline-flex items-center cursor-pointer shrink-0">
              <input type="checkbox" ${block.active ? 'checked' : ''}
                class="sr-only peer block-toggle" data-id="${block.id}" />
              <div class="w-10 h-5 bg-gray-700 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-neon-green transition-colors"></div>
            </label>
            <div class="relative shrink-0">
              <button class="block-menu-btn opacity-0 group-hover:opacity-100 transition-opacity p-2 glass rounded-lg border border-white/5 text-gray-500 hover:text-white hover:border-white/20 transition-all"
                data-id="${block.id}" aria-label="Options">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                </svg>
              </button>
              <div class="block-menu-dropdown hidden absolute right-0 top-full mt-1 w-44 rounded-xl shadow-2xl z-30 py-1 border border-white/10 overflow-hidden"
                data-id="${block.id}">
                <button class="block-edit-btn w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors text-left" data-id="${block.id}">
                  <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  Edit
                </button>
                <button class="block-pin-btn w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors text-left" data-id="${block.id}" data-pinned="${isPinned}">
                  <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                  ${isPinned ? 'Désépingler' : 'Épingler en haut'}
                </button>
                <button class="block-duplicate-btn w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition-colors text-left" data-id="${block.id}">
                  <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                  Duplicate
                </button>
                <div class="my-1 border-t border-white/10"></div>
                <button class="block-delete-btn w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm text-red-400 hover:bg-red-500/5 transition-colors text-left" data-id="${block.id}">
                  <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  Delete
                </button>
              </div>
            </div>
          </div>
          ${extraHtml}
        </div>`;
    }).join('');

    attachCardListeners();
    initSortable();
    updateBulkBar();
  }

  document.addEventListener('click', () => {
    document.querySelectorAll('.block-menu-dropdown').forEach(d => d.classList.add('hidden'));
  });

  function attachCardListeners() {
    document.querySelectorAll('.block-toggle').forEach(toggle => {
      toggle.addEventListener('change', async (e: any) => {
        const id = e.target.dataset.id; const active = e.target.checked;
        try {
          await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active }) });
          const b = blocks.find((b: any) => b.id === id);
          if (b) b.active = active;
          toast.success(active ? 'Block activé' : 'Block désactivé');
        } catch { e.target.checked = !active; toast.error('Failed to update'); }
      });
    });
    document.querySelectorAll('.block-select').forEach(cb => {
      cb.addEventListener('change', (e: any) => {
        const id = e.target.dataset.id;
        e.target.checked ? selectedIds.add(id) : selectedIds.delete(id);
        document.querySelector(`.block-card[data-id="${id}"]`)?.classList.toggle('selected', e.target.checked);
        updateBulkBar();
      });
    });
    document.querySelectorAll('.block-menu-btn').forEach(btn => {
      btn.addEventListener('click', (e: any) => {
        e.stopPropagation();
        document.querySelectorAll('.block-menu-dropdown').forEach(d => d.classList.add('hidden'));
        const id = (btn as HTMLElement).dataset.id;
        document.querySelector(`.block-menu-dropdown[data-id="${id}"]`)?.classList.toggle('hidden');
      });
    });
    document.querySelectorAll('.block-edit-btn').forEach(btn =>
      btn.addEventListener('click', () => handleEditBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-pin-btn').forEach(btn =>
      btn.addEventListener('click', () => handlePinBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-duplicate-btn').forEach(btn =>
      btn.addEventListener('click', () => handleDuplicateBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-delete-btn').forEach(btn =>
      btn.addEventListener('click', () => handleDeleteBlock((btn as HTMLElement).dataset.id!)));
  }

  // ── Pin ───────────────────────────────────────────────────────────────────
  async function handlePinBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block) return;
    const newPinned = !block.is_pinned;
    try {
      await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ is_pinned: newPinned }) });
      block.is_pinned = newPinned;
      renderBlocks();
      toast.success(newPinned ? '📌 Block épinglé' : 'Block désépinglé');
    } catch { toast.error('Failed to update pin'); }
  }

  // ── Sortable ──────────────────────────────────────────────────────────────
  function initSortable() {
    const container = document.getElementById('sortable-blocks');
    if (!container) return;
    if (!(window as any).Sortable) { setTimeout(initSortable, 30); return; }
    sortable?.destroy();
    sortable = new (window as any).Sortable(container, {
      animation: 200, handle: '.drag-handle',
      ghostClass: 'sortable-ghost', dragClass: 'sortable-drag',
      onEnd: async () => {
        const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
        const visibleIds = Array.from(container.children)
          .map((el: any) => el.dataset.id)
          .filter((id: any) => id && UUID_RE.test(id));
        if (!visibleIds.length) return;
        let blockIds: string[];
        if (activeFilter === 'all' && !searchQuery) {
          blockIds = visibleIds;
        } else {
          const vs = new Set(visibleIds);
          blockIds = [...visibleIds, ...blocks.filter((b: any) => !vs.has(b.id)).map((b: any) => b.id)];
        }
        try {
          await apiCall('/api/blocks/reorder', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ blockIds }) });
          blocks = blockIds.map((id: string) => blocks.find((b: any) => b.id === id)).filter(Boolean);
          toast.success('Ordre sauvegardé');
        } catch { toast.error('Failed to save order'); renderBlocks(); }
      },
    });
  }

  function updateBulkBar() {
    const bar = document.getElementById('bulk-bar');
    const cnt = document.getElementById('bulk-count');
    if (!bar || !cnt) return;
    if (selectedIds.size > 0) { bar.classList.remove('hidden'); bar.classList.add('flex'); cnt.textContent = `${selectedIds.size} selected`; }
    else { bar.classList.add('hidden'); bar.classList.remove('flex'); }
  }

  document.getElementById('bulk-cancel-btn')?.addEventListener('click', () => { selectedIds.clear(); renderBlocks(); });
  document.getElementById('bulk-toggle-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    const newActive = !ids.every(id => blocks.find((b: any) => b.id === id)?.active);
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active: newActive }) })));
      ids.forEach(id => { const b = blocks.find((b: any) => b.id === id); if (b) b.active = newActive; });
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} ${newActive ? 'activés' : 'désactivés'}`);
    } catch { toast.error('Bulk toggle failed'); }
  });
  document.getElementById('bulk-delete-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    if (!confirm(`Supprimer ${ids.length} block${ids.length > 1 ? 's' : ''} ? Action irréversible.`)) return;
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, { method:'DELETE' })));
      blocks = blocks.filter((b: any) => !ids.includes(b.id));
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} supprimés`);
    } catch { toast.error('Bulk delete failed'); }
  });


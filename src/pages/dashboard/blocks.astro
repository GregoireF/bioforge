---
// src/pages/dashboard/blocks.astro

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import Alert from '@/components/ui/Alert.astro';
import Modal from '@/components/ui/Modal.astro';
import PlanLimitIndicator from '@/components/features/PlanLimitIndicator.astro';
import { withAuth } from '@/lib/auth/auth';
import { getBlocks } from '@/lib/supabase/queries';

interface Block {
  id: string;
  type: string;
  title: string | null;
  active: boolean;
  config: Record<string, any>;
  position?: number;
  created_at?: string;
  deleted_at?: string;
}

// ==================== AUTH & DATA ====================

const authResult = await withAuth({
  cookies: Astro.cookies,
  request: Astro.request,
});

if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}

const { user, profile, planLimits } = authResult.data;

// ==================== GET BLOCKS ====================

const blocksResult = await getBlocks(profile.id);

let blocks: Block[] = [];
let blocksError: string | null = null;

if (blocksResult.success) {
  blocks = blocksResult.data ?? [];
} else {
  blocksError = blocksResult.error?.message ?? 'Erreur inconnue lors du chargement des blocks';
  console.error('Échec chargement blocks:', blocksResult);
}

// Valeurs sécurisées avec fallback
const activeBlocks = blocks.filter(block => !block.deleted_at);

const blockCount = activeBlocks.length;
const blockLimit = planLimits?.max_blocks_total ?? 15; // fallback raisonnable
const canAddBlock = blockLimit === -1 || blockCount < blockLimit;
const isNearLimit =
  blockLimit !== -1 &&
  blockCount >= blockLimit * 0.8 &&
  blockCount < blockLimit;
const progressPercent =
  blockLimit > 0 ? Math.min(100, Math.round((blockCount / blockLimit) * 100)) : 0;
---

<DashboardLayout title="Blocks">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h2 class="text-lg lg:text-xl font-semibold text-white mb-1">Manage Your Blocks</h2>
      <p class="text-sm text-gray-400">Build your page with links, headings, images and more</p>
    </div>
    <Button 
      variant={canAddBlock ? 'primary' : 'secondary'}
      class="w-full sm:w-auto"
      id="add-block-btn"
    >
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      {canAddBlock ? 'Add Block' : 'Upgrade to Add More'}
    </Button>
  </div>

  <PlanLimitIndicator 
    current={blockCount}
    limit={blockLimit}
    feature="Blocks"
    showUpgrade={true}
  />

  <!-- Error Alert -->
  {blocksError && (
    <Alert variant="danger" title="Error loading blocks">
      <p>{blocksError}</p>
      <p class="text-sm mt-2">Please refresh the page. If the problem persists, contact support.</p>
    </Alert>
  )}

  <!-- Approaching limit -->
  {isNearLimit && (
    <Alert variant="warning" title="Approaching limit" class="mb-6">
      <p>You're using {blockCount} of {blockLimit} blocks ({progressPercent}%).</p>
      <a href="/pricing" class="text-yellow-400 hover:underline text-sm">
        Upgrade to add more blocks
      </a>
    </Alert>
  )}

  <!-- Limit reached (seulement si vraiment atteint) -->
  {!canAddBlock && blockLimit !== -1 && (
    <Alert variant="danger" title="Block limit reached" class="mb-6">
      <p>You've reached your limit of {blockLimit} blocks.</p>
      <a href="/pricing" class="text-red-400 hover:underline text-sm">
        Upgrade to add more blocks
      </a>
    </Alert>
  )}

  <!-- Blocks Container -->
  <div id="blocks-container">
    {blocks.length === 0 ? (
      <!-- Empty State -->
      <Card>
        <div class="text-center py-12">
          <div class="w-16 h-16 rounded-full bg-gradient-to-br from-neon-green/20 to-neon-blue/20 border border-neon-green/30 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-white mb-2">No blocks yet</h3>
          <p class="text-gray-400 mb-6">Start building your page by adding your first block</p>
          {canAddBlock ? (
            <Button variant="primary" id="empty-state-btn">
              Add Your First Block
            </Button>
          ) : (
            <Button variant="secondary" href="/pricing">
              Upgrade to Add Blocks
            </Button>
          )}
        </div>
      </Card>
    ) : (
      <!-- Blocks List -->
      <div class="space-y-4" id="sortable-blocks">
        {blocks.map((block) => (
          <div class="glass-strong rounded-2xl p-4 lg:p-6 border border-white/10 hover:border-neon-green/30 transition-all group cursor-move" data-id={block.id.trim()}>
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center space-x-3 lg:space-x-4 flex-1 min-w-0">
                <button class="cursor-move text-gray-500 hover:text-white transition-colors touch-none">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
                  </svg>
                </button>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center space-x-2 mb-1">
                    <Badge variant="default" size="sm">{block.type}</Badge>
                    {block.title ? (
                      <h3 class="text-white font-semibold truncate">{block.title}</h3>
                    ) : (
                      <span class="text-gray-500 text-sm">No title</span>
                    )}
                  </div>
                  <p class="text-sm text-gray-400 truncate">
                    {block.active ? 'Active' : 'Inactive'}
                  </p>
                </div>
              </div>
              <div class="flex items-center space-x-2">
                <label class="relative inline-flex items-center cursor-pointer">
                  <input 
                    type="checkbox" 
                    checked={block.active}
                    class="sr-only peer block-toggle" 
                    data-id={block.id}
                  />
                  <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-neon-green"></div>
                </label>
              </div>
            </div>
            <div class="flex items-center space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
              <button class="block-edit-btn px-3 lg:px-4 py-2 text-sm text-gray-400 hover:text-white glass border border-white/10 rounded-lg transition-colors" data-id={block.id}>
                Edit
              </button>
              <button class="block-delete-btn px-3 lg:px-4 py-2 text-sm text-gray-400 hover:text-red-400 glass border border-white/10 rounded-lg transition-colors" data-id={block.id}>
                Delete
              </button>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Block Type Selection Modal -->
  <Modal id="type-modal" title="Choose Block Type" size="lg">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <!-- Link Block -->
      <button 
        class="block-type-btn p-4 glass border border-white/10 rounded-xl hover:border-neon-green/50 transition-all group text-left"
        data-type="link"
      >
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-neon-green/20 to-neon-green/10 border border-neon-green/30 flex items-center justify-center mb-3">
          <span class="text-xl">🔗</span>
        </div>
        <h4 class="text-white font-semibold mb-1">Link</h4>
        <p class="text-xs text-gray-400">Add a clickable link</p>
      </button>

      <!-- Heading Block -->
      <button 
        class="block-type-btn p-4 glass border border-white/10 rounded-xl hover:border-neon-purple/50 transition-all group text-left"
        data-type="heading"
      >
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-neon-purple/20 to-neon-purple/10 border border-neon-purple/30 flex items-center justify-center mb-3">
          <span class="text-xl">📝</span>
        </div>
        <h4 class="text-white font-semibold mb-1">Heading</h4>
        <p class="text-xs text-gray-400">Section title</p>
      </button>

      <!-- Spacer Block -->
      <button 
        class="block-type-btn p-4 glass border border-white/10 rounded-xl hover:border-neon-blue/50 transition-all group text-left"
        data-type="spacer"
      >
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-neon-blue/20 to-neon-blue/10 border border-neon-blue/30 flex items-center justify-center mb-3">
          <span class="text-xl">—</span>
        </div>
        <h4 class="text-white font-semibold mb-1">Spacer</h4>
        <p class="text-xs text-gray-400">Add spacing</p>
      </button>

      <!-- Image Block -->
      <button 
        class="block-type-btn p-4 glass border border-white/10 rounded-xl hover:border-neon-pink/50 transition-all group text-left"
        data-type="image"
      >
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-neon-pink/20 to-neon-pink/10 border border-neon-pink/30 flex items-center justify-center mb-3">
          <span class="text-xl">🖼️</span>
        </div>
        <h4 class="text-white font-semibold mb-1">Image</h4>
        <p class="text-xs text-gray-400">Display image</p>
      </button>

      <!-- Video Block -->
      <button 
        class="block-type-btn p-4 glass border border-white/10 rounded-xl hover:border-neon-green/50 transition-all group text-left"
        data-type="video"
      >
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-neon-green/20 to-neon-green/10 border border-neon-green/30 flex items-center justify-center mb-3">
          <span class="text-xl">🎥</span>
        </div>
        <h4 class="text-white font-semibold mb-1">Video</h4>
        <p class="text-xs text-gray-400">Embed video</p>
      </button>

      <!-- Social Block -->
      <button 
        class="block-type-btn p-4 glass border border-white/10 rounded-xl hover:border-neon-purple/50 transition-all group text-left"
        data-type="social"
      >
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-neon-purple/20 to-neon-purple/10 border border-neon-purple/30 flex items-center justify-center mb-3">
          <span class="text-xl">👥</span>
        </div>
        <h4 class="text-white font-semibold mb-1">Social</h4>
        <p class="text-xs text-gray-400">Social icons</p>
      </button>
    </div>
  </Modal>

  <!-- Edit Block Modal -->
  <Modal id="edit-modal" title="Edit Block" size="md">
    <form id="block-form" class="space-y-4">
      <input type="hidden" id="block-id" />
      <input type="hidden" id="block-type" />
      
      <div id="form-fields"></div>

      <div class="flex space-x-3">
        <Button type="submit" variant="primary" class="flex-1" id="submit-btn">
          <span id="submit-text">Save Block</span>
        </Button>
        <Button type="button" variant="ghost" class="px-6" id="cancel-btn">
          Cancel
        </Button>
      </div>
    </form>
  </Modal>

  <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
  <script>
    import { toast } from '@/lib/utils/toast';

    // ==================== STATE ====================
    let selectedType = null;
    let editingId = null;
    let blocks = [];

    // ==================== LOAD BLOCKS ====================
    async function loadBlocks(forceRefresh = false) {
      try {
        const response = await fetch('/api/blocks', {
          cache: forceRefresh ? 'no-store' : 'default',
          credentials: 'include'
        });

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData.error || `Failed to load blocks (${response.status})`);
        }

        const data = await response.json();
        // Supporte { data: [...], blocks: [...] } ou tableau direct
        blocks = Array.isArray(data) ? data 
               : data.data ?? data.blocks ?? [];
        
        console.log('[loadBlocks] Loaded', blocks.length, 'blocks →', blocks.map(b => b.id));
        renderBlocks();
      } catch (error) {
        console.error('Error loading blocks:', error);
        toast.error(error.message || 'Failed to load blocks');
      }
    }

    // ==================== RENDER BLOCKS ====================
    function renderBlocks() {
      const container = document.getElementById('sortable-blocks');
      if (!container) return;

      if (blocks.length === 0) {
        container.innerHTML = '';
        return;
      }

      container.innerHTML = blocks.map(block => `
        <div class="glass-strong rounded-2xl p-4 lg:p-6 border border-white/10 hover:border-neon-green/30 transition-all group cursor-move" data-id="${block.id}">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center space-x-3 lg:space-x-4 flex-1 min-w-0">
              <button class="cursor-move text-gray-500 hover:text-white transition-colors touch-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
                </svg>
              </button>
              <div class="flex-1 min-w-0">
                <div class="flex items-center space-x-2 mb-1">
                  <span class="text-xs px-2 py-0.5 rounded-full bg-gray-500/20 text-gray-400">${block.type}</span>
                  ${block.title ? `<h3 class="text-white font-semibold truncate">${block.title}</h3>` : '<span class="text-gray-500 text-sm">No title</span>'}
                </div>
                <p class="text-sm text-gray-400 truncate">${block.active ? 'Active' : 'Inactive'}</p>
              </div>
            </div>
            <div class="flex items-center space-x-2">
              <label class="relative inline-flex items-center cursor-pointer">
                <input 
                  type="checkbox" 
                  ${block.active ? 'checked' : ''} 
                  class="sr-only peer block-toggle" 
                  data-id="${block.id}"
                />
                <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-neon-green"></div>
              </label>
            </div>
          </div>
          <div class="flex items-center space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="block-edit-btn px-3 lg:px-4 py-2 text-sm text-gray-400 hover:text-white glass border border-white/10 rounded-lg transition-colors" data-id="${block.id}">
              Edit
            </button>
            <button class="block-delete-btn px-3 lg:px-4 py-2 text-sm text-gray-400 hover:text-red-400 glass border border-white/10 rounded-lg transition-colors" data-id="${block.id}">
              Delete
            </button>
          </div>
        </div>
      `).join('');

      attachEventListeners();
      initSortable();
    }

    // ==================== EVENT LISTENERS ====================
    function attachEventListeners() {
      // Toggle active
      document.querySelectorAll('.block-toggle').forEach(toggle => {
        toggle.addEventListener('change', async (e) => {
          const id = e.target.dataset.id;
          const active = e.target.checked;
          
          try {
            const res = await fetch(`/api/blocks/${id}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ active })
            });
            
            if (!res.ok) throw new Error((await res.json()).error || 'Update failed');
            
            toast.success('Block updated!');
            await loadBlocks(true);
          } catch (err) {
            e.target.checked = !active;
            toast.error(err.message || 'Failed to update block');
          }
        });
      });

      // Edit
      document.querySelectorAll('.block-edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id;
          if (id) handleEditBlock(id);
        });
      });

      // Delete
      document.querySelectorAll('.block-delete-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id;
          if (id) handleDeleteBlock(id);
        });
      });
    }

    // ==================== SORTABLE ====================
    function initSortable() {
      const container = document.getElementById('sortable-blocks');
      if (!container) return;

      new Sortable(container, {
        animation: 150,
        handle: '.cursor-move',
        onEnd: async function() {
          const blockIds = Array.from(container.children).map(el => el.dataset.id);
          
          try {
            const res = await fetch('/api/blocks/reorder', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ blockIds })
            });
            
            if (!res.ok) throw new Error((await res.json()).error || 'Reorder failed');
            
            toast.success('Blocks reordered!');
          } catch (err) {
            toast.error(err.message || 'Failed to reorder');
            await loadBlocks(true);
          }
        }
      });
    }

    // ==================== MODALS ====================
    function openModal(id) {
      document.getElementById(id)?.classList.remove('hidden');
      document.getElementById(id)?.classList.add('flex');
    }

    function closeModal(id) {
      document.getElementById(id)?.classList.add('hidden');
      document.getElementById(id)?.classList.remove('flex');
    }

    // Add block buttons
    document.getElementById('add-block-btn')?.addEventListener('click', () => openModal('type-modal'));
    document.getElementById('empty-state-btn')?.addEventListener('click', () => openModal('type-modal'));

    // Type selection
    document.querySelectorAll('.block-type-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedType = btn.dataset.type;
        editingId = null;
        closeModal('type-modal');
        renderForm(selectedType, null);
        openModal('edit-modal');
      });
    });

    document.getElementById('cancel-btn')?.addEventListener('click', () => closeModal('edit-modal'));

    // ==================== FORM HANDLING ====================
    function renderForm(type, block = null) {
      const container = document.getElementById('form-fields');
      const submitText = document.getElementById('submit-text');
      if (submitText) submitText.textContent = block ? 'Update Block' : 'Add Block';

      let html = '';

      switch (type) {
        case 'link':
          html = `
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Title</label>
              <input 
                type="text" 
                id="field-title" 
                required 
                value="${block?.title || ''}"
                class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-green/50 focus:outline-none focus:ring-2 focus:ring-neon-green/20"
                placeholder="Instagram"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">URL</label>
              <input 
                type="url" 
                id="field-url" 
                required 
                value="${block?.config?.url || ''}"
                class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-green/50 focus:outline-none focus:ring-2 focus:ring-neon-green/20"
                placeholder="https://instagram.com/username"
              />
            </div>
          `;
          break;

        case 'heading':
          html = `
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Heading Text</label>
              <input 
                type="text" 
                id="field-title" 
                required 
                value="${block?.title || ''}"
                class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-purple/50 focus:outline-none focus:ring-2 focus:ring-neon-purple/20"
                placeholder="Social Media"
              />
            </div>
          `;
          break;

        case 'spacer':
          html = `
            <div class="text-center py-4 text-gray-400">
              <p>No configuration needed for spacer</p>
            </div>
          `;
          break;

        case 'image':
          html = `
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Image URL</label>
              <input 
                type="url" 
                id="field-url" 
                required 
                value="${block?.config?.url || ''}"
                class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-pink/50 focus:outline-none focus:ring-2 focus:ring-neon-pink/20"
                placeholder="https://example.com/image.jpg"
              />
            </div>
          `;
          break;

        case 'video':
          html = `
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Video URL</label>
              <input 
                type="url" 
                id="field-url" 
                required 
                value="${block?.config?.url || ''}"
                class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-green/50 focus:outline-none focus:ring-2 focus:ring-neon-green/20"
                placeholder="https://youtube.com/watch?v=..."
              />
              <p class="text-xs text-gray-500 mt-1.5">Supports YouTube, Vimeo, TikTok</p>
            </div>
          `;
          break;

        case 'social':
          html = `
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Title (Optional)</label>
              <input 
                type="text" 
                id="field-title" 
                value="${block?.title || ''}"
                class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-purple/50 focus:outline-none focus:ring-2 focus:ring-neon-purple/20"
                placeholder="Follow Me"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-2">Social Links (comma-separated URLs)</label>
              <textarea 
                id="field-links" 
                rows="3" 
                required 
                class="w-full px-4 py-3 glass border border-white/10 rounded-xl text-white placeholder-gray-500 focus:border-neon-purple/50 focus:outline-none focus:ring-2 focus:ring-neon-purple/20"
                placeholder="https://twitter.com/user, https://instagram.com/user"
              >${block?.config?.links?.map((l) => l.url || l).join(', ') || ''}</textarea>
            </div>
          `;
          break;
      }

      if (container) container.innerHTML = html;

      document.getElementById('block-type').value = type;
      if (block) document.getElementById('block-id').value = block.id;
    }

    // Form submit
    const blockForm = document.getElementById('block-form');
    blockForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const type = document.getElementById('block-type').value;
      const blockId = document.getElementById('block-id')?.value || '';

      let title = null;
      let config = {};

      switch (type) {
        case 'link':
          title = document.getElementById('field-title').value;
          config = { url: document.getElementById('field-url').value };
          break;

        case 'heading':
          title = document.getElementById('field-title').value;
          config = {};
          break;

        case 'spacer':
          config = {};
          break;

        case 'image':
          config = { url: document.getElementById('field-url').value };
          break;

        case 'video':
          config = { url: document.getElementById('field-url').value };
          break;

        case 'social':
          title = document.getElementById('field-title').value || null;
          const linksText = document.getElementById('field-links').value;
          const links = linksText.split(',').map(url => ({ url: url.trim() })).filter(l => l.url);
          config = { links };
          break;
      }

      try {
        const url = blockId ? `/api/blocks/${blockId}` : '/api/blocks';
        const method = blockId ? 'PUT' : 'POST';

        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type, title, config })
        });

        const data = await response.json();

        if (!response.ok) {
          if (response.status === 403 && /limit|BLOCK_LIMIT_REACHED/i.test(data.error || '')) {
            toast.error('Limite de blocs atteinte. Upgradez votre plan !');
          } else {
            throw new Error(data.error || 'Échec de la sauvegarde');
          }
          return;
        }

        toast.success(blockId ? 'Bloc mis à jour !' : 'Bloc créé !');
        closeModal('edit-modal');
        blockForm.reset();
        await loadBlocks(true);  // recharge forcé
      } catch (err) {
        toast.error(err.message || 'Erreur lors de la sauvegarde');
      }
    });

    // ==================== EDIT & DELETE ====================
    function handleEditBlock(id) {
      const block = blocks.find(b => b.id === id);
      if (!block) return;

      editingId = id;
      selectedType = block.type;
      renderForm(block.type, block);
      openModal('edit-modal');
    }

    async function handleDeleteBlock(id) {
      if (!confirm('Are you sure you want to delete this block?')) return;

      try {
        const response = await fetch(`/api/blocks/${id}`, {
          method: 'DELETE'
        });
        
        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || 'Failed to delete block');
        }
        
        toast.success('Block deleted!');
        await loadBlocks(true);
      } catch (error) {
        toast.error(error.message || 'Failed to delete block');
      }
    }

    // Initial load
    loadBlocks();
  </script>
</DashboardLayout>
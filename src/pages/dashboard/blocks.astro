        const url = (btn as HTMLElement).dataset.url!;
        await navigator.clipboard.writeText(url).catch(() => {});
        const orig = (btn as HTMLElement).innerHTML;
        (btn as HTMLElement).innerHTML = `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`;
        setTimeout(() => { (btn as HTMLElement).innerHTML = orig; }, 1500);
        toast.success('URL copiée !');
      });
    });

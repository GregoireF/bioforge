  .sch-time-input:focus { border-color: var(--green-glow); }
  .sch-day-label { font-size: 13px; color: var(--text-1); }

  /* poll */
  .poll-option-row { display: flex; align-items: center; gap: 7px; }
  .poll-num { font-size: 11px; color: var(--text-3); width: 16px; flex-shrink: 0; }

  /* merch items */
  .merch-item {
    border: 1px solid var(--border);

            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-white">${p.label}</p>
              <p class="text-xs text-gray-500 truncate">${p.match[0]}</p>
            </div>
            <svg class="w-4 h-4 text-gray-600 group-hover:text-neon-green transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>`;
      });
      html += `</div></div>`;
    }

    if (blockItems.length) {
      html += `<div>
        <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-3 px-1">Types de block</p>

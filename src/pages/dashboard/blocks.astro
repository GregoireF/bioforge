    try {
      const data = await apiCall('/api/blocks', { method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ type:'link', title, config:{ url: quickUrl, ...(iconUrl ? { icon_url: iconUrl } : {}) } }) });
      blocks.push({ id: data.id, type:'link', title, config:{ url: quickUrl, icon_url: iconUrl }, active:true, created_at: new Date().toISOString(), clicks:0, is_pinned:false });
      renderBlocks();
      toast.success(`${quickPlat?.label ?? 'Link'} ajouté !`);

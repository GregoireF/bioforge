  function attachCardListeners() {
    document.querySelectorAll('.block-toggle').forEach(toggle => {
      toggle.addEventListener('change', async (e: any) => {
        const id = e.target.dataset.id; const active = e.target.checked;
        try {
          await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active }) });
          const b = blocks.find((b: any) => b.id === id);
          if (b) b.active = active;
          toast.success(active ? 'Block activé' : 'Block désactivé');
        } catch { e.target.checked = !active; toast.error('Failed to update'); }
      });
    });
    document.querySelectorAll('.block-select').forEach(cb => {
      cb.addEventListener('change', (e: any) => {
        const id = e.target.dataset.id;
        e.target.checked ? selectedIds.add(id) : selectedIds.delete(id);
        document.querySelector(`.block-card[data-id="${id}"]`)?.classList.toggle('selected', e.target.checked);
        updateBulkBar();
      });
    });
    document.querySelectorAll('.block-menu-btn').forEach(btn => {
      btn.addEventListener('click', (e: any) => {
        e.stopPropagation();
        document.querySelectorAll('.block-menu-dropdown').forEach(d => d.classList.add('hidden'));
        const id = (btn as HTMLElement).dataset.id;
        document.querySelector(`.block-menu-dropdown[data-id="${id}"]`)?.classList.toggle('hidden');
      });
    });
    document.querySelectorAll('.block-edit-btn').forEach(btn =>
      btn.addEventListener('click', () => handleEditBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-pin-btn').forEach(btn =>
      btn.addEventListener('click', () => handlePinBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-duplicate-btn').forEach(btn =>
      btn.addEventListener('click', () => handleDuplicateBlock((btn as HTMLElement).dataset.id!)));
    document.querySelectorAll('.block-delete-btn').forEach(btn =>
      btn.addEventListener('click', () => handleDeleteBlock((btn as HTMLElement).dataset.id!)));
  }

  // ── Pin ───────────────────────────────────────────────────────────────────
  async function handlePinBlock(id: string) {
    const block = blocks.find((b: any) => b.id === id);
    if (!block) return;
    const newPinned = !block.is_pinned;
    try {
      await apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ is_pinned: newPinned }) });
      block.is_pinned = newPinned;
      renderBlocks();
      toast.success(newPinned ? '📌 Block épinglé' : 'Block désépinglé');
    } catch { toast.error('Failed to update pin'); }
  }

  // ── Sortable ──────────────────────────────────────────────────────────────
  function initSortable() {
    const container = document.getElementById('sortable-blocks');
    if (!container) return;
    if (!(window as any).Sortable) { setTimeout(initSortable, 30); return; }
    sortable?.destroy();
    sortable = new (window as any).Sortable(container, {
      animation: 200, handle: '.drag-handle',
      ghostClass: 'sortable-ghost', dragClass: 'sortable-drag',
      onEnd: async () => {
        const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
        const visibleIds = Array.from(container.children)
          .map((el: any) => el.dataset.id)
          .filter((id: any) => id && UUID_RE.test(id));
        if (!visibleIds.length) return;
        let blockIds: string[];
        if (activeFilter === 'all' && !searchQuery) {
          blockIds = visibleIds;
        } else {
          const vs = new Set(visibleIds);
          blockIds = [...visibleIds, ...blocks.filter((b: any) => !vs.has(b.id)).map((b: any) => b.id)];
        }
        try {
          await apiCall('/api/blocks/reorder', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ blockIds }) });
          blocks = blockIds.map((id: string) => blocks.find((b: any) => b.id === id)).filter(Boolean);
          toast.success('Ordre sauvegardé');
        } catch { toast.error('Failed to save order'); renderBlocks(); }
      },
    });
  }

  function updateBulkBar() {
    const bar = document.getElementById('bulk-bar');
    const cnt = document.getElementById('bulk-count');
    if (!bar || !cnt) return;
    if (selectedIds.size > 0) { bar.classList.remove('hidden'); bar.classList.add('flex'); cnt.textContent = `${selectedIds.size} selected`; }
    else { bar.classList.add('hidden'); bar.classList.remove('flex'); }
  }

  document.getElementById('bulk-cancel-btn')?.addEventListener('click', () => { selectedIds.clear(); renderBlocks(); });
  document.getElementById('bulk-toggle-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    const newActive = !ids.every(id => blocks.find((b: any) => b.id === id)?.active);
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ active: newActive }) })));
      ids.forEach(id => { const b = blocks.find((b: any) => b.id === id); if (b) b.active = newActive; });
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} ${newActive ? 'activés' : 'désactivés'}`);
    } catch { toast.error('Bulk toggle failed'); }
  });
  document.getElementById('bulk-delete-btn')?.addEventListener('click', async () => {
    const ids = [...selectedIds];
    if (!confirm(`Supprimer ${ids.length} block${ids.length > 1 ? 's' : ''} ? Action irréversible.`)) return;
    try {
      await Promise.all(ids.map(id => apiCall(`/api/blocks/${id}`, { method:'DELETE' })));
      blocks = blocks.filter((b: any) => !ids.includes(b.id));
      selectedIds.clear(); renderBlocks();
      toast.success(`${ids.length} block${ids.length > 1 ? 's' : ''} supprimés`);
    } catch { toast.error('Bulk delete failed'); }
  });

  document.getElementById('search-input')?.addEventListener('input', (e: any) => {

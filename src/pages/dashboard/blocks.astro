  /* icon preview */
  .icon-preview-wrap {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border);
    background: var(--surface-3);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--text-3);
  }
  .icon-preview-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .icon-row { display: flex; align-items: center; gap: 10px; }

  /* donate platform buttons */
  .plat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 7px; }
  .plat-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 10px 6px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-2);
    transition: all .12s;
    text-transform: capitalize;
  }
  .plat-btn:hover { border-color: var(--border-hover); color: var(--text-0); }
  .plat-btn.active { border-color: var(--green-glow); background: var(--green-dim); color: var(--text-0); }
  .plat-btn-icon { font-size: 18px; line-height: 1; }

  /* visibility toggle */
  .visibility-section { border-top: 1px solid var(--border); padding-top: 14px; }
  .visibility-toggle-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    font-size: 13px;
    padding: 0;
    transition: color .15s;
  }
  .visibility-toggle-btn:hover { color: var(--text-0); }
  .vis-toggle-left { display: flex; align-items: center; gap: 8px; }
  #visibility-panel { padding-top: 12px; display: flex; flex-direction: column; gap: 10px; }

  /* Schedule widget */
  .sch-time-input {
    padding: 7px 11px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);

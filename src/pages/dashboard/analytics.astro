          return`<div style="margin-bottom:8px"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px"><span style="font-size:11px;color:#484f58">${item.label}</span><span style="font-size:11px;font-weight:700;color:${done?'#00ff9d':item.color};font-variant-numeric:tabular-nums">${done?'✓ ':''} ${pct}%</span></div><div style="background:rgba(255,255,255,.04);border-radius:9999px;height:3px;overflow:hidden"><div style="height:100%;border-radius:9999px;width:${pct}%;background:${done?'#00ff9d':item.color};transition:width .9s cubic-bezier(.16,1,.3,1)"></div></div></div>`;
        }).join('');

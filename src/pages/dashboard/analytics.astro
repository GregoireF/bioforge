---
// src/pages/dashboard/analytics.astro — Analytics v3
// Powered by get_profile_analytics RPC + daily_clicks query
// Redesigned: bento grid · animated KPIs · sparklines · tabbed insights

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import Alert from '@/components/ui/Alert.astro';
import { withAuth } from '@/lib/auth/auth';
import { getBlocks } from '@/lib/supabase/queries';
import { createServerClient } from '@supabase/ssr';
import { parse } from 'cookie';

// ==================== PERIOD ====================
const allowedDays = [7, 30, 90] as const;
type Period = typeof allowedDays[number];
const rawDays = Number(Astro.url.searchParams.get('days') ?? 7);
const days: Period = (allowedDays.includes(rawDays as Period) ? rawDays : 7) as Period;

// ==================== SUPABASE CLIENT ====================
const cookies = parse(Astro.request.headers.get('cookie') ?? '');
const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL!,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY!,
  { cookies: { get: (k) => cookies[k], set: () => {}, remove: () => {} } }
);

// ==================== AUTH ====================
const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}
const { profile } = authResult.data;
const profileId = profile?.id;
if (!profileId) return Astro.redirect('/signin?error=no_profile');

// ==================== DATA FETCH ====================
type AnalyticsRPC = {
  total_views:     number;
  clean_views:     number;
  unique_visitors: number;
  total_clicks:    number;
  daily_views:     { date: string; views: number }[] | null;
  devices:         Record<string, number> | null;
  top_countries:   { country: string; views: number }[] | null;
  top_referrers:   { referrer: string; views: number }[] | null;
  top_blocks:      { block_id: string; title: string; type: string; clicks: number }[] | null;
  bots:            Record<string, number> | null;
};

let rpcData: AnalyticsRPC | null = null;
let rpcError: string | null = null;
let dailyClicks: { date: string; clicks: number }[] = [];
let blocks: any[] = [];

const { data: rpcRaw, error: rpcErr } = await supabase.rpc('get_profile_analytics', {
  p_profile_id: profileId,
  p_days: days,
});
if (rpcErr) { rpcError = rpcErr.message; }
else { rpcData = rpcRaw as AnalyticsRPC; }

const since = new Date();
since.setDate(since.getDate() - days);
const { data: clickRows } = await supabase
  .from('block_clicks').select('click_date')
  .eq('profile_id', profileId)
  .gte('click_date', since.toISOString().split('T')[0]);

if (clickRows) {
  const map = new Map<string, number>();
  for (const row of clickRows) {
    const d = row.click_date as string;
    map.set(d, (map.get(d) ?? 0) + 1);
  }
  dailyClicks = Array.from(map.entries())
    .map(([date, clicks]) => ({ date, clicks }))
    .sort((a, b) => a.date.localeCompare(b.date));
}

const { data: blockRows } = await supabase
  .from('blocks').select('id, type, title, active')
  .eq('profile_id', profileId).is('deleted_at', null).order('position');
blocks = blockRows ?? [];

// ==================== DERIVED METRICS ====================
const summary = {
  totalViews:     rpcData?.total_views     ?? 0,
  cleanViews:     rpcData?.clean_views     ?? 0,
  uniqueVisitors: rpcData?.unique_visitors ?? 0,
  totalClicks:    rpcData?.total_clicks    ?? 0,
  clickRate:      rpcData && rpcData.total_views > 0
    ? ((rpcData.total_clicks / rpcData.total_views) * 100) : 0,
  botViews: Object.values(rpcData?.bots ?? {}).reduce((a, b) => a + b, 0),
  avgPerDay: days > 0 ? Math.round((rpcData?.total_views ?? 0) / days) : 0,
};

const topBlocks    = rpcData?.top_blocks    ?? [];
const topCountries = rpcData?.top_countries ?? [];
const devices      = rpcData?.devices       ?? {};
const topReferrers = rpcData?.top_referrers ?? [];

// ── Chart data ──
const allDates = new Set<string>();
(rpcData?.daily_views ?? []).forEach(r => allDates.add(r.date));
dailyClicks.forEach(r => allDates.add(r.date));
const sortedDates  = Array.from(allDates).sort();
const viewsByDate  = new Map((rpcData?.daily_views ?? []).map(r => [r.date, r.views]));
const clicksByDate = new Map(dailyClicks.map(r => [r.date, r.clicks]));
const chartLabels  = sortedDates.map(d =>
  new Date(d + 'T12:00:00Z').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short' })
);
const chartViews  = sortedDates.map(d => viewsByDate.get(d)  ?? 0);
const chartClicks = sortedDates.map(d => clicksByDate.get(d) ?? 0);
const chartRates  = sortedDates.map((_, i) => {
  const v = chartViews[i], c = chartClicks[i];
  return v > 0 ? parseFloat(((c / v) * 100).toFixed(1)) : 0;
});

// Sparkline SVG helper — tiny 32×16 path from data array
function sparkline(data: number[], color: string): string {
  if (!data.length) return '';
  const max = Math.max(...data, 1);
  const W = 80, H = 24;
  const pts = data.map((v, i) => {
    const x = (i / Math.max(data.length - 1, 1)) * W;
    const y = H - (v / max) * H;
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polyline points="${pts}" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.8"/>
  </svg>`;
}
const viewSparkline  = sparkline(chartViews,  '#00ff9d');
const clickSparkline = sparkline(chartClicks, '#bf00ff');

// ── Device ──
const deviceData = {
  mobile:  devices['mobile']  ?? 0,
  desktop: devices['desktop'] ?? 0,
  tablet:  devices['tablet']  ?? 0,
  unknown: devices['unknown'] ?? 0,
};
const deviceTotal = deviceData.mobile + deviceData.desktop + deviceData.tablet + deviceData.unknown;

// ── Referrer ──
const SOCIAL = ['twitter.com','x.com','instagram.com','tiktok.com','facebook.com','linkedin.com','youtube.com','pinterest.com','snapchat.com','reddit.com','discord.com','twitch.tv'];
const SEARCH  = ['google.','bing.com','duckduckgo.com','yahoo.com','baidu.com','yandex.'];
function classifyReferrer(ref: string | null): { label: string; category: 'direct'|'social'|'search'|'other' } {
  if (!ref) return { label: 'Direct / liens', category: 'direct' };
  try {
    const host = new URL(ref.includes('://') ? ref : `https://${ref}`).hostname.replace(/^www\./, '');
    if (SOCIAL.some(s => host.includes(s))) return { label: host, category: 'social' };
    if (SEARCH.some(s => host.includes(s)))  return { label: host, category: 'search' };
    return { label: host, category: 'other' };
  } catch { return { label: ref.slice(0, 40), category: 'other' }; }
}
const parsedReferrers = topReferrers.map(r => ({ ...classifyReferrer(r.referrer), views: r.views }));
const refAgg = new Map<string, { label: string; category: string; views: number }>();
for (const r of parsedReferrers) {
  const e = refAgg.get(r.label);
  if (e) e.views += r.views; else refAgg.set(r.label, { ...r });
}
const aggregatedReferrers = Array.from(refAgg.values()).sort((a, b) => b.views - a.views).slice(0, 6);
const maxReferrerViews = aggregatedReferrers[0]?.views ?? 1;
const maxCountryViews  = topCountries[0]?.views ?? 1;

function countryFlag(code: string): string {
  if (!code || code.length !== 2) return '🌐';
  return String.fromCodePoint(...[...code.toUpperCase()].map(c => 0x1F1E0 - 65 + c.charCodeAt(0)));
}

// Static lookups — kept out of JSX to avoid TS-generic parse errors
const CAT_COLORS: Record<string, string> = {
  direct: '#00ff9d', social: '#bf00ff', search: '#00aaff', other: '#ff6b6b',
};
const CAT_LABELS: Record<string, string> = {
  direct: 'Direct', social: 'Social', search: 'Recherche', other: 'Autre',
};

// Bridge
const exportedChart   = { labels: chartLabels, views: chartViews, clicks: chartClicks, rates: chartRates };
const exportedDevices = deviceData;
const exportedDays    = days;
---

<DashboardLayout title="Analytics">

<style>
  /* ── Animations ── */
  @keyframes countUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes barGrow {
    from { width: 0 !important; }
  }
  @keyframes fadeSlide {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .kpi-value  { animation: countUp  0.5s ease both; }
  .bar-fill   { animation: barGrow  0.8s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .fade-slide { animation: fadeSlide 0.4s ease both; }

  /* ── Bento grid ── */
  .bento { display: grid; gap: 1rem; }
  @media (min-width: 768px) {
    .bento-main { grid-template-columns: 2fr 1fr; }
    .bento-insights { grid-template-columns: 1fr 1fr; }
  }

  /* ── KPI card glow ── */
  .kpi-card { position: relative; overflow: hidden; }
  .kpi-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 0% 0%, var(--glow) 0%, transparent 65%);
    opacity: 0.12;
    pointer-events: none;
  }

  /* ── Tab system ── */
  .insight-panel { display: none; }
  .insight-panel.active { display: block; }

  /* ── Rank badge ── */
  .rank-1 { background: linear-gradient(135deg, #ffd70022, #ffd70011); border-color: #ffd70040; color: #ffd700; }
  .rank-2 { background: rgba(192,192,192,0.1); border-color: rgba(192,192,192,0.2); color: #c0c0c0; }
  .rank-3 { background: rgba(205,127,50,0.1);  border-color: rgba(205,127,50,0.2);  color: #cd7f32; }

  /* ── Progress bar track ── */
  .bar-track { background: rgba(255,255,255,0.04); border-radius: 9999px; overflow: hidden; height: 3px; }
  .bar-fill  { height: 100%; border-radius: 9999px; }

  /* ── Source badge ── */
  .source-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 8px; border-radius: 9999px;
    font-size: 10px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
  }


  /* ── Choropleth map ── */
  @keyframes spin { to { transform: rotate(360deg); } }
  .map-spinner {
    width: 24px; height: 24px;
    border: 2px solid rgba(0,255,157,0.15);
    border-top-color: #00ff9d;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  #world-map .country {
    transition: fill 0.2s, stroke 0.2s;
    cursor: default;
  }
  #world-map .country:hover {
    stroke: #00ff9d !important;
    stroke-width: 1px !important;
    filter: brightness(1.4);
  }
  #world-map .country.highlighted {
    stroke: #00ff9d;
    stroke-width: 1px;
    filter: brightness(1.6) drop-shadow(0 0 4px #00ff9d80);
  }

  /* ── Scrollbar ── */
  .scrollbar-none { scrollbar-width: none; }
  .scrollbar-none::-webkit-scrollbar { display: none; }

  /* ── Stagger delay helpers ── */
  .d-0 { animation-delay: 0ms; }
  .d-1 { animation-delay: 60ms; }
  .d-2 { animation-delay: 120ms; }
  .d-3 { animation-delay: 180ms; }
  .d-4 { animation-delay: 240ms; }
  .d-5 { animation-delay: 300ms; }
</style>

  <!-- ===== HEADER ===== -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8 fade-slide">
    <div>
      <h2 class="text-xl font-semibold text-white tracking-tight mb-1">Analytics</h2>
      <p class="text-sm text-gray-500">
        Données sur <span class="text-gray-300 font-medium">{days} jours</span>
        {summary.botViews > 0 && (
          <span class="ml-2 text-xs text-yellow-500/70">· {summary.botViews} bots exclus</span>
        )}
      </p>
    </div>

    <!-- Period pills -->
    <div class="flex items-center gap-1 p-1 rounded-xl border border-white/8 bg-white/3 w-fit self-start">
      {([7, 30, 90] as const).map(d => (
        <a href={`?days=${d}`}
          class={`px-4 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 ${
            days === d
              ? 'bg-neon-green text-black shadow-lg shadow-neon-green/20'
              : 'text-gray-500 hover:text-gray-300 hover:bg-white/5'
          }`}>
          {d === 7 ? '7j' : d === 30 ? '30j' : '90j'}
        </a>
      ))}
    </div>
  </div>

  <!-- Error -->
  {rpcError && (
    <Alert variant="danger" title="Données indisponibles">
      <p>{rpcError}</p>
    </Alert>
  )}

  <!-- ===== KPI ROW ===== -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">

    <!-- Views -->
    <div class="kpi-card fade-slide d-0 p-5 glass rounded-2xl border border-white/8 cursor-default"
      style="--glow: #00ff9d">
      <div class="flex items-start justify-between mb-4">
        <div class="w-8 h-8 rounded-lg bg-neon-green/10 border border-neon-green/20 flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </div>
        <div set:html={viewSparkline} class="opacity-60 mt-1"></div>
      </div>
      <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">
        {summary.totalViews.toLocaleString('fr-FR')}
      </div>
      <p class="text-xs text-gray-500 mt-1.5 font-medium">Vues totales</p>
      <p class="text-xs text-gray-600 mt-0.5">{summary.avgPerDay.toLocaleString('fr-FR')}/j en moy.</p>
    </div>

    <!-- Unique visitors -->
    <div class="kpi-card fade-slide d-1 p-5 glass rounded-2xl border border-white/8"
      style="--glow: #00aaff">
      <div class="flex items-start justify-between mb-4">
        <div class="w-8 h-8 rounded-lg bg-neon-blue/10 border border-neon-blue/20 flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <!-- Ratio badge -->
        {summary.totalViews > 0 && (
          <span class="text-xs text-neon-blue/70 bg-neon-blue/8 px-2 py-0.5 rounded-full border border-neon-blue/15 font-mono mt-1">
            {Math.round((summary.uniqueVisitors / summary.totalViews) * 100)}%
          </span>
        )}
      </div>
      <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">
        {summary.uniqueVisitors.toLocaleString('fr-FR')}
      </div>
      <p class="text-xs text-gray-500 mt-1.5 font-medium">Visiteurs uniques</p>
      <p class="text-xs text-gray-600 mt-0.5">{summary.cleanViews.toLocaleString('fr-FR')} vues nettes</p>
    </div>

    <!-- Clicks -->
    <div class="kpi-card fade-slide d-2 p-5 glass rounded-2xl border border-white/8"
      style="--glow: #bf00ff">
      <div class="flex items-start justify-between mb-4">
        <div class="w-8 h-8 rounded-lg bg-neon-purple/10 border border-neon-purple/20 flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/>
          </svg>
        </div>
        <div set:html={clickSparkline} class="opacity-60 mt-1"></div>
      </div>
      <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">
        {summary.totalClicks.toLocaleString('fr-FR')}
      </div>
      <p class="text-xs text-gray-500 mt-1.5 font-medium">Clics sur liens</p>
      <p class="text-xs text-gray-600 mt-0.5">sur {blocks.filter((b) => b.active).length} blocs actifs</p>
    </div>

    <!-- CTR -->
    <div class="kpi-card fade-slide d-3 p-5 glass rounded-2xl border border-white/8"
      style="--glow: #ff6b6b">
      <div class="flex items-start justify-between mb-4">
        <div class="w-8 h-8 rounded-lg bg-neon-pink/10 border border-neon-pink/20 flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
        </div>
        <!-- CTR quality pill -->
        <span class={`text-xs px-2 py-0.5 rounded-full border font-mono mt-1 ${
          summary.clickRate >= 10 ? 'text-neon-green/70 bg-neon-green/8 border-neon-green/15' :
          summary.clickRate >= 5  ? 'text-yellow-400/70 bg-yellow-400/8 border-yellow-400/15' :
          'text-gray-500 bg-white/5 border-white/10'
        }`}>
          {summary.clickRate >= 10 ? '🔥 Top' : summary.clickRate >= 5 ? '↗ Bien' : '· Faible'}
        </span>
      </div>
      <div class="kpi-value text-2xl lg:text-3xl font-bold text-white tabular-nums tracking-tight">
        {summary.clickRate.toFixed(1)}<span class="text-lg text-gray-400">%</span>
      </div>
      <p class="text-xs text-gray-500 mt-1.5 font-medium">Taux de clic</p>
      <p class="text-xs text-gray-600 mt-0.5">clics / vues</p>
    </div>

  </div>

  <!-- ===== MAIN BENTO: CHART + DEVICE ===== -->
  <div class="bento bento-main mb-6">

    <!-- Traffic chart — large -->
    <div class="fade-slide d-2 p-5 glass rounded-2xl border border-white/8">
      <div class="flex items-center justify-between mb-5">
        <div>
          <h3 class="text-sm font-semibold text-white">Trafic</h3>
          <p class="text-xs text-gray-500 mt-0.5">Vues & clics · {days}j</p>
        </div>
        <!-- Legend -->
        <div class="flex items-center gap-4">
          <span class="flex items-center gap-1.5 text-xs text-gray-400">
            <span class="w-3 h-0.5 bg-neon-green rounded-full inline-block"></span>Vues
          </span>
          <span class="flex items-center gap-1.5 text-xs text-gray-400">
            <span class="w-3 h-0.5 bg-neon-purple rounded-full inline-block"></span>Clics
          </span>
        </div>
      </div>
      {chartLabels.length === 0 ? (
        <div class="flex flex-col items-center justify-center h-52 text-gray-600">
          <svg class="w-10 h-10 mb-3 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4v16"/>
          </svg>
          <p class="text-sm">Aucune donnée sur cette période</p>
        </div>
      ) : (
        <canvas id="traffic-chart" style="max-height: 240px; width: 100%;"></canvas>
      )}
    </div>

    <!-- Right column: device + CTR mini chart -->
    <div class="flex flex-col gap-4">

      <!-- Device breakdown -->
      <div class="fade-slide d-3 p-5 glass rounded-2xl border border-white/8 flex-1">
        <h3 class="text-sm font-semibold text-white mb-4">Appareils</h3>
        {deviceTotal === 0 ? (
          <p class="text-sm text-gray-600 text-center py-6">Aucune donnée</p>
        ) : (
          <div class="space-y-3">
            {[
              { key: 'mobile',  label: 'Mobile',  color: '#00ff9d', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z' },
              { key: 'desktop', label: 'Desktop', color: '#bf00ff', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
              { key: 'tablet',  label: 'Tablet',  color: '#00aaff', icon: 'M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z' },
            ].map(dev => {
              const val  = deviceData[dev.key as keyof typeof deviceData];
              const pct  = deviceTotal > 0 ? Math.round((val / deviceTotal) * 100) : 0;
              if (val === 0) return null;
              return (
                <div>
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="flex items-center gap-2 text-xs text-gray-400">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" style={`color:${dev.color}`} viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={dev.icon}/>
                      </svg>
                      {dev.label}
                    </span>
                    <span class="text-xs font-semibold text-white tabular-nums">{pct}%</span>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill" style={`width:${pct}%; background:${dev.color}; animation-delay:${300 + (pct * 3)}ms`}></div>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <!-- CTR mini chart -->
      {chartLabels.length > 0 && (
        <div class="fade-slide d-4 p-5 glass rounded-2xl border border-white/8">
          <h3 class="text-sm font-semibold text-white mb-1">Taux de clic / jour</h3>
          <canvas id="rate-chart" style="max-height: 80px; width: 100%;"></canvas>
        </div>
      )}

    </div>
  </div>

  <!-- ===== INSIGHTS: TABBED (Geo · Sources · Blocks) ===== -->
  <div class="fade-slide d-3 p-5 glass rounded-2xl border border-white/8 mb-6">

    <!-- Tab nav -->
    <div class="flex items-center gap-1 mb-6 border-b border-white/8 pb-3 -mt-1 overflow-x-auto scrollbar-none">
      {[
        { id: 'geo',     label: 'Géographie', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064' },
        { id: 'sources', label: 'Sources',    icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.1-1.1m-.757-4.9a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
        { id: 'blocks',  label: 'Top Blocks', icon: 'M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5' },
      ].map((tab, i) => (
        <button
          class={`insight-tab flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-all ${i === 0 ? 'text-white bg-white/8' : 'text-gray-500 hover:text-gray-300'}`}
          data-tab={tab.id}>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tab.icon}/>
          </svg>
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Panel: Geo -->
    <div class="insight-panel active" id="panel-geo">
      {topCountries.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 gap-3 text-gray-600">
          <svg class="w-12 h-12 opacity-15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
          </svg>
          <p class="text-sm">Aucune donnée géographique disponible</p>
        </div>
      ) : (
        <div>
          <!-- Choropleth map -->
          <div class="relative rounded-xl overflow-hidden mb-5" style="background:#080c0a;">
            <div id="world-map-loader" class="absolute inset-0 flex items-center justify-center">
              <div class="map-spinner"></div>
            </div>
            <svg id="world-map" style="width:100%;height:280px;display:block;opacity:0;transition:opacity 0.4s;"></svg>
            <!-- Tooltip -->
            <div id="map-tooltip" class="pointer-events-none absolute hidden z-10
              bg-black/90 border border-neon-green/20 text-white text-xs px-3 py-1.5 rounded-lg
              backdrop-blur-sm shadow-lg shadow-neon-green/5 whitespace-nowrap">
            </div>
          </div>

          <!-- Country list -->
          <div class="grid sm:grid-cols-2 gap-2">
            {topCountries.slice(0, 8).map((ctry, i) => {
              const pct = Math.round((ctry.views / maxCountryViews) * 100);
              return (
                <div class="country-row flex items-center gap-2.5 px-3 py-2 rounded-xl border border-white/5
                  hover:border-neon-green/20 hover:bg-neon-green/3 transition-all cursor-default group"
                  data-iso={ctry.country}>
                  <span class="text-base leading-none shrink-0 w-6 text-center">{countryFlag(ctry.country ?? '')}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2 mb-1">
                      <span class="text-xs text-gray-300 font-medium group-hover:text-neon-green transition-colors truncate">{ctry.country || '??'}</span>
                      <span class="text-xs text-gray-600 tabular-nums font-mono shrink-0">{ctry.views.toLocaleString('fr-FR')}</span>
                    </div>
                    <div class="bar-track">
                      <div class="bar-fill" style={`width:${pct}%;background:linear-gradient(90deg,#00ff9d,#00ff9d40);animation-delay:${i*50}ms`}></div>
                    </div>
                  </div>
                  <span class="text-xs shrink-0 w-5 text-right opacity-50">
                    {i < 3 ? ['🥇','🥈','🥉'][i] : `#${i+1}`}
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>

    <!-- Panel: Sources -->
    <div class="insight-panel" id="panel-sources">
      {aggregatedReferrers.length === 0 ? (
        <p class="text-sm text-gray-600 text-center py-8">Aucune source identifiée</p>
      ) : (
        <div class="space-y-3">
          {aggregatedReferrers.map((r, i) => {
            const pct   = Math.round((r.views / maxReferrerViews) * 100);
            const color = CAT_COLORS[r.category] ?? '#9ca3af';
            const label = CAT_LABELS[r.category] ?? r.category;
            return (
              <div class="flex items-center gap-3">
                <div class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-xs font-bold text-gray-600 border border-white/8 bg-white/3">
                  {i + 1}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between mb-1">
                    <div class="flex items-center gap-2 min-w-0">
                      <span class="text-sm text-white font-medium truncate">{r.label}</span>
                      <span class="source-badge shrink-0" style={`background:${color}15; color:${color}; border: 1px solid ${color}30;`}>
                        {label}
                      </span>
                    </div>
                    <span class="text-xs text-gray-500 tabular-nums font-mono ml-2 shrink-0">{r.views.toLocaleString('fr-FR')}</span>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill" style={`width:${pct}%; background:${color}70; animation-delay:${i * 60}ms`}></div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Panel: Blocks -->
    <div class="insight-panel" id="panel-blocks">
      {topBlocks.length === 0 ? (
        <div class="text-center py-8">
          <p class="text-sm text-gray-600 mb-2">Aucun clic enregistré</p>
          <a href="/dashboard/blocks" class="text-xs text-neon-green hover:underline">Ajouter des blocs →</a>
        </div>
      ) : (
        <div class="space-y-2">
          {topBlocks.map((block, i) => {
            const ctr     = summary.totalViews > 0 ? ((block.clicks / summary.totalViews) * 100).toFixed(1) : '0.0';
            const barPct  = Math.round((block.clicks / (topBlocks[0]?.clicks ?? 1)) * 100);
            const isFirst = i === 0;
            return (
              <div class={`flex items-center gap-3 p-3 rounded-xl border transition-all ${isFirst ? 'border-neon-green/20 bg-neon-green/3' : 'border-white/5 hover:border-white/10'}`}>
                <div class={`w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold shrink-0 border ${i < 3 ? ['rank-1','rank-2','rank-3'][i] : 'text-gray-600 bg-white/3 border-white/8'}`}>
                  {i + 1}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <Badge variant="default" size="sm">{block.type}</Badge>
                    <span class="text-sm text-white font-medium truncate">{block.title || 'Untitled'}</span>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill" style={`width:${barPct}%; background: ${isFirst ? '#00ff9d' : '#00ff9d50'}; animation-delay:${i * 50}ms`}></div>
                  </div>
                </div>
                <div class="text-right shrink-0 pl-2">
                  <div class={`text-sm font-bold tabular-nums ${isFirst ? 'text-neon-green' : 'text-white'}`}>
                    {block.clicks.toLocaleString('fr-FR')}
                  </div>
                  <div class="text-xs text-gray-600">{ctr}%</div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

  </div>

  <!-- ===== ALL BLOCKS TABLE ===== -->
  <div class="fade-slide d-4 p-5 glass rounded-2xl border border-white/8">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h3 class="text-sm font-semibold text-white">Tous les blocs</h3>
        <p class="text-xs text-gray-500 mt-0.5">Performance complète · {blocks.length} bloc{blocks.length !== 1 ? 's' : ''}</p>
      </div>
      <a href="/dashboard/blocks" class="text-xs text-neon-green/70 hover:text-neon-green transition-colors">
        Gérer →
      </a>
    </div>
    {blocks.length === 0 ? (
      <div class="text-center py-10 text-gray-600 text-sm">
        <a href="/dashboard/blocks" class="text-neon-green hover:underline">Ajouter des blocs</a>
      </div>
    ) : (
      <div class="overflow-x-auto -mx-1 scrollbar-none">
        <table class="w-full text-sm min-w-[500px]">
          <thead>
            <tr>
              <th class="text-left pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Bloc</th>
              <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Clics</th>
              <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">CTR</th>
              <th class="text-center pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Statut</th>
            </tr>
          </thead>
          <tbody>
            {blocks.map((block, i) => {
              const found       = topBlocks.find((tb) => tb.block_id === block.id);
              const blockClicks = found?.clicks ?? 0;
              const ctr         = summary.totalViews > 0
                ? ((blockClicks / summary.totalViews) * 100).toFixed(1) : '0.0';
              const isTop       = !!found;
              return (
                <tr class="group border-b border-white/4 last:border-0 hover:bg-white/2 transition-colors">
                  <td class="py-3 px-2">
                    <div class="flex items-center gap-2.5">
                      <Badge variant="default" size="sm">{block.type}</Badge>
                      <span class="text-white font-medium truncate max-w-[200px]">
                        {block.title || 'Untitled'}
                      </span>
                      {i === 0 && topBlocks.length > 0 && isTop && (
                        <span class="text-xs text-yellow-400/70">★</span>
                      )}
                    </div>
                  </td>
                  <td class="py-3 px-2 text-right">
                    <span class={`font-semibold tabular-nums ${blockClicks > 0 ? 'text-neon-green' : 'text-gray-700'}`}>
                      {blockClicks.toLocaleString('fr-FR')}
                    </span>
                  </td>
                  <td class="py-3 px-2 text-right text-gray-500 tabular-nums">{ctr}%</td>
                  <td class="py-3 px-2 text-center">
                    <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${block.active ? 'text-neon-green bg-neon-green/10' : 'text-gray-600 bg-white/5'}`}>
                      <span class={`w-1.5 h-1.5 rounded-full ${block.active ? 'bg-neon-green' : 'bg-gray-600'}`}></span>
                      {block.active ? 'Actif' : 'Inactif'}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- ===== DATA BRIDGE + SCRIPT ===== -->
  <div aria-hidden="true" class="contents">
    <div id="chart-data" class="hidden"
      data-chart={JSON.stringify(exportedChart)}
      data-devices={JSON.stringify(exportedDevices)}
      data-days={String(exportedDays)}
      data-countries={JSON.stringify(topCountries)}>
    </div>
  </div>

  <script>
    (async () => {
      const el = document.getElementById('chart-data');
      if (!el) return;
      const exportedChart   = JSON.parse(el.dataset.chart   ?? '{}');
      const exportedDevices = JSON.parse(el.dataset.devices ?? '{}');
      const exportedDays    = Number(el.dataset.days ?? 7);

      await new Promise((resolve, reject) => {
        if (typeof Chart !== 'undefined') { resolve(null); return; }
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js';
        s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
      });

      Chart.defaults.font.family = 'DM Sans, system-ui, sans-serif';
      const GRID   = 'rgba(255,255,255,0.03)';
      const GREEN  = '#00ff9d';
      const PURPLE = '#bf00ff';

      // ── Traffic chart ──────────────────────────────────────────────────
      const trafficCtx = document.getElementById('traffic-chart');
      if (trafficCtx && exportedChart.labels?.length > 0) {
        new Chart(trafficCtx, {
          type: 'line',
          data: {
            labels: exportedChart.labels,
            datasets: [
              {
                label: 'Vues',
                data: exportedChart.views,
                borderColor: GREEN,
                backgroundColor: (ctx) => {
                  const gradient = ctx.chart.ctx.createLinearGradient(0, 0, 0, ctx.chart.height);
                  gradient.addColorStop(0,   GREEN + '22');
                  gradient.addColorStop(1,   GREEN + '00');
                  return gradient;
                },
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointRadius: 0,
                pointHoverRadius: 4,
                pointHoverBackgroundColor: GREEN,
                pointHoverBorderColor: '#0a0a0a',
                pointHoverBorderWidth: 2,
              },
              {
                label: 'Clics',
                data: exportedChart.clicks,
                borderColor: PURPLE,
                backgroundColor: (ctx) => {
                  const gradient = ctx.chart.ctx.createLinearGradient(0, 0, 0, ctx.chart.height);
                  gradient.addColorStop(0,   PURPLE + '22');
                  gradient.addColorStop(1,   PURPLE + '00');
                  return gradient;
                },
                borderWidth: 2,
                tension: 0.4,
                fill: true,
                pointRadius: 0,
                pointHoverRadius: 4,
                pointHoverBackgroundColor: PURPLE,
                pointHoverBorderColor: '#0a0a0a',
                pointHoverBorderWidth: 2,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#111115',
                titleColor: '#fff',
                bodyColor: '#9ca3af',
                borderColor: 'rgba(255,255,255,0.08)',
                borderWidth: 1,
                padding: 12,
                displayColors: true,
                boxWidth: 8,
                boxHeight: 8,
                boxPadding: 4,
                usePointStyle: true,
              },
            },
            scales: {
              y: {
                beginAtZero: true,
                ticks: { color: '#4b5563', font: { size: 10 }, maxTicksLimit: 5 },
                grid: { color: GRID },
                border: { display: false },
              },
              x: {
                ticks: {
                  color: '#4b5563',
                  font: { size: 10 },
                  maxTicksLimit: exportedDays === 7 ? 7 : exportedDays === 30 ? 10 : 12,
                  maxRotation: 0,
                },
                grid: { display: false },
                border: { display: false },
              },
            },
          },
        });
      }

      // ── Click rate mini bar chart ────────────────────────────────────────
      const rateCtx = document.getElementById('rate-chart');
      if (rateCtx && exportedChart.labels?.length > 0) {
        new Chart(rateCtx, {
          type: 'bar',
          data: {
            labels: exportedChart.labels,
            datasets: [{
              data: exportedChart.rates,
              backgroundColor: GREEN + '30',
              borderColor: GREEN + '70',
              borderWidth: 1,
              borderRadius: 3,
            }],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: '#111115',
                titleColor: '#fff',
                bodyColor: '#9ca3af',
                borderColor: 'rgba(255,255,255,0.08)',
                borderWidth: 1,
                callbacks: { label: (ctx) => ` ${ctx.parsed.y}%` },
              },
            },
            scales: {
              y: {
                display: false, beginAtZero: true,
                grid: { display: false }, border: { display: false },
              },
              x: {
                display: false,
                grid: { display: false }, border: { display: false },
              },
            },
          },
        });
      }


      // ── D3 Choropleth World Map ─────────────────────────────────────────────
      const countriesData = JSON.parse(el.dataset.countries ?? '[]');
      const mapSvgEl = document.getElementById('world-map');
      const mapLoader = document.getElementById('world-map-loader');
      const mapTooltip = document.getElementById('map-tooltip');

      if (mapSvgEl && countriesData.length > 0) {

        // Load D3 + TopoJSON from CDN
        await Promise.all([
          new Promise((res, rej) => {
            if (window.d3) { res(null); return; }
            const s = document.createElement('script');
            s.src = 'https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js';
            s.onload = res; s.onerror = rej;
            document.head.appendChild(s);
          }),
          new Promise((res, rej) => {
            if (window.topojson) { res(null); return; }
            const s = document.createElement('script');
            s.src = 'https://cdn.jsdelivr.net/npm/topojson@3.0.2/dist/topojson.min.js';
            s.onload = res; s.onerror = rej;
            document.head.appendChild(s);
          }),
        ]);

        // Fetch world topojson
        const world = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2.0.2/countries-110m.json').then(r => r.json());

        // Build ISO numeric → views map (world-atlas uses numeric codes)
        // ISO2 → numeric lookup
        const ISO2_NUM = {
          AF:'004',AL:'008',DZ:'012',AO:'024',AR:'032',AU:'036',AT:'040',AZ:'031',
          BD:'050',BE:'056',BJ:'204',BO:'068',BR:'076',BG:'100',CA:'124',CL:'152',
          CN:'156',CO:'170',CD:'180',CR:'188',HR:'191',CZ:'203',DK:'208',EG:'818',
          ET:'231',FI:'246',FR:'250',DE:'276',GH:'288',GR:'300',HK:'344',HU:'348',
          IN:'356',ID:'360',IR:'364',IQ:'368',IE:'372',IL:'376',IT:'380',CI:'384',
          JP:'392',JO:'400',KZ:'398',KE:'404',KR:'410',KW:'414',LB:'422',LY:'434',
          MA:'504',MX:'484',MM:'104',NL:'528',NZ:'554',NG:'566',NO:'578',PK:'586',
          PE:'604',PH:'608',PL:'616',PT:'620',QA:'634',RO:'642',RU:'643',SA:'682',
          SN:'686',SG:'702',SK:'703',SI:'705',SO:'706',ZA:'710',ES:'724',SE:'752',
          CH:'756',SY:'760',TW:'158',TZ:'834',TH:'764',TN:'788',TR:'792',UA:'804',
          AE:'784',GB:'826',US:'840',UY:'858',VE:'862',VN:'704',YE:'887',ZW:'716',
          MG:'450',CM:'120',GN:'324',ML:'466',TD:'148',NE:'562',LK:'144',KH:'116',
          MN:'496',IS:'352',LV:'428',LT:'440',EE:'233',RS:'688',BA:'070',MK:'807',
          GE:'268',BY:'112',MD:'498',AM:'051',UZ:'860',TM:'795',KG:'417',TJ:'762',
          LU:'442',AT:'040',CY:'196',MT:'470',MZ:'508',ZM:'894',MW:'454',UG:'800',
          RW:'646',BI:'108',SS:'728',SD:'729',LR:'430',SL:'694',BF:'854',GW:'624',
          GM:'270',CV:'132',ST:'678',GQ:'226',GA:'266',CG:'178',CF:'140',ER:'232',
          DJ:'262',KM:'174',SC:'690',MU:'480',MR:'478',EH:'732',LI:'438',MC:'492',
          SM:'674',VA:'336',AD:'020',ME:'499',XK:'383',AL:'008',MK:'807',
        };

        const maxViews = countriesData[0]?.views ?? 1;
        const viewsMap = new Map();
        countriesData.forEach(c => {
          const num = ISO2_NUM[c.country];
          if (num) viewsMap.set(+num, c.views);
        });
        const nameMap = new Map();
        countriesData.forEach(c => {
          const num = ISO2_NUM[c.country];
          if (num) nameMap.set(+num, c.country);
        });

        // Color scale: dark base → neon green
        const colorScale = d3.scaleLog()
          .domain([1, maxViews])
          .range(['#0f2e1e', '#00ff9d'])
          .clamp(true);

        const W = mapSvgEl.clientWidth || 700;
        const H = 280;

        const svg = d3.select(mapSvgEl)
          .attr('viewBox', `0 0 ${W} ${H}`)
          .attr('preserveAspectRatio', 'xMidYMid meet');

        // Natural Earth projection
        const projection = d3.geoNaturalEarth1()
          .scale(W / 6.3)
          .translate([W / 2, H / 2 + 10]);

        const path = d3.geoPath().projection(projection);

        // Background sphere
        svg.append('path')
          .datum({ type: 'Sphere' })
          .attr('d', path)
          .attr('fill', '#06090a')
          .attr('stroke', 'none');

        // Graticule (subtle grid lines)
        const graticule = d3.geoGraticule().step([30, 30]);
        svg.append('path')
          .datum(graticule())
          .attr('d', path)
          .attr('fill', 'none')
          .attr('stroke', 'rgba(255,255,255,0.03)')
          .attr('stroke-width', 0.5);

        // Countries
        const countries = topojson.feature(world, world.objects.countries);
        svg.selectAll('.country')
          .data(countries.features)
          .join('path')
          .attr('class', 'country')
          .attr('d', path)
          .attr('fill', d => {
            const v = viewsMap.get(+d.id);
            return v ? colorScale(v) : '#141a18';
          })
          .attr('stroke', '#1a2420')
          .attr('stroke-width', 0.4)
          .on('mousemove', function(event, d) {
            const views = viewsMap.get(+d.id);
            if (!views || !mapTooltip) return;
            const name = nameMap.get(+d.id) || '—';
            const rect = mapSvgEl.getBoundingClientRect();
            mapTooltip.innerHTML = `<span style="color:#00ff9d;font-weight:600">${name}</span>&nbsp;&nbsp;<span style="color:#6b7280">${views.toLocaleString('fr-FR')} vues</span>`;
            mapTooltip.style.left = (event.clientX - rect.left + 12) + 'px';
            mapTooltip.style.top  = (event.clientY - rect.top - 32) + 'px';
            mapTooltip.classList.remove('hidden');
          })
          .on('mouseleave', function() {
            if (mapTooltip) mapTooltip.classList.add('hidden');
          });

        // Country borders
        svg.append('path')
          .datum(topojson.mesh(world, world.objects.countries, (a, b) => a !== b))
          .attr('d', path)
          .attr('fill', 'none')
          .attr('stroke', '#1e2e26')
          .attr('stroke-width', 0.6);

        // Pulse dots on top countries
        countriesData.slice(0, 5).forEach(ctry => {
          const num = ISO2_NUM[ctry.country];
          if (!num) return;
          const feat = countries.features.find(f => +f.id === +num);
          if (!feat) return;
          const centroid = path.centroid(feat);
          if (!centroid || isNaN(centroid[0])) return;
          const r = 2 + (ctry.views / maxViews) * 5;
          // Glow halo
          svg.append('circle')
            .attr('cx', centroid[0]).attr('cy', centroid[1])
            .attr('r', r + 4)
            .attr('fill', 'rgba(0,255,157,0.08)')
            .attr('pointer-events', 'none');
          // Dot
          svg.append('circle')
            .attr('cx', centroid[0]).attr('cy', centroid[1])
            .attr('r', r)
            .attr('fill', '#00ff9d')
            .attr('opacity', 0.85)
            .attr('pointer-events', 'none');
        });

        // Reveal map + hide loader
        mapSvgEl.style.opacity = '1';
        if (mapLoader) mapLoader.style.display = 'none';

        // Country row hover → highlight on map
        document.querySelectorAll('.country-row').forEach(row => {
          row.addEventListener('mouseenter', () => {
            const iso2 = row.getAttribute('data-iso');
            const num = ISO2_NUM[iso2];
            if (!num) return;
            svg.selectAll('.country')
              .classed('highlighted', d => +d.id === +num);
          });
          row.addEventListener('mouseleave', () => {
            svg.selectAll('.country').classed('highlighted', false);
          });
        });

        // Responsive resize
        const ro = new ResizeObserver(() => {
          const nW = mapSvgEl.clientWidth;
          projection.scale(nW / 6.3).translate([nW / 2, H / 2 + 10]);
          svg.attr('viewBox', `0 0 ${nW} ${H}`);
          svg.selectAll('.country').attr('d', path);
        });
        ro.observe(mapSvgEl);

      } else if (mapLoader) {
        mapLoader.innerHTML = '<p style="color:#374151;font-size:12px;padding:24px">Carte non disponible</p>';
      }

      // ── Insight tabs ─────────────────────────────────────────────────────
      document.querySelectorAll('.insight-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-tab');
          document.querySelectorAll('.insight-tab').forEach(b => {
            b.classList.toggle('text-white', b === btn);
            b.classList.toggle('bg-white/8', b === btn);
            b.classList.toggle('text-gray-500', b !== btn);
          });
          document.querySelectorAll('.insight-panel').forEach(p => {
            p.classList.toggle('active', p.id === `panel-${target}`);
          });
        });
      });

    })();
  </script>

</DashboardLayout>
          </div>
          <div class="space-y-1.5 pt-2 border-t border-white/6">
            {topRecos.map(r => <div class="flex gap-2 text-xs text-gray-500 leading-relaxed"><span class="shrink-0" style={`color:${perfColor}`}>→</span><span>{r}</span></div>)}
          </div>
        </div>

        <!-- Prédictions + Objectifs -->
        <div class="flex flex-col gap-4">
          <!-- Prédictions -->
          <div class="p-4 glass rounded-xl border border-white/8 flex-1">
            <h3 class="text-xs font-semibold text-white mb-3 uppercase tracking-widest" style="color:rgba(255,255,255,.5)">Prédictions 30j</h3>
            {proj30Views === 0 ? (
              <p class="text-xs text-gray-700 py-2">Pas assez de données</p>
            ) : (
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <div set:html={predSparkViews} class="opacity-80"></div>
                  <div class="text-right"><p class="text-sm font-bold tabular-nums" style="color:#00ff9d">{proj30Views.toLocaleString('fr-FR')}</p><p class="text-xs text-gray-600">vues</p></div>
                </div>
                <div class="flex items-center justify-between">
                  <div set:html={predSparkClicks} class="opacity-80"></div>
                  <div class="text-right"><p class="text-sm font-bold tabular-nums" style="color:#38bdf8">{proj30Clicks.toLocaleString('fr-FR')}</p><p class="text-xs text-gray-600">clics</p></div>
                </div>
              </div>
            )}
          </div>
          <!-- Objectifs -->
          <div class="p-4 glass rounded-xl border border-white/8">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-xs font-semibold uppercase tracking-widest" style="color:rgba(255,255,255,.5)">Objectifs</h3>

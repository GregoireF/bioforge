---
// src/pages/dashboard/analytics.astro — v4
// Base v3 + Funnel · Attribution · UTM · Short URLs · Revenue KPIs · Live visitors

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import Alert from '@/components/ui/Alert.astro';
import { withAuth } from '@/lib/auth/auth';
import { getBlocks } from '@/lib/supabase/queries';
import { createServerClient } from '@supabase/ssr';
import { parse } from 'cookie';

const allowedDays = [7, 30, 90] as const;
type Period = typeof allowedDays[number];
const rawDays = Number(Astro.url.searchParams.get('days') ?? 7);
const days: Period = (allowedDays.includes(rawDays as Period) ? rawDays : 7) as Period;

const cookies = parse(Astro.request.headers.get('cookie') ?? '');
const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL!,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY!,
  { cookies: { get: (k) => cookies[k], set: () => {}, remove: () => {} } }
);

const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}
const { profile, planLimits } = authResult.data;
const profileId = profile?.id;
if (!profileId) return Astro.redirect('/signin?error=no_profile');

// v4: plan detection
const plan: string = (planLimits as any)?.plan ?? (profile as any)?.plan ?? 'Free';
const isPro     = ['Pro', 'Enterprise'].includes(plan);
const isCreator = ['Creator', 'Pro', 'Enterprise'].includes(plan);

type AnalyticsRPC = {
  total_views: number; clean_views: number; unique_visitors: number; total_clicks: number;
  daily_views: { date: string; views: number }[] | null;
  devices: Record<string, number> | null;
  top_countries: { country: string; views: number }[] | null;
  top_referrers: { referrer: string; views: number }[] | null;
  top_blocks: { block_id: string; title: string; type: string; clicks: number }[] | null;
  bots: Record<string, number> | null;
};

let rpcData: AnalyticsRPC | null = null;
let rpcError: string | null = null;
let dailyClicks: { date: string; clicks: number }[] = [];
let blocks: any[] = [];

const { data: rpcRaw, error: rpcErr } = await supabase.rpc('get_profile_analytics', { p_profile_id: profileId, p_days: days });
if (rpcErr) { rpcError = rpcErr.message; } else { rpcData = rpcRaw as AnalyticsRPC; }

const since = new Date();
since.setDate(since.getDate() - days);

const { data: clickRows } = await supabase.from('block_clicks').select('click_date')
  .eq('profile_id', profileId).gte('click_date', since.toISOString().split('T')[0]);
if (clickRows) {
  const map = new Map<string, number>();
  for (const row of clickRows) { const d = row.click_date as string; map.set(d, (map.get(d) ?? 0) + 1); }
  dailyClicks = Array.from(map.entries()).map(([date, clicks]) => ({ date, clicks })).sort((a, b) => a.date.localeCompare(b.date));
}

const { data: blockRows } = await supabase.from('blocks').select('id, type, title, active')
  .eq('profile_id', profileId).is('deleted_at', null).order('position');
blocks = blockRows ?? [];

// v4: active visitors (last 5 min)
const fiveMinAgo = new Date(Date.now() - 5 * 60 * 1000).toISOString();
const { count: activeVisitors } = await supabase.from('profile_views')
  .select('id', { count: 'exact', head: true }).eq('profile_id', profileId).gte('created_at', fiveMinAgo);

// v4: conversion events
const { data: convRows } = await supabase.from('conversion_events')
  .select('type, value, source, created_at').eq('profile_id', profileId).gte('created_at', since.toISOString());
const conversionRows = convRows ?? [];

// v4: UTM events (Pro+)
let utmData: any[] = [];
if (isPro) {
  const { data: utmRows } = await supabase.from('utm_events')
    .select('source, medium, campaign, country, device, converted, revenue, created_at')
    .eq('profile_id', profileId).gte('created_at', since.toISOString())
    .order('created_at', { ascending: false }).limit(2000);
  utmData = utmRows ?? [];
}

// v4: short URLs (Creator+)
let shortUrls: any[] = [];
if (isCreator) {
  const { data: shortRows } = await supabase.from('short_urls')
    .select('id, slug, target_url, title, click_count, created_at')
    .eq('profile_id', profileId).order('click_count', { ascending: false }).limit(10);
  shortUrls = shortRows ?? [];
}

// v3 derived (intact)
const summary = {
  totalViews:     rpcData?.total_views     ?? 0,
  cleanViews:     rpcData?.clean_views     ?? 0,
  uniqueVisitors: rpcData?.unique_visitors ?? 0,
  totalClicks:    rpcData?.total_clicks    ?? 0,
  clickRate:      rpcData && rpcData.total_views > 0 ? ((rpcData.total_clicks / rpcData.total_views) * 100) : 0,
  botViews:       Object.values(rpcData?.bots ?? {}).reduce((a, b) => a + b, 0),
  avgPerDay:      days > 0 ? Math.round((rpcData?.total_views ?? 0) / days) : 0,
};
const topBlocks    = rpcData?.top_blocks    ?? [];
const topCountries = rpcData?.top_countries ?? [];
const devices      = rpcData?.devices       ?? {};
const topReferrers = rpcData?.top_referrers ?? [];

// v4 derived
const leads    = conversionRows.filter(r => r.type === 'lead').length;
const sales    = conversionRows.filter(r => r.type === 'sale').length;
const revenue  = conversionRows.filter(r => r.type === 'sale').reduce((s, r) => s + (r.value ?? 0), 0);
const leadRate = summary.totalClicks > 0 ? (leads / summary.totalClicks) * 100 : 0;
const convRate = leads > 0 ? (sales / leads) * 100 : 0;

const funnelSteps = [
  { label: 'Vues',   value: summary.totalViews,  color: '#00ff9d' },
  { label: 'Clics',  value: summary.totalClicks, color: '#38bdf8' },
  { label: 'Leads',  value: leads,               color: '#f59e0b' },
  { label: 'Ventes', value: sales,               color: '#a78bfa' },
];

type ChannelStat = { views: number; leads: number; sales: number; revenue: number };
const channelMap = new Map<string, ChannelStat>();

function classifyChannel(medium: string | null, source: string | null): string {
  if (!medium && !source) return 'Direct';
  const m = (medium ?? '').toLowerCase();
  const s = (source ?? '').toLowerCase();
  if (['cpc','paid','ppc','paidsocial'].includes(m)) {
    if (s.includes('google'))  return 'Google Ads';
    if (s.includes('facebook') || s.includes('meta') || s.includes('instagram')) return 'Meta Ads';
    if (s.includes('tiktok'))  return 'TikTok Ads';
    return 'Paid Ads';
  }
  if (m === 'email' || m === 'newsletter')  return 'Email';
  if (m === 'influencer' || m === 'collab') return 'Influenceurs';
  if (m === 'organic' || m === 'social')    return 'Organic Social';
  if (s.includes('google'))                 return 'SEO';
  return 'Autre';
}

if (utmData.length > 0) {
  for (const row of utmData) {
    const ch = classifyChannel(row.medium, row.source);
    const e  = channelMap.get(ch) ?? { views: 0, leads: 0, sales: 0, revenue: 0 };
    e.views++;
    if (row.converted)   e.leads++;
    if (row.revenue > 0) { e.sales++; e.revenue += row.revenue; }
    channelMap.set(ch, e);
  }
} else {
  const SH = ['twitter.com','x.com','instagram.com','tiktok.com','facebook.com','linkedin.com','youtube.com'];
  const SE = ['google.','bing.com','duckduckgo.com','yahoo.com'];
  for (const r of topReferrers) {
    let ch = 'Direct';
    try {
      const rf   = r.referrer ?? '';
      const host = new URL(rf.includes('://')?rf:`https://${rf}`).hostname.replace(/^www\./,'');
      if (SH.some(s => host.includes(s))) ch = 'Organic Social';
      else if (SE.some(s => host.includes(s))) ch = 'SEO';
      else if (r.referrer) ch = 'Autre';
    } catch { }
    const e = channelMap.get(ch) ?? { views: 0, leads: 0, sales: 0, revenue: 0 };
    e.views += r.views;
    channelMap.set(ch, e);
  }
}

const channels = Array.from(channelMap.entries()).map(([name, s]) => ({ name, ...s })).sort((a, b) => b.views - a.views);
const totalChViews = channels.reduce((s, c) => s + c.views, 0);

// v3 chart data (intact)
const allDates = new Set<string>();
(rpcData?.daily_views ?? []).forEach(r => allDates.add(r.date));
dailyClicks.forEach(r => allDates.add(r.date));
const sortedDates  = Array.from(allDates).sort();
const viewsByDate  = new Map((rpcData?.daily_views ?? []).map(r => [r.date, r.views]));
const clicksByDate = new Map(dailyClicks.map(r => [r.date, r.clicks]));
const chartLabels  = sortedDates.map(d => new Date(d + 'T12:00:00Z').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short' }));
const chartViews   = sortedDates.map(d => viewsByDate.get(d)  ?? 0);
const chartClicks  = sortedDates.map(d => clicksByDate.get(d) ?? 0);
const chartRates   = sortedDates.map((_, i) => { const v = chartViews[i], c = chartClicks[i]; return v > 0 ? parseFloat(((c / v) * 100).toFixed(1)) : 0; });

function sparkline(data: number[], color: string): string {
  if (!data.length) return '';
  const max = Math.max(...data, 1);
  const min = Math.min(...data, 0);
  const range = max - min || 1;
  const W = 88, H = 28, PAD = 2;
  const uid = `sp${Math.abs(data.reduce((a,b)=>a+b,0)).toString(36).slice(0,4)}${color.slice(1,4)}`;
  const xs = data.map((_, i) => PAD + (i / Math.max(data.length - 1, 1)) * (W - PAD * 2));
  const ys = data.map(v    => PAD + ((max - v) / range) * (H - PAD * 2));
  const polyPts = xs.map((x, i) => `${x.toFixed(1)},${ys[i].toFixed(1)}`).join(' ');
  const lx = xs[xs.length - 1] ?? (W - PAD);
  const ly = ys[ys.length - 1] ?? (H / 2);
  const x0 = xs[0]?.toFixed(1) ?? '2';
  const fillPath = `M${x0},${(H-PAD).toFixed(1)} L${polyPts.split(' ').join(' L')} L${lx.toFixed(1)},${(H-PAD).toFixed(1)} Z`;
  const trend = data.length > 3
    ? (data.slice(-3).reduce((a,b)=>a+b,0)/3) - (data.slice(0,3).reduce((a,b)=>a+b,0)/3)
    : 0;
  const dotColor = trend >= 0 ? color : '#f87171';
  return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" fill="none" xmlns="http://www.w3.org/2000/svg" style="overflow:visible">
    <defs>
      <linearGradient id="${uid}" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="${color}" stop-opacity="0.2"/>
        <stop offset="65%" stop-color="${color}" stop-opacity="0.04"/>
        <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
      </linearGradient>
    </defs>
    <path d="${fillPath}" fill="url(#${uid})"/>
    <polyline points="${polyPts}" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.9"/>
    <circle cx="${lx.toFixed(1)}" cy="${ly.toFixed(1)}" r="2.5" fill="${dotColor}"/>
    <circle cx="${lx.toFixed(1)}" cy="${ly.toFixed(1)}" r="2.5" fill="${dotColor}" opacity="0.25">
      <animate attributeName="r" values="2.5;5.5;2.5" dur="2.4s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.25;0;0.25" dur="2.4s" repeatCount="indefinite"/>
    </circle>
  </svg>`;
}


const viewSparkline    = sparkline(chartViews,  '#00ff9d');
const clickSparkline   = sparkline(chartClicks, '#bf00ff');
const revenueSparkline = sparkline(conversionRows.filter(r => r.type === 'sale').map(r => r.value ?? 0), '#a78bfa');

const deviceData = { mobile: devices['mobile'] ?? 0, desktop: devices['desktop'] ?? 0, tablet: devices['tablet'] ?? 0, unknown: devices['unknown'] ?? 0 };
const deviceTotal = deviceData.mobile + deviceData.desktop + deviceData.tablet + deviceData.unknown;

const SOCIAL = ['twitter.com','x.com','instagram.com','tiktok.com','facebook.com','linkedin.com','youtube.com','pinterest.com','snapchat.com','reddit.com','discord.com','twitch.tv'];
const SEARCH  = ['google.','bing.com','duckduckgo.com','yahoo.com','baidu.com','yandex.'];
function classifyReferrer(ref: string | null): { label: string; category: 'direct'|'social'|'search'|'other' } {
  if (!ref) return { label: 'Direct / liens', category: 'direct' };
  try {
    const host = new URL(ref.includes('://') ? ref : `https://${ref}`).hostname.replace(/^www\./, '');
    if (SOCIAL.some(s => host.includes(s))) return { label: host, category: 'social' };
    if (SEARCH.some(s => host.includes(s)))  return { label: host, category: 'search' };
    return { label: host, category: 'other' };
  } catch { return { label: ref.slice(0, 40), category: 'other' }; }
}
const parsedReferrers     = topReferrers.map(r => ({ ...classifyReferrer(r.referrer), views: r.views }));
const refAgg              = new Map<string, { label: string; category: string; views: number }>();
for (const r of parsedReferrers) { const e = refAgg.get(r.label); if (e) e.views += r.views; else refAgg.set(r.label, { ...r }); }
const aggregatedReferrers = Array.from(refAgg.values()).sort((a, b) => b.views - a.views).slice(0, 6);
const maxReferrerViews    = aggregatedReferrers[0]?.views ?? 1;
const maxCountryViews     = topCountries[0]?.views ?? 1;

function countryFlag(code: string): string {
  if (!code || code.length !== 2) return '🌐';
  return String.fromCodePoint(...[...code.toUpperCase()].map(c => 0x1F1E0 - 65 + c.charCodeAt(0)));
}

const CAT_COLORS: Record<string, string> = { direct: '#00ff9d', social: '#bf00ff', search: '#00aaff', other: '#ff6b6b' };
const CAT_LABELS: Record<string, string> = { direct: 'Direct', social: 'Social', search: 'Recherche', other: 'Autre' };

// UTM campaigns aggregated (computed in frontmatter — no TS generics in JSX)
const utmCamps: { source:string; medium:string; campaign:string; views:number; leads:number; sales:number; revenue:number; topDevice:string; topCountry:string }[] = [];
if (isPro && utmData.length > 0) {
  const cm = new Map<string, { source:string; medium:string; campaign:string; views:number; leads:number; sales:number; revenue:number; devices:Record<string,number>; countries:Record<string,number> }>();
  for (const row of utmData) {
    const key = `${row.source}|${row.medium}|${row.campaign ?? '(none)'}`;
    const e   = cm.get(key) ?? { source:row.source??'', medium:row.medium??'', campaign:row.campaign??'(none)', views:0, leads:0, sales:0, revenue:0, devices:{} as Record<string,number>, countries:{} as Record<string,number> };
    e.views++;
    if (row.converted)   e.leads++;
    if (row.revenue > 0) { e.sales++; e.revenue += row.revenue; }
    if (row.device)  e.devices[row.device]  = (e.devices[row.device]  ?? 0) + 1;
    if (row.country) e.countries[row.country] = (e.countries[row.country] ?? 0) + 1;
    cm.set(key, e);
  }
  for (const c of Array.from(cm.values()).sort((a,b) => b.views - a.views).slice(0, 10)) {
    utmCamps.push({
      source:     c.source,
      medium:     c.medium,
      campaign:   c.campaign,
      views:      c.views,
      leads:      c.leads,
      sales:      c.sales,
      revenue:    c.revenue,
      topDevice:  Object.entries(c.devices).sort((a,b)=>b[1]-a[1])[0]?.[0] ?? '—',
      topCountry: Object.entries(c.countries).sort((a,b)=>b[1]-a[1])[0]?.[0] ?? '—',
    });
  }
}

// ── v5: PREVIOUS PERIOD (for delta comparisons) ─────────────────────────────
const prevSince = new Date(since);
prevSince.setDate(prevSince.getDate() - days);
const { data: prevRpcRaw } = await supabase.rpc('get_profile_analytics', {
  p_profile_id: profileId,
  p_days: days * 2,
});
// We use the difference: total over 2x period minus current period ≈ previous period
// Simpler: fetch with prev window
const { data: prevConvRows } = await supabase.from('conversion_events')
  .select('type, value, created_at').eq('profile_id', profileId)
  .gte('created_at', prevSince.toISOString()).lt('created_at', since.toISOString());
const prevConv = prevConvRows ?? [];

// Prev period proxied from doubled RPC minus current
const prevRpc = prevRpcRaw as typeof rpcData;
const prevViews    = Math.max(0, (prevRpc?.total_views     ?? 0) - summary.totalViews);
const prevClicks   = Math.max(0, (prevRpc?.total_clicks    ?? 0) - summary.totalClicks);
const prevUniques  = Math.max(0, (prevRpc?.unique_visitors ?? 0) - summary.uniqueVisitors);
const prevLeads    = prevConv.filter(r => r.type === 'lead').length;
const prevSales    = prevConv.filter(r => r.type === 'sale').length;
const prevRevenue  = prevConv.filter(r => r.type === 'sale').reduce((s, r) => s + (r.value ?? 0), 0);

function pctDelta(curr: number, prev: number): { val: number; pos: boolean; neutral: boolean } {
  if (prev === 0) return { val: curr > 0 ? 100 : 0, pos: curr > 0, neutral: curr === 0 };
  const v = Math.round(((curr - prev) / prev) * 100);
  return { val: Math.abs(v), pos: v >= 0, neutral: v === 0 };
}
const deltaViews   = pctDelta(summary.totalViews,  prevViews);
const deltaClicks  = pctDelta(summary.totalClicks, prevClicks);
const deltaUniques = pctDelta(summary.uniqueVisitors, prevUniques);
const deltaLeads   = pctDelta(leads,   prevLeads);
const deltaRevenue = pctDelta(revenue, prevRevenue);

// ── v5: PERFORMANCE SCORE IA (deterministic, no API call) ────────────────────
function scoreMetric(val: number, thresholds: [number, number, number, number]): number {
  if (val >= thresholds[3]) return 25;
  if (val >= thresholds[2]) return 20;
  if (val >= thresholds[1]) return 12;
  if (val >= thresholds[0]) return 5;
  return 0;
}
const scoreCTR        = scoreMetric(summary.clickRate,   [1, 3, 7, 12]);
const scoreGrowth     = scoreMetric(deltaViews.pos ? deltaViews.val : -deltaViews.val, [-20, 0, 10, 25]);
const scoreConversion = scoreMetric(convRate,            [0, 5, 15, 30]);
const scoreRevenue    = scoreMetric(revenue,             [0, 50, 200, 1000]);
const perfScore       = Math.min(100, scoreCTR + scoreGrowth + scoreConversion + scoreRevenue);
const perfGrade       = perfScore >= 80 ? 'A' : perfScore >= 60 ? 'B' : perfScore >= 40 ? 'C' : 'D';
const perfColor       = perfScore >= 80 ? '#00ff9d' : perfScore >= 60 ? '#38bdf8' : perfScore >= 40 ? '#f59e0b' : '#f87171';

const perfRecos: string[] = [];
if (summary.clickRate < 5)  perfRecos.push("Améliore tes titres de liens — un CTR < 5% signale un manque d'accroche.");
if (summary.clickRate >= 5) perfRecos.push('Bon CTR ! Teste des variantes de CTA pour encore progresser.');
if (deltaViews.pos === false && deltaViews.val > 10) perfRecos.push('Trafic en baisse vs période préc. — relance une campagne ou poste plus fréquemment.');
if (channels.length <= 1) perfRecos.push("Diversifie tes sources : tu dépends d'un seul canal, risqué.");
if (leads === 0 && summary.totalClicks > 20) perfRecos.push('Beaucoup de clics mais 0 lead — ajoute un formulaire ou une offre directe.');
if (revenue > 0 && convRate < 10) perfRecos.push(`Taux de conv. ${convRate.toFixed(1)}% — teste une page de vente plus courte ou une offre à durée limitée.`);
if (perfRecos.length < 3) perfRecos.push('Continue sur cette lancée — ta cohérence est ta meilleure arme de croissance.');
const topRecos = perfRecos.slice(0, 3);

function sparklinePred(data: number[], slope: number, intercept: number, color: string): string {
  const W = 200, H = 40;
  const extended = [...data];
  for (let i = data.length; i < data.length + 14; i++) {
    extended.push(Math.max(0, intercept + slope * i));
  }
  const max = Math.max(...extended, 1);
  const uid = Math.random().toString(36).slice(2, 7);
  const x = (i: number) => ((i / (extended.length - 1)) * W).toFixed(1);
  const y = (v: number) => (H - (v / max) * (H - 4) - 2).toFixed(1);
  const pts     = data.map((v, i) => `${x(i)},${y(v)}`).join(' ');
  const predPts = extended.slice(data.length - 1).map((v, i) => `${x(data.length - 1 + i)},${y(v)}`).join(' ');
  // Fill under real data
  const fillPath = `M0,${H} L${pts.replace(/ /g,'L')} L${x(data.length-1)},${H} Z`;
  return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" fill="none" style="overflow:visible">
    <defs>
      <linearGradient id="pf${uid}" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="${color}" stop-opacity="0.15"/>
        <stop offset="100%" stop-color="${color}" stop-opacity="0"/>
      </linearGradient>
    </defs>
    <path d="${fillPath}" fill="url(#pf${uid})"/>
    <polyline points="${pts}" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.9"/>
    <polyline points="${predPts}" stroke="${color}" stroke-width="1.5" stroke-dasharray="4 3" stroke-linecap="round" stroke-linejoin="round" opacity="0.45"/>
    <line x1="${x(data.length-1)}" y1="0" x2="${x(data.length-1)}" y2="${H}" stroke="${color}" stroke-width="0.5" stroke-dasharray="2 3" opacity="0.3"/>
  </svg>`;
}
// ── Predictions data (linear regression) ────────────────────────────────────
const last7Views  = chartViews.slice(-7);
const last7Clicks = chartClicks.slice(-7);
function linReg(data: number[]): { slope: number; intercept: number } {
  const n = data.length;
  if (n < 2) return { slope: 0, intercept: data[0] ?? 0 };
  const sumX  = data.reduce((s, _, i) => s + i, 0);
  const sumY  = data.reduce((s, v)    => s + v, 0);
  const sumXY = data.reduce((s, v, i) => s + i * v, 0);
  const sumX2 = data.reduce((s, _, i) => s + i * i, 0);
  const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
  const intercept = (sumY - slope * sumX) / n;
  return { slope, intercept };
}
const regViews  = linReg(last7Views);
const regClicks = linReg(last7Clicks);
const proj30Views  = Math.max(0, Math.round((regViews.intercept  + regViews.slope  * (last7Views.length  + 22)) * 30));
const proj30Clicks = Math.max(0, Math.round((regClicks.intercept + regClicks.slope * (last7Clicks.length + 22)) * 30));
const proj30Revenue = revenue > 0 && days > 0 ? Math.round((revenue / days) * 30) : 0;

const predSparkViews  = sparklinePred(last7Views,  regViews.slope,  regViews.intercept,  '#00ff9d');
const predSparkClicks = sparklinePred(last7Clicks, regClicks.slope, regClicks.intercept, '#38bdf8');

// ── v5: HEATMAP data for blocks by position ───────────────────────────────────
const heatmapBlocks = blocks.map((b, i) => {
  const found    = topBlocks.find(tb => tb.block_id === b.id);
  const clicks   = found?.clicks ?? 0;
  const maxClicks = topBlocks[0]?.clicks ?? 1;
  const intensity = maxClicks > 0 ? clicks / maxClicks : 0;
  return { id: b.id, title: b.title || 'Untitled', type: b.type, clicks, intensity, position: i + 1, active: b.active };
});


// ── v8: COHORT ANALYSIS ──────────────────────────────────────────────────────
const cohortWeeks: { week: string; views: number; retention: number }[] = [];
if (sortedDates.length >= 7) {
  const weekSize = 7;
  const numWeeks = Math.min(4, Math.floor(sortedDates.length / weekSize));
  for (let w = 0; w < numWeeks; w++) {
    const weekDates = sortedDates.slice(w * weekSize, (w + 1) * weekSize);
    const weekViews = weekDates.reduce((s, d) => s + (viewsByDate.get(d) ?? 0), 0);
    const baseViews = cohortWeeks[0]?.views ?? weekViews;
    const retention = baseViews > 0 ? Math.round((weekViews / baseViews) * 100) : 100;
    const weekLabel = `S${numWeeks - w} (${weekDates[0]?.slice(5) ?? ''})`;
    cohortWeeks.unshift({ week: weekLabel, views: weekViews, retention });
  }
}
// ── v8: COMPARE PREV PERIOD ───────────────────────────────────────────────────
const comparePrev: number[] = (() => {
  if (prevViews <= 0 || chartViews.length === 0) return chartViews.map(() => 0);
  const avgPrev = prevViews  / chartViews.length;
  const avgCurr = summary.totalViews / Math.max(chartViews.length, 1);
  return chartViews.map(v => avgCurr > 0 ? Math.round((v / avgCurr) * avgPrev) : 0);
})();

const exportedChart    = { labels: chartLabels, views: chartViews, clicks: chartClicks, rates: chartRates };
const exportedDevices  = deviceData;
const exportedDays     = days;
const exportedChannels = channels.map(c => ({ name: c.name, views: c.views, revenue: c.revenue }));
// ── v6: RETENTION ────────────────────────────────────────────────────────────
// Proxy retention from unique vs total: uniqueVisitors / totalViews ratio
// Compare current vs previous period
const retentionRate     = summary.totalViews > 0 ? Math.round((summary.uniqueVisitors / summary.totalViews) * 100) : 0;
const prevRetentionRate = prevViews > 0 ? Math.round((prevUniques / prevViews) * 100) : 0;
const returningVisitors = Math.max(0, summary.totalViews - summary.uniqueVisitors);
const returningRate     = summary.totalViews > 0 ? Math.round((returningVisitors / summary.totalViews) * 100) : 0;
// Returning vs new over time — estimate from daily data
const retentionData = chartViews.map((v, i) => {
  const newV = Math.round(v * (retentionRate / 100));
  const retV = v - newV;
  return { date: chartLabels[i] ?? '', total: v, new: newV, returning: retV };
});


// ── v6: A/B TEST BLOCS ───────────────────────────────────────────────────────
// Top 2 blocks by clicks — compare side by side
const abBlocks = heatmapBlocks.filter(b => b.clicks > 0).slice(0, 4);


// ── v6: SMART ALERTS ─────────────────────────────────────────────────────────
type AlertItem = { type: 'warning'|'success'|'info'; icon: string; title: string; body: string };
const alerts: AlertItem[] = [];

if (summary.clickRate < 2 && summary.totalViews > 100)
  alerts.push({ type:"warning", icon:"↓", title:"CTR très faible", body:`${summary.clickRate.toFixed(1)}% de taux de clic — tes liens n'attirent pas assez l'attention. Teste des emojis ou des CTA plus directs.` });

if (deltaViews.pos === false && deltaViews.val > 20)
  alerts.push({ type:"warning", icon:"↘", title:"Trafic en baisse significative", body:`-${deltaViews.val}% de vues vs la période précédente. Vérifie si une source s'est tarie.` });

if (revenue > 0 && deltaRevenue.pos === false && deltaRevenue.val > 15)
  alerts.push({ type:"warning", icon:"⚠", title:"Revenue en recul", body:`-${deltaRevenue.val}% de revenue. Ton CPA a probablement augmenté — réévalue tes campagnes.` });

if (deltaViews.pos && deltaViews.val > 30)
  alerts.push({ type:"success", icon:"🚀", title:"Forte croissance du trafic", body:`+${deltaViews.val}% de vues vs la période précédente — capitalise sur cette dynamique.` });

if (summary.clickRate >= 12)
  alerts.push({ type:"success", icon:"🔥", title:"CTR exceptionnel", body:`${summary.clickRate.toFixed(1)}% de CTR — tu es dans le top des profils BioForge.` });

if (channels.length > 0 && channels[0].views / Math.max(totalChViews, 1) > 0.8)
  alerts.push({ type:"info", icon:"⚡", title:"Dépendance à 1 seul canal", body:`${Math.round((channels[0].views/totalChViews)*100)}% de ton trafic vient de "${channels[0].name}". Diversifie pour éviter un risque de coupure.` });

if (alerts.length === 0)
  alerts.push({ type:"info", icon:"✓", title:"Tout est nominal", body:"Aucune anomalie détectée. Continue sur ta lancée." });

const alertCount = alerts.filter(a => a.type === 'warning').length;


// ── v7: NEW METRICS ──────────────────────────────────────────────────────────
// Peak hour / best day — approximate from daily labels (day of week frequency)
const dayFreq: Record<string, number> = {};
(rpcData?.daily_views ?? []).forEach(r => {
  const dow = new Date(r.date + 'T12:00:00Z').toLocaleDateString('fr-FR', { weekday: 'long' });
  dayFreq[dow] = (dayFreq[dow] ?? 0) + r.views;
});
const bestDay = Object.entries(dayFreq).sort((a, b) => b[1] - a[1])[0]?.[0] ?? '—';

// Scroll depth proxy: clean_views / total_views (clean = stayed > Xs)
const scrollDepth = summary.totalViews > 0
  ? Math.round((summary.cleanViews / summary.totalViews) * 100) : 0;

// Bounce rate proxy: 100 - scrollDepth (rough estimate)
const bounceRate = Math.max(0, 100 - scrollDepth);

// AOV & LTV
const aov = sales > 0 ? revenue / sales : 0;
const uniqueBuyers = sales; // proxy: 1 sale = 1 buyer
const ltv = uniqueBuyers > 0 ? revenue / uniqueBuyers : 0;

// Bloc activation rate
const activeBlocks  = blocks.filter(b => b.active).length;
const activationRate = blocks.length > 0 ? Math.round((activeBlocks / blocks.length) * 100) : 0;

// Best delta bloc (highest click intensity)
const bestBloc = heatmapBlocks.find(b => b.intensity === 1);



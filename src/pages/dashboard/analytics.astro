          </div>
        </div>

        <!-- Score IA -->
        <div class="p-5 glass rounded-2xl border border-white/8 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <div><h3 class="text-sm font-semibold text-white">Score performance</h3><p class="text-xs text-gray-500 mt-0.5">{days}j</p></div>
            <div class="flex flex-col items-center w-12 h-12 rounded-xl border-2 justify-center" style={`border-color:${perfColor}40;background:${perfColor}0d`}>

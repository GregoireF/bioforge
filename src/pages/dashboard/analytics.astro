      aiBtn?.addEventListener('click', async () => {
        if (aiBtn.dataset.loading === 'true') return;
        aiBtn.dataset.loading = 'true';
        aiBtn.innerHTML = '<svg class="w-3 h-3 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity=".2"/><path fill="currentColor" d="M4 12a8 8 0 018-8v4l3-3-3-3v4a8 8 0 00-8 8h4z"/></svg>';
        aiPanel.classList.remove('hidden');
        aiContent.innerHTML = '<div class="text-gray-600 text-xs flex items-center gap-2"><span class="skeleton w-4 h-4 rounded-full shrink-0"></span>Analyse…</div>';

        const actualViews   = Number(el.dataset.goalsViews   ?? 0);
        const actualClicks  = Number(el.dataset.goalsClicks  ?? 0);
        const actualRevenue = Number(el.dataset.goalsRevenue ?? 0);
        const rates = exportedChart.rates ?? [];
        const avgCTR = rates.length ? (rates.reduce((a,b)=>a+b,0)/rates.length).toFixed(1) : '—';
        const trend = (() => {
          const v=exportedChart.views??[];
          if(v.length<4)return'insuffisant';
          const first=v.slice(0,3).reduce((a,b)=>a+b,0)/3;
          const last =v.slice(-3).reduce((a,b)=>a+b,0)/3;
          return last>first*1.1?'croissance':last<first*0.9?'déclin':'stable';
        })();
        const chans = exportedChannels.slice(0,3).map(c=>`${c.name} (${c.views} vues)`).join(', ')||'non disponible';

        try {
          const resp = await fetch('https://api.anthropic.com/v1/messages', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body:JSON.stringify({
              model:'claude-sonnet-4-20250514', max_tokens:1000,
              messages:[{role:'user',content:`Tu es un analyste marketing expert. Métriques BioForge sur ${exportedDays} jours :\n\nVues : ${actualViews.toLocaleString('fr-FR')}\nClics : ${actualClicks.toLocaleString('fr-FR')}\nCTR moyen : ${avgCTR}%\nRevenue : ${actualRevenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0})}\nTendance : ${trend}\nCanaux : ${chans}\n\nRédige un rapport en 3 sections :\n1. **Ce qui s'est passé** (2-3 phrases factuelles)\n2. **Pourquoi** (1-2 hypothèses)\n3. **3 actions prioritaires** (bullet points concrets)\n\nDirectement en français, sans introduction. Markdown simple.`}],
            }),
          });
          if (!resp.ok) throw new Error(`API ${resp.status}`);
          const data = await resp.json();
          const text = data.content?.map(b=>b.text??'').join('')??'';

          aiContent.innerHTML = '';
          const sections = text.split('\n').filter(l=>l.trim());
          let i = 0;
          function renderNext() {
            if (i >= sections.length) {
              aiBtn.dataset.loading = 'false';
              aiBtn.innerHTML = '↺ Régénérer';
              return;
            }
            const line = sections[i++];
            const div  = document.createElement('div');
            div.className = 'slide-in-up stagger-1';
            if (line.startsWith('**') && line.endsWith('**')) {
              div.innerHTML = `<p style="font-size:10px;font-weight:700;color:rgba(0,255,157,.8);text-transform:uppercase;letter-spacing:.08em;margin:10px 0 4px">${line.slice(2,-2)}</p>`;
            } else if (line.startsWith('- ') || line.startsWith('• ')) {
              div.innerHTML = `<div style="display:flex;gap:8px;font-size:11px;color:#6e7681;line-height:1.5"><span style="color:rgba(0,255,157,.5);margin-top:1px;flex-shrink:0">→</span><span>${line.slice(2)}</span></div>`;
            } else {
              div.innerHTML = `<p style="font-size:11px;color:#6e7681;line-height:1.5">${line}</p>`;
            }
            aiContent.appendChild(div);
            setTimeout(renderNext, 70);
          }
          renderNext();
        } catch(err) {
          aiContent.innerHTML = `<p style="font-size:11px;color:#f87171">Erreur : ${err.message}</p>`;
          aiBtn.dataset.loading = 'false';
          aiBtn.innerHTML = '↺ Réessayer';
        }
      });

      // ── EXPORTS ───────────────────────────────────────────────────────────

                <div class="flex justify-between text-xs mb-1"><span class="text-gray-500">Rebond estimé</span><span class="font-semibold" style={`color:${bounceRate>60?'#f87171':bounceRate>40?'#f59e0b':'#00ff9d'}`}>{bounceRate}%</span></div>
                <div class="bar-track" style="height:4px"><div class="bar-fill" style={`width:${bounceRate}%;background:${bounceRate>60?'#f87171':bounceRate>40?'#f59e0b':'#00ff9d'};opacity:.8`}></div></div>
              </div>
              <div>
                <div class="flex justify-between text-xs mb-1"><span class="text-gray-500">Récurrents</span><span class="font-semibold" style="color:#a78bfa">{returningRate}%</span></div>
                <div class="bar-track" style="height:4px"><div class="bar-fill" style={`width:${returningRate}%;background:#a78bfa;opacity:.8`}></div></div>
              </div>
            </div>
          </div>
          <!-- Live feed compact -->

      // ── LIVE FEED ─────────────────────────────────────────────────────────
      const liveList  = document.getElementById('live-feed-list');
      const liveCount = document.getElementById('live-count');
      async function initLiveFeed(){
        const supaUrl=el.dataset.sbUrl;
        const supaKey=el.dataset.sbKey;
        if(!supaUrl||!supaKey||!liveList)return;
        await new Promise((res,rej)=>{
          if(window.supabase){res(null);return;}
          const s=document.createElement('script');
          s.src='https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js';
          s.onload=res;s.onerror=rej;document.head.appendChild(s);
        });
        const client=window.supabase.createClient(supaUrl,supaKey);
        const profileId=el.dataset.profileId;
        if(!profileId)return;
        let visitors=[];
        const{data:recent}=await client.from('profile_views').select('id,country,device,created_at').eq('profile_id',profileId).order('created_at',{ascending:false}).limit(10);
        if(recent)visitors=recent;
        const renderLive=()=>{
          if(!liveList)return;
          if(!visitors.length){liveList.innerHTML='<p class="text-xs text-gray-700 text-center py-2">Aucun visiteur récent</p>';return;}
          if(liveCount)liveCount.textContent=visitors.filter(v=>new Date(v.created_at)>new Date(Date.now()-5*60*1000)).length+' actif(s)';
          liveList.innerHTML=visitors.map((v,i)=>{
            const ago=Math.round((Date.now()-new Date(v.created_at).getTime())/60000);
            const flag=v.country?.length===2?String.fromCodePoint(...[...v.country.toUpperCase()].map(c=>0x1F1E0-65+c.charCodeAt(0))):'🌐';
            const dev=v.device==='mobile'?'📱':v.device==='tablet'?'📊':'🖥';
            return`<div class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-white/3 ${i===0?'live-entry':''}"><span class="text-sm">${flag}</span><span class="text-sm">${dev}</span><span class="text-xs text-gray-500 flex-1">${v.country||'?'}</span><span class="text-xs text-gray-700 tabular-nums">${ago<1?"à l'instant":ago+'min'}</span>${i===0?'<span class="w-1.5 h-1.5 rounded-full bg-neon-green shrink-0"></span>':''}</div>`;
          }).join('');
        };
        renderLive();
        client.channel('live-views').on('postgres_changes',{event:'INSERT',schema:'public',table:'profile_views',filter:`profile_id=eq.${profileId}`},payload=>{
          visitors.unshift(payload.new);if(visitors.length>12)visitors.pop();renderLive();
        }).subscribe();
      }
      document.querySelector('[data-section="traffic"]')?.addEventListener('click',()=>setTimeout(initLiveFeed,100),{once:true});

      // ── D3 MAP (IntersectionObserver lazy) ───────────────────────────────
      const countriesData=JSON.parse(el.dataset.countries??'[]');
      const mapSvgEl=document.getElementById('world-map');
      const mapLoader=document.getElementById('world-map-loader');
      const mapTooltip2=document.getElementById('map-tooltip');
      async function initMap(){
        if(!mapSvgEl||mapSvgEl._inited)return;mapSvgEl._inited=true;
        await Promise.all([
          new Promise((res,rej)=>{if(window.d3){res(null);return;}const s=document.createElement('script');s.src='https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js';s.onload=res;s.onerror=rej;document.head.appendChild(s);}),
          new Promise((res,rej)=>{if(window.topojson){res(null);return;}const s=document.createElement('script');s.src='https://cdn.jsdelivr.net/npm/topojson@3.0.2/dist/topojson.min.js';s.onload=res;s.onerror=rej;document.head.appendChild(s);}),
        ]);
        const world=await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2.0.2/countries-50m.json').then(r=>r.json());
        const ISO2_NUM={AF:'4',AL:'8',DZ:'12',AO:'24',AR:'32',AU:'36',AT:'40',AZ:'31',BD:'50',BE:'56',BJ:'204',BO:'68',BR:'76',BG:'100',CA:'124',CL:'152',CN:'156',CO:'170',CD:'180',CR:'188',HR:'191',CZ:'203',DK:'208',EG:'818',ET:'231',FI:'246',FR:'250',DE:'276',GH:'288',GR:'300',HK:'344',HU:'348',IN:'356',ID:'360',IR:'364',IQ:'368',IE:'372',IL:'376',IT:'380',CI:'384',JP:'392',JO:'400',KZ:'398',KE:'404',KR:'410',KW:'414',LB:'422',LY:'434',MA:'504',MX:'484',MM:'104',NL:'528',NZ:'554',NG:'566',NO:'578',PK:'586',PE:'604',PH:'608',PL:'616',PT:'620',QA:'634',RO:'642',RU:'643',SA:'682',SN:'686',SG:'702',SK:'703',SI:'705',SO:'706',ZA:'710',ES:'724',SE:'752',CH:'756',SY:'760',TW:'158',TZ:'834',TH:'764',TN:'788',TR:'792',UA:'804',AE:'784',GB:'826',US:'840',UY:'858',VE:'862',VN:'704',YE:'887',ZW:'716',MG:'450',CM:'120',GN:'324',ML:'466',TD:'148',NE:'562',LK:'144',KH:'116',MN:'496',IS:'352',LV:'428',LT:'440',EE:'233',RS:'688',BA:'70',MK:'807',GE:'268',BY:'112',MD:'498',AM:'51',UZ:'860',TM:'795',KG:'417',TJ:'762',LU:'442',CY:'196',MT:'470',MZ:'508',ZM:'894',MW:'454',UG:'800',RW:'646',BI:'108',SS:'728',SD:'729',LR:'430',SL:'694',BF:'854',GW:'624',GM:'270',CV:'132',GQ:'226',GA:'266',CG:'178',CF:'140',ER:'232',DJ:'262',KM:'174',SC:'690',MU:'480',MR:'478',LI:'438',MC:'492',SM:'674',VA:'336',AD:'20',ME:'499',XK:'383'};
        const maxViews=countriesData.length>0?countriesData[0].views:1;
        const viewsMap=new Map(),iso2Map=new Map(),labelMap=new Map();
        countriesData.forEach(r=>{const n=ISO2_NUM[r.country];if(!n)return;viewsMap.set(+n,r.views);iso2Map.set(+n,r.country);labelMap.set(+n,r.country);});
        const colorScale=maxViews>1?d3.scaleSequentialLog().domain([1,maxViews]).interpolator(d3.interpolate('#0f2a1a','#00ff9d')):()=>'#0f2a1a';
        const W=mapSvgEl.clientWidth||720,H=300;
        const svg=d3.select(mapSvgEl).attr('width',W).attr('height',H);
        const proj=d3.geoNaturalEarth1().scale(W/6.1).translate([W/2,H/2+15]);
        const path=d3.geoPath().projection(proj);
        const g=svg.append('g');
        g.append('path').datum({type:'Sphere'}).attr('d',path).attr('fill','#060d0a').attr('stroke','rgba(0,255,157,.04)').attr('stroke-width',.8);
        g.append('path').datum(d3.geoGraticule().step([20,20])()).attr('d',path).attr('fill','none').attr('stroke','rgba(255,255,255,.02)').attr('stroke-width',.4);
        const countries=topojson.feature(world,world.objects.countries);
        g.selectAll('.country').data(countries.features).join('path').attr('class','country').attr('d',path).attr('fill',d=>{const v=viewsMap.get(+d.id);return v?colorScale(v):'#101f16';}).attr('stroke','#0c1a12').attr('stroke-width',.4);
        g.append('path').datum(topojson.mesh(world,world.objects.countries,(a,b)=>a!==b)).attr('d',path).attr('fill','none').attr('stroke','rgba(0,255,157,.07)').attr('stroke-width',.5);
        const dotsG=g.append('g');
        countriesData.slice(0,6).forEach((row,idx)=>{
          const n=ISO2_NUM[row.country];if(!n)return;
          const feat=countries.features.find(f=>+f.id===+n);if(!feat)return;
          const cen=path.centroid(feat);if(!cen||isNaN(cen[0])||isNaN(cen[1]))return;
          const intensity=row.views/maxViews,r=2.5+intensity*5.5;
          dotsG.append('circle').attr('cx',cen[0]).attr('cy',cen[1]).attr('r',r+6).attr('fill',`rgba(0,255,157,${.06+intensity*.08})`).attr('pointer-events','none');
          dotsG.append('circle').attr('cx',cen[0]).attr('cy',cen[1]).attr('r',r).attr('fill',idx===0?'#00ff9d':`rgba(0,255,157,${.5+intensity*.4})`).attr('stroke',idx===0?'rgba(0,255,157,.4)':'none').attr('stroke-width',1.5).attr('pointer-events','none');
        });
        g.selectAll('.country-hit').data(countries.features).join('path').attr('class','country-hit').attr('d',path).attr('fill','transparent').attr('stroke','none')
          .attr('cursor',d=>viewsMap.has(+d.id)?'pointer':'default')
          .on('mousemove',function(evt,d){
            const v=viewsMap.get(+d.id);if(!v||!mapTooltip2)return;
            const iso2=iso2Map.get(+d.id)||'',name=labelMap.get(+d.id)||iso2;
            const rect=mapSvgEl.getBoundingClientRect();
            mapTooltip2.innerHTML=`<span style="color:#00ff9d;font-weight:700">${iso2} — ${name}</span><span style="color:#484f58;margin:0 6px">·</span><span style="color:#e6edf3">${v.toLocaleString('fr-FR')} vues</span>`;
            let tx=evt.clientX-rect.left+12,ty=evt.clientY-rect.top-36;
            if(tx+240>W)tx-=252;if(ty<4)ty=evt.clientY-rect.top+16;
            mapTooltip2.style.left=tx+'px';mapTooltip2.style.top=ty+'px';mapTooltip2.classList.remove('hidden');
            d3.select(this.parentNode).selectAll('.country').filter(fd=>fd===d).attr('fill',fv=>{const val=viewsMap.get(+fv.id);return val?d3.color(colorScale(val)).brighter(.8).formatHex():'#1e3525';});
          })
          .on('mouseleave',function(evt,d){
            if(mapTooltip2)mapTooltip2.classList.add('hidden');
            d3.select(this.parentNode).selectAll('.country').filter(fd=>fd===d).attr('fill',fd=>{const v=viewsMap.get(+fd.id);return v?colorScale(v):'#101f16';});
          });
        const zoom=d3.zoom().scaleExtent([.9,12]).translateExtent([[-W*.5,-H*.5],[W*1.5,H*1.5]])
          .filter(ev=>{if(ev.type==='dblclick')return false;return true;})
          .on('zoom',ev=>{g.attr('transform',ev.transform);g.selectAll('.country').attr('stroke-width',Math.max(.2,.4/ev.transform.k));mapSvgEl.style.cursor=ev.sourceEvent?.buttons?'grabbing':'grab';});
        svg.call(zoom);
        document.getElementById('map-zoom-in')?.addEventListener('click',()=>svg.transition().duration(300).call(zoom.scaleBy,1.6));
        document.getElementById('map-zoom-out')?.addEventListener('click',()=>svg.transition().duration(300).call(zoom.scaleBy,.625));
        document.getElementById('map-reset')?.addEventListener('click',()=>svg.transition().duration(450).call(zoom.transform,d3.zoomIdentity));
        document.querySelectorAll('.country-row').forEach(row=>{
          row.addEventListener('mouseenter',()=>{
            const n=ISO2_NUM[row.getAttribute('data-iso')];if(!n)return;
            const feat=countries.features.find(f=>+f.id===+n);if(!feat)return;
            g.selectAll('.country').classed('highlighted',fd=>+fd.id===+n);
            const b=path.bounds(feat),dx=b[1][0]-b[0][0],dy=b[1][1]-b[0][1];
            const cx=(b[0][0]+b[1][0])/2,cy=(b[0][1]+b[1][1])/2;
            const scale=Math.max(1.2,Math.min(8,.85/Math.max(dx/W,dy/H)));
            svg.transition().duration(550).ease(d3.easeCubicOut).call(zoom.transform,d3.zoomIdentity.translate(W/2-scale*cx,H/2-scale*cy).scale(scale));
          });
          row.addEventListener('mouseleave',()=>{
            g.selectAll('.country').classed('highlighted',false);
            svg.transition().duration(450).ease(d3.easeCubicOut).call(zoom.transform,d3.zoomIdentity);
          });
        });
        mapSvgEl.style.opacity='1';
        if(mapLoader)mapLoader.style.display='none';
        const ro=new ResizeObserver(()=>{const nW=mapSvgEl.clientWidth;if(!nW)return;proj.scale(nW/6.1).translate([nW/2,H/2+15]);svg.attr('width',nW);g.selectAll('path').attr('d',path);});
        ro.observe(mapSvgEl);
      }
      if(mapSvgEl){
        const obs=new IntersectionObserver(entries=>{if(entries[0].isIntersecting){initMap();obs.disconnect();}},{threshold:.1});
        obs.observe(mapSvgEl);
      }else if(mapLoader){
        mapLoader.innerHTML='<p style="color:#484f58;font-size:12px;padding:24px">Carte non disponible</p>';
      }

    })();
  </script>

</DashboardLayout>
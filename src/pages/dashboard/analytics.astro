          </div>
          <div class="grid grid-cols-2 gap-1.5">
            {[{l:'CTR',v:scoreCTR},{l:'Croissance',v:scoreGrowth},{l:'Conversion',v:scoreConversion},{l:'Revenue',v:scoreRevenue}].map(s => (
              <div class="px-2.5 py-2 rounded-lg" style="background:rgba(255,255,255,.03)">
                <div class="flex justify-between text-xs mb-1"><span class="text-gray-600">{s.l}</span><span class="text-white font-semibold">{s.v}/25</span></div>
                <div class="bar-track" style="height:2px"><div class="bar-fill" style={`width:${(s.v/25)*100}%;background:${perfColor};opacity:.7`}></div></div>
              </div>

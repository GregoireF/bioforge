            <p class="text-xs text-gray-600 mt-0.5">{prevRetentionRate > 0 ? `${prevRetentionRate}% préc.` : '—'}</p>
          </div>
        </div>
        <canvas id="retention-chart" style="max-height:120px;width:100%"></canvas>
      </div>

      <!-- Cohort Analysis -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <h3 class="text-sm font-semibold text-white mb-4">Cohort Analysis <span class="text-gray-600 font-normal text-xs ml-1">· rétention semaine/semaine</span></h3>
        {cohortWeeks.length < 2 ? (
          <p class="text-sm text-gray-700 text-center py-4">Pas assez de données (min 14 jours)</p>
        ) : (
          <div class="space-y-3">
            {cohortWeeks.map((cw, i) => {
              const color = cw.retention >= 80 ? '#00ff9d' : cw.retention >= 50 ? '#f59e0b' : '#f87171';
              return (
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-500 font-mono w-20 shrink-0">{cw.week}</span>
                  <div class="flex-1 bg-white/4 rounded-lg overflow-hidden" style="height:20px">
                    <div class="cohort-bar-fill" style={`width:${cw.retention}%;background:linear-gradient(90deg,${color}55,${color}22)`}></div>
                  </div>
                  <span class="text-xs font-bold tabular-nums w-10 text-right" style={`color:${color}`}>{cw.retention}%</span>
                  <span class="text-xs text-gray-700 tabular-nums w-16 text-right">{cw.views.toLocaleString('fr-FR')}</span>
                </div>
              );
            })}
          </div>
        )}
      </div>

      <!-- Carte + Sources (inner tabs) -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center gap-1 mb-5 border-b border-white/8 pb-3 overflow-x-auto scrollbar-none">
          {[
            {id:'geo',     label:'Géographie', icon:'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064'},
            {id:'sources', label:'Sources',    icon:'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.1-1.1m-.757-4.9a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1'},
          ].map((tab, i) => (
            <button class={`insight-tab-inner flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-all ${i===0?'active text-white bg-white/8':'text-gray-500 hover:text-gray-300'}`} data-inner-tab={tab.id}>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tab.icon}/></svg>
              {tab.label}
            </button>
          ))}
        </div>
        <div class="insight-panel active" id="inner-panel-geo">
          {topCountries.length === 0 ? (
            <p class="text-sm text-gray-600 text-center py-8">Aucune donnée géographique</p>
          ) : (
            <div>
              <div class="relative rounded-xl overflow-hidden mb-4" style="background:#07100d;">
                <div id="world-map-loader" class="absolute inset-0 flex items-center justify-center z-10"><div class="map-spinner"></div></div>
                <svg id="world-map" style="width:100%;height:300px;display:block;opacity:0;transition:opacity .5s;cursor:grab;"></svg>
                <div id="map-tooltip" class="pointer-events-none absolute hidden z-20 bg-black/95 border border-neon-green/25 text-white text-xs px-3 py-2 rounded-lg backdrop-blur-sm whitespace-nowrap"></div>
                <div class="absolute bottom-3 right-3 z-20 flex flex-col gap-1">
                  <button id="map-zoom-in"  class="w-7 h-7 rounded-lg glass border border-white/10 text-gray-400 hover:text-neon-green transition-all flex items-center justify-center text-base leading-none">+</button>
                  <button id="map-zoom-out" class="w-7 h-7 rounded-lg glass border border-white/10 text-gray-400 hover:text-neon-green transition-all flex items-center justify-center text-base leading-none">−</button>
                  <button id="map-reset"    class="w-7 h-7 rounded-lg glass border border-white/10 text-gray-400 hover:text-neon-green transition-all flex items-center justify-center">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  </button>
                </div>
              </div>
              <div class="grid sm:grid-cols-2 gap-2">
                {topCountries.slice(0,8).map((ctry, i) => {
                  const pct = Math.round((ctry.views/maxCountryViews)*100);
                  return (
                    <div class="country-row flex items-center gap-2.5 px-3 py-2 rounded-xl border border-white/5 hover:border-neon-green/20 hover:bg-neon-green/3 transition-all cursor-default group" data-iso={ctry.country}>
                      <span class="text-base leading-none shrink-0 w-6 text-center">{countryFlag(ctry.country??'')}</span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2 mb-1">
                          <span class="text-xs text-gray-300 font-medium group-hover:text-neon-green transition-colors truncate">{ctry.country||'??'}</span>
                          <span class="text-xs text-gray-600 tabular-nums font-mono shrink-0">{ctry.views.toLocaleString('fr-FR')}</span>
                        </div>
                        <div class="bar-track"><div class="bar-fill" style={`width:${pct}%;background:linear-gradient(90deg,#00ff9d,#00ff9d40);animation-delay:${i*50}ms`}></div></div>
                      </div>
                      <span class="text-xs shrink-0 w-5 text-right opacity-50">{i<3?['🥇','🥈','🥉'][i]:`#${i+1}`}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          )}
        </div>
        <div class="insight-panel" id="inner-panel-sources">
          {aggregatedReferrers.length === 0 ? (
            <p class="text-sm text-gray-600 text-center py-8">Aucune source identifiée</p>
          ) : (
            <div class="space-y-3">
              {aggregatedReferrers.map((r, i) => {
                const pct   = Math.round((r.views/maxReferrerViews)*100);
                const color = CAT_COLORS[r.category]??'#9ca3af';
                const label = CAT_LABELS[r.category]??r.category;
                return (
                  <div class="flex items-center gap-3">
                    <div class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-xs font-bold text-gray-600 border border-white/8 bg-white/3">{i+1}</div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between mb-1">
                        <div class="flex items-center gap-2 min-w-0">
                          <span class="text-sm text-white font-medium truncate">{r.label}</span>
                          <span class="source-badge shrink-0" style={`background:${color}15;color:${color};border:1px solid ${color}30`}>{label}</span>
                        </div>
                        <span class="text-xs text-gray-500 tabular-nums font-mono ml-2 shrink-0">{r.views.toLocaleString('fr-FR')}</span>
                      </div>
                      <div class="bar-track"><div class="bar-fill" style={`width:${pct}%;background:${color}70;animation-delay:${i*60}ms`}></div></div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>

    </div>
  </div>

  <!-- ══ REVENUS & CONVERSION ══ -->
  <div class="sec-panel" id="panel-revenue">
    <div class="space-y-5">

      <!-- Hero revenue (Stripe-style) -->
      <div class="revenue-hero p-6 rounded-2xl">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:rgba(167,139,250,.6)">Revenue total · {days}j</p>
            <div class="revenue-hero-value text-white tabular-nums">
              {revenue > 0 ? revenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}) : <span class="text-gray-600">—</span>}
            </div>
            {revenue > 0 && (
              <div class="flex items-center gap-2 mt-2">
                {deltaRevenue.neutral ? <span class="text-sm text-gray-600">— vs préc.</span> : deltaRevenue.pos ? <span class="text-sm font-semibold" style="color:#00ff9d">↑ {deltaRevenue.val}% vs période préc.</span> : <span class="text-sm font-semibold" style="color:#f87171">↓ {deltaRevenue.val}% vs période préc.</span>}
              </div>
            )}
          </div>
          <div class="flex gap-6 shrink-0">
            <div class="text-right">
              <p class="text-xs text-gray-600 mb-1">Ventes</p>
              <p class="text-2xl font-bold text-white tabular-nums">{sales}</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-gray-600 mb-1">Panier moy.</p>
              <p class="text-2xl font-bold tabular-nums" style="color:#38bdf8">{aov > 0 ? aov.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}) : '—'}</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-gray-600 mb-1">LTV</p>
              <p class="text-2xl font-bold tabular-nums" style="color:#00ff9d">{ltv > 0 ? ltv.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}) : '—'}</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-gray-600 mb-1">Conv.</p>
              <p class="text-2xl font-bold tabular-nums" style="color:#f59e0b">{convRate.toFixed(1)}%</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Funnel revenue (visual) -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <h3 class="text-sm font-semibold text-white mb-4">Funnel</h3>
        <div class="space-y-2">
          {funnelSteps.map((step, i) => {
            const prev     = i > 0 ? funnelSteps[i-1].value : step.value;
            const dropPct  = prev > 0 && i > 0 ? (1-step.value/prev)*100 : 0;
            const widthPct = funnelSteps[0].value > 0 ? (step.value/funnelSteps[0].value)*100 : 100;
            return (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-lg shrink-0 flex items-center justify-center text-xs font-bold" style={`background:${step.color}18;color:${step.color};border:.5px solid ${step.color}30`}>{i+1}</div>
                <div class="flex-1">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs font-semibold text-white">{step.label}</span>
                    <div class="flex items-center gap-2">
                      {i > 0 && dropPct > 0 && <span class="text-xs" style="color:rgba(248,113,113,.6)">↓{dropPct.toFixed(0)}%</span>}
                      <span class="text-sm font-bold tabular-nums" style={`color:${step.color}`}>{step.value.toLocaleString('fr-FR')}</span>
                    </div>
                  </div>
                  <div style={`background:rgba(255,255,255,.04);border-radius:9999px;height:8px;overflow:hidden`}>
                    <div style={`height:100%;border-radius:9999px;width:${widthPct}%;background:${step.color};opacity:.65;animation:barGrow .8s cubic-bezier(.16,1,.3,1) both;animation-delay:${i*100}ms`}></div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Attribution + ROAS -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-5">
          <div><h3 class="text-sm font-semibold text-white">Attribution par canal</h3><p class="text-xs text-gray-500 mt-0.5">Sources de trafic et revenus</p></div>
          {!isPro && <span class="badge-pro">⚡ Pro</span>}
        </div>
        {channels.length === 0 ? (
          <p class="text-sm text-gray-700 text-center py-6">Ajoute des UTM à tes liens pour tracker les sources</p>
        ) : (
          <div class="space-y-1">
            <div class="grid grid-cols-12 gap-2 px-3 pb-2 border-b border-white/6">
              <span class="col-span-3 text-xs text-gray-600 font-medium uppercase tracking-wider">Canal</span>
              <span class="col-span-2 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Vues</span>
              <span class="col-span-2 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Leads</span>
              <span class="col-span-2 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Revenue</span>
              <span class="col-span-3 text-xs text-gray-600 font-medium uppercase tracking-wider text-right">Part</span>
            </div>
            {channels.map((ch, i) => {
              const sharePct = totalChViews > 0 ? Math.round((ch.views/totalChViews)*100) : 0;
              const chClass  = ch.name.includes('Google')?'ch-google':ch.name.includes('Meta')?'ch-meta':ch.name.includes('TikTok')?'ch-tiktok':(ch.name.includes('Organic')||ch.name==='SEO')?'ch-organic':ch.name==='Email'?'ch-email':ch.name==='Influenceurs'?'ch-infl':ch.name==='Direct'?'ch-direct':'ch-other';
              return (
                <div class="grid grid-cols-12 gap-2 items-center px-3 py-2.5 rounded-xl hover:bg-white/3 transition-colors">
                  <div class="col-span-3"><span class={`text-xs font-bold px-2 py-0.5 rounded-full ${chClass}`}>{ch.name}</span></div>
                  <span class="col-span-2 text-sm text-white font-semibold tabular-nums text-right">{ch.views.toLocaleString('fr-FR')}</span>
                  <span class="col-span-2 text-sm tabular-nums text-right" style="color:#f59e0b">{ch.leads>0?ch.leads:<span class="text-gray-700">—</span>}</span>
                  <span class="col-span-2 text-sm tabular-nums text-right" style="color:#a78bfa">{ch.revenue>0?ch.revenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}):<span class="text-gray-700">—</span>}</span>
                  <div class="col-span-3 flex items-center gap-2">
                    <div class="bar-track flex-1" style="height:4px"><div class="bar-fill" style={`width:${sharePct}%;background:#00ff9d60;animation-delay:${i*50}ms`}></div></div>
                    <span class="text-xs text-gray-500 tabular-nums w-7 text-right">{sharePct}%</span>
                  </div>
                </div>
              );
            })}
          </div>
        )}
        {isPro && channels.some(c => c.revenue > 0) && (
          <div class="mt-4 pt-4 border-t border-white/6">
            <p class="text-xs text-gray-600 uppercase tracking-widest font-medium mb-3">Revenue par canal</p>
            <canvas id="roas-chart" style="max-height:120px;width:100%"></canvas>
          </div>
        )}
      </div>

      <!-- UTM Campaigns -->
      <div class="p-5 glass rounded-2xl border border-white/8" style="position:relative;overflow:hidden">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h3 class="text-sm font-semibold text-white flex items-center gap-2">Campagnes UTM <span class="badge-pro">⚡ Pro</span></h3>
            <p class="text-xs text-gray-500 mt-0.5">source · medium · campaign · CPA</p>
          </div>
          {isPro && utmData.length > 0 && <span class="text-xs text-gray-600">{utmData.length} événements</span>}
        </div>
        {!isPro ? (
          <div style="position:absolute;inset:0;z-index:10;display:flex;flex-direction:column;align-items:center;justify-content:center;backdrop-filter:blur(8px);background:rgba(0,0,0,.72);border-radius:inherit">
            <div class="text-center px-8 py-6">
              <p class="text-sm font-bold text-white mb-1">Tracking UTM avancé</p>
              <p class="text-xs text-gray-500 mb-4 max-w-xs mx-auto">Source / medium / device / pays — ROAS et CPA calculés auto.</p>
              <a href="/dashboard/billing" style="display:inline-flex;padding:8px 18px;border-radius:10px;background:rgba(168,85,247,.2);border:1px solid rgba(168,85,247,.4);color:#c084fc;font-size:13px;font-weight:700;text-decoration:none">Passer Pro →</a>
            </div>
          </div>
        ) : utmData.length === 0 ? (
          <p class="text-sm text-gray-700 text-center py-6">Aucun événement UTM · ajoute <code class="text-neon-green">?utm_source=...</code></p>
        ) : (
          <div>
            {isPro && utmCamps.length > 0 && (
              <div class="flex items-center gap-1.5 flex-wrap mb-4" id="utm-filter">
                <span class="text-xs text-gray-600 mr-1">Source :</span>
                <button class="filter-chip active text-xs px-2.5 py-1 rounded-full border border-white/10 text-gray-400" data-utm-filter="all">Tous</button>
                {[...new Set(utmCamps.map(c => c.source))].slice(0,6).map(s => (
                  <button class="filter-chip text-xs px-2.5 py-1 rounded-full border border-white/10 text-gray-400" data-utm-filter={s}>{s}</button>
                ))}
              </div>
            )}
            <div class="overflow-x-auto -mx-1 scrollbar-none">
              <table class="w-full text-sm min-w-[680px]">
                <thead>
                  <tr>{['Campaign','Source','Medium','Vues','Leads','Revenue','CPA','Device','Pays'].map(h => <th class="text-left pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5 whitespace-nowrap">{h}</th>)}</tr>
                </thead>
                <tbody id="utm-table">
                  {utmCamps.map(c => {
                    const cpa   = c.sales > 0 ? `${(c.revenue/c.sales).toFixed(0)}€` : '—';
                    const chCls = c.medium?.toLowerCase().includes('cpc') ? 'ch-google' : 'ch-organic';
                    return (
                      <tr class="border-b border-white/4 last:border-0 hover:bg-white/2 transition-colors" data-source={c.source||''}>
                        <td class="py-2.5 px-2 text-white text-xs font-medium max-w-[110px] truncate">{c.campaign}</td>
                        <td class="py-2.5 px-2"><span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${chCls}`}>{c.source||'—'}</span></td>
                        <td class="py-2.5 px-2 text-gray-500 text-xs">{c.medium||'—'}</td>
                        <td class="py-2.5 px-2 tabular-nums font-semibold text-white">{c.views.toLocaleString('fr-FR')}</td>
                        <td class="py-2.5 px-2 tabular-nums text-xs" style="color:#f59e0b">{c.leads>0?c.leads:<span class="text-gray-700">—</span>}</td>
                        <td class="py-2.5 px-2 tabular-nums text-xs" style="color:#a78bfa">{c.revenue>0?c.revenue.toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}):<span class="text-gray-700">—</span>}</td>
                        <td class="py-2.5 px-2 tabular-nums text-gray-400 text-xs">{cpa}</td>
                        <td class="py-2.5 px-2 text-gray-400 text-xs capitalize">{c.topDevice}</td>
                        <td class="py-2.5 px-2 text-gray-400 text-xs">{c.topCountry!=='—'?`${countryFlag(c.topCountry)} ${c.topCountry}`:'—'}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>

    </div>
  </div>

  <!-- ══ CONTENU ══ -->
  <div class="sec-panel" id="panel-content">
    <div class="space-y-5">

      <!-- Heatmap canvas -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-4">
          <div><h3 class="text-sm font-semibold text-white">Heatmap des clics</h3><p class="text-xs text-gray-500 mt-0.5">Intensité canvas · {blocks.length} blocs</p></div>
          <div class="flex items-center gap-1" id="heatmap-sort">
            <button class="sort-btn active text-xs px-2 py-1 rounded-lg border border-white/8 text-gray-500 hover:text-gray-300 transition-all" data-sort="clicks">Clics</button>
            <button class="sort-btn text-xs px-2 py-1 rounded-lg border border-white/8 text-gray-500 hover:text-gray-300 transition-all" data-sort="position">Position</button>
            <button class="sort-btn text-xs px-2 py-1 rounded-lg border border-white/8 text-gray-500 hover:text-gray-300 transition-all" data-sort="ctr">CTR</button>
          </div>
        </div>
        {heatmapBlocks.length === 0 ? (
          <div class="text-center py-8">
            <p class="text-sm text-gray-600 mb-2">Aucun clic enregistré</p>
            <a href="/dashboard/blocks" class="text-xs text-neon-green hover:underline">Ajouter des blocs →</a>
          </div>
        ) : (
          <div>
            <!-- Canvas heatmap visualization -->
            <div class="relative mb-4 rounded-xl overflow-hidden" style="background:rgba(0,0,0,.3)">
              <canvas id="heatmap-canvas" style="width:100%;display:block"></canvas>
              <div id="heatmap-tooltip" class="pointer-events-none absolute hidden z-20 bg-black/95 border border-neon-green/25 text-white text-xs px-3 py-2 rounded-lg backdrop-blur-sm whitespace-nowrap"></div>
            </div>
            <!-- List rows (sortable) -->
            <div id="heatmap-rows" class="space-y-1.5">
              {heatmapBlocks.map((block, i) => {
                const ctr   = summary.totalViews > 0 ? ((block.clicks/summary.totalViews)*100) : 0;
                const alpha = block.intensity > 0 ? Math.max(.05, block.intensity*.8) : .03;
                const bdr   = block.intensity > 0.5 ? `rgba(0,255,157,${Math.min(.5,block.intensity)})` : 'rgba(255,255,255,.06)';
                const heat  = block.intensity >= .8 ? '🔥' : block.intensity >= .5 ? '↑' : '';
                return (
                  <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all"
                    style={`background:rgba(0,255,157,${alpha});border:.5px solid ${bdr}`}
                    data-pos={block.position} data-clicks={block.clicks} data-ctr={ctr.toFixed(2)}>
                    <div class="w-6 h-6 rounded-lg flex items-center justify-center text-xs font-bold shrink-0 border"
                      style={block.intensity>.5?'background:rgba(0,255,157,.15);border-color:rgba(0,255,157,.3);color:#00ff9d':'background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.1);color:#6b7280'}>
                      {block.position}
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1.5">
                        <span class="text-xs px-1.5 py-0.5 rounded border border-white/10 bg-white/5 text-gray-400 shrink-0">{block.type}</span>
                        <span class="text-sm font-medium truncate" style={`color:${block.intensity>0?'#fff':'rgba(255,255,255,.4)'}`}>{block.title}</span>
                        {heat && <span class="text-xs shrink-0">{heat}</span>}
                      </div>
                      <div class="relative h-2 rounded-full overflow-hidden" style="background:rgba(255,255,255,.04)">
                        <div class="h-full rounded-full" style={`width:${(block.intensity*100).toFixed(1)}%;background:linear-gradient(90deg,rgba(0,255,157,${Math.max(.3,block.intensity)}),rgba(0,255,157,${Math.max(.1,block.intensity*.4)}));animation:barGrow .9s cubic-bezier(.16,1,.3,1) both;animation-delay:${i*60}ms`}></div>
                      </div>
                    </div>
                    <div class="text-right shrink-0 pl-1">
                      <div class="text-sm font-bold tabular-nums" style={`color:${block.intensity>.5?'#00ff9d':block.intensity>0?'#fff':'rgba(255,255,255,.3)'}`}>{block.clicks.toLocaleString('fr-FR')}</div>
                      <div class="text-xs text-gray-600">{ctr.toFixed(1)}%</div>
                    </div>
                  </div>
                );
              })}
            </div>
            <!-- Legend + activation -->
            <div class="flex items-center justify-between pt-3 mt-3 border-t border-white/6">
              <div class="flex items-center gap-2">
                {[.1,.35,.65,.9].map(v => (
                  <div class="flex items-center gap-1">
                    <div class="w-3 h-3 rounded" style={`background:rgba(0,255,157,${Math.max(.05,v*.8)})`}></div>
                    <span class="text-xs text-gray-700">{Math.round(v*100)}%</span>
                  </div>
                ))}
              </div>
              <span class="text-xs text-gray-600">Activation <span class="font-semibold" style={`color:${activationRate>=80?'#00ff9d':activationRate>=50?'#f59e0b':'#f87171'}`}>{activationRate}%</span></span>
            </div>
          </div>
        )}
      </div>

      <!-- A/B Comparison (2 cols, side by side) -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <h3 class="text-sm font-semibold text-white mb-4">Comparaison de blocs <span class="text-gray-600 font-normal text-xs ml-1">· top {abBlocks.length} par clics</span></h3>
        {abBlocks.length < 2 ? (
          <p class="text-sm text-gray-700 text-center py-6">Pas assez de données (min 2 blocs avec des clics)</p>
        ) : (
          <div>
            <!-- Visual bar comparison -->
            <div class="mb-4 space-y-2">
              {abBlocks.slice(0,4).map((block, i) => {
                const ctr     = summary.totalViews > 0 ? (block.clicks/summary.totalViews)*100 : 0;
                const maxC    = abBlocks[0]?.clicks ?? 1;
                const relPct  = maxC > 0 ? (block.clicks/maxC)*100 : 0;
                const COLS    = ['#00ff9d','#38bdf8','#f59e0b','#a78bfa'];
                const color   = COLS[i] ?? '#9ca3af';
                const isWin   = i === 0;
                return (
                  <div class="flex items-center gap-3">
                    <div class="w-28 shrink-0 flex items-center gap-2 min-w-0">
                      {isWin && <span class="text-xs shrink-0">🏆</span>}
                      <span class="text-xs text-gray-400 truncate">{block.title}</span>
                    </div>
                    <div class="flex-1 relative h-7 rounded-lg overflow-hidden" style="background:rgba(255,255,255,.04)">
                      <div class="absolute inset-y-0 left-0 rounded-lg flex items-center px-2"
                        style={`width:${relPct}%;background:${color}25;border-right:2px solid ${color}60;transition:width .7s cubic-bezier(.16,1,.3,1);animation:barGrow .8s cubic-bezier(.16,1,.3,1) both;animation-delay:${i*100}ms`}>
                      </div>
                      <div class="absolute inset-0 flex items-center justify-between px-3">
                        <span class="text-xs font-semibold text-white">{block.clicks.toLocaleString('fr-FR')} clics</span>
                        <span class="text-xs font-semibold" style={`color:${color}`}>{ctr.toFixed(1)}%</span>
                      </div>
                    </div>
                    <span class="text-xs text-gray-600 w-8 text-right shrink-0">#{block.position}</span>
                  </div>
                );
              })}
            </div>
            <!-- Insight below -->
            {abBlocks.length >= 2 && (() => {
              const top    = abBlocks[0];
              const second = abBlocks[1];
              const ratio  = second.clicks > 0 ? (top.clicks / second.clicks).toFixed(1) : '∞';
              return (
                <div class="px-4 py-3 rounded-xl" style="background:rgba(0,255,157,.04);border:.5px solid rgba(0,255,157,.12)">
                  <p class="text-xs text-gray-400">
                    <span class="text-neon-green font-semibold">"{top.title}"</span> performe {ratio}× mieux que <span class="text-white">"{second.title}"</span> —
                    {Number(ratio) >= 2 ? " fort signal, dupliquer ce format en priorité." : " avantage modéré, A/B test recommandé."}
                  </p>
                </div>
              );
            })()}
          </div>
        )}
      </div>

      <!-- Short URL Tracker -->
      {isCreator && (
        <div class="p-5 glass rounded-2xl border border-white/8">
          <div class="flex items-center justify-between mb-4">
            <div><h3 class="text-sm font-semibold text-white flex items-center gap-2">Short URLs <span class="badge-creator">👑 Creator</span></h3><p class="text-xs text-gray-500 mt-0.5">{shortUrls.length} lien{shortUrls.length!==1?'s':''}</p></div>
            <a href="/dashboard/links" class="text-xs text-neon-green/70 hover:text-neon-green transition-colors">Gérer →</a>
          </div>
          {shortUrls.length === 0 ? (
            <div class="text-center py-6 text-gray-700">
              <p class="text-sm">Aucun lien court créé</p>
              <a href="/dashboard/links" class="text-xs text-neon-green hover:underline mt-1 inline-block">Créer →</a>
            </div>
          ) : (
            <div class="space-y-2">
              {shortUrls.map((link, i) => {
                const maxC   = shortUrls[0]?.click_count ?? 1;
                const barPct = maxC > 0 ? Math.round((link.click_count/maxC)*100) : 0;
                return (
                  <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl border border-white/6 hover:border-white/12 transition-colors">
                    {i === 0 && <span class="text-yellow-400 text-xs shrink-0">★</span>}
                    <span class="font-mono text-neon-green text-xs font-semibold shrink-0">/{link.slug}</span>
                    <span class="text-gray-600 text-xs truncate flex-1 hidden sm:block">{link.target_url?.replace(/^https?:\/\/(www\.)?/,'').slice(0,40)}</span>
                    <div class="w-24 hidden lg:block">
                      <div class="bar-track" style="height:4px"><div class="bar-fill" style={`width:${barPct}%;background:#00ff9d60;animation-delay:${i*40}ms`}></div></div>
                    </div>
                    <span class={`text-sm font-bold tabular-nums shrink-0 ${link.click_count>0?'text-neon-green':'text-gray-700'}`}>{(link.click_count??0).toLocaleString('fr-FR')}</span>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      )}

      <!-- All blocks table -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-4">
          <div><h3 class="text-sm font-semibold text-white">Tous les blocs</h3><p class="text-xs text-gray-500 mt-0.5">{blocks.length} bloc{blocks.length!==1?'s':''}</p></div>
          <a href="/dashboard/blocks" class="text-xs text-neon-green/70 hover:text-neon-green transition-colors">Gérer →</a>
        </div>
        <div class="overflow-x-auto -mx-1 scrollbar-none">
          <table class="w-full text-sm min-w-[440px]">
            <thead>
              <tr>
                <th class="text-left pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Bloc</th>
                <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Clics</th>
                <th class="text-right pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">CTR</th>
                <th class="text-center pb-3 px-2 text-xs font-medium text-gray-600 uppercase tracking-widest border-b border-white/5">Statut</th>
              </tr>
            </thead>
            <tbody>
              {blocks.map((block, i) => {
                const found       = topBlocks.find(tb => tb.block_id === block.id);
                const blockClicks = found?.clicks ?? 0;
                const ctr         = summary.totalViews > 0 ? ((blockClicks/summary.totalViews)*100).toFixed(1) : '0.0';
                return (
                  <tr class="border-b border-white/4 last:border-0 hover:bg-white/2 transition-colors">
                    <td class="py-2.5 px-2">
                      <div class="flex items-center gap-2">
                        <span class="text-xs px-1.5 py-0.5 rounded border border-white/10 bg-white/5 text-gray-400">{block.type}</span>
                        <span class="text-white text-xs font-medium truncate max-w-[160px]">{block.title||'Untitled'}</span>
                      </div>
                    </td>
                    <td class="py-2.5 px-2 text-right"><span class={`font-semibold tabular-nums text-xs ${blockClicks>0?'text-neon-green':'text-gray-700'}`}>{blockClicks.toLocaleString('fr-FR')}</span></td>
                    <td class="py-2.5 px-2 text-right text-gray-500 tabular-nums text-xs">{ctr}%</td>
                    <td class="py-2.5 px-2 text-center">
                      <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${block.active?'text-neon-green bg-neon-green/10':'text-gray-600 bg-white/5'}`}>
                        <span class={`w-1.5 h-1.5 rounded-full ${block.active?'bg-neon-green':'bg-gray-600'}`}></span>
                        {block.active?'Actif':'Inactif'}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <!-- DATA BRIDGE -->
  <div aria-hidden="true" class="contents">
    <div id="chart-data" class="hidden"
      data-chart={JSON.stringify(exportedChart)}
      data-devices={JSON.stringify(exportedDevices)}
      data-days={String(exportedDays)}
      data-countries={JSON.stringify(topCountries)}
      data-channels={JSON.stringify(exportedChannels)}
      data-is-pro={String(isPro)}
      data-goals-views={String(summary.totalViews)}
      data-goals-clicks={String(summary.totalClicks)}
      data-goals-leads={String(leads)}
      data-goals-revenue={String(revenue)}
      data-retention={JSON.stringify(retentionData)}
      data-cohorts={JSON.stringify(cohortWeeks)}
      data-compare={JSON.stringify(comparePrev)}
      data-profile-id={profileId}
      data-sb-url={import.meta.env.PUBLIC_SUPABASE_URL}
      data-sb-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
      data-heatmap={JSON.stringify(heatmapBlocks)}>
    </div>
  </div>

  <script>
    (async () => {
      const el = document.getElementById('chart-data');
      if (!el) return;
      const exportedChart    = JSON.parse(el.dataset.chart    ?? '{}');
      const exportedChannels = JSON.parse(el.dataset.channels ?? '[]');
      const exportedDays     = Number(el.dataset.days ?? 7);
      const isPro            = el.dataset.isPro === 'true';
      const retentionData    = JSON.parse(el.dataset.retention ?? '[]');
      const cohortData       = JSON.parse(el.dataset.cohorts  ?? '[]');
      const comparePrev      = JSON.parse(el.dataset.compare  ?? '[]');
      const heatmapData      = JSON.parse(el.dataset.heatmap  ?? '[]');

      // ── Skeleton loaders ──────────────────────────────────────────────────
      ['traffic-chart','rate-chart','roas-chart','retention-chart'].forEach(id => {
        const c = document.getElementById(id);
        if (!c) return;
        c.style.display = 'none';
        const sk = document.createElement('div');
        sk.className = 'skeleton';
        sk.style.cssText = `height:${id==='rate-chart'?'120px':id==='roas-chart'?'120px':id==='retention-chart'?'120px':'260px'};width:100%;border-radius:12px`;
        c.parentNode.insertBefore(sk, c);
        c._skeleton = sk;
      });

      // ── Chart.js ──────────────────────────────────────────────────────────
      await new Promise((resolve, reject) => {
        if (typeof Chart !== 'undefined') { resolve(null); return; }
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js';
        s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
      });
      document.querySelectorAll('canvas').forEach(c => {
        if (c._skeleton) { c._skeleton.remove(); c.style.display = ''; }
      });

      Chart.defaults.font.family = 'DM Sans, system-ui, sans-serif';
      const GRID_C = 'rgba(255,255,255,0.03)';
      const GREEN  = '#00ff9d';
      const PURPLE = '#bf00ff';
      const BLUE   = '#38bdf8';
      const AMBER  = '#f59e0b';

      function makeGrad(ctx, color, alphaTop = 0.2) {
        const g = ctx.chart.ctx.createLinearGradient(0, 0, 0, ctx.chart.height);
        g.addColorStop(0,   color + Math.round(alphaTop * 255).toString(16).padStart(2,'0'));
        g.addColorStop(0.6, color + Math.round(alphaTop * 0.25 * 255).toString(16).padStart(2,'0'));
        g.addColorStop(1,   '00000000');
        return g;
      }
      const TOOLTIP_BASE = {
        backgroundColor:'#0d1117', titleColor:'#e6edf3', bodyColor:'#8b949e',
        borderColor:'rgba(0,255,157,0.15)', borderWidth:1, padding:14, cornerRadius:10,
        displayColors:true, boxWidth:8, boxHeight:8, boxPadding:5, usePointStyle:true,
        titleFont:{size:11,weight:'600'}, bodyFont:{size:11},
      };
      const SCALE_Y = { beginAtZero:true, grid:{color:GRID_C,drawBorder:false}, border:{display:false}, ticks:{color:'#484f58',font:{size:10},maxTicksLimit:4,padding:6} };
      const SCALE_X = { grid:{display:false}, border:{display:false}, ticks:{color:'#484f58',font:{size:10},maxRotation:0} };
      const SCALE_X_HIDE = { display:false, grid:{display:false}, border:{display:false} };

      // ── TRAFFIC CHART ─────────────────────────────────────────────────────
      let trafficChart = null;
      let compareMode  = false;
      const trafficCtx = document.getElementById('traffic-chart');

      function buildTrafficChart(mode) {
        if (trafficChart) trafficChart.destroy();
        if (!trafficCtx || !exportedChart.labels?.length) return;
        const isCTR    = mode === 'ctr';
        const isViews  = mode === 'views'  || mode === 'both';
        const isClicks = mode === 'clicks' || mode === 'both';
        const viewsAvg    = exportedChart.views.reduce((a,b)=>a+b,0) / Math.max(exportedChart.views.length,1);
        const peakViewIdx = exportedChart.views.indexOf(Math.max(...exportedChart.views));
        const datasets = [];
        if (isViews && !isCTR) {
          datasets.push({ label:'Vues', data:exportedChart.views, borderColor:GREEN,
            backgroundColor:ctx=>makeGrad(ctx,GREEN,0.2), borderWidth:2, tension:0.42, fill:true,
            pointRadius:exportedChart.views.map((_,i)=>i===peakViewIdx?5:0),
            pointHoverRadius:5, pointBackgroundColor:GREEN, pointBorderColor:'#0d1117', pointBorderWidth:2,
            pointHoverBackgroundColor:GREEN, pointHoverBorderColor:'#0d1117', pointHoverBorderWidth:2,
          });
          if (compareMode && comparePrev.length > 0) {
            datasets.push({ label:'Vues (période préc.)', data:comparePrev, borderColor:GREEN+'55',
              backgroundColor:'transparent', borderWidth:1.5, tension:0.42, fill:false,
              borderDash:[5,4], pointRadius:0, pointHoverRadius:4,
              pointHoverBackgroundColor:GREEN+'88', pointHoverBorderColor:'#0d1117', pointHoverBorderWidth:1,
            });
          }
        }
        if (isClicks && !isCTR) datasets.push({ label:'Clics', data:exportedChart.clicks, borderColor:PURPLE,
          backgroundColor:ctx=>makeGrad(ctx,PURPLE,0.15), borderWidth:2, tension:0.42, fill:true,
          pointRadius:0, pointHoverRadius:5,
          pointHoverBackgroundColor:PURPLE, pointHoverBorderColor:'#0d1117', pointHoverBorderWidth:2,
        });
        if (isCTR) datasets.push({ label:'CTR %', data:exportedChart.rates, borderColor:AMBER,
          backgroundColor:ctx=>makeGrad(ctx,AMBER,0.15), borderWidth:2, tension:0.42, fill:true,
          pointRadius:0, pointHoverRadius:5,
          pointHoverBackgroundColor:AMBER, pointHoverBorderColor:'#0d1117', pointHoverBorderWidth:2,
        });
        trafficChart = new Chart(trafficCtx, {
          type:'line', data:{ labels:exportedChart.labels, datasets },
          options:{
            responsive:true, maintainAspectRatio:false,
            interaction:{mode:'index',intersect:false},
            plugins:{
              legend:{ display:compareMode, position:'top', labels:{color:'#484f58',font:{size:10},boxWidth:8,usePointStyle:true} },
              tooltip:{
                ...TOOLTIP_BASE,
                callbacks:{
                  title:items=>items[0].label,
                  label:item=>` ${item.dataset.label}: ${item.parsed.y.toLocaleString('fr-FR')}${isCTR?'%':''}`,
                  afterBody:items=>{
                    const i=items[0]?.dataIndex;
                    const v=exportedChart.views[i]??0;
                    const tot=exportedChart.views.reduce((a,b)=>a+b,0);
                    if(!tot||isCTR)return'';
                    return[``,`  Part du trafic : ${Math.round((v/tot)*100)}%`];
                  },
                },
              },
            },
            scales:{
              y:{...SCALE_Y,ticks:{...SCALE_Y.ticks,callback:v=>v>=1000?`${(v/1000).toFixed(1)}k`:v}},
              x:{...SCALE_X,ticks:{...SCALE_X.ticks,maxTicksLimit:exportedDays===7?7:exportedDays===30?10:12}},
            },
          },
          plugins:[{
            id:'avgLine',
            afterDraw(chart) {
              if(isCTR||!isViews)return;
              const{ctx:c,chartArea:{left,right},scales:{y}}=chart;
              const yPos=y.getPixelForValue(viewsAvg);
              c.save();c.setLineDash([4,5]);c.strokeStyle=GREEN+'40';c.lineWidth=1;
              c.beginPath();c.moveTo(left,yPos);c.lineTo(right,yPos);c.stroke();
              c.setLineDash([]);c.fillStyle=GREEN+'80';c.font='9px DM Sans,sans-serif';
              c.fillText(`moy. ${Math.round(viewsAvg).toLocaleString('fr-FR')}`,right-78,yPos-4);
              c.restore();
            },
          }],
        });
      }
      buildTrafficChart('both');

      // Glow cursor
      if (trafficCtx) {
        const wrap = trafficCtx.parentElement;
        if (wrap && getComputedStyle(wrap).position !== 'relative') wrap.style.position = 'relative';
        const glow = document.createElement('div'); glow.className = 'chart-glow';
        wrap?.appendChild(glow);
        trafficCtx.addEventListener('mousemove', e => {
          const r = trafficCtx.getBoundingClientRect();
          glow.style.left = (e.clientX-r.left)+'px'; glow.style.top = (e.clientY-r.top)+'px'; glow.style.opacity='1';
        });
        trafficCtx.addEventListener('mouseleave', () => { glow.style.opacity='0'; });
      }

      // Metric toggle
      document.getElementById('metric-toggle')?.querySelectorAll('.metric-btn').forEach(btn=>{
        btn.addEventListener('click',()=>{
          document.querySelectorAll('.metric-btn').forEach(b=>b.classList.remove('active'));
          btn.classList.add('active'); buildTrafficChart(btn.dataset.metric);
        });
      });
      // Compare toggle
      document.getElementById('compare-btn')?.addEventListener('click',function(){
        compareMode=!compareMode;
        this.classList.toggle('active',compareMode);
        this.textContent=compareMode?'✕ Comparer':'⊕ Comparer';
        buildTrafficChart(document.querySelector('.metric-btn.active')?.dataset.metric??'both');
      });

      // ── CTR BAR ───────────────────────────────────────────────────────────
      const rateCtx = document.getElementById('rate-chart');
      if (rateCtx && exportedChart.labels?.length > 0) {
        const rates=exportedChart.rates;
        const avgCTR=rates.reduce((a,b)=>a+b,0)/Math.max(rates.length,1);
        new Chart(rateCtx,{
          type:'bar',
          data:{labels:exportedChart.labels,datasets:[{
            data:rates,
            backgroundColor:rates.map(r=>r>=8?GREEN+'55':r>=3?AMBER+'55':'#f87171'+'55'),
            borderColor:rates.map(r=>r>=8?GREEN+'cc':r>=3?AMBER+'cc':'#f87171cc'),
            borderWidth:1,borderRadius:4,
          }]},
          options:{responsive:true,maintainAspectRatio:false,
            plugins:{legend:{display:false},tooltip:{...TOOLTIP_BASE,callbacks:{label:ctx=>` CTR: ${ctx.parsed.y.toFixed(1)}%`}}},
            scales:{y:{...SCALE_Y,ticks:{...SCALE_Y.ticks,callback:v=>`${v}%`}},x:SCALE_X_HIDE},
          },
          plugins:[{id:'ctrAvgLine',afterDraw(chart){
            if(!avgCTR)return;
            const{ctx:c,chartArea:{left,right},scales:{y}}=chart;
            c.save();c.setLineDash([3,4]);c.strokeStyle='rgba(255,255,255,0.15)';c.lineWidth=1;
            c.beginPath();c.moveTo(left,y.getPixelForValue(avgCTR));c.lineTo(right,y.getPixelForValue(avgCTR));c.stroke();
            c.setLineDash([]);c.restore();
          }}],
        });
      }

      // ── RETENTION CHART ───────────────────────────────────────────────────
      const retCtx = document.getElementById('retention-chart');
      if (retCtx && retentionData.length > 0) {
        new Chart(retCtx,{
          type:'bar',
          data:{labels:retentionData.map(d=>d.date),datasets:[
            {label:'Nouveaux',data:retentionData.map(d=>d.new),
              backgroundColor:ctx=>{const g=ctx.chart.ctx.createLinearGradient(0,0,0,ctx.chart.height);g.addColorStop(0,GREEN+'66');g.addColorStop(1,GREEN+'22');return g;},
              borderColor:GREEN+'aa',borderWidth:1,borderRadius:{topLeft:4,topRight:4,bottomLeft:0,bottomRight:0},borderSkipped:'bottom',stack:'s'},
            {label:'Récurrents',data:retentionData.map(d=>d.returning),
              backgroundColor:ctx=>{const g=ctx.chart.ctx.createLinearGradient(0,0,0,ctx.chart.height);g.addColorStop(0,BLUE+'55');g.addColorStop(1,BLUE+'22');return g;},
              borderColor:BLUE+'88',borderWidth:1,borderRadius:{topLeft:0,topRight:0,bottomLeft:4,bottomRight:4},borderSkipped:'top',stack:'s'},
          ]},
          options:{responsive:true,maintainAspectRatio:false,
            interaction:{mode:'index',intersect:false},
            plugins:{
              legend:{display:true,position:'top',labels:{color:'#6b7280',font:{size:10},boxWidth:8,usePointStyle:true}},
              tooltip:{...TOOLTIP_BASE,callbacks:{
                label:item=>` ${item.dataset.label}: ${item.parsed.y.toLocaleString('fr-FR')}`,
                afterBody:items=>{const t=items.reduce((s,it)=>s+it.parsed.y,0);if(!t)return'';return['', ...items.map(it=>`  ${it.dataset.label}: ${Math.round((it.parsed.y/t)*100)}%`)];},
              }},
            },
            scales:{y:{...SCALE_Y,stacked:true},x:{...SCALE_X,stacked:true,ticks:{...SCALE_X.ticks,maxTicksLimit:exportedDays===7?7:10}}},
          },
        });
      }

      // ── ROAS CHART (horizontal) ───────────────────────────────────────────
      const roasCtx = document.getElementById('roas-chart');
      if (roasCtx && isPro && exportedChannels?.length > 0) {
        const chR=exportedChannels.filter(c=>c.revenue>0).sort((a,b)=>b.revenue-a.revenue);
        if (chR.length > 0) {
          const PAL=['#a78bfa',BLUE,GREEN,AMBER,'#fb7185','#34d399'];
          new Chart(roasCtx,{
            type:'bar',
            data:{labels:chR.map(c=>c.name),datasets:[{
              label:'Revenue',data:chR.map(c=>c.revenue),
              backgroundColor:chR.map((_,i)=>PAL[i%PAL.length]+'55'),
              borderColor:chR.map((_,i)=>PAL[i%PAL.length]+'cc'),
              borderWidth:1.5,borderRadius:6,borderSkipped:false,
            }]},
            options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
              plugins:{legend:{display:false},tooltip:{...TOOLTIP_BASE,callbacks:{label:ctx=>` ${Number(ctx.parsed.x).toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0})}`}}},
              scales:{x:{...SCALE_Y,ticks:{...SCALE_Y.ticks,callback:v=>v>=1000?`${Math.round(v/1000)}k€`:`${v}€`}},y:{grid:{display:false},border:{display:false},ticks:{color:'#8b949e',font:{size:10},padding:4}}},
            },
            plugins:[{id:'roasLabels',afterDatasetsDraw(chart){
              const{ctx:c,data,scales:{x,y}}=chart;
              data.datasets[0].data.forEach((val,i)=>{
                if(!val)return;
                c.save();c.fillStyle='#8b949e';c.font='9px DM Sans,sans-serif';c.textAlign='left';
                c.fillText(Number(val).toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0}),x.getPixelForValue(val)+6,y.getPixelForValue(i)+3.5);
                c.restore();
              });
            }}],
          });
        }
      }

      // ── HEATMAP CANVAS ────────────────────────────────────────────────────
      const heatCanvas = document.getElementById('heatmap-canvas');
      const heatTooltip = document.getElementById('heatmap-tooltip');
      if (heatCanvas && heatmapData.length > 0) {
        const COLS = heatmapData.length;
        const ROWS = 1;
        const W    = heatCanvas.parentElement.clientWidth || 600;
        const cellW = Math.floor(W / COLS);
        const cellH = 56;
        heatCanvas.width  = W;
        heatCanvas.height = cellH;
        heatCanvas.style.height = cellH + 'px';
        const c2 = heatCanvas.getContext('2d');
        const sorted = [...heatmapData].sort((a,b)=>b.intensity-a.intensity);

        heatmapData.forEach((block, i) => {
          const x     = i * cellW;
          const alpha = Math.max(0.05, block.intensity * 0.85);
          // Cell background
          c2.fillStyle = `rgba(0,255,157,${alpha})`;
          c2.beginPath();
          c2.roundRect(x+2, 2, cellW-4, cellH-4, 6);
          c2.fill();
          // Rank indicator at top
          if (block.intensity > 0.5) {
            c2.fillStyle = `rgba(0,255,157,${Math.min(0.9, block.intensity)})`;
            c2.fillRect(x+2, 2, 3, cellH-4);
          }
          // Position number
          c2.fillStyle = block.intensity > 0.5 ? '#00ff9d' : 'rgba(255,255,255,0.3)';
          c2.font = 'bold 10px DM Sans,sans-serif';
          c2.textAlign = 'center';
          c2.fillText(`#${block.position}`, x + cellW/2, 18);
          // Click count
          c2.fillStyle = block.intensity > 0 ? '#fff' : 'rgba(255,255,255,0.2)';
          c2.font = 'bold 11px DM Sans,sans-serif';
          c2.fillText(block.clicks > 999 ? `${(block.clicks/1000).toFixed(1)}k` : String(block.clicks), x + cellW/2, 36);
          // Fire emoji for top
          if (block.intensity >= 0.8) {
            c2.font = '11px sans-serif';
            c2.fillText('🔥', x + cellW/2, 52);
          }
        });

        // Tooltip on hover
        heatCanvas.addEventListener('mousemove', e => {
          const rect = heatCanvas.getBoundingClientRect();
          const mx   = (e.clientX - rect.left) * (heatCanvas.width / rect.width);
          const idx  = Math.floor(mx / cellW);
          if (idx < 0 || idx >= heatmapData.length || !heatTooltip) return;
          const block = heatmapData[idx];
          const ctr   = (block.clicks > 0 && exportedChart.views?.length > 0)
            ? ((block.clicks / exportedChart.views.reduce((a,b)=>a+b,0)) * 100 * exportedChart.views.length).toFixed(1)
            : '0.0';
          heatTooltip.innerHTML = `<span style="color:#00ff9d;font-weight:700">#${block.position} ${block.title}</span> <span style="color:#484f58">·</span> <span style="color:#e6edf3">${block.clicks.toLocaleString('fr-FR')} clics</span> <span style="color:#484f58">·</span> <span style="color:#f59e0b">${(block.intensity*100).toFixed(0)}% intensité</span>`;
          let tx = e.clientX - rect.left + 12;
          let ty = e.clientY - rect.top - 40;
          if (tx + 280 > rect.width) tx -= 280;
          heatTooltip.style.left = tx+'px'; heatTooltip.style.top = ty+'px';
          heatTooltip.classList.remove('hidden');
        });
        heatCanvas.addEventListener('mouseleave', () => heatTooltip?.classList.add('hidden'));
      }

      // ── AI REPORT ─────────────────────────────────────────────────────────
      const aiBtn     = document.getElementById('ai-report-btn');
      const aiPanel   = document.getElementById('ai-report-panel');

                  <input type="number" id={g.id} placeholder={g.ph} min="0" class="flex-1 px-2.5 py-1.5 glass border border-white/10 rounded-lg text-white text-xs focus:border-neon-green/40 focus:outline-none" />
                </div>
              ))}
              <button id="save-goals-btn" class="w-full py-1.5 rounded-lg text-xs font-bold mt-1" style="background:rgba(0,255,157,.1);border:1px solid rgba(0,255,157,.25);color:#00ff9d">Sauvegarder</button>
            </div>
          </div>
        </div>

      </div>

      <!-- Funnel (compact) -->

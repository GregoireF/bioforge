        <div class="grid grid-cols-4 gap-2">
          {funnelSteps.map((step, i) => {
            const prev     = i > 0 ? funnelSteps[i-1].value : step.value;
            const dropPct  = prev > 0 && i > 0 ? (1-step.value/prev)*100 : 0;
            const widthPct = funnelSteps[0].value > 0 ? (step.value/funnelSteps[0].value)*100 : 0;
            return (
              <div class="flex flex-col gap-2">
                <div class="text-center p-3 rounded-xl border" style={`background:${step.color}08;border-color:${step.color}20`}>
                  <div class="text-lg font-black tabular-nums" style={`color:${step.color}`}>{step.value.toLocaleString('fr-FR')}</div>
                  <div class="text-xs text-gray-500 mt-0.5">{step.label}</div>
                  {i > 0 && dropPct > 0 && <div class="text-xs mt-1 font-semibold" style="color:rgba(248,113,113,.7)">↓{dropPct.toFixed(0)}%</div>}
                </div>
                <div class="bar-track" style="height:4px">
                  <div class="bar-fill" style={`width:${widthPct}%;background:${step.color};opacity:.7;animation-delay:${i*80}ms`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

    </div>
  </div>

  <!-- ══ TRAFIC & AUDIENCE ══ -->
  <div class="sec-panel" id="panel-traffic">
    <div class="space-y-5">

      <!-- Chart principal + metric toggle + compare -->
      <div class="p-5 glass rounded-2xl border border-white/8">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div>
              <h3 class="text-sm font-semibold text-white">Trafic</h3>
              <p class="text-xs text-gray-500 mt-0.5">· {days}j</p>
            </div>
            <button id="compare-btn" class="compare-btn text-xs px-2.5 py-1 rounded-lg border border-white/10 text-gray-500 hover:text-gray-300 transition-all">⊕ Comparer</button>
          </div>
          <div class="flex items-center gap-1" id="metric-toggle">
            <button class="metric-btn active text-xs px-2.5 py-1 rounded-lg border border-white/10 text-gray-400" data-metric="both">Tout</button>
            <button class="metric-btn text-xs px-2.5 py-1 rounded-lg border border-white/10 text-gray-400" data-metric="views">Vues</button>
            <button class="metric-btn text-xs px-2.5 py-1 rounded-lg border border-white/10 text-gray-400" data-metric="clicks">Clics</button>
            <button class="metric-btn text-xs px-2.5 py-1 rounded-lg border border-white/10 text-gray-400" data-metric="ctr">CTR</button>
          </div>
        </div>
        {chartLabels.length === 0 ? (
          <div class="flex flex-col items-center justify-center h-52 text-gray-700"><p class="text-sm">Aucune donnée</p></div>
        ) : (
          <div style="position:relative">
            <canvas id="traffic-chart" style="max-height:260px;width:100%"></canvas>
          </div>
        )}
      </div>

      <!-- Devices + CTR + Scroll/Bounce -->
      <div class="grid sm:grid-cols-3 gap-4">
        <!-- Devices -->
        <div class="p-5 glass rounded-2xl border border-white/8">
          <h3 class="text-xs font-semibold text-white mb-4 uppercase tracking-widest" style="color:rgba(255,255,255,.4)">Appareils</h3>
          {deviceTotal === 0 ? <p class="text-sm text-gray-600 text-center py-6">Aucune donnée</p> : (
            <div class="space-y-3">
              {[
                {key:'mobile', label:'Mobile', color:'#00ff9d', icon:'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z'},
                {key:'desktop',label:'Desktop',color:'#bf00ff', icon:'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'},
                {key:'tablet', label:'Tablet', color:'#38bdf8', icon:'M12 18h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'},
              ].map(dev => {
                const val = deviceData[dev.key as keyof typeof deviceData];
                const pct = deviceTotal > 0 ? Math.round((val/deviceTotal)*100) : 0;
                if (val === 0) return null;
                return (
                  <div>
                    <div class="flex items-center justify-between mb-1.5">
                      <span class="flex items-center gap-2 text-xs text-gray-400">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" style={`color:${dev.color}`} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={dev.icon}/></svg>
                        {dev.label}
                      </span>
                      <span class="text-xs font-semibold text-white tabular-nums">{pct}%</span>
                    </div>
                    <div class="bar-track"><div class="bar-fill" style={`width:${pct}%;background:${dev.color};animation-delay:${pct*3}ms`}></div></div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
        <!-- CTR / jour -->
        <div class="p-5 glass rounded-2xl border border-white/8">
          <h3 class="text-xs font-semibold text-white mb-4 uppercase tracking-widest" style="color:rgba(255,255,255,.4)">CTR / jour</h3>
          <canvas id="rate-chart" style="max-height:120px;width:100%"></canvas>
          <div class="flex items-center justify-between mt-3 text-xs">
            <span class="text-gray-700">CTR moyen</span>
            <span class="font-semibold" style={`color:${summary.clickRate>=8?'#00ff9d':summary.clickRate>=4?'#f59e0b':'#f87171'}`}>{summary.clickRate.toFixed(1)}%</span>
          </div>
        </div>
        <!-- Scroll depth + Bounce + Live feed -->
        <div class="flex flex-col gap-3">
          <div class="p-4 glass rounded-xl border border-white/8 flex-1">

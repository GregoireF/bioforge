---
// src/pages/dashboard/billing.astro
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { withAuth } from '@/lib/auth/auth';
import { createClient } from '@supabase/supabase-js';
import Stripe from 'stripe';

// ── Auth & redirection ───────────────────────────────────────────────────────
let profile: any = null;
try {
  const auth = await withAuth({ cookies: Astro.cookies, request: Astro.request });
  if (auth.success && auth.data) profile = auth.data.profile;
} catch {}

if (!profile) return Astro.redirect('/login');

// ── Stripe + Supabase ─────────────────────────────────────────────────────────
const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY);
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

// Subscription active
const { data: subscription } = await supabase
  .from('subscriptions')
  .select('*')
  .eq('profile_id', profile.id)
  .in('status', ['active', 'trialing', 'past_due', 'incomplete'])
  .order('created_at', { ascending: false })
  .limit(1)
  .maybeSingle();

// Factures Stripe (6 dernières)
let invoices: any[] = [];
if (profile.stripe_customer_id) {
  try {
    const inv = await stripe.invoices.list({
      customer: profile.stripe_customer_id,
      limit: 6,
    });
    invoices = inv.data.map(i => ({
      id:       i.id,
      number:   i.number,
      date:     new Date(i.created * 1000).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' }),
      amount:   ((i.amount_paid ?? i.amount_due ?? 0) / 100).toFixed(2),
      currency: (i.currency ?? 'eur').toUpperCase(),
      status:   i.status,
      pdf:      i.invoice_pdf,
    }));
  } catch (e) {
    console.error("Erreur factures:", e);
  }
}

// ── Plans ─────────────────────────────────────────────────────────────────────
const PLANS = [
  {
    key: 'Free', label: 'Free', priceLabel: 'Gratuit', color: '#6b7280',
    features: ['5 blocks', 'Domaine BioForge', 'Analytics basiques', 'Communauté'],
    priceId: null, monthlyEur: 0,
  },
  {
    key: 'Creator', label: 'Creator', priceLabel: '7€/mois', color: '#38bdf8',
    features: ['20 blocks', 'Analytics 30j', 'Sans branding', 'Blocs premium'],
    priceId: import.meta.env.STRIPE_PRICE_CREATOR, monthlyEur: 7,
  },
  {
    key: 'Pro', label: 'Pro', priceLabel: '14€/mois', color: '#39ff8f', popular: true,
    features: ['Blocks illimités', 'Domaine custom', 'Analytics avancés', 'Support prioritaire', 'API access'],
    priceId: import.meta.env.STRIPE_PRICE_PRO, monthlyEur: 14,
  },
  {
    key: 'Enterprise', label: 'Enterprise', priceLabel: '49€/mois', color: '#fb923c',
    features: ['Tout Pro +', 'SLA 99.9%', 'Onboarding dédié', 'Facturation annuelle'],
    priceId: import.meta.env.STRIPE_PRICE_ENTERPRISE, monthlyEur: 49,
  },
];

const currentPlan = profile.plan ?? 'Free';
const currentPlanMeta = PLANS.find(p => p.key === currentPlan) ?? PLANS[0];
const currentPlanIdx  = PLANS.findIndex(p => p.key === currentPlan);

// Format date
function fmtDate(ts: string | null | undefined) {
  if (!ts) return '—';
  return new Date(ts).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
}

const clientCtx = JSON.stringify({
  currentPlan,
  hasCustomer: !!profile.stripe_customer_id,
  plans: PLANS.map(p => ({ key: p.key, label: p.label, priceLabel: p.priceLabel, priceId: p.priceId ?? null })),
});
---

<DashboardLayout title="Billing">
<div class="bp">

  <!-- En-tête -->
  <div class="bp-header">
    <div>
      <h1 class="bp-title">Billing</h1>
      <p class="bp-sub">Gère ton abonnement, ta carte et tes factures</p>
    </div>
    {profile.stripe_customer_id && (
      <button id="portal-btn" class="btn-portal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
        </svg>
        Gérer via Stripe
      </button>
    )}
  </div>

  <!-- Plan actuel -->
  <div class="section">
    <p class="section-label">Plan actuel</p>
    <div class="current-card">
      <div class="cc-left">
        <div class="plan-pill" style={`color:${currentPlanMeta.color}; background:${currentPlanMeta.color}18; border-color:${currentPlanMeta.color}35;`}>
          <span class="plan-dot" style={`background:${currentPlanMeta.color};`}></span>
          {currentPlan}
        </div>
        <div>
          {subscription ? (
            <p class="cc-meta">
              {subscription.cancel_at
                ? `Annulation prévue le ${fmtDate(subscription.cancel_at)}`
                : `Renouvellement le ${fmtDate(subscription.current_period_end)}`}
            </p>
          ) : (
            <p class="cc-meta">Aucun abonnement actif</p>
          )}
          {subscription && (
            <p class={`cc-status s-${subscription.status}`}>
              {subscription.status === 'active'   && '● Actif'}
              {subscription.status === 'trialing' && '◌ Essai en cours'}
              {subscription.status === 'past_due' && '⚠ Paiement en retard'}
              {subscription.status === 'incomplete' && '⚠ Paiement incomplet'}
            </p>
          )}
        </div>
      </div>
      <div class="cc-right">
        <p class="cc-price">{currentPlanMeta.priceLabel}</p>
        {subscription && !subscription.cancel_at && currentPlan !== 'Free' && (
          <button id="cancel-btn" class="btn-cancel-sub">Annuler l'abonnement</button>
        )}
      </div>
    </div>
  </div>

  <!-- Changer de plan -->
  <div class="section">
    <p class="section-label">Changer de plan</p>
    <div class="plans-grid">
      {PLANS.map((plan, idx) => {
        const isCurrent = plan.key === currentPlan;
        const isUpgrade = idx > currentPlanIdx;
        return (
          <div class={`plan-card${plan.popular ? ' pop' : ''}${isCurrent ? ' cur' : ''}`}
               style={`--pc:${plan.color};`}>
            {plan.popular && <div class="pop-tag">Populaire</div>}

            <div class="pc-head">
              <span class="pc-name" style={`color:${plan.color};`}>{plan.label}</span>
              <span class="pc-price">{plan.priceLabel}</span>
            </div>

            <ul class="pc-feats">
              {plan.features.map(f => (
                <li>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={plan.color} stroke-width="2.5">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            {isCurrent ? (
              <div class="pc-current">Plan actuel</div>
            ) : (
              <button
                class="pc-btn"
                data-plan={plan.key}
                data-price-id={plan.priceId ?? ''}
                data-label={plan.label}
                data-price-label={plan.priceLabel}
                disabled={!plan.priceId && plan.key !== 'Free'}
                style={`color:${plan.color}; background:${plan.color}15; border-color:${plan.color}35;`}
              >
                {plan.key === 'Free' ? 'Rétrograder' : isUpgrade ? 'Upgrader →' : 'Passer à ce plan'}
              </button>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Historique factures -->
  <div class="section">
    <p class="section-label">Historique des factures</p>
    {invoices.length > 0 ? (
      <div class="inv-table">
        {invoices.map(inv => (
          <div class="inv-row" key={inv.id}>
            <div>
              <p class="inv-num">{inv.number ?? '—'}</p>
              <p class="inv-date">{inv.date}</p>
            </div>
            <div class="inv-right">
              <span class={`inv-badge s-${inv.status}`}>
                {inv.status === 'paid' ? 'Payée' : inv.status === 'open' ? 'En attente' : inv.status}
              </span>
              <span class="inv-amount">{inv.amount} {inv.currency}</span>
              {inv.pdf && (
                <a href={inv.pdf} target="_blank" rel="noopener" class="inv-dl" title="Télécharger PDF">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="inv-empty">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5">
          <path d="M9 14H5a2 2 0 01-2-2V5a2 2 0 012-2h11l3 3v4M9 14v7h10V14H9z"/>
        </svg>
        <span>Aucune facture pour le moment</span>
      </div>
    )}
  </div>

</div>

<!-- Modal checkout -->
<div id="checkout-modal" class="modal-bg">
  <div class="modal">
    <div class="mhead">
      <div>
        <h2 id="mo-title" class="mo-title">Mettre à jour l'abonnement</h2>
        <p id="mo-price" class="mo-price"></p>
      </div>
      <button id="mo-close" class="mo-x">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="mbody">
      <div id="stripe-wrap">
        <div id="stripe-loading" class="stripe-loader">
          <div class="s-spin"></div>
          <span>Chargement de la méthode de paiement…</span>
        </div>
        <div id="payment-element"></div>
      </div>
      <p id="pay-error" class="pay-error hidden"></p>
    </div>
    <div class="mfoot">
      <span class="secure">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Sécurisé par Stripe
      </span>
      <button id="pay-btn" class="btn-pay" disabled>
        <span id="pay-lbl">Confirmer le paiement</span>
        <svg id="pay-spin" class="spin hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<!-- Modal annulation -->
<div id="cancel-modal" class="modal-bg">
  <div class="modal" style="max-width:380px;">
    <div class="mhead">
      <h2 class="mo-title">Annuler l'abonnement ?</h2>
      <button id="cm-close" class="mo-x">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="mbody">
      <p style="font-size:0.875rem; color:rgba(255,255,255,0.55); line-height:1.7;">
        Ton abonnement reste actif jusqu'à la fin de la période en cours.<br/>
        Tu pourras te réabonner à tout moment sans perte de données.
      </p>
    </div>
    <div class="mfoot" style="gap:0.625rem;">
      <button id="cm-keep" class="btn-keep">Garder mon plan</button>
      <button id="cm-confirm" class="btn-danger">
        <span id="cm-lbl">Confirmer l'annulation</span>
        <svg id="cm-spin" class="spin hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script src="https://js.stripe.com/v3/" is:inline></script>

<script define:vars={{ clientCtx, stripePk: import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY }}>
(function () {
  const ctx = JSON.parse(clientCtx);
  let stripe = null;
  let elements = null;

  function toast(msg, type = 'ok') {
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 4000);
  }

  // ── Ouvrir le customer portal ─────────────────────────────────────────────
  document.getElementById('portal-btn')?.addEventListener('click', async function() {
    this.disabled = true;
    this.textContent = 'Redirection…';
    try {
      const res = await fetch('/api/billing/billingPortal', { method: 'POST' });
      const json = await res.json();
      if (json.url) window.location.href = json.url;
      else toast(json.error || 'Erreur', 'err');
    } catch {
      toast('Erreur réseau', 'err');
    }
    this.textContent = 'Gérer via Stripe';
    this.disabled = false;
  });

  // ── Gestion changement de plan ─────────────────────────────────────────────
  async function handlePlanChange(btn) {
    const { priceId, label, priceLabel } = btn.dataset;

    if (!priceId || priceId === '') {
      if (label?.toLowerCase() === 'free') {
        toast('Rétrogradation vers Free programmée à la fin de période', 'ok');
        // TODO : appelle /api/billing/downgrade-to-free quand tu l'auras créé
        // Pour l'instant on simule juste le refresh
        setTimeout(() => location.reload(), 1800);
      }
      return;
    }

    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = 'Traitement…';

    try {
      const res = await fetch('/api/billing/createSubscription', {   // ← CORRECTION ICI
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ priceId }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Erreur lors de la demande');
      }

      if (data.clientSecret && data.requiresAction) {
        openModal(label, priceLabel, data.clientSecret);
      } else {
        toast('Plan mis à jour avec succès !', 'ok');
        setTimeout(() => location.reload(), 1600);
      }
    } catch (err) {
      toast(err.message || 'Impossible de changer le plan', 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = originalText;
    }
  }

  document.querySelectorAll('.pc-btn').forEach(btn => {
    btn.addEventListener('click', () => handlePlanChange(btn));
  });

  // ── Modal paiement ─────────────────────────────────────────────────────────
  const modal = document.getElementById('checkout-modal');
  const moTitle = document.getElementById('mo-title');
  const moPrice = document.getElementById('mo-price');
  const moClose = document.getElementById('mo-close');
  const payErr = document.getElementById('pay-error');
  const payBtn = document.getElementById('pay-btn');
  const payLbl = document.getElementById('pay-lbl');
  const paySpin = document.getElementById('pay-spin');
  const loading = document.getElementById('stripe-loading');
  const paymentEl = document.getElementById('payment-element');

  async function openModal(planLabel, priceLabel, clientSecret) {
    if (moTitle) moTitle.textContent = `Finaliser le passage à ${planLabel}`;
    if (moPrice) moPrice.textContent = priceLabel;
    if (payErr) { payErr.textContent = ''; payErr.classList.add('hidden'); }
    if (payBtn) payBtn.disabled = true;
    if (loading) loading.style.display = '';
    if (paymentEl) paymentEl.innerHTML = '';

    modal?.classList.add('open');

    try {
      if (!stripe) stripe = Stripe(stripePk);

      elements = stripe.elements({
        clientSecret,
        appearance: {
          theme: 'night',
          variables: {
            colorPrimary:    '#39ff8f',
            colorBackground: '#0f1114',
            colorText:       '#e8f0eb',
            colorDanger:     '#ff6b6b',
            borderRadius:    '8px',
          }
        }
      });

      const pe = elements.create('payment');
      pe.mount('#payment-element');

      pe.on('ready', () => {
        if (loading) loading.style.display = 'none';
        if (payBtn) payBtn.disabled = false;
      });

      pe.on('change', e => {
        if (payErr) {
          payErr.textContent = e.error?.message || '';
          payErr.classList.toggle('hidden', !e.error?.message);
        }
      });
    } catch (err) {
      if (loading) loading.style.display = 'none';
      if (payErr) {
        payErr.textContent = err.message || 'Erreur de chargement du paiement';
        payErr.classList.remove('hidden');
      }
    }
  }

  function closeModal() {
    modal?.classList.remove('open');
    elements = null;
  }

  moClose?.addEventListener('click', closeModal);
  modal?.addEventListener('click', e => {
    if (e.target === modal) closeModal();
  });

  // Confirmer paiement
  payBtn?.addEventListener('click', async () => {
    if (!stripe || !elements) return;

    payLbl.textContent = 'Traitement…';
    paySpin?.classList.remove('hidden');
    payBtn.disabled = true;

    const { error } = await stripe.confirmPayment({
      elements,
      confirmParams: {
        return_url: `${window.location.origin}/dashboard/billing?success=1`,
      },
    });

    if (error) {
      if (payErr) {
        payErr.textContent = error.message;
        payErr.classList.remove('hidden');
      }
      payLbl.textContent = 'Confirmer le paiement';
      paySpin?.classList.add('hidden');
      payBtn.disabled = false;
    }
  });

  // Succès après redirect
  if (new URLSearchParams(location.search).get('success') === '1') {
    toast('Abonnement mis à jour avec succès ! 🎉', 'ok');
    history.replaceState({}, '', '/dashboard/billing');
  }

  // ── Annulation abonnement ──────────────────────────────────────────────────
  const cancelModal = document.getElementById('cancel-modal');
  const cmClose = document.getElementById('cm-close');
  const cmKeep = document.getElementById('cm-keep');
  const cmConfirm = document.getElementById('cm-confirm');
  const cmLbl = document.getElementById('cm-lbl');
  const cmSpin = document.getElementById('cm-spin');

  document.getElementById('cancel-btn')?.addEventListener('click', () => {
    cancelModal?.classList.add('open');
  });

  cmClose?.addEventListener('click', () => cancelModal?.classList.remove('open'));
  cmKeep?.addEventListener('click', () => cancelModal?.classList.remove('open'));
  cancelModal?.addEventListener('click', e => {
    if (e.target === cancelModal) cancelModal?.classList.remove('open');
  });

  cmConfirm?.addEventListener('click', async () => {
    cmLbl.textContent = 'Annulation…';
    cmSpin?.classList.remove('hidden');
    cmConfirm.disabled = true;

    try {
      const res = await fetch('/api/billing/cancelSubscription', { method: 'POST' });
      const json = await res.json();
      if (res.ok) {
        cancelModal?.classList.remove('open');
        toast('Abonnement annulé (valable jusqu’à la fin de période)', 'ok');
        setTimeout(() => location.reload(), 2200);
      } else {
        toast(json.error || 'Erreur lors de l’annulation', 'err');
      }
    } catch {
      toast('Erreur réseau', 'err');
    }

    cmLbl.textContent = 'Confirmer l’annulation';
    cmSpin?.classList.add('hidden');
    cmConfirm.disabled = false;
  });

  // Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      closeModal();
      cancelModal?.classList.remove('open');
    }
  });
})();
</script>

<style>
  .pc-btn:disabled {
    opacity: 0.5;
    cursor: wait;
  }
</style>
</DashboardLayout>
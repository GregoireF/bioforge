  document.getElementById('import-file')?.addEventListener('change', (e: any) => {
    if (!isCreator) { toast.error('Import disponible dès Creator'); return; }
    const file = e.target.files?.[0];
    if (!file||file.size>50000) { toast.error('Fichier invalide'); return; }
    const reader = new FileReader();
    reader.onload = (ev: any) => {
      try {
        const raw  = JSON.parse(ev.target.result);
        const safe: any = {};
        if (/^#[0-9A-Fa-f]{6}$/.test(raw.background_color)) safe.background_color = raw.background_color;
        if (/^#[0-9A-Fa-f]{6}$/.test(raw.primary_color))    safe.primary_color    = raw.primary_color;
        if (/^#[0-9A-Fa-f]{6}$/.test(raw.text_color))       safe.text_color       = raw.text_color;
        if (ALLOWED_FONTS.includes(raw.font_family))         safe.font_family      = raw.font_family;
        const numFields = ['border_radius','gradient_angle','pattern_opacity','glass_intensity','shadow_intensity','hover_scale'];
        numFields.forEach(k => { if (typeof raw[k]==='number') safe[k]=raw[k]; });
        const boolFields = ['block_shadow','animations','scroll_reveal','click_ripple','show_username','overlay_top','overlay_bottom'];
        boolFields.forEach(k => { if (typeof raw[k]==='boolean') safe[k]=raw[k]; });
        const strFields = ['preset','background_style','gradient_type','button_style','animation_preset','avatar_shape','avatar_size','avatar_border','spacing','profile_layout','header_style','hero_height','hero_position','content_width','button_width','hover_effect','social_icon_style','bio_size','bio_style','pattern'];
        strFields.forEach(k => { if (typeof raw[k]==='string') safe[k]=raw[k]; });
        applyFullTheme(safe);
        toast.success('Thème importé !');
      } catch { toast.error('Fichier JSON invalide'); }
    };
    reader.readAsText(file);
    e.target.value='';

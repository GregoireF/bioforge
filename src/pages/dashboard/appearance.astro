---
// src/pages/dashboard/appearance.astro — v2
// Phone mockup · AI theme generator · Background patterns · 6 button styles · Section nav

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import { withAuth } from '@/lib/auth/auth';

const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}
const { user, profile } = authResult.data;

// ==================== THEME DEFAULTS ====================
const DEFAULT_THEME = {
  // Core colors
  preset: 'dark' as const,
  background_color: '#0a0a0a',
  gradient_color_2: '#1a1a2e',
  primary_color: '#00ff9d',
  text_color: '#ffffff',
  // Background
  background_style: 'solid' as const,
  gradient_type: 'linear' as const,
  gradient_angle: 135,
  pattern: 'none' as const,
  pattern_opacity: 15,
  // Layout
  profile_layout: 'centered',
  header_style: 'simple',
  hero_image: '',
  hero_position: 'center',
  hero_height: 40,
  content_width: 'normal',
  // Avatar
  avatar_shape:     'circle',
  avatar_size:      'md',         // sm | md | lg
  avatar_border:    'glow',       // none | solid | glow | gradient | double
  // Bio
  bio_size:         'sm',         // xs | sm | md | lg
  bio_style:        'normal',     // normal | italic
  show_username:    true,
  // Buttons
  button_style:     'filled',
  border_radius:    14,
  shadow_intensity: 3,            // 0-5
  hover_effect:     'lift',       // none | lift | glow | slide | ripple
  button_width:     'full',       // full | auto
  // Typography
  font_family:      'Exo 2',
  // Effects
  animations:       true,
  animation_preset: 'fade',
  scroll_reveal:    true,
  click_ripple:     false,
  hover_scale:      3,            // 0-5
  block_shadow:     true,
  glass_intensity:  12,
  spacing:          'normal',
  // Overlays
  overlay_top:      false,
  overlay_bottom:   false,
  overlay_color:    '#000000',
  // Links appearance
  link_separator:   'none',      // none | line | dots | gradient | glow
  link_icon_pos:    'left',      // left | right | none
  link_subtitle:    false,       // show subtitle under link text
  link_hover_fill:  false,       // fill bg on hover
  // Logo
  show_logo:        false,
  logo_url:         '',
  logo_size:        'md',         // sm | md | lg (lg = Pro)
  // Wallpaper
  wallpaper_type:   'none',       // none | image | video
  wallpaper_url:    '',
  wallpaper_video_url: '',
  wallpaper_blur:   0,            // 0-20
  wallpaper_dim:    50,           // 0-90 opacity of dim overlay
  // Custom font
  custom_font_url:  '',
  custom_font_name: '',
} satisfies Record<string, any>;

type Theme = typeof DEFAULT_THEME;

function sanitizeHex(v: string, fb: string) { return /^#[0-9A-Fa-f]{6}$/.test(v) ? v : fb; }

function clamp(n: unknown, min: number, max: number, fb: number) {
  const v = Number(n); return Number.isFinite(v) ? Math.min(Math.max(v, min), max) : fb;
}

function sanitizeEnum<T extends string>(v: unknown, allowed: readonly T[], fb: T): T {
  return allowed.includes(v as T) ? v as T : fb;
}

const ALLOWED_FONTS = [
  // Gratuites — toutes
  'Exo 2','Orbitron','Rajdhani','Bebas Neue','Audiowide','Russo One',
  'Space Grotesk','DM Sans','Quicksand','Figtree','Inter','Syne',
  'Cabinet Grotesk','Outfit','Plus Jakarta Sans','Nunito','Poppins',
  'Josefin Sans','Archivo','Barlow','Rubik','Work Sans','Manrope',
  'Space Mono','JetBrains Mono','Fira Code',
  // Serif
  'Playfair Display','Lora','Merriweather','DM Serif Display',
  // Display
  'Bungee','Righteous','Teko','Oswald','Anton',
];

const ALLOWED_LAYOUTS = ['centered','left','card','minimal'] as const;
const ALLOWED_HEADERS = ['simple','glass','banner','hero'] as const;

function sanitizeFont(v: string, fb: string) { return ALLOWED_FONTS.includes(v) ? v : fb; }

let theme = { ...DEFAULT_THEME };
if (profile.theme) {
  try {
    const raw = typeof profile.theme === 'string' ? JSON.parse(profile.theme) : profile.theme;
    theme = {
      ...DEFAULT_THEME, ...raw,
      background_color:  sanitizeHex(raw.background_color,  DEFAULT_THEME.background_color),
      gradient_color_2:  sanitizeHex(raw.gradient_color_2,  DEFAULT_THEME.gradient_color_2),
      primary_color:     sanitizeHex(raw.primary_color,     DEFAULT_THEME.primary_color),
      text_color:        sanitizeHex(raw.text_color,        DEFAULT_THEME.text_color),
      overlay_color:     sanitizeHex(raw.overlay_color,     DEFAULT_THEME.overlay_color),
      font_family:       sanitizeFont(raw.font_family,      DEFAULT_THEME.font_family),
      border_radius:     Math.min(Math.max(parseInt(raw.border_radius) || 14, 0), 32),
      gradient_angle:    Math.min(Math.max(parseInt(raw.gradient_angle) || 135, 0), 360),
      pattern_opacity:   clamp(raw.pattern_opacity, 5, 60, 15),
      glass_intensity:   clamp(raw.glass_intensity, 4, 32, 12),
      hero_overlay:      clamp(raw.hero_overlay, 0, 80, 40),
      shadow_intensity:  clamp(raw.shadow_intensity, 0, 5 , 3),
      hover_scale:       clamp(raw.hover_scale, 0, 5, 3),
      profile_layout:    sanitizeEnum(raw.profile_layout, ALLOWED_LAYOUTS, 'centered'),
      header_style:      sanitizeEnum(raw.header_style, ALLOWED_HEADERS, 'simple'),
      background_style:  sanitizeEnum(raw.background_style, ['solid','gradient','blur'] as const, 'solid'),
      gradient_type:     sanitizeEnum(raw.gradient_type,    ['linear','radial'] as const, 'linear'),
      button_style:      sanitizeEnum(raw.button_style,     ['filled','outline','glass','gradient','neon','minimal'] as const, 'filled'),
      animation_preset:  sanitizeEnum(raw.animation_preset, ['none','fade','slide','bounce','stagger'] as const, 'fade'),
      avatar_shape:      sanitizeEnum(raw.avatar_shape,     ['circle','square','hex','ring'] as const, 'circle'),
      avatar_size:       sanitizeEnum(raw.avatar_size,      ['sm','md','lg'] as const, 'md'),
      avatar_border:     sanitizeEnum(raw.avatar_border,    ['none','solid','glow','gradient','double'] as const, 'glow'),
      social_icon_style: sanitizeEnum(raw.social_icon_style,['round','square','pill','ghost','colored'] as const, 'round'),
      hover_effect:      sanitizeEnum(raw.hover_effect,     ['none','lift','glow','slide','ripple'] as const, 'lift'),
      button_width:      sanitizeEnum(raw.button_width,     ['full','auto'] as const, 'full'),
      spacing:           sanitizeEnum(raw.spacing,          ['compact','normal','spacious'] as const, 'normal'),
      pattern:           sanitizeEnum(raw.pattern,          ['none','dots','grid','waves','noise','mesh','crosshatch','triangles'] as const, 'none'),
      hero_height:       sanitizeEnum(raw.hero_height,      ['sm','md','lg','full'] as const, 'md'),
      hero_position:     sanitizeEnum(raw.hero_position,    ['top','center','bottom'] as const, 'center'),
      content_width:     sanitizeEnum(raw.content_width,    ['narrow','normal','wide'] as const, 'normal'),
      bio_size:          sanitizeEnum(raw.bio_size,         ['xs','sm','md','lg'] as const, 'sm'),
      bio_style:         sanitizeEnum(raw.bio_style,        ['normal','italic'] as const, 'normal'),
    };
  } catch { /* keep defaults */ }
}

const themeJson   = JSON.stringify(theme);
const profileJson = JSON.stringify({
  display_name: profile.display_name ?? '',
  username:     profile.username ?? '',
  bio:          profile.bio ?? '',
  avatar_url:   profile.avatar_url ?? '',
});
---

<DashboardLayout title="Appearance">

<style>
  /* ── Section nav ── */
  .sec-tab { transition: all 0.2s; }
  .sec-tab.active { color: white; background: rgba(0,255,157,0.1); border-color: rgba(0,255,157,0.3); }
  .sec-panel { display: none; }
  .sec-panel.active { display: block; }

  /* ── Active states ── */
  .preset-btn.active    { outline: 2px solid rgba(0,255,157,0.7); outline-offset: 2px; }
  .btn-style-btn.active { border-color: rgba(0,255,157,0.7) !important; background: rgba(0,255,157,0.06); }
  .font-btn.active      { border-color: rgba(0,255,157,0.7) !important; color: #00ff9d; }
  .pattern-btn.active   { border-color: rgba(0,255,157,0.7) !important; }
  .anim-btn.active      { border-color: rgba(0,255,157,0.7) !important; color: #00ff9d; }
  .shape-btn.active     { border-color: rgba(0,255,157,0.7) !important; }
  .spacing-btn.active   { border-color: rgba(0,255,157,0.7) !important; color: white; }
  .bg-tab.active        { border-color: rgba(0,255,157,0.7) !important; color: white; }
  .grad-type-btn.active { border-color: rgba(0,255,157,0.7) !important; color: white; }

  /* ── Color swatch ── */
  input[type="color"].swatch { -webkit-appearance: none; appearance: none; }
  input[type="color"].swatch::-webkit-color-swatch-wrapper { padding: 2px; }
  input[type="color"].swatch::-webkit-color-swatch { border: none; border-radius: 8px; }

  /* ── Toggle ── */
  input[type="checkbox"].toggle { transition: background-color 0.2s; }
  input[type="checkbox"].toggle::after {
    content: ''; position: absolute; width: 18px; height: 18px;
    border-radius: 50%; background: white; top: 3px; left: 3px; transition: left 0.2s;
  }
  input[type="checkbox"].toggle:checked { background-color: rgba(0,255,157,0.8); }
  input[type="checkbox"].toggle:checked::after { left: calc(100% - 21px); }

  /* ── Phone mockup ── */
  .phone-frame {
    position: relative;
    width: 260px;
    background: #111;
    border-radius: 42px;
    padding: 14px 10px;
    box-shadow: 0 0 0 2px #2a2a2a, 0 0 0 4px #1a1a1a, 0 32px 80px rgba(0,0,0,0.8), 0 0 60px rgba(0,255,157,0.04);
    margin: 0 auto;
    flex-shrink: 0;
  }
  .phone-notch {
    position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
    width: 90px; height: 26px;
    background: #111; border-radius: 0 0 16px 16px;
    z-index: 10;
    display: flex; align-items: center; justify-content: center; gap: 6px;
  }
  .phone-notch::before { /* camera */ content: ''; width: 8px; height: 8px; border-radius: 50%; background: #1e1e1e; border: 1px solid #2a2a2a; }
  .phone-notch::after  { /* speaker */ content: ''; width: 36px; height: 4px; border-radius: 2px; background: #1a1a1a; }
  .phone-screen {
    border-radius: 32px;
    overflow: hidden;
    height: 500px;
    background: #0a0a0a;
    position: relative;
  }
  .phone-screen iframe { width: 100%; height: 100%; border: 0; }
  .phone-btn-side {
    position: absolute;
    width: 3px; height: 36px; background: #222; border-radius: 2px;
  }
  .phone-btn-vol-1 { right: -5px; top: 90px; }
  .phone-btn-vol-2 { right: -5px; top: 136px; }
  .phone-btn-power { left: -5px; top: 120px; height: 48px; }

  /* ── Preview device tabs ── */
  .device-tab.active svg { color: #00ff9d; }

  /* ── AI typing indicator ── */
  @keyframes blink { 0%,100%{opacity:0.2} 50%{opacity:1} }
  .ai-dot { animation: blink 1.2s infinite; }
  .ai-dot:nth-child(2) { animation-delay: 0.2s; }
  .ai-dot:nth-child(3) { animation-delay: 0.4s; }

  /* ── Palette swatch row ── */
  .palette-swatch { transition: transform 0.15s; cursor: pointer; }
  .palette-swatch:hover { transform: scale(1.1); }

  /* ── Save loading ── */
  #save-btn.loading { opacity: 0.6; pointer-events: none; }

  /* ── Section progress dots ── */
  .prog-dot { transition: all 0.2s; }
  .prog-dot.active { background: #00ff9d; width: 20px; border-radius: 4px; }

  @keyframes fadeInUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
  .sec-panel.active { animation: fadeInUp 0.25s ease both; }
</style>

  <!-- ===== HEADER ===== -->
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-xl font-semibold text-white tracking-tight mb-1">Appearance</h2>
      <p class="text-sm text-gray-500">Personnalise ton profil BioForge</p>
    </div>
    <div class="flex items-center gap-2">
      <label class="flex items-center gap-2 px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-400 hover:text-white hover:border-white/20 transition-all cursor-pointer">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Import
        <input type="file" id="import-file" accept=".json" class="hidden" />
      </label>
      <button id="export-btn" class="flex items-center gap-2 px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-400 hover:text-white hover:border-white/20 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Export
      </button>
      <a href={`/${profile.username}`} target="_blank" class="flex items-center gap-2 px-3 py-2 glass border border-neon-green/20 rounded-xl text-xs text-neon-green hover:bg-neon-green/10 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Voir profil
      </a>
    </div>
  </div>

  <!-- Data bridge -->
  <div id="server-data" class="hidden" data-theme={themeJson} data-profile={profileJson}></div>

  <!-- ===== MAIN LAYOUT ===== -->
  <div class="grid lg:grid-cols-5 gap-6 items-start">

    <!-- ===== LEFT: SECTION TABS + SETTINGS (3/5) ===== -->
    <div class="lg:col-span-3 space-y-4">

      <!-- Section navigation -->
      <div class="flex items-center gap-1.5 flex-wrap">
        {[
          { id: 'presets',    label: '🎨 Presets' },
          { id: 'background', label: '🖼 Fond' },
          { id: 'buttons',    label: '🔘 Boutons' },
          { id: 'typography', label: '✍ Typo' },
          { id: 'profile',    label: '👤 Profil' },
          { id: 'effects',    label: '✨ Effets' },
          { id: 'ai',         label: '✦ IA' },
        ].map((sec, i) => (
          <button
            class={`sec-tab flex items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold border border-white/8 text-gray-500 hover:text-gray-300 hover:border-white/15 ${i === 0 ? 'active' : ''} ${sec.id === 'ai' ? 'text-neon-green/70 border-neon-green/20 hover:border-neon-green/40 hover:text-neon-green' : ''}`}
            data-section={sec.id}>
            {sec.label}
          </button>
        ))}
      </div>

      <!-- ── PANEL: PRESETS ── -->
      <div class="sec-panel active" id="panel-presets">
        <div class="p-5 glass rounded-2xl border border-white/8 space-y-5">
          <div>
            <p class="text-sm font-semibold text-white mb-1">Thèmes prédéfinis</p>
            <p class="text-xs text-gray-500">Point de départ — modifiable après</p>
          </div>
          <div class="grid grid-cols-3 sm:grid-cols-6 gap-2.5">
            {[
              { id:'dark',    label:'Dark',     bg:'#0a0a0a', p:'#00ff9d', t:'#fff', g1:'#0a0a0a', g2:'#0f1f15', thumb:'from-[#0a0a0a] to-[#0f1f15]' },
              { id:'neon',    label:'Neon',     bg:'#1a0033', p:'#bf00ff', t:'#fff', g1:'#1a0033', g2:'#0d001a', thumb:'from-[#1a0033] to-[#0d001a]' },
              { id:'ocean',   label:'Ocean',    bg:'#001a33', p:'#00d4ff', t:'#fff', g1:'#001a33', g2:'#002244', thumb:'from-[#001a33] to-[#002244]' },
              { id:'sunset',  label:'Sunset',   bg:'#1a0800', p:'#ff6b00', t:'#fff', g1:'#1a0800', g2:'#2d0a00', thumb:'from-[#1a0800] to-[#2d0a00]' },
              { id:'light',   label:'Light',    bg:'#f8f8f8', p:'#0066ff', t:'#0a0a0a', g1:'#f8f8f8', g2:'#e8f0ff', thumb:'from-white to-[#e8f0ff]' },
              { id:'forest',  label:'Forest',   bg:'#0d1f0d', p:'#00cc66', t:'#fff', g1:'#0d1f0d', g2:'#0a1a0a', thumb:'from-[#0d1f0d] to-[#0a1a0a]' },
              { id:'rose',    label:'Rose',     bg:'#1a0a0f', p:'#ff2d78', t:'#fff', g1:'#1a0a0f', g2:'#0d0508', thumb:'from-[#1a0a0f] to-[#0d0508]' },
              { id:'gold',    label:'Gold',     bg:'#120d00', p:'#ffd700', t:'#fff', g1:'#120d00', g2:'#1f1500', thumb:'from-[#120d00] to-[#1f1500]' },
              { id:'cyber',   label:'Cyber',    bg:'#000d1a', p:'#00ffff', t:'#fff', g1:'#000d1a', g2:'#001433', thumb:'from-[#000d1a] to-[#001433]' },
              { id:'obsidian',label:'Obsidian', bg:'#0d0d0d', p:'#6366f1', t:'#fff', g1:'#0d0d0d', g2:'#13111a', thumb:'from-[#0d0d0d] to-[#13111a]' },
              { id:'aurora',  label:'Aurora',   bg:'#04080f', p:'#00ff9d', t:'#fff', g1:'#04080f', g2:'#0a1628', thumb:'from-[#04080f] to-[#0a1628]' },
              { id:'sand',    label:'Sand',     bg:'#1a1510', p:'#e8a84c', t:'#f5e6d0', g1:'#1a1510', g2:'#120f08', thumb:'from-[#1a1510] to-[#120f08]' },
            ].map(p => (
              <button
                class="preset-btn group flex flex-col rounded-xl overflow-hidden border-2 border-white/8 hover:border-white/20 transition-all hover:scale-[1.03] active:scale-[0.97]"
                data-preset={p.id} data-bg={p.bg} data-primary={p.p} data-text={p.t}
                data-g1={p.g1} data-g2={p.g2} title={p.label}>
                <div class={`h-12 bg-gradient-to-br ${p.thumb} flex items-end justify-end p-1.5`}>
                  <div class="w-5 h-2 rounded-full" style={`background:${p.p};opacity:0.9`}></div>
                </div>
                <div class="py-1.5 text-center bg-white/3">
                  <span class="text-xs text-gray-400 font-medium">{p.label}</span>
                </div>
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- ── PANEL: BACKGROUND ── -->
      <div class="sec-panel" id="panel-background">
        <div class="p-5 glass rounded-2xl border border-white/8 space-y-6">
          <p class="text-sm font-semibold text-white">Arrière-plan</p>

          <!-- Colors -->
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-widest font-medium mb-3">Couleurs</p>
            <div class="grid grid-cols-3 gap-4">
              {[
                { id:'background_color', label:'Fond',    key:'background_color' },
                { id:'primary_color',    label:'Primaire', key:'primary_color' },
                { id:'text_color',       label:'Texte',   key:'text_color' },
              ].map(c => (
                <div class="space-y-2">
                  <label class="text-xs text-gray-400 font-medium">{c.label}</label>
                  <div class="flex items-center gap-2">
                    <input type="color" id={c.id} value={(theme as any)[c.key]}
                      class="swatch w-10 h-10 rounded-xl cursor-pointer border border-white/10 p-0.5 shrink-0" />
                    <input type="text" id={`${c.id}_text`} value={(theme as any)[c.key]}
                      maxlength="7" placeholder="#000000"
                      class="w-full px-2 py-2 glass border border-white/10 rounded-lg text-white text-xs font-mono focus:border-neon-green/40 focus:outline-none" />
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Auto palette generator -->
          <div class="p-3.5 rounded-xl bg-white/3 border border-white/8 space-y-3">
            <div class="flex items-center justify-between">
              <p class="text-xs text-gray-400 font-semibold flex items-center gap-1.5">
                <span>🎨</span> Palettes harmonieuses
              </p>
              <button id="gen-palette-btn"
                class="text-xs text-neon-green hover:text-neon-green/70 transition flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Générer depuis l'accent
              </button>
            </div>
            <div id="palette-suggestions" class="flex gap-2 flex-wrap">
              <span class="text-xs text-gray-700">Clique sur "Générer" pour voir des combinaisons</span>
            </div>
          </div>

          <!-- BG Style -->
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-widest font-medium mb-3">Style</p>
            <div class="flex gap-2 mb-4">
              {['solid','gradient','blur'].map(s => (
                <button class="bg-tab flex-1 py-2 rounded-xl text-xs font-semibold border-2 border-white/10 text-gray-400 hover:text-white transition-all"
                  data-style={s}>
                  {{ solid:'Solide', gradient:'Dégradé', blur:'Blur' }[s]}
                </button>
              ))}
            </div>

            <!-- Gradient builder -->
            <div id="gradient-builder" class="hidden space-y-4 p-4 bg-white/3 rounded-xl border border-white/8">
              <div class="grid grid-cols-2 gap-3">
                {['gradient_color_1','gradient_color_2'].map((cid, i) => (
                  <div class="space-y-1.5">
                    <label class="text-xs text-gray-500">Couleur {i + 1}</label>
                    <div class="flex gap-2">
                      <input type="color" id={cid}
                        value={i === 0 ? theme.background_color : theme.gradient_color_2}
                        class="swatch w-10 h-10 rounded-lg cursor-pointer border border-white/10 p-0.5 shrink-0" />
                      <input type="text" id={`${cid}_text`}
                        value={i === 0 ? theme.background_color : theme.gradient_color_2}
                        maxlength="7"
                        class="w-full px-2 py-2 glass border border-white/10 rounded-lg text-white text-xs font-mono focus:border-neon-green/40 focus:outline-none" />
                    </div>
                  </div>
                ))}
              </div>

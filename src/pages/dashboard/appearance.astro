  // ── Palette auto-generator ────────────────────────────────────────────────────
  function hexToHsl(hex: string): [number,number,number] {
    const r = parseInt(hex.slice(1,3),16)/255;
    const g = parseInt(hex.slice(3,5),16)/255;
    const b = parseInt(hex.slice(5,7),16)/255;
    const max = Math.max(r,g,b), min = Math.min(r,g,b);
    let h = 0, s = 0, l = (max+min)/2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d/(2-max-min) : d/(max+min);
      switch(max) {
        case r: h = ((g-b)/d + (g<b?6:0))/6; break;
        case g: h = ((b-r)/d + 2)/6; break;
        case b: h = ((r-g)/d + 4)/6; break;
      }
    }
    return [Math.round(h*360), Math.round(s*100), Math.round(l*100)];
  }

  function hslToHex(h: number, s: number, l: number): string {
    h = ((h % 360) + 360) % 360;
    s = Math.min(100, Math.max(0, s));
    l = Math.min(100, Math.max(0, l));
    const hs = s/100, hl = l/100;
    const c = (1 - Math.abs(2*hl - 1)) * hs;
    const x = c * (1 - Math.abs((h/60)%2 - 1));
    const m = hl - c/2;
    let r=0,g=0,b=0;
    if(h<60){r=c;g=x}else if(h<120){r=x;g=c}else if(h<180){g=c;b=x}
    else if(h<240){g=x;b=c}else if(h<300){r=x;b=c}else{r=c;b=x}
    const toH = (v: number) => Math.round((v+m)*255).toString(16).padStart(2,'0');
    return `#${toH(r)}${toH(g)}${toH(b)}`;
  }

  function generatePalettes() {
    const primary = theme.primary_color ?? '#00ff9d';
    const [h, s, l] = hexToHsl(primary);

    const palettes = [
      { label:'Actuel',      bg: theme.background_color,  p: primary,             t: theme.text_color },
      { label:'Complémentaire', bg: hslToHex(h+180, 20, 8), p: primary,           t: '#ffffff' },
      { label:'Analogique',  bg: hslToHex(h+30, 20, 7),   p: hslToHex(h-30, s, l), t: '#ffffff' },
      { label:'Monochrome',  bg: hslToHex(h, 15, 6),      p: hslToHex(h, s, Math.min(l+20,85)), t: '#ffffff' },
      { label:'Pastel',      bg: hslToHex(h, 10, 95),     p: hslToHex(h, s, Math.max(l-10,20)), t: '#1a1a1a' },
      { label:'Sombre+',     bg: hslToHex(h, 25, 5),      p: hslToHex(h, s+10, Math.min(l+10,80)), t: '#ffffff' },
    ];

    const container = document.getElementById('palette-suggestions');
    if (!container) return;

    container.innerHTML = palettes.map(pal => `
      <button class="palette-swatch-btn group relative flex flex-col rounded-xl overflow-hidden border-2 border-white/8 hover:border-white/30 hover:scale-[1.06] transition-all"
        style="width:52px"
        data-bg="${pal.bg}" data-primary="${pal.p}" data-text="${pal.t}" title="${pal.label}">
        <div style="height:28px;background:${pal.bg};position:relative">
          <div style="position:absolute;bottom:4px;right:4px;width:10px;height:10px;border-radius:50%;background:${pal.p}"></div>
        </div>
        <div style="padding:3px 2px;text-align:center;background:rgba(255,255,255,0.04)">
          <span style="font-size:8px;color:#6b7280">${pal.label}</span>
        </div>
      </button>`).join('');

    container.querySelectorAll('.palette-swatch-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const { bg, primary, text } = (btn as HTMLElement).dataset;
        theme = { ...theme, background_color: bg!, primary_color: primary!, text_color: text! };
        syncColor('background_color', bg!);
        syncColor('gradient_color_1', bg!);
        syncColor('primary_color', primary!);
        syncColor('text_color', text!);
        schedulePreview();
      });
    });
  }

  document.getElementById('gen-palette-btn')?.addEventListener('click', generatePalettes);


---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import { withAuth } from '@/lib/auth/auth';

// ==================== AUTH CHECK ====================

const authResult = await withAuth({
  cookies: Astro.cookies,
  request: Astro.request,
});

if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}

const { user, profile } = authResult.data;

// ==================== THEME DEFAULTS & PARSE ====================

const DEFAULT_THEME = {
  preset: 'dark',
  background_color: '#0a0a0a',
  primary_color: '#00ff9d',
  text_color: '#ffffff',
  button_style: 'filled',
  border_radius: 12,
  font_family: 'Inter',
  background_style: 'solid',
  gradient_color_2: '#1a1a2e',
  gradient_angle: 135,
  gradient_type: 'linear',
  block_shadow: true,
  animations: true,
};

// Sanitize hex color server-side
function sanitizeHex(value: string, fallback: string): string {
  return /^#[0-9A-Fa-f]{6}$/.test(value) ? value : fallback;
}

// Sanitize font name server-side (allowlist)
const ALLOWED_FONTS = ['Inter', 'Poppins', 'Roboto', 'Montserrat', 'Open Sans', 'Lato', 'Space Grotesk', 'DM Sans', 'Geist', 'Figtree'];
function sanitizeFont(value: string, fallback: string): string {
  return ALLOWED_FONTS.includes(value) ? value : fallback;
}

let theme = { ...DEFAULT_THEME };

if (profile.theme) {
  try {
    const raw = typeof profile.theme === 'string' ? JSON.parse(profile.theme) : profile.theme;
    theme = {
      ...DEFAULT_THEME,
      ...raw,
      background_color: sanitizeHex(raw.background_color, DEFAULT_THEME.background_color),
      primary_color: sanitizeHex(raw.primary_color, DEFAULT_THEME.primary_color),
      text_color: sanitizeHex(raw.text_color, DEFAULT_THEME.text_color),
      gradient_color_2: sanitizeHex(raw.gradient_color_2, DEFAULT_THEME.gradient_color_2),
      font_family: sanitizeFont(raw.font_family, DEFAULT_THEME.font_family),
      border_radius: Math.min(Math.max(parseInt(raw.border_radius) || 12, 0), 32),
      gradient_angle: Math.min(Math.max(parseInt(raw.gradient_angle) || 135, 0), 360),
    };
  } catch {
    // keep defaults
  }
}

const themeJson = JSON.stringify(theme);
const profileJson = JSON.stringify({
  display_name: profile.display_name ?? '',
  username: profile.username ?? '',
  bio: profile.bio ?? '',
});
---

<DashboardLayout title="Appearance">

  <!-- ===== HEADER ===== -->
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h2 class="text-xl font-semibold text-white mb-1 tracking-tight">Appearance</h2>
      <p class="text-sm text-gray-400">Customize your profile theme and style</p>
    </div>
    <div class="flex items-center gap-3">
      <!-- Import JSON -->
      <label
        id="import-label"
        class="group cursor-pointer flex items-center gap-2 px-4 py-2 glass border border-white/10 rounded-xl text-sm text-gray-300 hover:text-white hover:border-white/25 transition-all"
        title="Import theme from JSON"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        Import
        <input type="file" id="import-file" accept=".json" class="hidden" />
      </label>
      <!-- Export JSON -->
      <button
        id="export-btn"
        class="flex items-center gap-2 px-4 py-2 glass border border-white/10 rounded-xl text-sm text-gray-300 hover:text-white hover:border-white/25 transition-all"
        title="Export theme as JSON"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Export
      </button>
    </div>
  </div>

  <!-- ===== MAIN GRID ===== -->
  <div class="grid lg:grid-cols-3 gap-6 lg:gap-8 items-start">

    <!-- ========== LEFT: SETTINGS ========== -->
    <div class="lg:col-span-2 space-y-5">

      <!-- QUICK PRESETS -->
      <Card title="Presets" description="Choose a starting point">
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
          {[
            { id: 'dark',    label: 'Dark',    bg: '#0a0a0a', primary: '#00ff9d', text: '#ffffff', thumb: 'from-gray-900 to-black',          border: 'border-emerald-400/40' },
            { id: 'light',   label: 'Light',   bg: '#f8f8f8', primary: '#0066ff', text: '#0a0a0a', thumb: 'from-white to-gray-200',           border: 'border-blue-400/40'    },
            { id: 'neon',    label: 'Neon',    bg: '#1a0033', primary: '#bf00ff', text: '#ffffff', thumb: 'from-purple-900 to-pink-900',      border: 'border-purple-400/40'  },
            { id: 'ocean',   label: 'Ocean',   bg: '#001a33', primary: '#00d4ff', text: '#ffffff', thumb: 'from-blue-900 to-cyan-900',        border: 'border-cyan-400/40'    },
            { id: 'sunset',  label: 'Sunset',  bg: '#1a0800', primary: '#ff6b00', text: '#ffffff', thumb: 'from-orange-900 to-red-900',       border: 'border-orange-400/40'  },
            { id: 'forest',  label: 'Forest',  bg: '#0d1f0d', primary: '#00cc66', text: '#ffffff', thumb: 'from-green-900 to-emerald-900',    border: 'border-green-400/40'   },
          ].map(p => (
            <button
              class="preset-btn group relative p-0 rounded-xl border-2 border-white/10 overflow-hidden hover:scale-[1.03] active:scale-[0.97] transition-all duration-200"
              data-preset={p.id}
              data-bg={p.bg}
              data-primary={p.primary}
              data-text={p.text}
              title={p.label}
            >
              <div class={`w-full h-14 bg-gradient-to-br ${p.thumb}`}></div>
              <div class="py-2 text-center bg-white/5">
                <span class="text-xs text-gray-300 font-medium">{p.label}</span>
              </div>
              <!-- active ring -->
              <div class={`preset-ring absolute inset-0 border-2 ${p.border} rounded-xl opacity-0 transition-opacity`}></div>
            </button>
          ))}
        </div>
      </Card>

      <!-- COLORS -->
      <Card title="Colors" description="Fine-tune your palette">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {[
            { id: 'background_color', label: 'Background', icon: '⬛' },
            { id: 'primary_color',    label: 'Primary',    icon: '🎨' },
            { id: 'text_color',       label: 'Text',        icon: '📝' },
          ].map(c => (
            <div class="space-y-2">
              <label class="text-sm font-medium text-gray-300">{c.label}</label>
              <div class="flex items-center gap-2">
                <div class="relative">
                  <input
                    type="color"
                    id={c.id}
                    value={(theme as any)[c.id]}
                    class="color-swatch w-11 h-11 rounded-xl cursor-pointer border border-white/10 bg-transparent p-0.5"
                  />
                </div>
                <input
                  type="text"
                  id={`${c.id}_text`}
                  value={(theme as any)[c.id]}
                  maxlength="7"
                  class="flex-1 px-3 py-2 glass border border-white/10 rounded-xl text-white text-sm font-mono tracking-wide focus:border-neon-green/50 focus:outline-none transition-colors"
                  placeholder="#000000"
                />
              </div>
            </div>
          ))}
        </div>
      </Card>

      <!-- BACKGROUND STYLE + GRADIENT BUILDER -->
      <Card title="Background Style" description="Solid color, gradient, or blur">
        <div class="space-y-5">
          <!-- Style selector tabs -->
          <div class="flex gap-2">
            {['solid', 'gradient', 'blur'].map(s => (
              <button
                class="bg-style-tab flex-1 py-2 rounded-xl text-sm font-medium border-2 border-white/10 text-gray-400 hover:text-white transition-all"
                data-style={s}
              >
                {{ solid: 'Solid', gradient: 'Gradient', blur: 'Blur' }[s]}
              </button>
            ))}
          </div>

          <!-- Gradient builder (shown when gradient selected) -->
          <div id="gradient-builder" class="hidden space-y-4 p-4 glass rounded-xl border border-white/10">
            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-2">
                <label class="text-xs text-gray-400 font-medium">Color 1</label>
                <div class="flex gap-2">
                  <input type="color" id="gradient_color_1" value={theme.background_color} class="color-swatch w-11 h-11 rounded-xl cursor-pointer border border-white/10 p-0.5" />
                  <input type="text" id="gradient_color_1_text" value={theme.background_color} maxlength="7" class="flex-1 px-3 py-2 glass border border-white/10 rounded-xl text-white text-sm font-mono focus:border-neon-green/50 focus:outline-none transition-colors" />
                </div>
              </div>
              <div class="space-y-2">
                <label class="text-xs text-gray-400 font-medium">Color 2</label>
                <div class="flex gap-2">
                  <input type="color" id="gradient_color_2" value={theme.gradient_color_2} class="color-swatch w-11 h-11 rounded-xl cursor-pointer border border-white/10 p-0.5" />
                  <input type="text" id="gradient_color_2_text" value={theme.gradient_color_2} maxlength="7" class="flex-1 px-3 py-2 glass border border-white/10 rounded-xl text-white text-sm font-mono focus:border-neon-green/50 focus:outline-none transition-colors" />
                </div>
              </div>
            </div>

            <!-- Gradient type -->
            <div class="flex gap-2">
              {['linear', 'radial'].map(t => (
                <button
                  class="gradient-type-btn flex-1 py-2 rounded-xl text-sm font-medium border-2 border-white/10 text-gray-400 hover:text-white transition-all"
                  data-type={t}
                >
                  {{ linear: '⟶ Linear', radial: '◎ Radial' }[t]}
                </button>
              ))}
            </div>

            <!-- Angle (linear only) -->
            <div id="angle-wrap" class="space-y-2">
              <div class="flex justify-between items-center">
                <label class="text-xs text-gray-400 font-medium">Angle</label>
                <span id="gradient-angle-value" class="text-xs font-mono text-white">{theme.gradient_angle}°</span>
              </div>
              <input type="range" id="gradient_angle" min="0" max="360" value={theme.gradient_angle} class="w-full accent-neon-green" />
              <!-- Angle presets -->
              <div class="flex gap-2 flex-wrap">
                {[0, 45, 90, 135, 180, 225, 270, 315].map(a => (
                  <button
                    class="angle-preset-btn text-xs px-2 py-1 glass rounded-lg border border-white/10 text-gray-400 hover:text-white hover:border-neon-green/40 transition-all"
                    data-angle={a}
                  >
                    {a}°
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- Blur info -->
          <div id="blur-info" class="hidden p-4 glass rounded-xl border border-white/10">
            <p class="text-sm text-gray-400">Blur effect adds a frosted glass overlay on top of your background color.</p>
          </div>
        </div>
      </Card>

      <!-- BUTTON STYLE -->
      <Card title="Button Style" description="How links look on your profile">
        <div class="grid grid-cols-3 gap-3">
          {[
            { id: 'filled',  label: 'Filled',  preview: 'bg-neon-green' },
            { id: 'outline', label: 'Outline', preview: 'border-2 border-neon-green' },
            { id: 'shadow',  label: 'Glow',    preview: 'bg-neon-green shadow-neon' },
          ].map(s => (
            <button
              class="button-style-btn p-3 glass border-2 border-white/10 rounded-xl hover:border-neon-green/40 transition-all group"
              data-style={s.id}
            >
              <div class={`w-full h-10 rounded-lg mb-3 ${s.preview} group-hover:scale-[1.02] transition-transform`}
                   style={s.id === 'shadow' ? 'box-shadow: 0 0 20px rgba(0,255,157,0.5)' : ''}
              ></div>
              <p class="text-sm text-center text-gray-300 font-medium">{s.label}</p>
            </button>
          ))}
        </div>
      </Card>

      <!-- BORDER RADIUS -->
      <Card title="Border Radius" description="Corner roundness">
        <div class="space-y-4">
          <!-- Quick picks -->
          <div class="flex gap-2">
            {[0, 6, 12, 18, 24, 32].map(r => (
              <button
                class="radius-preset-btn flex-1 py-2 glass rounded-xl border-2 border-white/10 text-xs text-gray-400 hover:text-white hover:border-neon-green/40 transition-all font-medium"
                data-radius={r}
              >
                {r}px
              </button>
            ))}
          </div>
          <input type="range" id="border_radius" min="0" max="32" value={theme.border_radius} class="w-full accent-neon-green" />
          <div class="flex justify-between text-xs text-gray-500">
            <span>Sharp</span>
            <span id="radius-value" class="text-white font-mono font-medium">{theme.border_radius}px</span>
            <span>Pill</span>
          </div>
        </div>
      </Card>

      <!-- TYPOGRAPHY -->
      <Card title="Typography" description="Choose your font">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {['Inter', 'Poppins', 'Roboto', 'Montserrat', 'Open Sans', 'Lato', 'Geist', 'Figtree'].map(font => (
            <button
              class="font-btn py-3 px-2 glass border-2 border-white/10 rounded-xl text-sm text-white hover:border-neon-green/40 transition-all truncate"
              data-font={font}
              style={`font-family: '${font}', sans-serif`}
            >
              {font}
            </button>
          ))}
        </div>
      </Card>

      <!-- ADVANCED -->
      <Card title="Advanced" description="Extra settings">
        <div class="space-y-3">
          {[
            { id: 'block_shadow', label: 'Block Shadows',    desc: 'Add depth to link blocks',    checked: theme.block_shadow  },
            { id: 'animations',   label: 'Hover Animations', desc: 'Subtle hover & click effects', checked: theme.animations    },
          ].map(opt => (
            <label class="flex items-center justify-between p-4 glass rounded-xl cursor-pointer hover:bg-white/5 transition-colors border border-white/5">
              <div>
                <div class="text-white font-medium text-sm">{opt.label}</div>
                <div class="text-xs text-gray-400">{opt.desc}</div>
              </div>
              <input
                type="checkbox"
                id={opt.id}
                checked={opt.checked}
                class="toggle w-11 h-6 rounded-full appearance-none bg-white/10 relative cursor-pointer transition-colors checked:bg-neon-green/80 focus:outline-none"
              />
            </label>
          ))}
        </div>
      </Card>

      <!-- ACTIONS -->
      <div class="flex items-center gap-3">
        <Button variant="primary" id="save-theme-btn" class="flex-1 relative overflow-hidden">
          <span id="save-btn-text" class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Save Theme
          </span>
        </Button>
        <Button variant="ghost" id="reset-theme-btn" title="Reset to default">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Reset
        </Button>
        <Button variant="secondary" href={`/${profile.username}`} target="_blank" title="Open live profile">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          Preview
        </Button>
      </div>

    </div>

    <!-- ========== RIGHT: PREVIEW + HISTORY ========== -->
    <div class="lg:col-span-1 space-y-5">

      <!-- LIVE PREVIEW (iframe) -->
      <div class="sticky top-6 space-y-5">
        <Card title="Live Preview" description="Real-time render" class="overflow-hidden">
          <div class="relative rounded-xl overflow-hidden" style="height: 520px;">
            <iframe
              id="preview-iframe"
              class="w-full h-full border-0 rounded-xl"
              sandbox="allow-same-origin"
              title="Theme preview"
            ></iframe>
            <!-- Mobile notch decoration -->
            <div class="pointer-events-none absolute top-0 inset-x-0 flex justify-center">
              <div class="w-20 h-1 bg-white/10 rounded-b-full"></div>
            </div>
          </div>
        </Card>

        <!-- THEME HISTORY -->
        <Card title="Recent Themes" description="Last 5 saved">
          <div id="history-list" class="space-y-2">
            <p class="text-xs text-gray-500 text-center py-3">No history yet</p>
          </div>
        </Card>
      </div>

    </div>
  </div>

</DashboardLayout>

<!-- ===================== STYLES ===================== -->
<style>
  /* Toggle checkbox style */
  input[type="checkbox"].toggle {
    transition: background-color 0.2s;
  }
  input[type="checkbox"].toggle:checked::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    top: 2px;
    left: calc(100% - 22px);
    transition: left 0.2s;
  }
  input[type="checkbox"].toggle::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: white;
    top: 2px;
    left: 2px;
    transition: left 0.2s;
  }

  /* Color swatch */
  input[type="color"].color-swatch {
    -webkit-appearance: none;
    appearance: none;
  }
  input[type="color"].color-swatch::-webkit-color-swatch-wrapper { padding: 2px; }
  input[type="color"].color-swatch::-webkit-color-swatch { border: none; border-radius: 8px; }

  /* Active states */
  .preset-btn.active .preset-ring { opacity: 1; }
  .button-style-btn.active { border-color: rgb(0 255 157 / 0.7); }
  .font-btn.active { border-color: rgb(0 255 157 / 0.7); }
  .bg-style-tab.active { border-color: rgb(0 255 157 / 0.7); color: white; }
  .gradient-type-btn.active { border-color: rgb(0 255 157 / 0.7); color: white; }

  /* Shadow neon helper */
  .shadow-neon { box-shadow: 0 0 20px rgba(0, 255, 157, 0.45); }

  /* Save btn loading state */
  #save-theme-btn.loading {
    opacity: 0.7;
    pointer-events: none;
  }
</style>

<!-- ===================== SCRIPT ===================== -->
<script define:vars={{ themeJson, profileJson }}>
  import { toast } from '@/lib/utils/toast';

  // ==================== CONSTANTS ====================
  const HISTORY_KEY = 'theme_history_v1';
  const MAX_HISTORY = 5;
  const ALLOWED_FONTS = ['Inter', 'Poppins', 'Roboto', 'Montserrat', 'Open Sans', 'Lato', 'Space Grotesk', 'DM Sans', 'Geist', 'Figtree'];

  // ==================== STATE ====================
  let currentTheme = JSON.parse(themeJson);
  const profileData = JSON.parse(profileJson);

  // ==================== SECURITY: INPUT SANITIZATION ====================
  function sanitizeHex(val) {
    return /^#[0-9A-Fa-f]{6}$/.test(val) ? val : null;
  }
  function sanitizeFont(val) {
    return ALLOWED_FONTS.includes(val) ? val : null;
  }
  function sanitizeInt(val, min, max, fallback) {
    const n = parseInt(val);
    return (!isNaN(n) && n >= min && n <= max) ? n : fallback;
  }

  // ==================== DEBOUNCE + RAF ====================
  let rafId = null;
  function schedulePreviewUpdate() {
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(renderIframePreview);
  }

  // ==================== IFRAME PREVIEW ====================
  function buildPreviewHTML(theme, profile) {
    const fontUrl = `https://fonts.googleapis.com/css2?family=${encodeURIComponent(theme.font_family)}:wght@400;500;600;700&display=swap`;

    const bgStyle = (() => {
      if (theme.background_style === 'gradient') {
        if (theme.gradient_type === 'radial') {
          return `radial-gradient(circle, ${theme.background_color}, ${theme.gradient_color_2})`;
        }
        return `linear-gradient(${theme.gradient_angle}deg, ${theme.background_color}, ${theme.gradient_color_2})`;
      }
      return theme.background_color;
    })();

    const btnStyles = (() => {
      const base = `
        display: block; width: 100%; padding: 14px 20px;
        font-size: 15px; font-weight: 600; cursor: pointer;
        border-radius: ${theme.border_radius}px;
        font-family: '${theme.font_family}', sans-serif;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        ${theme.block_shadow ? 'box-shadow: 0 4px 14px rgba(0,0,0,0.3);' : ''}
      `;
      if (theme.button_style === 'outline') {
        return `${base} background: transparent; border: 2px solid ${theme.primary_color}; color: ${theme.primary_color};`;
      }
      if (theme.button_style === 'shadow') {
        return `${base} background: ${theme.primary_color}; border: none; color: ${theme.background_color};
          box-shadow: 0 0 24px ${theme.primary_color}60;`;
      }
      return `${base} background: ${theme.primary_color}; border: none; color: ${theme.background_color};`;
    })();

    const blurOverlay = theme.background_style === 'blur'
      ? `<div style="position:fixed;inset:0;backdrop-filter:blur(60px);-webkit-backdrop-filter:blur(60px);background:${theme.background_color}88;z-index:0;"></div>`
      : '';

    const animCSS = theme.animations
      ? `button:hover { transform: scale(1.03) !important; } button:active { transform: scale(0.97) !important; }`
      : '';

    const sampleLinks = ['✦ My Portfolio', '✦ Twitter / X', '✦ Latest Project'];

    return `<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="${fontUrl}">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100%;
      font-family: '${theme.font_family}', sans-serif;
      background: ${bgStyle};
      color: ${theme.text_color};
      ${theme.background_style === 'blur' ? `background-color: ${theme.background_color};` : ''}
    }
    .page { position: relative; z-index: 1; max-width: 360px; margin: 0 auto; padding: 40px 20px; }
    .avatar { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, ${theme.primary_color}, ${theme.text_color}40); margin: 0 auto 16px; }
    .name { font-size: 20px; font-weight: 700; text-align: center; margin-bottom: 6px; }
    .bio  { font-size: 13px; text-align: center; opacity: 0.65; margin-bottom: 28px; line-height: 1.5; }
    .links { display: flex; flex-direction: column; gap: 12px; }
    button { ${btnStyles} }
    ${animCSS}
  </style>
</head>
<body>
  ${blurOverlay}
  <div class="page">
    <div class="avatar"></div>
    <div class="name">${profile.display_name || profile.username || 'Your Name'}</div>
    <div class="bio">${profile.bio || 'Your bio here ✨'}</div>
    <div class="links">
      ${sampleLinks.map(t => `<button>${t}</button>`).join('\n      ')}
    </div>
  </div>
</body>
</html>`;
  }

  function renderIframePreview() {
    const iframe = document.getElementById('preview-iframe');
    if (!iframe) return;
    const html = buildPreviewHTML(currentTheme, profileData);
    iframe.srcdoc = html;
  }

  // ==================== THEME HISTORY ====================
  function getHistory() {
    try {
      return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function pushHistory(theme) {
    const history = getHistory();
    const entry = { theme: { ...theme }, savedAt: new Date().toISOString() };
    history.unshift(entry);
    if (history.length > MAX_HISTORY) history.pop();
    localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
    renderHistory();
  }

  function renderHistory() {
    const list = document.getElementById('history-list');
    if (!list) return;
    const history = getHistory();

    if (history.length === 0) {
      list.innerHTML = '<p class="text-xs text-gray-500 text-center py-3">No history yet</p>';
      return;
    }

    list.innerHTML = history.map((entry, i) => {
      const date = new Date(entry.savedAt);
      const label = date.toLocaleString('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
      return `
        <button
          class="history-restore-btn w-full flex items-center gap-3 p-3 glass rounded-xl border border-white/5 hover:border-white/15 transition-all group text-left"
          data-index="${i}"
        >
          <div class="flex gap-1 shrink-0">
            <div class="w-4 h-8 rounded" style="background:${entry.theme.background_color}; border: 1px solid rgba(255,255,255,0.1)"></div>
            <div class="w-4 h-8 rounded" style="background:${entry.theme.primary_color}"></div>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-xs text-gray-300 font-medium capitalize truncate">${entry.theme.preset || 'custom'}</div>
            <div class="text-xs text-gray-500">${label}</div>
          </div>
          <svg class="w-3.5 h-3.5 text-gray-500 group-hover:text-neon-green transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9"/>
          </svg>
        </button>
      `;
    }).join('');

    // Restore click
    list.querySelectorAll('.history-restore-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.index);
        const entry = getHistory()[idx];
        if (entry) {
          applyTheme(entry.theme);
          toast.success('Theme restored!');
        }
      });
    });
  }

  // ==================== APPLY FULL THEME ====================
  function applyTheme(t) {
    currentTheme = { ...currentTheme, ...t };

    // Update all inputs
    setColorInput('background_color', currentTheme.background_color);
    setColorInput('primary_color', currentTheme.primary_color);
    setColorInput('text_color', currentTheme.text_color);
    setColorInput('gradient_color_1', currentTheme.background_color);
    setColorInput('gradient_color_2', currentTheme.gradient_color_2);

    const radiusSlider = document.getElementById('border_radius');
    const radiusValue = document.getElementById('radius-value');
    if (radiusSlider) radiusSlider.value = currentTheme.border_radius;
    if (radiusValue) radiusValue.textContent = `${currentTheme.border_radius}px`;

    const angleSlider = document.getElementById('gradient_angle');
    const angleValue = document.getElementById('gradient-angle-value');
    if (angleSlider) angleSlider.value = currentTheme.gradient_angle;
    if (angleValue) angleValue.textContent = `${currentTheme.gradient_angle}°`;

    const blockShadow = document.getElementById('block_shadow');
    const animations = document.getElementById('animations');
    if (blockShadow) blockShadow.checked = currentTheme.block_shadow;
    if (animations) animations.checked = currentTheme.animations;

    // Active states
    setActiveClass('.preset-btn', `[data-preset="${currentTheme.preset}"]`);
    setActiveClass('.button-style-btn', `[data-style="${currentTheme.button_style}"]`);
    setActiveClass('.font-btn', `[data-font="${currentTheme.font_family}"]`);
    setActiveClass('.bg-style-tab', `[data-style="${currentTheme.background_style}"]`);
    setActiveClass('.gradient-type-btn', `[data-type="${currentTheme.gradient_type}"]`);

    toggleGradientUI(currentTheme.background_style);
    toggleAngleUI(currentTheme.gradient_type);
    schedulePreviewUpdate();
  }

  function setColorInput(id, value) {
    const picker = document.getElementById(id);
    const text = document.getElementById(`${id}_text`);
    if (picker) picker.value = value;
    if (text) text.value = value;
  }

  function setActiveClass(groupSelector, targetSelector) {
    document.querySelectorAll(groupSelector).forEach(el => el.classList.remove('active'));
    document.querySelector(groupSelector + targetSelector)?.classList.add('active');
  }

  function toggleGradientUI(style) {
    const gb = document.getElementById('gradient-builder');
    const bi = document.getElementById('blur-info');
    gb?.classList.toggle('hidden', style !== 'gradient');
    bi?.classList.toggle('hidden', style !== 'blur');
  }

  function toggleAngleUI(type) {
    document.getElementById('angle-wrap')?.classList.toggle('hidden', type !== 'linear');
  }

  // ==================== COLOR PICKERS ====================
  const colorBindings = [
    { id: 'background_color',  key: 'background_color' },
    { id: 'primary_color',     key: 'primary_color'    },
    { id: 'text_color',        key: 'text_color'       },
    { id: 'gradient_color_1',  key: 'background_color' },
    { id: 'gradient_color_2',  key: 'gradient_color_2' },
  ];

  colorBindings.forEach(({ id, key }) => {
    const picker = document.getElementById(id);
    const text = document.getElementById(`${id}_text`);

    picker?.addEventListener('input', (e) => {
      const val = e.target.value;
      currentTheme[key] = val;
      // Sync gradient_color_1 <-> background_color
      if (id === 'background_color') setColorInput('gradient_color_1', val);
      if (id === 'gradient_color_1') setColorInput('background_color', val);
      if (text) text.value = val;
      schedulePreviewUpdate();
    });

    text?.addEventListener('input', (e) => {
      const val = e.target.value;
      const clean = sanitizeHex(val);
      if (clean) {
        currentTheme[key] = clean;
        if (picker) picker.value = clean;
        schedulePreviewUpdate();
      }
    });
  });

  // ==================== PRESETS ====================
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const { preset, bg, primary, text } = btn.dataset;
      if (!sanitizeHex(bg) || !sanitizeHex(primary) || !sanitizeHex(text)) return;
      currentTheme = { ...currentTheme, preset, background_color: bg, primary_color: primary, text_color: text };
      setColorInput('background_color', bg);
      setColorInput('gradient_color_1', bg);
      setColorInput('primary_color', primary);
      setColorInput('text_color', text);
      setActiveClass('.preset-btn', `[data-preset="${preset}"]`);
      schedulePreviewUpdate();
    });
  });

  // ==================== BUTTON STYLE ====================
  document.querySelectorAll('.button-style-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentTheme.button_style = btn.dataset.style;
      setActiveClass('.button-style-btn', `[data-style="${btn.dataset.style}"]`);
      schedulePreviewUpdate();
    });
  });

  // ==================== FONT ====================
  document.querySelectorAll('.font-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const font = sanitizeFont(btn.dataset.font);
      if (!font) return;
      currentTheme.font_family = font;
      setActiveClass('.font-btn', `[data-font="${font}"]`);
      schedulePreviewUpdate();
    });
  });

  // ==================== BG STYLE TABS ====================
  document.querySelectorAll('.bg-style-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      currentTheme.background_style = btn.dataset.style;
      setActiveClass('.bg-style-tab', `[data-style="${btn.dataset.style}"]`);
      toggleGradientUI(btn.dataset.style);
      schedulePreviewUpdate();
    });
  });

  // ==================== GRADIENT TYPE ====================
  document.querySelectorAll('.gradient-type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentTheme.gradient_type = btn.dataset.type;
      setActiveClass('.gradient-type-btn', `[data-type="${btn.dataset.type}"]`);
      toggleAngleUI(btn.dataset.type);
      schedulePreviewUpdate();
    });
  });

  // ==================== GRADIENT ANGLE ====================
  const angleSlider = document.getElementById('gradient_angle');
  const angleValue = document.getElementById('gradient-angle-value');
  angleSlider?.addEventListener('input', (e) => {
    const val = sanitizeInt(e.target.value, 0, 360, 135);
    currentTheme.gradient_angle = val;
    if (angleValue) angleValue.textContent = `${val}°`;
    schedulePreviewUpdate();
  });

  document.querySelectorAll('.angle-preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = sanitizeInt(btn.dataset.angle, 0, 360, 135);
      currentTheme.gradient_angle = val;
      if (angleSlider) angleSlider.value = val;
      if (angleValue) angleValue.textContent = `${val}°`;
      schedulePreviewUpdate();
    });
  });

  // ==================== BORDER RADIUS ====================
  const radiusSlider = document.getElementById('border_radius');
  const radiusDisplay = document.getElementById('radius-value');

  radiusSlider?.addEventListener('input', (e) => {
    const val = sanitizeInt(e.target.value, 0, 32, 12);
    currentTheme.border_radius = val;
    if (radiusDisplay) radiusDisplay.textContent = `${val}px`;
    schedulePreviewUpdate();
  });

  document.querySelectorAll('.radius-preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = sanitizeInt(btn.dataset.radius, 0, 32, 12);
      currentTheme.border_radius = val;
      if (radiusSlider) radiusSlider.value = val;
      if (radiusDisplay) radiusDisplay.textContent = `${val}px`;
      schedulePreviewUpdate();
    });
  });

  // ==================== ADVANCED TOGGLES ====================
  document.getElementById('block_shadow')?.addEventListener('change', (e) => {
    currentTheme.block_shadow = e.target.checked;
    schedulePreviewUpdate();
  });
  document.getElementById('animations')?.addEventListener('change', (e) => {
    currentTheme.animations = e.target.checked;
    schedulePreviewUpdate();
  });

  // ==================== SAVE (rate-limited) ====================
  let lastSaveTime = 0;
  const SAVE_COOLDOWN = 2000; // 2s

  document.getElementById('save-theme-btn')?.addEventListener('click', async () => {
    const now = Date.now();
    if (now - lastSaveTime < SAVE_COOLDOWN) {
      toast.error('Please wait before saving again');
      return;
    }

    const btn = document.getElementById('save-theme-btn');
    const btnText = document.getElementById('save-btn-text');
    btn?.classList.add('loading');
    if (btnText) btnText.innerHTML = `
      <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
      </svg>
      Saving…
    `;

    try {
      const response = await fetch('/api/profile', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ theme: currentTheme }),
      });

      if (!response.ok) {
        const result = await response.json().catch(() => ({}));
        throw new Error(result.error || `HTTP ${response.status}`);
      }

      lastSaveTime = Date.now();
      pushHistory(currentTheme); // Save to local history
      toast.success('Theme saved!');
    } catch (err) {
      toast.error(err instanceof Error ? err.message : 'Failed to save theme');
    } finally {
      btn?.classList.remove('loading');
      if (btnText) btnText.innerHTML = `
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Save Theme
      `;
    }
  });

  // ==================== RESET ====================
  document.getElementById('reset-theme-btn')?.addEventListener('click', () => {
    if (!confirm('Reset to default dark theme?')) return;
    applyTheme({
      preset: 'dark',
      background_color: '#0a0a0a',
      primary_color: '#00ff9d',
      text_color: '#ffffff',
      button_style: 'filled',
      border_radius: 12,
      font_family: 'Inter',
      background_style: 'solid',
      gradient_color_2: '#1a1a2e',
      gradient_angle: 135,
      gradient_type: 'linear',
      block_shadow: true,
      animations: true,
    });
    toast.success('Theme reset!');
  });

  // ==================== EXPORT ====================
  document.getElementById('export-btn')?.addEventListener('click', () => {
    const blob = new Blob([JSON.stringify(currentTheme, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `theme-${currentTheme.preset || 'custom'}-${Date.now()}.json`;
    a.click();
    URL.revokeObjectURL(url);
    toast.success('Theme exported!');
  });

  // ==================== IMPORT ====================
  document.getElementById('import-file')?.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    if (file.size > 50_000) { toast.error('File too large (max 50KB)'); return; }

    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const raw = JSON.parse(ev.target.result);

        // Validate & sanitize all fields
        const safe = {
          preset:           typeof raw.preset === 'string' ? raw.preset.slice(0, 20) : 'custom',
          background_color: sanitizeHex(raw.background_color) || '#0a0a0a',
          primary_color:    sanitizeHex(raw.primary_color)    || '#00ff9d',
          text_color:       sanitizeHex(raw.text_color)       || '#ffffff',
          gradient_color_2: sanitizeHex(raw.gradient_color_2) || '#1a1a2e',
          gradient_angle:   sanitizeInt(raw.gradient_angle, 0, 360, 135),
          gradient_type:    ['linear','radial'].includes(raw.gradient_type) ? raw.gradient_type : 'linear',
          background_style: ['solid','gradient','blur'].includes(raw.background_style) ? raw.background_style : 'solid',
          button_style:     ['filled','outline','shadow'].includes(raw.button_style) ? raw.button_style : 'filled',
          border_radius:    sanitizeInt(raw.border_radius, 0, 32, 12),
          font_family:      sanitizeFont(raw.font_family) || 'Inter',
          block_shadow:     typeof raw.block_shadow === 'boolean' ? raw.block_shadow : true,
          animations:       typeof raw.animations === 'boolean' ? raw.animations : true,
        };

        applyTheme(safe);
        toast.success('Theme imported!');
      } catch {
        toast.error('Invalid theme file');
      }
    };
    reader.readAsText(file);
    // Reset file input so same file can be re-imported
    e.target.value = '';
  });

  // ==================== INIT ====================
  applyTheme(currentTheme);
  renderHistory();
</script>
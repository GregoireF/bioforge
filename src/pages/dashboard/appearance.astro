  // ── AI generate ───────────────────────────────────────────────────────────────
  document.getElementById('ai-generate-btn')?.addEventListener('click', async () => {
    const prompt = ((document.getElementById('ai-prompt') as HTMLTextAreaElement)?.value ?? '').trim();
    if (!prompt) { toast.error('Décris ton univers d\'abord'); return; }

    const responseEl = document.getElementById('ai-response');
    const thinkingEl = document.getElementById('ai-thinking');
    const resultEl   = document.getElementById('ai-result');
    const errorEl    = document.getElementById('ai-error');
    const genBtn     = document.getElementById('ai-generate-btn') as HTMLButtonElement | null;

    responseEl?.classList.remove('hidden');
    thinkingEl?.classList.remove('hidden');
    resultEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');
    if (genBtn) genBtn.disabled = true;

    try {
      const r = await fetch('/api/ai/theme', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({prompt}) });
      if (!r.ok) throw new Error((await r.json().catch(()=>({}))).error || `HTTP ${r.status}`);
      const data = await r.json();
      if (!data.theme) throw new Error('Réponse invalide');
      aiSuggestedTheme = data.theme;

      const paletteEl = document.getElementById('ai-palette');
      if (paletteEl) {
        const colors = [aiSuggestedTheme.background_color, aiSuggestedTheme.primary_color, aiSuggestedTheme.text_color, aiSuggestedTheme.gradient_color_2];
        const labels = ['Fond','Accent','Texte','Dégradé'];
        paletteEl.innerHTML = colors.map((col, i) => `
          <div class="flex flex-col gap-1 items-center">
            <div style="width:32px;height:32px;border-radius:8px;background:${col};border:1px solid rgba(255,255,255,0.1)"></div>
            <span style="font-size:9px;color:#6b7280">${labels[i]}</span>
          </div>`).join('');
      }
      const reasonEl = document.getElementById('ai-reasoning');
      if (reasonEl) reasonEl.textContent = data.theme.reasoning ?? '';
      thinkingEl?.classList.add('hidden');
      resultEl?.classList.remove('hidden');
    } catch {
      thinkingEl?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
      const errMsg = document.getElementById('ai-error-msg');
      if (errMsg) errMsg.textContent = 'Erreur de génération — réessaie ou reformule.';
    } finally {
      if (genBtn) genBtn.disabled = false;
    }
  });


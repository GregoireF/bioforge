  // ── Apply full theme ──────────────────────────────────────────────────────────
  function applyFullTheme(t: any) {
    _applyingFull = true;
    theme = { ...theme, ...t };
    syncColor('background_color', theme.background_color);
    syncColor('gradient_color_1', theme.background_color);
    syncColor('primary_color',    theme.primary_color);
    syncColor('text_color',       theme.text_color);
    syncColor('gradient_color_2', theme.gradient_color_2 ?? theme.background_color);

    const setSlider = (id: string, val: number, displayId: string, fmt: (v:number)=>string) => {
      const s = document.getElementById(id) as HTMLInputElement | null;
      const d = document.getElementById(displayId);
      if (s) s.value = String(val);
      if (d) d.textContent = fmt(val);
    };
    setSlider('border_radius',      theme.border_radius,     'radius-val',          v=>`${v}px`);
    setSlider('gradient_angle',     theme.gradient_angle,    'angle-val',           v=>`${v}°`);
    setSlider('pattern_opacity',    theme.pattern_opacity,   'pattern-opacity-val', v=>`${v}%`);
    setSlider('glass_intensity',    theme.glass_intensity,   'glass-val',           v=>String(v));
    setSlider('shadow-intensity',   theme.shadow_intensity,  'shadow-val',          v=>String(v));
    setSlider('hover-scale',        theme.hover_scale,       'hover-scale-val',     v=>`${v}/5`);
    setSlider('hero-overlay-slider',theme.hero_overlay,      'hero-overlay-val',    v=>`${v}%`);

    const checks: [string, boolean][] = [
      ['block_shadow', theme.block_shadow],
      ['animations',   theme.animations],
      ['scroll_reveal',theme.scroll_reveal ?? true],
      ['click_ripple', theme.click_ripple ?? false],
      ['show_username',theme.show_username ?? true],
      ['overlay-top',  theme.overlay_top ?? false],
      ['overlay-bottom',theme.overlay_bottom ?? false],
    ];
    checks.forEach(([id, val]) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el) el.checked = val;
    });

    // Activate all choice buttons
    activateBtn('.preset-btn',        'preset',   theme.preset);
    activateBtn('.btn-style-btn',     'style',    theme.button_style);
    activateBtn('.font-btn',          'font',     theme.font_family);
    activateBtn('.bg-tab',            'style',    theme.background_style);
    activateBtn('.grad-type-btn',     'type',     theme.gradient_type);
    activateBtn('.pattern-btn',       'pattern',  theme.pattern);
    activateBtn('.anim-btn',          'anim',     theme.animation_preset);
    activateBtn('.shape-btn',         'shape',    theme.avatar_shape);
    activateBtn('.avatar-border-btn', 'border',   theme.avatar_border);
    activateBtn('.avatar-size-btn',   'size',     theme.avatar_size);
    activateBtn('.social-style-btn',  'social',   theme.social_icon_style);
    activateBtn('.spacing-btn',       'spacing',  theme.spacing);
    activateBtn('.layout-btn',        'layout',   theme.profile_layout);
    activateBtn('.header-btn',        'header',   theme.header_style);
    activateBtn('.hover-fx-btn',      'fx',       theme.hover_effect);
    activateBtn('.btn-width-btn',     'bw',       theme.button_width);
    activateBtn('.bio-size-btn',      'bioSize',  theme.bio_size);
    activateBtn('.bio-style-btn',     'bioStyle', theme.bio_style);
    activateBtn('.width-btn',         'width',    theme.content_width);

    activateBtn('.logo-size-btn',     'size',     theme.logo_size);
    activateBtn('.sep-btn',           'sep',      theme.link_separator ?? 'none');
    activateBtn('.icon-pos-btn',      'iconpos',  theme.link_icon_pos  ?? 'left');
    const lhf = document.getElementById('link-hover-fill') as HTMLInputElement | null;
    if (lhf) lhf.checked = theme.link_hover_fill ?? false;
    activateBtn('.wallpaper-type-btn','wallpaper',theme.wallpaper_type);
    activateBtn('.hero-height-btn',   'height',   theme.hero_height);
    activateBtn('.hero-pos-btn',      'pos',      theme.hero_position);

    // Hero settings visibility — use style.display not classList (because of hidden vs display:none conflict)
    const heroSett = document.getElementById('hero-settings');
    if (heroSett) heroSett.style.display = theme.header_style === 'hero' ? '' : 'none';

    // Logo
    const showLogoEl = document.getElementById('show-logo') as HTMLInputElement | null;
    if (showLogoEl) showLogoEl.checked = theme.show_logo ?? false;
    document.getElementById('logo-settings')?.classList.toggle('hidden', !theme.show_logo);
    const logoUrlEl = document.getElementById('logo-url') as HTMLInputElement | null;
    if (logoUrlEl) logoUrlEl.value = theme.logo_url ?? '';
    const logoPrev = document.getElementById('logo-preview');
    if (logoPrev) logoPrev.innerHTML = theme.logo_url
      ? `<img src="${theme.logo_url}" style="width:100%;height:100%;object-fit:contain" />`
      : '<span style="font-size:20px">🏷️</span>';

    // Wallpaper
    document.getElementById('wallpaper-image-settings')?.classList.toggle('hidden', theme.wallpaper_type !== 'image');
    document.getElementById('wallpaper-video-settings')?.classList.toggle('hidden', theme.wallpaper_type !== 'video');
    const wUrlEl  = document.getElementById('wallpaper-url')       as HTMLInputElement|null;
    const wVidEl  = document.getElementById('wallpaper-video-url') as HTMLInputElement|null;
    const wBlurEl = document.getElementById('wallpaper-blur')      as HTMLInputElement|null;
    const wDimEl  = document.getElementById('wallpaper-dim')       as HTMLInputElement|null;
    if (wUrlEl)  wUrlEl.value  = theme.wallpaper_url ?? '';
    if (wVidEl)  wVidEl.value  = theme.wallpaper_video_url ?? '';
    if (wBlurEl) { wBlurEl.value = String(theme.wallpaper_blur??0); const v=document.getElementById('wallpaper-blur-val'); if(v) v.textContent=`${theme.wallpaper_blur??0}px`; }
    if (wDimEl)  { wDimEl.value  = String(theme.wallpaper_dim??50);  const v=document.getElementById('wallpaper-dim-val');  if(v) v.textContent=`${theme.wallpaper_dim??50}%`; }

    document.getElementById('gradient-builder')?.classList.toggle('hidden', theme.background_style !== 'gradient');
    document.getElementById('pattern-opacity-wrap')?.classList.toggle('hidden', theme.pattern === 'none');
    document.getElementById('angle-wrap')?.classList.toggle('hidden', theme.gradient_type !== 'linear');

    if (cssEditor) { cssEditor.value = theme.custom_css ?? ''; if(cssCount) cssCount.textContent=`${cssEditor.value.length} / 4000`; }
    syncHeroToggle();

    schedulePreview();
    _applyingFull = false;
  }

  // ── History ───────────────────────────────────────────────────────────────────
  function getHistory() { try { return JSON.parse(localStorage.getItem(HISTORY_KEY)||'[]'); } catch { return []; } }
  function pushHistory(t: any) {
    const h = getHistory(); h.unshift({ theme:{...t}, savedAt:new Date().toISOString() });
    if (h.length>5) h.pop();
    localStorage.setItem(HISTORY_KEY, JSON.stringify(h));
    renderHistory();
  }
  function renderHistory() {
    const c = document.getElementById('history-items');
    if (!c) return;
    const h = getHistory();
    if (!h.length) { c.innerHTML='<p class="text-xs text-gray-700 py-2">Aucun historique</p>'; return; }
    c.innerHTML = h.map((entry: any, i: number) => {
      const d = new Date(entry.savedAt).toLocaleString('fr-FR',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'});
      return `<button class="hist-btn w-full flex items-center gap-2.5 p-2.5 glass rounded-xl border border-white/5 hover:border-white/15 transition-all text-left mb-1.5" data-idx="${i}">
        <div class="flex gap-1 shrink-0">
          <div style="width:12px;height:28px;border-radius:3px;background:${entry.theme.background_color};border:1px solid rgba(255,255,255,0.1)"></div>
          <div style="width:12px;height:28px;border-radius:3px;background:${entry.theme.primary_color}"></div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs text-gray-300 font-medium truncate">${entry.theme.preset||'custom'}</p>
          <p class="text-xs text-gray-600">${d}</p>
        </div>
      </button>`;
    }).join('');
    c.querySelectorAll('.hist-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const entry = getHistory()[+(btn as HTMLElement).dataset.idx!];
        if (entry) { applyFullTheme(entry.theme); toast.success('Thème restauré !'); }
      });
    });
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // TEST MODE — fonctionnalités premium testables, non sauvegardables
  // ═══════════════════════════════════════════════════════════════════════════
  const PREMIUM_FIELDS = {
    creator: ['hero_image','hero_height','hero_position','hero_overlay','show_logo','logo_url','logo_size',
              'wallpaper_type','wallpaper_url','wallpaper_blur','wallpaper_dim','wallpaper_video_url'],
    pro:     ['wallpaper_video_url','logo_size_lg','custom_font_url','custom_font_name','custom_css'],
  };

  let testModeActive   = false;
  let testModeFeatures: string[] = [];

  function requiresPremium(key: string): 'creator'|'pro'|null {
    if (PREMIUM_FIELDS.pro.includes(key))     return 'pro';
    if (PREMIUM_FIELDS.creator.includes(key)) return 'creator';
    return null;
  }

  function setThemeField(key: string, value: any) {
    const needed = requiresPremium(key);
    // Logo size lg is pro
    if (key === 'logo_size' && value === 'lg') {
      if (!isPro) {
        activateTestMode('pro', key);
        theme[key] = value;
        schedulePreview();
        return;
      }
    }
    if (needed === 'pro' && !isPro) {
      activateTestMode('pro', key);
    } else if (needed === 'creator' && !isCreator) {
      activateTestMode('creator', key);
    }
    theme[key] = value;
    schedulePreview();
  }

  function activateTestMode(tier: string, feature: string) {
    if (!testModeFeatures.includes(feature)) testModeFeatures.push(feature);
    if (!testModeActive) {
      testModeActive = true;
      showTestBanner(tier);
    }
  }

  function showTestBanner(tier: string) {
    const pill  = document.getElementById('test-mode-pill');
    const icon  = document.getElementById('test-mode-icon');
    const label = document.getElementById('test-mode-label');
    const cta   = document.getElementById('test-mode-cta') as HTMLAnchorElement | null;
    if (!pill) return;

    const isPro  = tier === 'pro';
    const color  = isPro ? '#c084fc' : '#00ff9d';
    const bgCol  = isPro ? 'rgba(168,85,247,0.12)' : 'rgba(0,255,157,0.08)';
    const border = isPro ? 'rgba(168,85,247,0.3)'  : 'rgba(0,255,157,0.25)';

    pill.style.cssText   = `display:flex;background:${bgCol};border:1px solid ${border};border-radius:16px;`;
    if (icon)  icon.textContent  = isPro ? '⚡' : '👑';
    if (label) { label.textContent = `Mode aperçu ${isPro ? 'Pro' : 'Creator'}`; label.style.color = color; }
    if (cta)   { cta.style.cssText = `background:${color};color:${isPro?'#fff':'#000'};padding:4px 10px;border-radius:8px;font-size:10px;font-weight:700;text-decoration:none;flex-shrink:0`; }
    pill.classList.remove('hidden');
  }

  function dismissTestMode() {
    testModeActive   = false;
    testModeFeatures = [];
    document.getElementById('test-mode-pill')?.classList.add('hidden');
    // Reset premium fields back to defaults
    theme.hero_image       = '';
    theme.show_logo        = false;
    theme.logo_url         = '';
    theme.logo_size        = 'md';
    theme.wallpaper_type   = 'none';
    theme.wallpaper_url    = '';
    theme.wallpaper_video_url = '';
    theme.custom_font_url  = '';
    theme.custom_font_name = '';
    // Reset header if it was hero
    if (theme.header_style === 'hero') theme.header_style = 'simple';
    _applyingFull = true;
    schedulePreview();
    _applyingFull = false;
    syncUIToTheme();
    toast.success('Aperçu premium réinitialisé');
  }
  (window as any).dismissTestMode = dismissTestMode;

  // Save btn — bloqué si test mode actif + non payant
  document.getElementById('save-btn')?.addEventListener('click', async () => {
    // Check if test mode is on and user can't save
    if (testModeActive && testModeFeatures.length > 0) {
      const hasPro      = testModeFeatures.some(f => PREMIUM_FIELDS.pro.includes(f));
      const needUpgrade = hasPro ? !isPro : !isCreator;
      if (needUpgrade) {
        const tier = hasPro ? 'Pro' : 'Creator';
        // Show upsell modal
        showUpsellModal(hasPro ? 'pro' : 'creator');
        return;
      }
    }
    if (Date.now()-lastSave < 2000) { toast.error('Attends avant de sauvegarder'); return; }
    const btn = document.getElementById('save-btn');
    const txt = document.getElementById('save-btn-text');
    btn?.classList.add('loading');
    if (txt) txt.textContent = 'Sauvegarde…';
    try {
      const r = await fetch('/api/profile', { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ theme }) });
      if (!r.ok) throw new Error((await r.json().catch(()=>({}))).error||`HTTP ${r.status}`);
      lastSave = Date.now();
      pushHistory(theme);
      testModeActive   = false;
      testModeFeatures = [];
      document.getElementById('test-mode-pill')?.classList.add('hidden');
      markSaved();
      toast.success('Thème sauvegardé ! ✓');
    } catch(err: any) {
      toast.error(err.message||'Erreur de sauvegarde');
    } finally {
      btn?.classList.remove('loading');
      if (txt) txt.textContent = 'Sauvegarder';
    }
  });


---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import { withAuth } from '@/lib/auth/auth';

const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}

const { user, profile } = authResult.data;

const DEFAULT_THEME = {
  preset: 'dark' as const,
  background_style: 'solid' as const,
  background_color: '#0a0a0a',
  gradient_color_2: '#1a1a2e',
  gradient_type: 'linear' as const,
  gradient_angle: 135,
  primary_color: '#00ff9d',
  text_color: '#ffffff',
  button_style: 'filled' as const,
  border_radius: 14,
  font_family: 'Geist' as const,
  block_shadow: true,
  animations: true,
  glass_intensity: 12,
} satisfies Record<string, any>;

type Theme = typeof DEFAULT_THEME;

function sanitizeHex(value: unknown, fallback: string): string {
  return typeof value === 'string' && /^#[0-9A-Fa-f]{6}$/.test(value) ? value : fallback;
}

const ALLOWED_FONTS = ['Geist', 'Inter', 'Poppins', 'Roboto', 'Space Grotesk', 'Figtree', 'DM Sans'] as const;
type AllowedFont = typeof ALLOWED_FONTS[number];

function sanitizeFont(value: unknown, fallback: AllowedFont): AllowedFont {
  return ALLOWED_FONTS.includes(value as any) ? value as AllowedFont : fallback;
}

function sanitizeEnum<T extends string>(value: unknown, allowed: readonly T[], fallback: T): T {
  return allowed.includes(value as any) ? value as T : fallback;
}

function clamp(n: unknown, min: number, max: number, fallback: number): number {
  const v = Number(n);
  return Number.isFinite(v) ? Math.min(Math.max(v, min), max) : fallback;
}

let theme: Theme = { ...DEFAULT_THEME };

if (profile.theme) {
  try {
    const raw = typeof profile.theme === 'string' ? JSON.parse(profile.theme) : profile.theme;
    if (raw && typeof raw === 'object') {
      theme = {
        ...DEFAULT_THEME,
        ...raw,
        background_color: sanitizeHex(raw.background_color, DEFAULT_THEME.background_color),
        primary_color: sanitizeHex(raw.primary_color, DEFAULT_THEME.primary_color),
        text_color: sanitizeHex(raw.text_color, DEFAULT_THEME.text_color),
        gradient_color_2: sanitizeHex(raw.gradient_color_2, DEFAULT_THEME.gradient_color_2),
        font_family: sanitizeFont(raw.font_family, DEFAULT_THEME.font_family),
        border_radius: clamp(raw.border_radius, 0, 40, 14),
        gradient_angle: clamp(raw.gradient_angle, 0, 360, 135),
        glass_intensity: clamp(raw.glass_intensity, 4, 32, 12),
        background_style: sanitizeEnum(raw.background_style, ['solid','gradient','blur'] as const, 'solid'),
        gradient_type: sanitizeEnum(raw.gradient_type, ['linear','radial'] as const, 'linear'),
        button_style: sanitizeEnum(raw.button_style, ['filled','outline','shadow','minimal'] as const, 'filled'),
      };
    }
  } catch {}
}

const themeJson = JSON.stringify(theme);

const defaultThemeJson = JSON.stringify(DEFAULT_THEME);

const profileJson = JSON.stringify({
  display_name: profile.display_name ?? user.email?.split('@')[0] ?? 'Utilisateur',
  username: profile.username ?? '',
  bio: profile.bio ?? '',
});
---

<DashboardLayout title="Apparence • 2026">

  <div class="mb-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold tracking-tight bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">Apparence</h1>
      <p class="text-sm text-gray-400 mt-1.5">Personnalise ton profil — glass, couleurs, mouvements</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <label class="group flex items-center gap-2.5 px-5 py-2.5 glass border border-white/8 rounded-2xl text-sm font-medium text-gray-300 hover:text-white hover:border-white/20 transition-all cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Importer
        <input type="file" id="import-file" accept=".json" class="hidden" />
      </label>

      <button id="export-btn" class="flex items-center gap-2.5 px-5 py-2.5 glass border border-white/8 rounded-2xl text-sm font-medium text-gray-300 hover:text-white hover:border-white/20 transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Exporter
      </button>
    </div>
  </div>

  <div id="server-data" class="hidden" data-theme={themeJson} data-profile={profileJson} data-default-theme={defaultThemeJson}></div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 xl:gap-8">

    <div class="lg:col-span-8 space-y-6 xl:space-y-8">

      <Card title="Préréglages" description="Ambiances instantanées" className="overflow-hidden">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {
            [
              { id: 'dark', label: 'Éclipse', bg: '#0a0a0a', primary: '#00ff9d', text: '#f0f0f0', thumb: 'from-gray-950 via-slate-900 to-black' },
              { id: 'light', label: 'Aube', bg: '#fafafa', primary: '#0066ff', text: '#111111', thumb: 'from-gray-50 via-white to-gray-100' },
              { id: 'neon', label: 'Cyber', bg: '#0f001a', primary: '#d600ff', text: '#f0f0ff', thumb: 'from-purple-950 to-fuchsia-950' },
              { id: 'ocean', label: 'Abysse', bg: '#001522', primary: '#00eaff', text: '#e0f8ff', thumb: 'from-blue-950 to-cyan-950' },
              { id: 'sunset', label: 'Braise', bg: '#1a0d00', primary: '#ff5e00', text: '#fff5e0', thumb: 'from-amber-950 to-red-950' },
              { id: 'clay', label: 'Doux', bg: '#111111', primary: '#ff80ab', text: '#f5f5f5', thumb: 'from-rose-950 via-pink-950 to-purple-950' },
            ].map(p => (
              <button
                class="preset-btn group relative aspect-[4/3] rounded-2xl overflow-hidden border-2 border-white/10 hover:border-emerald-400/50 hover:scale-105 active:scale-95 transition-all duration-200 shadow-sm hover:shadow-lg"
                data-preset={p.id}
                data-bg={p.bg}
                data-primary={p.primary}
                data-text={p.text}
                aria-label={`Préréglage ${p.label}`}
              >
                <div class={`absolute inset-0 bg-gradient-to-br ${p.thumb}`}></div>
                <div class="absolute inset-x-0 bottom-0 p-3 bg-gradient-to-t from-black/60 to-transparent">
                  <span class="text-xs font-semibold text-white drop-shadow-md">{p.label}</span>
                </div>
                <div class="absolute inset-0 border-2 border-emerald-400/0 group-hover:border-emerald-400/40 rounded-2xl transition-all duration-300"></div>
              </button>
            ))
          }
        </div>
      </Card>

      <Card title="Palette & Glass" description="Couleurs principales + intensité du verre">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          {[
            { id: 'background_color', label: 'Arrière-plan' },
            { id: 'primary_color', label: 'Accent' },
            { id: 'text_color', label: 'Texte' },
          ].map(c => (
            <div class="space-y-3">
              <label class="block text-sm font-medium text-gray-300">{c.label}</label>
              <div class="flex gap-3">
                <input
                  type="color"
                  id={c.id}
                  value={(theme as any)[c.id]}
                  class="color-swatch w-14 h-14 rounded-2xl cursor-pointer border-2 border-white/10 shadow-sm"
                />
                <input
                  type="text"
                  id={`${c.id}_hex`}
                  value={(theme as any)[c.id]}
                  maxlength="7"
                  class="flex-1 px-4 py-2.5 glass rounded-2xl text-sm font-mono tracking-wider focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/20 transition-all"
                  placeholder="#000000"
                />
              </div>
            </div>
          ))}

          <div class="space-y-3">
            <label class="block text-sm font-medium text-gray-300">Intensité Glass</label>
            <div class="flex items-center gap-4">
              <input
                type="range"
                id="glass_intensity"
                min="4"
                max="32"
                step="2"
                value={theme.glass_intensity ?? 12}
                class="flex-1 accent-emerald-500"
              />
              <span id="glass-value" class="text-sm font-mono text-gray-300 w-10 text-right">
                {theme.glass_intensity ?? 12}px
              </span>
            </div>
          </div>
        </div>
      </Card>

      <Card title="Type d'arrière-plan" description="Uni • Dégradé • Verre givré">
        <div class="space-y-6">
          <div class="grid grid-cols-3 gap-3">
            {['solid', 'gradient', 'blur'].map(s => (
              <button
                class="bg-style-tab py-3 px-4 rounded-2xl glass border-2 border-white/8 text-sm font-medium transition-all hover:border-emerald-500/40 hover:text-white data-[active]:border-emerald-500 data-[active]:bg-emerald-500/10 data-[active]:text-white"
                data-style={s}
                aria-pressed={theme.background_style === s}
              >
                {s === 'solid' ? 'Uni' : s === 'gradient' ? 'Dégradé' : 'Givré'}
              </button>
            ))}
          </div>

          <div id="gradient-panel" class:list={['space-y-6', theme.background_style !== 'gradient' && 'hidden']}>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div class="space-y-3">
                <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Couleur A</label>
                <div class="flex gap-3">
                  <input type="color" id="gradient_color_1" value={theme.background_color} class="color-swatch w-12 h-12 rounded-xl border border-white/10" />
                  <input type="text" id="gradient_color_1_hex" value={theme.background_color} maxlength="7" class="flex-1 glass rounded-xl px-4 py-2.5 text-sm font-mono" />
                </div>
              </div>
              <div class="space-y-3">
                <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Couleur B</label>
                <div class="flex gap-3">
                  <input type="color" id="gradient_color_2" value={theme.gradient_color_2} class="color-swatch w-12 h-12 rounded-xl border border-white/10" />
                  <input type="text" id="gradient_color_2_hex" value={theme.gradient_color_2} maxlength="7" class="flex-1 glass rounded-xl px-4 py-2.5 text-sm font-mono" />
                </div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              {['linear', 'radial'].map(t => (
                <button
                  class="gradient-type py-3 rounded-2xl glass border-2 border-white/8 hover:border-emerald-500/40 data-[active]:border-emerald-500 data-[active]:bg-emerald-500/10 transition-all"
                  data-type={t}
                >
                  {t === 'linear' ? 'Linéaire ⟶' : 'Radial ◎'}
                </button>
              ))}
            </div>

            <div id="angle-container" class:list={['space-y-4', theme.gradient_type !== 'linear' && 'hidden']}>
              <div class="flex justify-between text-xs text-gray-400">
                <span>Angle</span>
                <span id="angle-display">{theme.gradient_angle}°</span>
              </div>
              <input type="range" id="gradient_angle" min="0" max="360" value={theme.gradient_angle} class="w-full accent-emerald-500" />
              <div class="flex flex-wrap gap-2">
                {[0, 45, 90, 135, 180, 225, 270, 315].map(a => (
                  <button class="angle-preset text-xs px-3 py-1.5 glass rounded-lg hover:border-emerald-500/40 data-[active]:border-emerald-500 transition-colors" data-angle={a}>
                    {a}°
                  </button>
                ))}
              </div>
            </div>
          </div>

          <div id="blur-hint" class:list={['p-5 glass rounded-2xl border border-white/8 text-sm text-gray-300 leading-relaxed', theme.background_style !== 'blur' && 'hidden']}>
            Effet verre givré — l'intensité est contrôlée par le curseur « Intensité Glass » ci-dessus.
          </div>
        </div>
      </Card>

      <Card title="Style des boutons" description="Apparence de tes liens">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {[
            { id: 'filled', label: 'Plein', preview: 'bg-gradient-to-br from-emerald-500 to-teal-600 text-white' },
            { id: 'outline', label: 'Contour', preview: 'border-2 border-emerald-400/70 text-emerald-300' },
            { id: 'shadow', label: 'Glow', preview: 'bg-emerald-500/90 shadow-[0_0_24px_#00ff9d80] text-black' },
            { id: 'minimal', label: 'Minimal', preview: 'text-emerald-400 hover:underline' },
          ].map(s => (
            <button
              class="style-btn group p-4 glass rounded-2xl border-2 border-transparent hover:border-emerald-500/30 transition-all data-[active]:border-emerald-500 data-[active]:bg-emerald-500/10"
              data-style={s.id}
            >
              <div class={`h-14 rounded-xl flex items-center justify-center text-sm font-semibold transition-transform group-hover:scale-105 ${s.preview}`}>
                Bouton
              </div>
              <p class="mt-3 text-xs text-center text-gray-300 font-medium">{s.label}</p>
            </button>
          ))}
        </div>
      </Card>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 xl:gap-8">
        <Card title="Coins" description="Arrondi & douceur">
          <div class="space-y-6">
            <div class="grid grid-cols-6 gap-2">
              {[0, 8, 14, 20, 28, 40].map(r => (
                <button
                  class="radius-preset py-2.5 text-xs font-medium glass rounded-xl hover:border-emerald-500/40 data-[active]:border-emerald-500 data-[active]:bg-emerald-500/10 transition-colors"
                  data-radius={r}
                >
                  {r}
                </button>
              ))}
            </div>
            <div class="space-y-3">
              <input type="range" id="border_radius" min="0" max="40" step="2" value={theme.border_radius} class="w-full accent-emerald-500" />
              <div class="flex justify-between text-xs text-gray-400">
                <span>Pointu</span>
                <span id="radius-display">{theme.border_radius}px</span>
                <span>Pilule</span>
              </div>
            </div>
          </div>
        </Card>

        <Card title="Typographie" description="Police d'écriture">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {ALLOWED_FONTS.map(f => (
              <button
                class="font-swatch py-4 px-3 glass rounded-2xl border-2 border-transparent hover:border-emerald-500/30 data-[active]:border-emerald-500 data-[active]:bg-emerald-500/10 transition-all text-sm truncate"
                style={`font-family: "${f}", system-ui, sans-serif;`}
                data-font={f}
              >
                {f}
              </button>
            ))}
          </div>
        </Card>
      </div>

      <Card title="Préférences" description="Options supplémentaires">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { id: 'block_shadow', label: 'Ombres en profondeur', desc: 'Effet 3D sur les blocs' },
            { id: 'animations', label: 'Micro-animations', desc: 'Effets au survol et clic' },
          ].map(opt => (
            <label class="group flex items-center justify-between p-5 glass rounded-2xl cursor-pointer hover:bg-white/5 transition-colors border border-white/10">
              <div>
                <div class="font-medium">{opt.label}</div>
                <div class="text-xs text-gray-400 mt-0.5">{opt.desc}</div>
              </div>
              <div class="relative inline-flex items-center cursor-pointer">
                <input
                  type="checkbox"
                  id={opt.id}
                  checked={theme[opt.id as keyof Theme]}
                  class="sr-only peer"
                />
                <div class="w-12 h-7 bg-white/10 rounded-full peer peer-checked:bg-emerald-600/70 transition-colors duration-200"></div>
                <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-all duration-200 peer-checked:translate-x-5 shadow-md"></div>
              </div>
            </label>
          ))}
        </div>
      </Card>

      <div class="flex flex-wrap gap-4 pt-4">
        <Button id="save-theme-btn" variant="primary" size="lg" className="flex-1 min-w-[160px]">
          <span id="save-text">Enregistrer le thème</span>
        </Button>
        <Button id="reset-theme-btn" variant="outline" size="lg">Réinitialiser</Button>
        <Button variant="secondary" href={`/${profile.username}`} target="_blank" size="lg">
          Aperçu en direct →
        </Button>
      </div>

    </div>

    <div class="lg:col-span-4 space-y-6 xl:space-y-8">
      <div class="sticky top-6 space-y-6 xl:space-y-8">

        <Card title="Aperçu en direct" description="Ton profil en temps réel" className="overflow-hidden">
          <div class="relative rounded-3xl overflow-hidden aspect-[9/16] max-h-[640px] bg-black/40 border border-white/5 shadow-2xl">
            <iframe
              id="preview-iframe"
              class="absolute inset-0 w-full h-full border-0"
              sandbox="allow-same-origin allow-scripts"
              title="Aperçu du thème du profil"
              loading="lazy"
            ></iframe>
            <div class="pointer-events-none absolute top-0 inset-x-0 h-6 flex justify-center">
              <div class="w-28 h-1.5 bg-white/15 rounded-b-3xl"></div>
            </div>
          </div>
        </Card>

        <Card title="Historique" description="Versions récentes (local)">
          <div id="history-list" class="space-y-3 min-h-[180px]">
            <p class="text-center text-sm text-gray-500 py-8">Aucune version enregistrée pour l'instant</p>
          </div>
        </Card>

      </div>
    </div>
  </div>

</DashboardLayout>

<style is:global>
  .glass {
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  }

  input[type="color"].color-swatch {
    -webkit-appearance: none;
    appearance: none;
    padding: 3px;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
  }
  input[type="color"].color-swatch::-webkit-color-swatch-wrapper { padding: 0; }
  input[type="color"].color-swatch::-webkit-color-swatch { border: none; border-radius: 10px; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  [data-active] {
    border-color: #10b981 !important;
    background: rgba(16, 185, 129, 0.12) !important;
    color: white !important;
  }

  .preset-btn.active {
    border-color: #10b981 !important;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.3);
  }
</style>

<script is:inline>
if (typeof window !== "undefined") {

  document.addEventListener("DOMContentLoaded", function () {

    const serverData = document.getElementById("server-data");
    if (!serverData) return;

    const initialTheme = JSON.parse(serverData.dataset.theme || "{}");
    const profileData = JSON.parse(serverData.dataset.profile || "{}");
    const defaultTheme = JSON.parse(serverData.dataset.defaultTheme || "{}");

    let currentTheme = { ...initialTheme };

    function sanitizeHex(v) {
      return /^#[0-9A-Fa-f]{6}$/.test(v) ? v : null;
    }

    function clamp(v, min, max) {
      v = Number(v);
      if (!Number.isFinite(v)) return min;
      return Math.min(Math.max(v, min), max);
    }

    function updatePreview() {
      const iframe = document.getElementById("preview-iframe");
      if (!iframe) return;

      const bg =
        currentTheme.background_style === "gradient"
          ? currentTheme.gradient_type === "radial"
            ? "radial-gradient(circle at center," +
              currentTheme.background_color +
              "," +
              currentTheme.gradient_color_2 +
              ")"
            : "linear-gradient(" +
              currentTheme.gradient_angle +
              "deg," +
              currentTheme.background_color +
              "," +
              currentTheme.gradient_color_2 +
              ")"
          : currentTheme.background_color;

      iframe.srcdoc =
        "<html><body style='margin:0;padding:40px;background:" +
        bg +
        ";color:" +
        currentTheme.text_color +
        ";font-family:" +
        currentTheme.font_family +
        ",system-ui'>" +
        "<h2 style='text-align:center'>" +
        (profileData.display_name || "Toi") +
        "</h2>" +
        "<button style='width:100%;padding:14px;margin-top:30px;border-radius:" +
        currentTheme.border_radius +
        "px;background:" +
        currentTheme.primary_color +
        ";border:none;font-weight:600'>Portfolio</button>" +
        "</body></html>";
    }

    function applyTheme(partial) {
      currentTheme = Object.assign({}, currentTheme, partial);
      updatePreview();
    }

    /* SAVE */

    const saveBtn = document.getElementById("save-theme-btn");
    if (saveBtn) {
      saveBtn.addEventListener("click", async function () {
        try {
          const res = await fetch("/api/profile", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ theme: currentTheme })
          });

          if (!res.ok) throw new Error();
          if (window.toast) toast.success("Thème enregistré ✨");

        } catch (e) {
          if (window.toast) toast.error("Erreur lors de l'enregistrement");
        }
      });
    }

    /* RESET */

    const resetBtn = document.getElementById("reset-theme-btn");
    if (resetBtn) {
      resetBtn.addEventListener("click", function () {
        if (confirm("Réinitialiser le thème ?")) {
          currentTheme = Object.assign({}, defaultTheme);
          updatePreview();
          if (window.toast) toast.info("Thème réinitialisé");
        }
      });
    }

    updatePreview();
  });
}
</script>
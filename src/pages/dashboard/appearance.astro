---
// src/pages/dashboard/appearance.astro — v3
// Hero · Layout · Social icons · Hover FX · Overlays · Tout free sauf CSS custom + IA

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { withAuth } from '@/lib/auth/auth';

const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) {
  return Astro.redirect(authResult.redirect || '/signin?error=auth_failed');
}
const { profile, planLimits } = authResult.data;

// ── Plan detection ──────────────────────────────────────────────────────────
const PAID_TIERS = ['Creator','Pro','Enterprise' ];
const PRO_TIERS  = ['Pro','Enterprise' ];
const plan: string = (planLimits as any)?.plan ?? (profile as any)?.plan ?? 'Free';
const isCreator = PAID_TIERS.includes(plan);
const isPro     = PRO_TIERS.includes(plan);

// ── Defaults ────────────────────────────────────────────────────────────────
const DEFAULT_THEME = {
  // Core colors
  preset:           'dark',
  background_color: '#0a0a0a',
  gradient_color_2: '#1a1a2e',
  primary_color:    '#00ff9d',
  text_color:       '#ffffff',
  // Background
  background_style: 'solid',
  gradient_type:    'linear',
  gradient_angle:   135,
  pattern:          'none',
  pattern_opacity:  15,
  // Layout (NEW)
  profile_layout:   'centered',   // centered | left | card | minimal
  header_style:     'simple',     // simple | glass | banner | hero
  hero_image:       '',
  hero_position:    'center',     // top | center | bottom
  hero_height:      'md',         // sm | md | lg | full
  hero_overlay:     40,           // 0-80 opacity %
  content_width:    'normal',     // narrow | normal | wide
  // Avatar
  avatar_shape:     'circle',
  avatar_size:      'md',         // sm | md | lg
  avatar_border:    'glow',       // none | solid | glow | gradient | double
  // Bio
  bio_size:         'sm',         // xs | sm | md | lg
  bio_style:        'normal',     // normal | italic
  show_username:    true,
  // Social icons
  social_icon_style:'round',      // round | square | pill | ghost | colored
  // Buttons
  button_style:     'filled',
  border_radius:    14,
  shadow_intensity: 3,            // 0-5
  hover_effect:     'lift',       // none | lift | glow | slide | ripple
  button_width:     'full',       // full | auto
  // Typography
  font_family:      'Exo 2',
  // Effects
  animations:       true,
  animation_preset: 'fade',
  scroll_reveal:    true,
  click_ripple:     false,
  hover_scale:      3,            // 0-5
  block_shadow:     true,
  glass_intensity:  12,
  spacing:          'normal',
  // Overlays
  overlay_top:      false,
  overlay_bottom:   false,
  overlay_color:    '#000000',
  // Links appearance
  link_separator:   'none',      // none | line | dots | gradient | glow
  link_icon_pos:    'left',      // left | right | none
  link_subtitle:    false,       // show subtitle under link text
  link_hover_fill:  false,       // fill bg on hover
  // Logo (Creator+)
  show_logo:        false,
  logo_url:         '',
  logo_size:        'md',         // sm | md | lg (lg = Pro)
  // Wallpaper (Creator+ = image, Pro = video)
  wallpaper_type:   'none',       // none | image | video
  wallpaper_url:    '',
  wallpaper_video_url: '',
  wallpaper_blur:   0,            // 0-20
  wallpaper_dim:    50,           // 0-90 opacity of dim overlay
  // Custom font (Pro)
  custom_font_url:  '',
  custom_font_name: '',
};

const ALLOWED_FONTS = [
  // Gratuites — toutes
  'Exo 2','Orbitron','Rajdhani','Bebas Neue','Audiowide','Russo One',
  'Space Grotesk','DM Sans','Quicksand','Figtree','Inter','Syne',
  'Cabinet Grotesk','Outfit','Plus Jakarta Sans','Nunito','Poppins',
  'Josefin Sans','Archivo','Barlow','Rubik','Work Sans','Manrope',
  'Space Mono','JetBrains Mono','Fira Code',
  // Serif
  'Playfair Display','Lora','Merriweather','DM Serif Display',
  // Display
  'Bungee','Righteous','Teko','Oswald','Anton',
];
const ALLOWED_LAYOUTS = ['centered','left','card','minimal'] as const;
const ALLOWED_HEADERS = ['simple','glass','banner','hero'] as const;

function hex(v: string, fb: string) { return /^#[0-9A-Fa-f]{6}$/.test(v) ? v : fb; }
function clamp(n: unknown, mn: number, mx: number, fb: number) { const v=Number(n); return isFinite(v)?Math.min(Math.max(v,mn),mx):fb; }
function pick<T extends string>(v: unknown, opts: readonly T[], fb: T): T { return opts.includes(v as T) ? v as T : fb; }

let theme: any = { ...DEFAULT_THEME };
if (profile.theme) {
  try {
    const r = typeof profile.theme === 'string' ? JSON.parse(profile.theme) : profile.theme;
    theme = {
      ...DEFAULT_THEME, ...r,
      background_color: hex(r.background_color, DEFAULT_THEME.background_color),
      gradient_color_2: hex(r.gradient_color_2, DEFAULT_THEME.gradient_color_2),
      primary_color:    hex(r.primary_color,    DEFAULT_THEME.primary_color),
      text_color:       hex(r.text_color,       DEFAULT_THEME.text_color),
      overlay_color:    hex(r.overlay_color,    DEFAULT_THEME.overlay_color),
      font_family:      ALLOWED_FONTS.includes(r.font_family) ? r.font_family : DEFAULT_THEME.font_family,
      border_radius:    clamp(r.border_radius, 0, 40, 14),
      gradient_angle:   clamp(r.gradient_angle, 0, 360, 135),
      pattern_opacity:  clamp(r.pattern_opacity, 5, 60, 15),
      glass_intensity:  clamp(r.glass_intensity, 4, 32, 12),
      hero_overlay:     clamp(r.hero_overlay, 0, 80, 40),
      shadow_intensity: clamp(r.shadow_intensity, 0, 5, 3),
      hover_scale:      clamp(r.hover_scale, 0, 5, 3),
      profile_layout:   pick(r.profile_layout,   ALLOWED_LAYOUTS, 'centered'),
      header_style:     pick(r.header_style,      ALLOWED_HEADERS, 'simple'),
      background_style: pick(r.background_style, ['solid','gradient','blur'] as const, 'solid'),
      gradient_type:    pick(r.gradient_type,    ['linear','radial'] as const, 'linear'),
      button_style:     pick(r.button_style,     ['filled','outline','glass','gradient','neon','minimal'] as const, 'filled'),
      animation_preset: pick(r.animation_preset, ['none','fade','slide','bounce','stagger'] as const, 'fade'),
      avatar_shape:     pick(r.avatar_shape,     ['circle','square','hex','ring'] as const, 'circle'),
      avatar_size:      pick(r.avatar_size,      ['sm','md','lg'] as const, 'md'),
      avatar_border:    pick(r.avatar_border,    ['none','solid','glow','gradient','double'] as const, 'glow'),
      social_icon_style:pick(r.social_icon_style,['round','square','pill','ghost','colored'] as const, 'round'),
      hover_effect:     pick(r.hover_effect,     ['none','lift','glow','slide','ripple'] as const, 'lift'),
      button_width:     pick(r.button_width,     ['full','auto'] as const, 'full'),
      spacing:          pick(r.spacing,          ['compact','normal','spacious'] as const, 'normal'),
      pattern:          pick(r.pattern,          ['none','dots','grid','waves','noise','mesh','crosshatch','triangles'] as const, 'none'),
      hero_height:      pick(r.hero_height,      ['sm','md','lg','full'] as const, 'md'),
      hero_position:    pick(r.hero_position,    ['top','center','bottom'] as const, 'center'),
      content_width:    pick(r.content_width,    ['narrow','normal','wide'] as const, 'normal'),
      bio_size:         pick(r.bio_size,         ['xs','sm','md','lg'] as const, 'sm'),
      bio_style:        pick(r.bio_style,        ['normal','italic'] as const, 'normal'),
    };
  } catch { /* keep defaults */ }
}

const themeJson   = JSON.stringify(theme);
const profileJson = JSON.stringify({
  display_name: profile.display_name ?? '',
  username:     profile.username ?? '',
  bio:          profile.bio ?? '',
  avatar_url:   profile.avatar_url ?? '',
});

// All presets — ALL FREE
const PRESETS = [
  // ── Free (4 presets) ────────────────────────────────────────────────────────
  { id:'dark',     label:'Dark',     bg:'#0a0a0a', p:'#00ff9d', t:'#ffffff', g2:'#0f1f15',  tier:'free' },
  { id:'light',    label:'Light',    bg:'#f8f8f8', p:'#0066ff', t:'#0a0a0a', g2:'#e8f0ff',  tier:'free' },
  { id:'neon',     label:'Neon',     bg:'#1a0033', p:'#bf00ff', t:'#ffffff', g2:'#0d001a',  tier:'free' },
  { id:'ocean',    label:'Ocean',    bg:'#001a33', p:'#00d4ff', t:'#ffffff', g2:'#002244',  tier:'free' },
  // ── Creator ─────────────────────────────────────────────────────────────────
  { id:'sunset',   label:'Sunset',   bg:'#1a0800', p:'#ff6b00', t:'#ffffff', g2:'#2d0a00',  tier:'creator' },
  { id:'forest',   label:'Forest',   bg:'#0d1f0d', p:'#00cc66', t:'#ffffff', g2:'#0a1a0a',  tier:'creator' },
  { id:'rose',     label:'Rose',     bg:'#1a0a0f', p:'#ff2d78', t:'#ffffff', g2:'#0d0508',  tier:'creator' },
  { id:'gold',     label:'Gold',     bg:'#120d00', p:'#ffd700', t:'#ffffff', g2:'#1f1500',  tier:'creator' },
  { id:'cyber',    label:'Cyber',    bg:'#000d1a', p:'#00ffff', t:'#ffffff', g2:'#001433',  tier:'creator' },
  { id:'obsidian', label:'Obsidian', bg:'#0d0d0d', p:'#6366f1', t:'#ffffff', g2:'#13111a',  tier:'creator' },
  { id:'aurora',   label:'Aurora',   bg:'#04080f', p:'#00ff9d', t:'#ffffff', g2:'#0a1628',  tier:'creator' },
  { id:'sand',     label:'Sand',     bg:'#1a1510', p:'#e8a84c', t:'#f5e6d0', g2:'#120f08',  tier:'creator' },
  // ── Pro ─────────────────────────────────────────────────────────────────────
  { id:'midnight', label:'Midnight', bg:'#000010', p:'#4f46e5', t:'#e0e0ff', g2:'#100020',  tier:'pro' },
  { id:'blood',    label:'Blood',    bg:'#0d0000', p:'#ef4444', t:'#ffe0e0', g2:'#200000',  tier:'pro' },
  { id:'matrix',   label:'Matrix',   bg:'#000a00', p:'#00ff41', t:'#ccffcc', g2:'#001a00',  tier:'pro' },
  { id:'hologram', label:'Hologram', bg:'#010115', p:'#a78bfa', t:'#ffffff', g2:'#0a0a30',  tier:'pro' },
];
---

<DashboardLayout title="Appearance">
<style>
  .sec-tab { transition:all 0.2s; }
  .sec-tab.active { color:white; background:rgba(0,255,157,0.1); border-color:rgba(0,255,157,0.3); }
  .sec-panel { display:none; }
  .sec-panel.active { display:block; animation:fadeInUp 0.22s ease both; }
  @keyframes fadeInUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }

  .active-ring { outline:2px solid rgba(0,255,157,0.8); outline-offset:2px; }
  .choice-btn { transition:all 0.15s; }
  .choice-btn.active { border-color:rgba(0,255,157,0.7)!important; background:rgba(0,255,157,0.06)!important; color:white!important; }

  input[type="color"].swatch { -webkit-appearance:none; appearance:none; }
  input[type="color"].swatch::-webkit-color-swatch-wrapper { padding:2px; }
  input[type="color"].swatch::-webkit-color-swatch { border:none; border-radius:8px; }

  input[type="checkbox"].toggle { transition:background-color 0.2s; }
  input[type="checkbox"].toggle::after { content:''; position:absolute; width:18px; height:18px; border-radius:50%; background:white; top:3px; left:3px; transition:left 0.2s; }
  input[type="checkbox"].toggle:checked { background-color:rgba(0,255,157,0.8); }
  input[type="checkbox"].toggle:checked::after { left:calc(100% - 21px); }

  /* Phone */
  .phone-frame { position:relative; width:260px; background:#111; border-radius:42px; padding:14px 10px; box-shadow:0 0 0 2px #2a2a2a,0 0 0 4px #1a1a1a,0 32px 80px rgba(0,0,0,0.8); margin:0 auto; flex-shrink:0; }
  .phone-notch { position:absolute; top:14px; left:50%; transform:translateX(-50%); width:90px; height:26px; background:#111; border-radius:0 0 16px 16px; z-index:10; display:flex; align-items:center; justify-content:center; gap:6px; }
  .phone-notch::before { content:''; width:8px; height:8px; border-radius:50%; background:#1e1e1e; border:1px solid #2a2a2a; }
  .phone-notch::after  { content:''; width:36px; height:4px; border-radius:2px; background:#1a1a1a; }
  .phone-screen { border-radius:32px; overflow:hidden; height:500px; background:#0a0a0a; }
  .phone-screen iframe { width:100%; height:100%; border:0; }
  .phone-btn { position:absolute; width:3px; background:#222; border-radius:2px; }

  /* Lock badges */
  .badge-creator { display:inline-flex; align-items:center; gap:2px; padding:1px 5px; border-radius:5px; font-size:9px; font-weight:700; background:rgba(0,255,157,0.12); color:#00ff9d; border:1px solid rgba(0,255,157,0.3); }
  .badge-pro     { display:inline-flex; align-items:center; gap:2px; padding:1px 5px; border-radius:5px; font-size:9px; font-weight:700; background:rgba(168,85,247,0.15); color:#c084fc; border:1px solid rgba(168,85,247,0.35); }

  /* AI lock overlay */
  .pro-gate { position:relative; overflow:hidden; border-radius:inherit; }
  .pro-gate-overlay { position:absolute; inset:0; z-index:10; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; backdrop-filter:blur(6px); background:rgba(0,0,0,0.65); border-radius:inherit; }

  /* Prog dots */
  .prog-dot { transition:all 0.2s; }
  .prog-dot.active { background:#00ff9d; width:20px; border-radius:4px; }

  #save-btn.loading { opacity:0.6; pointer-events:none; }
  @keyframes blink{0%,100%{opacity:0.2}50%{opacity:1}}
  .ai-dot { animation:blink 1.2s infinite; }
  .ai-dot:nth-child(2){animation-delay:0.2s;}
  .ai-dot:nth-child(3){animation-delay:0.4s;}

  /* Hover FX preview */
  .hfx-preview { transition:all 0.2s; }
  .hfx-lift:hover    { transform:translateY(-3px); box-shadow:0 8px 20px rgba(0,0,0,0.4); }
  .hfx-glow:hover    { box-shadow:0 0 20px var(--p,#00ff9d)80; }
  .hfx-slide:hover   { background-position:right center !important; }
  .device-tab.active svg { color:#00ff9d; }
</style>

  <!-- Header -->
  <div class="flex items-start justify-between mb-6 flex-wrap gap-3">
    <div>
      <h2 class="text-xl font-semibold text-white mb-1">Appearance</h2>
      <p class="text-sm text-gray-500">Personnalise l'apparence de ton profil BioForge</p>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <a href={`/@${profile.username}`} target="_blank"
        class="flex items-center gap-2 px-3 py-2 glass border border-neon-green/20 rounded-xl text-xs text-neon-green hover:bg-neon-green/10 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Voir profil
      </a>
      <!-- Export Creator / Import Creator -->
      <button id="export-btn" class="flex items-center gap-1.5 px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-400 hover:text-white hover:border-white/20 transition-all">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Export
        {!isCreator && <span class="badge-creator">Creator</span>}
      </button>
      <label class="flex items-center gap-1.5 px-3 py-2 glass border border-white/10 rounded-xl text-xs text-gray-400 hover:text-white hover:border-white/20 transition-all cursor-pointer">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Import
        {!isCreator && <span class="badge-creator">Creator</span>}
        <input type="file" id="import-file" accept=".json" class="hidden" />
      </label>
    </div>
  </div>

  <div id="server-data" class="hidden" data-theme={themeJson} data-profile={profileJson} data-plan={plan} data-is-pro={String(isPro)} data-is-creator={String(isCreator)}></div>

  <div class="grid lg:grid-cols-5 gap-6 items-start">
    <!-- ═══ LEFT PANELS ═══ -->
    <div class="lg:col-span-3 space-y-4">

      <!-- Section tabs -->
      <div class="flex items-center gap-1.5 flex-wrap">
        {[
          { id:'presets',    label:'🎨 Presets'  },
          { id:'layout',     label:'📐 Layout'   },
          { id:'background', label:'🖼 Fond'     },
          { id:'buttons',    label:'🔘 Boutons'  },
          { id:'links',      label:'🔗 Liens'    },
          { id:'profile',    label:'👤 Profil'   },
          { id:'typography', label:'✍ Typo'     },
          { id:'effects',    label:'✨ Effets'   },
          { id:'advanced',   label:'⚙ Avancé'   },
          { id:'ai',         label:'✦ IA'        },
        ].map((s, i) => (
          <button class={`sec-tab px-3 py-2 rounded-xl text-xs font-semibold border border-white/8 text-gray-500 hover:text-gray-300 hover:border-white/15 ${i===0?'active':''} ${s.id==='ai'?'text-neon-green/70 border-neon-green/20 hover:border-neon-green/40':''}`}
            data-section={s.id}>
            {s.label}
            {s.id==='advanced' && !isPro && <span class="badge-pro ml-1">Pro</span>}
            {s.id==='ai' && !isCreator && <span class="badge-creator ml-1">Creator</span>}
          </button>
        ))}
      </div>

      <!-- ══ PRESETS ══ -->
      <div class="sec-panel active" id="panel-presets">
        <div class="p-5 glass rounded-2xl border border-white/8 space-y-5">
          <div>
            <p class="text-sm font-semibold text-white">Thèmes prédéfinis</p>
            <p class="text-xs text-gray-500 mt-0.5">4 thèmes gratuits · 8 Creator · 4 Pro — tous testables</p>
          </div>

          {/* Free */}
          <div>
            <p class="text-xs text-gray-600 uppercase tracking-widest font-medium mb-2">Gratuits</p>
            <div class="grid grid-cols-4 gap-2">
              {PRESETS.filter(p => p.tier === 'free').map(p => (
                <button class="preset-btn group flex flex-col rounded-xl overflow-hidden border-2 border-white/8 hover:border-white/25 transition-all hover:scale-[1.04] active:scale-[0.97]"
                  data-preset={p.id} data-bg={p.bg} data-primary={p.p} data-text={p.t} data-g2={p.g2} data-tier="free">
                  <div class="h-12 w-full relative" style={`background:linear-gradient(135deg,${p.bg},${p.g2})`}>
                    <div class="absolute bottom-2 right-2 w-3 h-3 rounded-full" style={`background:${p.p}`}></div>
                  </div>
                  <div class="py-1.5 text-center bg-white/4">
                    <span class="text-xs text-gray-400" style="font-size:10px">{p.label}</span>
                  </div>
                </button>
              ))}
            </div>
          </div>

          {/* Creator */}
          <div>
            <div class="flex items-center gap-2 mb-2">
              <p class="text-xs text-gray-600 uppercase tracking-widest font-medium">Creator</p>
              <span class="badge-creator">👑</span>
              {!isCreator && <span class="text-xs text-gray-600">— testables, non sauvegardables</span>}
            </div>
            <div class="grid grid-cols-4 gap-2">
              {PRESETS.filter(p => p.tier === 'creator').map(p => (
                <button class="preset-btn group flex flex-col rounded-xl overflow-hidden border-2 transition-all hover:scale-[1.04] active:scale-[0.97] relative"
                  style={isCreator ? 'border-color:rgba(0,255,157,0.15)' : 'border-color:rgba(255,255,255,0.08)'}
                  data-preset={p.id} data-bg={p.bg} data-primary={p.p} data-text={p.t} data-g2={p.g2} data-tier="creator">
                  <div class="h-12 w-full relative" style={`background:linear-gradient(135deg,${p.bg},${p.g2})`}>
                    <div class="absolute bottom-2 right-2 w-3 h-3 rounded-full" style={`background:${p.p}`}></div>
                    {!isCreator && <div class="absolute inset-0 flex items-center justify-center bg-black/40"><span style="font-size:14px">👑</span></div>}
                  </div>
                  <div class="py-1.5 text-center bg-white/4">
                    <span class="text-xs text-gray-400" style="font-size:10px">{p.label}</span>
                  </div>
                </button>
              ))}
            </div>
          </div>

          {/* Pro */}
          <div>
            <div class="flex items-center gap-2 mb-2">
              <p class="text-xs text-gray-600 uppercase tracking-widest font-medium">Pro</p>
              <span class="badge-pro">⚡</span>
              {!isPro && <span class="text-xs text-gray-600">— testables, non sauvegardables</span>}
            </div>
            <div class="grid grid-cols-4 gap-2">
              {PRESETS.filter(p => p.tier === 'pro').map(p => (
                <button class="preset-btn group flex flex-col rounded-xl overflow-hidden border-2 transition-all hover:scale-[1.04] active:scale-[0.97] relative"
                  style={isPro ? 'border-color:rgba(168,85,247,0.25)' : 'border-color:rgba(255,255,255,0.08)'}
                  data-preset={p.id} data-bg={p.bg} data-primary={p.p} data-text={p.t} data-g2={p.g2} data-tier="pro">
                  <div class="h-12 w-full relative" style={`background:linear-gradient(135deg,${p.bg},${p.g2})`}>
                    <div class="absolute bottom-2 right-2 w-3 h-3 rounded-full" style={`background:${p.p}`}></div>
                    {!isPro && <div class="absolute inset-0 flex items-center justify-center bg-black/50"><span style="font-size:14px">⚡</span></div>}
                  </div>
                  <div class="py-1.5 text-center bg-white/4">
                    <span class="text-xs text-gray-400" style="font-size:10px">{p.label}</span>
                  </div>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- ══ LAYOUT ══ -->
      <div class="sec-panel" id="panel-layout">
        <div class="p-5 glass rounded-2xl border border-white/8 space-y-6">
          <p class="text-sm font-semibold text-white">Layout & Structure</p>

          <!-- Profile layout -->
          <div class="space-y-3">
            <p class="text-xs text-gray-500 uppercase tracking-widest font-medium">Disposition du profil</p>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
              {[

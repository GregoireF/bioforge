  generatePalettes();
  renderHistory();
  document.querySelector('.prog-dot[data-for="presets"]')?.classList.add('active');

  // Init hero-settings visibility
  const heroSettings = document.getElementById('hero-settings');
  if (heroSettings) heroSettings.style.display = theme.header_style === 'hero' ? '' : 'none';
  // Init wallpaper panels
  document.getElementById('wallpaper-image-settings')?.classList.toggle('hidden', theme.wallpaper_type !== 'image');
  document.getElementById('wallpaper-video-settings')?.classList.toggle('hidden', theme.wallpaper_type !== 'video');
  // Init logo settings
  document.getElementById('logo-settings')?.classList.toggle('hidden', !theme.show_logo);
</script>
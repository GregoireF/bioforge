---
// src/pages/dashboard/onboarding.astro
import { withAuth } from '@/lib/auth/auth';

const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) return Astro.redirect('/signin');
const { profile } = authResult.data;

if ((profile as any)?.onboarding_completed_at) return Astro.redirect('/dashboard');

const avatarUrl        = profile?.avatar_url    ?? '';
const existingName     = profile?.display_name  ?? '';
const existingUsername = (profile as any)?.username ?? '';
---
<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>BioForge — Bienvenue</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            green: { DEFAULT: '#00ff9d', dark: '#00cc7a', glow: 'rgba(0,255,157,0.15)' },
            surface: { 1: '#0c0e11', 2: '#141719', 3: '#1c1f23' },
            ink: { 1: 'rgba(255,255,255,0.9)', 2: 'rgba(255,255,255,0.55)', 3: 'rgba(255,255,255,0.25)', 4: 'rgba(255,255,255,0.08)' }
          },
          fontFamily: { display: ['Cabinet Grotesk','system-ui','sans-serif'], body: ['DM Sans','system-ui','sans-serif'] },
          keyframes: {
            'slide-up': { '0%': { opacity:'0', transform:'translateY(20px)' }, '100%': { opacity:'1', transform:'translateY(0)' } },
            'fade-in':  { '0%': { opacity:'0' }, '100%': { opacity:'1' } },
            'step-in':  { '0%': { opacity:'0', transform:'translateX(24px)' }, '100%': { opacity:'1', transform:'translateX(0)' } },
            'step-out': { '0%': { opacity:'1', transform:'translateX(0)' }, '100%': { opacity:'0', transform:'translateX(-24px)' } },
            'pulse-dot':{ '0%,100%':{ boxShadow:'0 0 0 0 rgba(0,255,157,0.5)' }, '50%':{ boxShadow:'0 0 0 6px rgba(0,255,157,0)' } },
            'shimmer':  { '0%':{ backgroundPosition:'200% 0' }, '100%':{ backgroundPosition:'-200% 0' } },
            'pop':      { '0%':{ transform:'scale(0) rotate(-12deg)', opacity:'0' }, '60%':{ transform:'scale(1.12) rotate(2deg)' }, '100%':{ transform:'scale(1) rotate(0)', opacity:'1' } },
            'confetti-fall': { 'to':{ transform:'translateY(110vh) rotate(720deg)', opacity:'0' } },
          },
          animation: {
            'slide-up':    'slide-up 0.5s cubic-bezier(0.22,1,0.36,1) both',
            'fade-in':     'fade-in 0.4s ease both',
            'step-in':     'step-in 0.35s cubic-bezier(0.22,1,0.36,1) both',
            'step-out':    'step-out 0.2s ease forwards',
            'pulse-dot':   'pulse-dot 2s ease-in-out infinite',
            'shimmer':     'shimmer 2s linear infinite',
            'pop':         'pop 0.5s cubic-bezier(0.34,1.56,0.64,1) both',
            'confetti-fall':'confetti-fall linear forwards',
          },
          backgroundImage: {
            'noise': "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E\")",
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@500;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet"/>
  <style>
    *{ -webkit-font-smoothing: antialiased }
    /* ── RESET — isoler la page de global.css ── */
    html, body { all: revert }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
    body{ font-family: 'DM Sans', sans-serif; background: #080a0d; color: white }
    a { text-decoration: none; color: inherit }
    button { font-family: inherit; cursor: pointer; background: none; border: none }
    .font-display{ font-family: 'Cabinet Grotesk', sans-serif }

    /* Panels */
    .panel { display: none }
    .panel.active { display: block }
    @keyframes step-out { 0% { opacity:1; transform:translateX(0) } 100% { opacity:0; transform:translateX(-24px) } }
    @keyframes shimmer  { 0% { background-position:200% 0 } 100% { background-position:-200% 0 } }
    @keyframes pulse-dot { 0%,100% { box-shadow:0 0 0 0 rgba(0,255,157,0.5) } 50% { box-shadow:0 0 0 6px rgba(0,255,157,0) } }
    .panel.leaving { animation: step-out 0.2s ease forwards; pointer-events: none }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px }
    ::-webkit-scrollbar-track { background: transparent }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px }

    /* Input focus ring */
    .inp:focus { outline: none; border-color: rgba(0,255,157,0.45); background: rgba(0,255,157,0.025); box-shadow: 0 0 0 3px rgba(0,255,157,0.07) }
    .inp.ok    { border-color: #00ff9d }
    .inp.bad   { border-color: #ff5050 }

    /* Preset card selected ring */
    .preset.selected { border-color: #00ff9d; box-shadow: 0 0 0 1px #00ff9d, 0 8px 24px rgba(0,255,157,0.12) }
    .preset.selected .pcheck { display: grid }

    /* Usage btn */
    .ubtn.selected { border-color: #00ff9d; background: rgba(0,255,157,0.07); color: #00ff9d }

    /* Chip */
    .chip.selected { border-color: #00ff9d; background: rgba(0,255,157,0.07); color: #00ff9d }

    /* NPS */
    .nps.selected { background: #00ff9d; border-color: #00ff9d; color: #000; transform: scale(1.08); box-shadow: 0 4px 14px rgba(0,255,157,0.3) }

    /* Step dot active */
    .sdot.active { background: #00ff9d; animation: pulse-dot 2s ease-in-out infinite }
    .sdot.done   { background: #00cc7a; width: 20px; border-radius: 4px }

    /* Shimmer loader */
    .checking {
      background: linear-gradient(90deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.12) 50%, rgba(255,255,255,0.05) 100%);
      background-size: 200% 100%;
      animation: shimmer 1.5s linear infinite;
    }

    /* Phone glow */
    .phone-glow { transition: box-shadow 0.4s ease }
    .phone-glow:hover { box-shadow: 0 0 60px rgba(0,255,157,0.12), 0 40px 80px rgba(0,0,0,0.6) }

    /* CTA hover arrow */
    .cta-arrow { transition: transform 0.2s ease }
    button:not(:disabled):hover .cta-arrow { transform: translateX(4px) }
  </style>
</head>

<body class="h-full overflow-hidden bg-noise">

<!-- ══ ROOT ══════════════════════════════════════════════════════════════ -->
<div class="flex flex-col h-full lg:flex-row">


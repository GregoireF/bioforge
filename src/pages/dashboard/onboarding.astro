        <div class="grid grid-cols-2 gap-2 mb-6">
          <button class="ubtn flex items-center gap-2.5 border border-white/[0.09] rounded-xl px-3.5 py-2.5 text-[13px] text-white/50 font-medium transition-all duration-150 hover:text-white hover:border-white/20 text-left" data-u="creator"><span class="text-base">🎥</span>Créateur</button>
          <button class="ubtn flex items-center gap-2.5 border border-white/[0.09] rounded-xl px-3.5 py-2.5 text-[13px] text-white/50 font-medium transition-all duration-150 hover:text-white hover:border-white/20 text-left" data-u="dev"><span class="text-base">💻</span>Dev / Tech</button>
          <button class="ubtn flex items-center gap-2.5 border border-white/[0.09] rounded-xl px-3.5 py-2.5 text-[13px] text-white/50 font-medium transition-all duration-150 hover:text-white hover:border-white/20 text-left" data-u="brand"><span class="text-base">🏢</span>Marque</button>
          <button class="ubtn flex items-center gap-2.5 border border-white/[0.09] rounded-xl px-3.5 py-2.5 text-[13px] text-white/50 font-medium transition-all duration-150 hover:text-white hover:border-white/20 text-left" data-u="artist"><span class="text-base">🎨</span>Artiste</button>
          <button class="ubtn flex items-center gap-2.5 border border-white/[0.09] rounded-xl px-3.5 py-2.5 text-[13px] text-white/50 font-medium transition-all duration-150 hover:text-white hover:border-white/20 text-left" data-u="free"><span class="text-base">🚀</span>Freelance</button>
          <button class="ubtn flex items-center gap-2.5 border border-white/[0.09] rounded-xl px-3.5 py-2.5 text-[13px] text-white/50 font-medium transition-all duration-150 hover:text-white hover:border-white/20 text-left" data-u="other"><span class="text-base">✨</span>Autre</button>
        </div>

        <!-- Source -->
        <p class="text-[11px] font-bold tracking-[0.08em] uppercase text-white/35 mb-2.5">Découvert via…</p>
        <div class="flex flex-wrap gap-2 mb-6">
          <button class="chip border border-white/[0.09] rounded-full px-3.5 py-1.5 text-[12px] text-white/45 font-medium transition-all duration-150 hover:text-white hover:border-white/20" data-s="social">Réseaux sociaux</button>
          <button class="chip border border-white/[0.09] rounded-full px-3.5 py-1.5 text-[12px] text-white/45 font-medium transition-all duration-150 hover:text-white hover:border-white/20" data-s="friend">Bouche à oreille</button>
          <button class="chip border border-white/[0.09] rounded-full px-3.5 py-1.5 text-[12px] text-white/45 font-medium transition-all duration-150 hover:text-white hover:border-white/20" data-s="search">Google</button>
          <button class="chip border border-white/[0.09] rounded-full px-3.5 py-1.5 text-[12px] text-white/45 font-medium transition-all duration-150 hover:text-white hover:border-white/20" data-s="ph">Product Hunt</button>
          <button class="chip border border-white/[0.09] rounded-full px-3.5 py-1.5 text-[12px] text-white/45 font-medium transition-all duration-150 hover:text-white hover:border-white/20" data-s="ad">Pub</button>
          <button class="chip border border-white/[0.09] rounded-full px-3.5 py-1.5 text-[12px] text-white/45 font-medium transition-all duration-150 hover:text-white hover:border-white/20" data-s="other">Autre</button>
        </div>

        <!-- NPS -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-2.5">
            <p class="text-[11px] font-bold tracking-[0.08em] uppercase text-white/35">Première impression</p>
            <span id="nps-lbl" class="text-[12px] text-white/30 transition-all duration-200">noter de 0 à 10</span>
          </div>
          <div class="flex gap-1.5">
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="0">0</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="1">1</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="2">2</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="3">3</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="4">4</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="5">5</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="6">6</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="7">7</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="8">8</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="9">9</button>
            <button class="nps flex-1 h-10 rounded-lg border border-white/[0.09] text-[12px] font-bold text-white/45 transition-all duration-150 hover:text-white hover:border-white/20" data-n="10">10</button>
          </div>
          <div class="flex justify-between mt-1.5">
            <span class="text-[10px] text-white/25">Pas convaincu</span>
            <span class="text-[10px] text-white/25">Excellent 🔥</span>
          </div>
        </div>

        <!-- Comment -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-2">
            <label class="text-[11px] font-bold tracking-[0.08em] uppercase text-white/35">Un mot <span class="normal-case tracking-normal font-normal text-white/25">— optionnel</span></label>
            <span class="text-[11px] text-white/25"><span id="fbc">0</span>/500</span>
          </div>
          <textarea id="fbi" rows="2" maxlength="500" placeholder="Ce que tu attends, une idée, un retour…"
            class="inp w-full bg-[#0c0e11] border border-white/[0.09] rounded-xl px-4 py-3 text-[14px] text-white placeholder-white/20 resize-none transition-all duration-200 focus:outline-none"></textarea>
        </div>

        <button id="cta-sub"
          class="group w-full flex items-center justify-center gap-2.5
            bg-[#00ff9d] text-black font-display font-extrabold text-[14px] tracking-[0.01em]
            py-3.5 rounded-xl transition-all duration-200
            hover:bg-[#1affa8] hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(0,255,157,0.22)]
            active:scale-[0.98] disabled:opacity-40 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none">
          <span id="sub-txt">Créer mon profil ✦</span>
          <svg class="cta-arrow w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
        <p class="text-center text-[12px] text-white/25 mt-3">Tu peux passer — vraiment 20 secondes 🙏</p>
      </div>

      <!-- ══ PANEL DONE ══ -->
      <div class="panel" id="pdone">
        <div class="w-16 h-16 rounded-full border-2 border-[#00ff9d] bg-[#00ff9d]/10 grid place-items-center text-2xl mb-7 animate-pop">✦</div>
        <p class="text-[11px] font-bold tracking-[0.12em] uppercase text-[#00ff9d] mb-4 flex items-center gap-2">
          <span class="block w-4 h-px bg-[#00ff9d]"></span>C'est parti !
        </p>
        <h1 class="font-display font-black text-[clamp(32px,6vw,52px)] leading-[0.96] tracking-[-0.03em] mb-3">
          Ton profil<em class="not-italic text-[#00ff9d]">est prêt</em>
        </h1>
        <p class="text-[15px] text-white/50 leading-relaxed mb-8">Tout est en place. Ajoute tes premiers liens et partage ton URL.</p>
        <div class="flex flex-col gap-3">
          <a id="done-href" href="#" target="_blank"
            class="flex items-center justify-between px-5 py-3.5 rounded-xl
              bg-[#00ff9d] text-black font-display font-extrabold text-[14px]
              transition-all hover:bg-[#1affa8] hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(0,255,157,0.22)]">
            Voir mon profil <span>→</span>
          </a>
          <a href="/dashboard"
            class="flex items-center justify-between px-5 py-3.5 rounded-xl
              border border-white/[0.09] text-white font-semibold text-[14px]
              transition-all hover:border-white/20 hover:translate-x-0.5">
            Aller au dashboard <span class="text-white/30">→</span>
          </a>
          <a href="/dashboard/appearance"
            class="flex items-center justify-between px-5 py-3.5 rounded-xl
              border border-white/[0.09] text-white font-semibold text-[14px]
              transition-all hover:border-white/20 hover:translate-x-0.5">
            Personnaliser l'apparence <span class="text-white/30">→</span>
          </a>
        </div>
      </div>

    </div><!-- /inner -->

    <!-- Desktop footer -->
    <div class="hidden lg:block px-14 pb-10 mt-auto pt-8 text-[12px] text-white/20">
      BioForge · <a href="/privacy" class="hover:text-white/40 transition-colors">Confidentialité</a>
    </div>

  </main>

  <!-- ══ RIGHT — Preview panel ══════════════════════════════════════════ -->
  <aside class="hidden lg:flex flex-col items-center justify-center flex-shrink-0
    w-[400px] border-l border-white/[0.06] relative overflow-hidden"
    style="background: #0a0c0f">

    <!-- Ambient radial glow -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 60%, rgba(0,255,157,0.07) 0%, transparent 70%)"></div>

    <!-- Grid pattern -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
      style="background-image: linear-gradient(rgba(255,255,255,0.8) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 40px 40px"></div>

    <p class="text-[11px] font-bold tracking-[0.1em] uppercase text-white/25 mb-6 relative z-10">Aperçu de ton profil</p>

    <!-- Phone mockup -->
    <div class="phone-glow relative z-10 w-[220px] rounded-[34px] overflow-hidden"
      style="border: 1.5px solid rgba(255,255,255,0.12); box-shadow: 0 40px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.08)">
      <!-- Notch -->
      <div class="h-6 flex items-center justify-center" style="background:#070809">
        <div class="w-14 h-[5px] bg-white/[0.12] rounded-full"></div>
      </div>
      <!-- Screen -->
      <div id="phone-body" class="flex flex-col items-center px-3.5 pb-6 pt-4 min-h-[360px] transition-all duration-500" style="background:#0a0a0a">
        <!-- Avatar -->
        <div id="pav" class="w-14 h-14 rounded-full overflow-hidden flex items-center justify-center font-display font-black text-xl mb-2.5 flex-shrink-0 border-2 transition-all duration-400" style="border-color:#00ff9d;background:rgba(0,255,157,0.1);color:#00ff9d">
          {avatarUrl
            ? <img src={avatarUrl} alt="" class="w-full h-full object-cover"/>
            : <span id="pavl">?</span>
          }
        </div>
        <!-- Name -->
        <div id="pname" class="font-display font-black text-[14px] text-white text-center tracking-tight mb-0.5 transition-all duration-300">@bioforge</div>
        <div id="phdl" class="text-[10px] text-white/35 mb-1.5">@username</div>
        <div id="pbio" class="text-[10px] text-white/50 text-center leading-relaxed mb-3.5 max-w-[180px] min-h-[12px] transition-all duration-300"></div>
        <!-- Links -->
        <div class="w-full space-y-1.5">
          <div id="pl1" class="w-full h-8 rounded-[9px] flex items-center justify-center text-[10px] font-bold transition-all duration-400 font-display" style="background:#00ff9d;color:#000">Mon premier lien ✦</div>
          <div id="pl2" class="w-full h-8 rounded-[9px] flex items-center justify-center text-[10px] font-bold transition-all duration-400" style="background:rgba(0,255,157,0.09);border:1px solid rgba(0,255,157,0.3);color:#00ff9d">Lien 2</div>
          <div id="pl3" class="w-full h-8 rounded-[9px] flex items-center justify-center text-[10px] font-bold transition-all duration-400" style="background:rgba(0,255,157,0.09);border:1px solid rgba(0,255,157,0.3);color:#00ff9d">Lien 3</div>
        </div>
      </div>
    </div>

    <!-- URL pill -->
    <div id="url-pill" class="relative z-10 mt-5 flex items-center gap-2 px-4 py-2 rounded-full text-[12px] font-medium transition-all duration-300"
      style="background:rgba(0,255,157,0.08);border:1px solid rgba(0,255,157,0.2);color:#00ff9d">
      <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.1-1.1"/></svg>
      <span class="text-white/40 font-normal">bioforge.click/</span><strong id="url-slug">@username</strong>
    </div>

    <!-- Testimonial quote -->
    <div class="relative z-10 mt-8 mx-6 p-4 rounded-2xl bg-white/[0.03] border border-white/[0.05]">
      <p class="text-[12px] text-white/40 leading-relaxed italic">"J'ai mis mon profil en ligne en 3 minutes. Mes abonnés ont adoré le design."</p>
      <div class="flex items-center gap-2 mt-2.5">
        <div class="w-6 h-6 rounded-full bg-[#00ff9d]/20 flex items-center justify-center text-[10px]">🎙</div>
        <span class="text-[11px] text-white/30">Créateur · 42k abonnés</span>
      </div>
    </div>

  </aside>

</div><!-- /root -->

<!-- Confetti canvas -->
<div id="cf-wrap" class="fixed inset-0 pointer-events-none z-50 overflow-hidden"></div>

<!-- Toast -->
<div id="toast" class="fixed bottom-7 left-1/2 -translate-x-1/2 bg-[#1a0000] border border-red-500/25 text-red-400 px-5 py-3 rounded-xl text-[13px] z-50 hidden whitespace-nowrap shadow-xl"></div>

<script define:vars={{ avatarUrl, existingName, existingUsername }}>
  /* ── STATE ──────────────────────────────────────────────────── */
  var step=0, uValid=false, uVal='', preset='dark', usages=[], src=null, npsVal=null, timer=null;
  var currentUsername = existingUsername || '';

  var PRESETS = {
    dark:  {bg:'#0a0a0a', pc:'#00ff9d', tc:'#fff',    b1:'#00ff9d',             b1c:'#000', b2:'rgba(0,255,157,0.09)',   b2c:'#00ff9d'},
    neon:  {bg:'#1a0033', pc:'#bf00ff', tc:'#fff',    b1:'#bf00ff',             b1c:'#fff', b2:'rgba(191,0,255,0.09)',   b2c:'#bf00ff'},
    ocean: {bg:'#001a33', pc:'#00d4ff', tc:'#fff',    b1:'#00d4ff',             b1c:'#000', b2:'rgba(0,212,255,0.09)',   b2c:'#00d4ff'},
    light: {bg:'#f0f0f0', pc:'#0066ff', tc:'#0a0a0a', b1:'#0066ff',             b1c:'#fff', b2:'rgba(0,102,255,0.09)',   b2c:'#0066ff'},
  };

  /* ── NAVIGATION ─────────────────────────────────────────────── */
  function go(n) {
    var curId = step === 99 ? 'pdone' : 'p' + step;
    var cur = document.getElementById(curId);
    if (cur) {
      cur.classList.add('leaving');
      setTimeout(function() {
        cur.classList.remove('active', 'leaving');
        step = n;
        var nextId = n === 99 ? 'pdone' : 'p' + n;
        var nxt = document.getElementById(nextId);
        if (nxt) {
          nxt.classList.add('active', 'animate-step-in');
          setTimeout(function() { nxt.classList.remove('animate-step-in') }, 400);
        }
        syncDots();
        if (n !== 99) {
          var inp = nxt && nxt.querySelector('input, textarea');
          if (inp) setTimeout(function() { inp.focus() }, 130);
        }
      }, 190);
    }
  }

  function syncDots() {
    ['mobile','desktop'].forEach(function(variant) {
      for (var i = 0; i < 4; i++) {
        var prefix = variant === 'mobile' ? 'dm' : 'dd';
        var d = document.getElementById(prefix + i);
        if (!d) continue;
        d.className = 'sdot h-1.5 rounded-full transition-all duration-300 ';
        if (i < step)      { d.className += 'done bg-[#00cc7a]'; d.style.width = '20px' }
        else if (i===step) { d.className += 'active bg-[#00ff9d]'; d.style.width = '6px' }
        else               { d.className += 'bg-white/10'; d.style.width = '6px' }
      }
    });
  }

  /* ── BACK BUTTONS ───────────────────────────────────────────── */
  document.getElementById('back1').addEventListener('click', function() { go(0) });
  document.getElementById('back2').addEventListener('click', function() { go(1) });
  document.getElementById('back3').addEventListener('click', function() { go(2) });

  /* ── CTA BUTTONS ────────────────────────────────────────────── */
  document.getElementById('cta1').addEventListener('click', function() { go(2) });
  document.getElementById('cta2').addEventListener('click', function() { go(3) });

  /* ── USERNAME ───────────────────────────────────────────────── */
  var ui   = document.getElementById('ui');
  var uic  = document.getElementById('u-icon');
  var umsg = document.getElementById('u-msg');
  var cta0 = document.getElementById('cta0');

  ui.addEventListener('input', function() {
    var v = ui.value.toLowerCase().replace(/[^a-z0-9_]/g, '');
    ui.value = v;
    document.getElementById('phdl').textContent = '@' + (v || 'username');
    document.getElementById('url-slug').textContent = '@' + (v || 'username');

    uValid = false; cta0.disabled = true;
    if (v.length < 3) { setState(v ? 'idle' : 'idle', v ? 'Minimum 3 caractères' : '3 à 24 caractères — lettres, chiffres, _'); return }
    if (v.length > 24){ setState('bad', 'Maximum 24 caractères'); return }

    // Pattern de settings.astro : vérification locale d'abord
    if (v === currentUsername && currentUsername.length >= 3) {
      uVal = v; uValid = true; cta0.disabled = false;
      setState('ok', '@' + v + ' ✓'); return;
    }

    setState('checking', 'Vérification');
    clearTimeout(timer);
    timer = setTimeout(function() { checkUsername(v) }, 600);
  });
  ui.addEventListener('keydown', function(e) { if (e.key === 'Enter' && uValid) go(1) });
  cta0.addEventListener('click', function() { if (uValid) go(1) });

  async function checkUsername(v) {
    try {
      var r = await fetch('/api/profile/check-username?username=' + encodeURIComponent(v));
      var d = await r.json();
      var available = d.data && d.data.available;
      if (available) {
        uVal = v; uValid = true; cta0.disabled = false;
        setState('ok', '@' + v + ' est disponible ✓');
      } else {
        setState('bad', d.data && !d.data.available ? 'Ce pseudo est déjà pris' : 'Erreur de vérification');
      }
    } catch { setState('bad', 'Erreur réseau') }
  }

  function setState(s, msg) {
    ui.classList.remove('ok', 'bad');
    uic.textContent = '';
    umsg.className = 'text-[12px] mt-2 min-h-[18px] transition-colors duration-200 ';

    if (s === 'ok')       { ui.classList.add('ok');  uic.textContent = '✓'; uic.style.color = '#00ff9d'; umsg.className += 'text-[#00ff9d]' }
    else if (s === 'bad') { ui.classList.add('bad'); uic.textContent = '✗'; uic.style.color = '#ff5050'; umsg.className += 'text-red-400' }
    else if (s === 'checking') { uic.style.color = 'rgba(255,255,255,0.3)'; uic.textContent = '…'; umsg.className += 'checking rounded text-transparent' }
    else                  { uic.style.color = ''; umsg.className += 'text-white/35' }

    if (s !== 'checking') umsg.textContent = msg;
  }

  /* ── PROFILE ────────────────────────────────────────────────── */
  var ni = document.getElementById('ni');
  var bi = document.getElementById('bi');
  if (existingName) ni.value = existingName;

  ni.addEventListener('input', function() {
    var v = ni.value.trim();
    document.getElementById('pname').textContent = v || ('@' + (uVal || 'bioforge'));
    if (!avatarUrl) { var l = document.getElementById('pavl'); if (l) l.textContent = v.charAt(0).toUpperCase() || '?' }
    syncPreview();
  });
  bi.addEventListener('input', function() {
    document.getElementById('bc').textContent = String(bi.value.length);
    document.getElementById('pbio').textContent = bi.value.trim();
  });
  document.getElementById('fbi').addEventListener('input', function(e) {
    document.getElementById('fbc').textContent = String(e.target.value.length);
  });

  /* ── PRESETS ────────────────────────────────────────────────── */
  document.querySelectorAll('.preset').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.preset').forEach(function(b) { b.classList.remove('selected') });
      btn.classList.add('selected');
      preset = btn.dataset.p;
      syncPreview();
    });
  });

  function syncPreview() {
    var p = PRESETS[preset] || PRESETS.dark;
    var body = document.getElementById('phone-body');
    body.style.background = p.bg;

    var pname = document.getElementById('pname');
    pname.style.color = p.tc;
    document.getElementById('pbio').style.color = p.tc;

    var av = document.getElementById('pav');
    av.style.borderColor = p.pc; av.style.color = p.pc;
    if (!avatarUrl) av.style.background = p.pc + '18';

    var pl1 = document.getElementById('pl1');
    pl1.style.background = p.b1; pl1.style.color = p.b1c; pl1.style.border = 'none';

    [document.getElementById('pl2'), document.getElementById('pl3')].forEach(function(el) {
      el.style.background = p.b2; el.style.color = p.b2c;
      el.style.border = '1px solid ' + p.pc + '40';
    });

    var pill = document.getElementById('url-pill');
    pill.style.background = p.pc + '10';
    pill.style.borderColor = p.pc + '28';
    pill.style.color = p.pc;
  }

  /* ── FEEDBACK ───────────────────────────────────────────────── */
  document.querySelectorAll('.ubtn').forEach(function(b) {
    b.addEventListener('click', function() {
      b.classList.toggle('selected');
      var u = b.dataset.u;
      usages = usages.includes(u) ? usages.filter(function(x){return x!==u}) : usages.concat([u]);
    });
  });
  document.querySelectorAll('.chip').forEach(function(b) {
    b.addEventListener('click', function() {
      document.querySelectorAll('.chip').forEach(function(c){c.classList.remove('selected')});
      b.classList.add('selected'); src = b.dataset.s;
    });
  });
  document.querySelectorAll('.nps').forEach(function(b) {
    b.addEventListener('click', function() {
      document.querySelectorAll('.nps').forEach(function(x){x.classList.remove('selected')});
      b.classList.add('selected'); npsVal = parseInt(b.dataset.n);
      var e=['😐','😐','😕','😕','😑','😐','🙂','😊','😄','🤩','🔥'];
      var t=['Très déçu','Déçu','Pas convaincu','Plutôt non','Moyen','Neutre','Bien','Bien !','Super !','Excellent !','Exceptionnel 🔥'];
      document.getElementById('nps-lbl').textContent = e[npsVal] + ' ' + t[npsVal];
    });
  });

  /* ── SUBMIT ─────────────────────────────────────────────────── */
  document.getElementById('cta-sub').addEventListener('click', async function() {
    var btn = document.getElementById('cta-sub');
    var txt = document.getElementById('sub-txt');
    btn.disabled = true; txt.textContent = 'Création en cours…';

    try {
      var r = await fetch('/api/profile/onboarding', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          username:     uVal,
          display_name: ni.value.trim() || uVal,
          bio:          bi.value.trim() || '',
          preset:       preset,
          feedback:     {usages, source: src, nps: npsVal, comment: document.getElementById('fbi').value.trim() || null}
        })
      });
      var d = await r.json();
      if (!d.success) throw new Error(d.error || 'Erreur');
      document.getElementById('done-href').href = '/@' + d.data.username;
      launchConfetti();
      step = 99;
      var p3 = document.getElementById('p3');
      p3.classList.add('leaving');
      setTimeout(function() {
        p3.classList.remove('active', 'leaving');
        var done = document.getElementById('pdone');
        done.classList.add('active', 'animate-step-in');
        ['sdots-mobile','sdots-desktop'].forEach(function(id){
          var el = document.getElementById(id); if (el) el.style.opacity = '0';
        });
      }, 190);
    } catch(e) {
      showToast(e.message || 'Une erreur est survenue');
      btn.disabled = false; txt.textContent = 'Créer mon profil ✦';
    }
  });

  /* ── CONFETTI ───────────────────────────────────────────────── */
  function launchConfetti() {
    var wrap = document.getElementById('cf-wrap');
    var cols = ['#00ff9d','#00cc7a','#ffffff','#a0ffd6','#00ff9d'];
    for (var i = 0; i < 60; i++) {
      (function(i) {
        setTimeout(function() {
          var el = document.createElement('div');
          el.className = 'animate-confetti-fall';
          el.style.cssText = 'position:absolute;left:' + Math.random()*100 + '%;top:-10px;background:' + cols[Math.floor(Math.random()*cols.length)] + ';width:' + (4 + Math.random()*8) + 'px;height:' + (4 + Math.random()*8) + 'px;border-radius:' + (Math.random() > 0.5 ? '50%' : '2px') + ';animation-duration:' + (2 + Math.random()*2) + 's;animation-delay:' + (Math.random()*0.4) + 's;pointer-events:none';
          wrap.appendChild(el);
          setTimeout(function() { el.remove() }, 4500);
        }, i * 28);
      })(i);
    }
  }

  /* ── TOAST ──────────────────────────────────────────────────── */
  function showToast(msg) {
    var t = document.getElementById('toast');
    t.textContent = msg; t.classList.remove('hidden');
    t.style.animation = 'none'; t.offsetHeight; t.style.animation = '';
    setTimeout(function() { t.classList.add('hidden') }, 4000);
  }

  /* ── INIT ───────────────────────────────────────────────────── */
  syncDots();
  syncPreview();
  if (existingName) {
    document.getElementById('pname').textContent = existingName;
    if (!avatarUrl) { var l = document.getElementById('pavl'); if (l) l.textContent = existingName.charAt(0).toUpperCase() }
  }
  if (currentUsername) {
    ui.value = currentUsername;
    document.getElementById('phdl').textContent = '@' + currentUsername;
    document.getElementById('url-slug').textContent = '@' + currentUsername;
    uVal = currentUsername; uValid = true; cta0.disabled = false;
    setState('ok', '@' + currentUsername + ' ✓');
  }
  // Focus username on load
  setTimeout(function() { if (!currentUsername) ui.focus() }, 300);
</script>
</body>
</html>
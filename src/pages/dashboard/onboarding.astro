        <div class="sdot h-1.5 rounded-full bg-white/10 transition-all duration-300" style="width:6px" id="dd1"></div>
        <div class="sdot h-1.5 rounded-full bg-white/10 transition-all duration-300" style="width:6px" id="dd2"></div>
        <div class="sdot h-1.5 rounded-full bg-white/10 transition-all duration-300" style="width:6px" id="dd3"></div>
      </div>

      <!-- ══ PANEL 0 — Username ══ -->

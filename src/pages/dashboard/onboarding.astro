      <div class="sdot h-1.5 rounded-full bg-white/10 transition-all duration-300" style="width:6px" id="dm1"></div>
      <div class="sdot h-1.5 rounded-full bg-white/10 transition-all duration-300" style="width:6px" id="dm2"></div>
      <div class="sdot h-1.5 rounded-full bg-white/10 transition-all duration-300" style="width:6px" id="dm3"></div>

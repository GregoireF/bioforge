        <div class="grid grid-cols-2 gap-3 mb-6">
          <button class="preset selected text-left border border-white/[0.09] rounded-2xl p-4 cursor-pointer transition-all duration-200 hover:-translate-y-0.5 relative group" data-p="dark">

---
// src/pages/dashboard/onboarding.astro
import { withAuth } from '@/lib/auth/auth';

const authResult = await withAuth({ cookies: Astro.cookies, request: Astro.request });
if (!authResult.success || !authResult.data) return Astro.redirect('/signin');
const { profile } = authResult.data;

if ((profile as any)?.onboarding_completed_at) return Astro.redirect('/dashboard');

const avatarUrl        = profile?.avatar_url    ?? '';
const existingName     = profile?.display_name  ?? '';
const existingUsername = (profile as any)?.username ?? '';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>BioForge — Bienvenue</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@500;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet"/>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
  html, body { height: 100%; overflow: hidden }
  body {
    font-family: "DM Sans", sans-serif;
    background: #07090c;
    color: #fff;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none }
  button { font-family: inherit; background: none; border: none; cursor: pointer; padding: 0; color: inherit }
  input, textarea { font-family: inherit }
  ::-webkit-scrollbar { width: 4px }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px }

  /* ── Root layout ── */
  .root { display: flex; flex-direction: column; height: 100vh }
  @media (min-width: 1024px) { .root { flex-direction: row } }

  /* ── Ambient background ── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 55% 45% at 25% 55%, rgba(0,255,157,0.06) 0%, transparent 65%),
      radial-gradient(ellipse 40% 50% at 75% 30%, rgba(0,200,120,0.04) 0%, transparent 60%);
  }

  /* ── Topbar mobile ── */
  .topbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 24px;
    background: rgba(7,9,12,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.055);
  }
  @media (min-width: 1024px) { .topbar { display: none } }

  .logo { display: flex; align-items: center; gap: 9px }
  .logo-mark {
    width: 30px; height: 30px; border-radius: 8px;
    background: #00ff9d;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .logo-name { font-family: "Cabinet Grotesk", sans-serif; font-weight: 800; font-size: 15px }

  /* ── Step dots ── */
  .dots { display: flex; align-items: center; gap: 6px }
  .dot {
    height: 6px; width: 6px; border-radius: 3px;
    background: rgba(255,255,255,0.14);
    transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
  }
  .dot.active { background: #00ff9d; animation: pulsedot 2s ease-in-out infinite }
  .dot.done   { background: #00cc7a; width: 22px; border-radius: 4px }
  @keyframes pulsedot {
    0%,100% { box-shadow: 0 0 0 0 rgba(0,255,157,0.5) }
    50%      { box-shadow: 0 0 0 7px rgba(0,255,157,0) }
  }

  /* ── MAIN — colonne gauche ── */
  .main {
    position: relative; z-index: 1;
    flex: 1;
    overflow-y: auto;
    display: flex; flex-direction: column;
    padding-top: 72px;
  }
  @media (min-width: 1024px) {
    .main {
      padding-top: 0;
      border-right: 1px solid rgba(255,255,255,0.055);
    }
  }

  .main-logo {
    display: none;
    padding: 28px 52px 0;
    flex-shrink: 0;
  }
  @media (min-width: 1024px) { .main-logo { display: flex; align-items: center } }

  .inner {
    flex: 1;
    display: flex; flex-direction: column; justify-content: center;
    padding: 32px 24px 48px;
    max-width: 520px;
  }
  @media (min-width: 1024px) { .inner { padding: 36px 52px; max-width: 100% } }

  .dots-desktop {
    display: none; margin-bottom: 44px;
  }
  @media (min-width: 1024px) { .dots-desktop { display: flex; align-items: center; gap: 7px } }

  .main-footer {
    display: none;
    padding: 0 52px 28px;
    flex-shrink: 0;
  }
  @media (min-width: 1024px) { .main-footer { display: block } }
  .main-footer p { font-size: 12px; color: rgba(255,255,255,0.18) }
  .main-footer a { transition: color 0.2s }
  .main-footer a:hover { color: rgba(255,255,255,0.45) }

  /* ── Panels ── */
  .panel { display: none }
  .panel.active { display: block; animation: stepin 0.4s cubic-bezier(0.22,1,0.36,1) both }
  .panel.leaving { animation: stepout 0.22s ease forwards; pointer-events: none }
  @keyframes stepin  { from { opacity:0; transform:translateX(28px) } to { opacity:1; transform:none } }
  @keyframes stepout { to   { opacity:0; transform:translateX(-28px) } }
  @keyframes shimmer { 0%   { background-position:200% 0 } 100% { background-position:-200% 0 } }

  /* ── Typography ── */
  .eyebrow {
    display: flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.13em;
    text-transform: uppercase; color: #00ff9d;
    margin-bottom: 16px;
  }
  .eyebrow::before {
    content: ''; display: block;
    width: 16px; height: 1.5px;
    background: #00ff9d; border-radius: 1px; flex-shrink: 0;
  }
  .title {
    font-family: "Cabinet Grotesk", sans-serif;
    font-weight: 900;
    font-size: clamp(32px, 5.5vw, 54px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    margin-bottom: 12px;
  }
  .accent { color: #00ff9d; display: block }
  .subtitle {
    font-size: 15px; color: rgba(255,255,255,0.48);
    line-height: 1.65; margin-bottom: 32px;
  }
  .subtitle strong { color: rgba(255,255,255,0.8); font-weight: 500 }
  .back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; color: rgba(255,255,255,0.38);
    margin-bottom: 28px; transition: color 0.2s;
  }
  .back:hover { color: rgba(255,255,255,0.75) }

  /* ── Fields ── */
  .field { margin-bottom: 16px }
  .flabel {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: rgba(255,255,255,0.32);
    margin-bottom: 7px;
  }
  .fwrap { position: relative }
  .fpfx {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    font-size: 14px; color: rgba(255,255,255,0.32); pointer-events: none;
  }
  .inp {
    width: 100%; padding: 13px 44px 13px 14px;
    background: rgba(255,255,255,0.04);
    border: 1.5px solid rgba(255,255,255,0.08);
    border-radius: 12px; color: #fff; font-size: 15px;
    outline: none;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  }
  .inp.pfx { padding-left: 34px }
  .inp:focus {
    border-color: rgba(0,255,157,0.45);
    background: rgba(0,255,157,0.03);
    box-shadow: 0 0 0 3px rgba(0,255,157,0.07);
  }
  .inp.ok  { border-color: #00ff9d }
  .inp.bad { border-color: #ff5050 }
  .inp::placeholder { color: rgba(255,255,255,0.16) }
  textarea.inp { resize: none; padding-top: 13px }
  .ficon {
    position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
    font-size: 13px;
  }
  .fmsg { font-size: 12px; color: rgba(255,255,255,0.32); margin-top: 5px; min-height: 17px }
  .fmsg.ok  { color: #00ff9d }
  .fmsg.bad { color: #ff5050 }
  .fmsg.checking {
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.12) 50%, rgba(255,255,255,0.04) 100%);
    background-size: 200% 100%;
    animation: shimmer 1.6s linear infinite;
    border-radius: 4px; color: transparent; height: 14px; margin-top: 6px;
  }

  /* ── CTA ── */
  .cta {
    width: 100%;
    display: flex; align-items: center; justify-content: center; gap: 9px;
    padding: 14px 24px;
    background: #00ff9d; color: #000;
    font-family: "Cabinet Grotesk", sans-serif;
    font-size: 14px; font-weight: 800;
    border-radius: 12px; letter-spacing: 0.01em;
    transition: background 0.18s, transform 0.18s, box-shadow 0.18s, opacity 0.18s;
    margin-top: 8px;
  }
  .cta:hover:not(:disabled) {
    background: #20ffaa;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0,255,157,0.22);
  }
  .cta:active:not(:disabled) { transform: scale(0.98) }
  .cta:disabled { opacity: 0.32; cursor: not-allowed }
  .arr { transition: transform 0.2s; flex-shrink: 0 }
  .cta:hover:not(:disabled) .arr { transform: translateX(4px) }

  /* ── Presets ── */
  .presets { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 22px }
  .preset {
    position: relative; text-align: left;
    border: 1.5px solid rgba(255,255,255,0.08);
    border-radius: 16px; padding: 14px;
    cursor: pointer; transition: all 0.2s;
    background: rgba(255,255,255,0.02);
  }
  .preset:hover { border-color: rgba(255,255,255,0.18); transform: translateY(-2px) }
  .preset.selected {
    border-color: #00ff9d;
    background: rgba(0,255,157,0.04);
    box-shadow: 0 0 0 1px #00ff9d, 0 8px 24px rgba(0,255,157,0.1);
  }
  .pcheck {
    position: absolute; top: 10px; right: 10px;
    width: 16px; height: 16px; border-radius: 50%;
    background: #00ff9d;
    display: none; align-items: center; justify-content: center;
  }
  .preset.selected .pcheck { display: flex }
  .pswatch { height: 40px; border-radius: 9px; margin-bottom: 9px; position: relative; overflow: hidden }
  .pdot { position: absolute; bottom: 7px; right: 7px; width: 9px; height: 9px; border-radius: 50% }
  .pname { font-family: "Cabinet Grotesk", sans-serif; font-size: 13px; font-weight: 800; color: #fff }
  .pdesc { font-size: 11px; color: rgba(255,255,255,0.38); margin-top: 2px }

  /* ── Usage / chips / NPS ── */
  .ugrid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 18px }
  .ubtn {
    display: flex; align-items: center; gap: 9px;
    padding: 10px 12px;
    border: 1.5px solid rgba(255,255,255,0.08);
    border-radius: 11px; color: rgba(255,255,255,0.48);
    font-size: 13px; font-weight: 500;
    transition: all 0.15s; text-align: left;
    background: rgba(255,255,255,0.02);
  }
  .ubtn:hover { border-color: rgba(255,255,255,0.2); color: #fff }
  .ubtn.selected { border-color: #00ff9d; background: rgba(0,255,157,0.07); color: #00ff9d }
  .chips { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 18px }
  .chip {
    padding: 6px 14px;
    border: 1.5px solid rgba(255,255,255,0.08);
    border-radius: 99px; color: rgba(255,255,255,0.42);
    font-size: 12px; font-weight: 500;
    transition: all 0.15s; background: rgba(255,255,255,0.02);
  }
  .chip:hover { border-color: rgba(255,255,255,0.2); color: #fff }
  .chip.selected { border-color: #00ff9d; background: rgba(0,255,157,0.07); color: #00ff9d }
  .npsrow { display: flex; gap: 4px }
  .npsbtn {
    flex: 1; height: 38px;
    border: 1.5px solid rgba(255,255,255,0.08);
    border-radius: 9px; color: rgba(255,255,255,0.42);
    font-size: 12px; font-weight: 700;
    transition: all 0.15s; background: rgba(255,255,255,0.02);
  }
  .npsbtn:hover { border-color: rgba(255,255,255,0.2); color: #fff }
  .npsbtn.selected {
    background: #00ff9d; border-color: #00ff9d; color: #000;
    transform: scale(1.07); box-shadow: 0 4px 14px rgba(0,255,157,0.3);
  }
  .nps-ends { display: flex; justify-content: space-between; margin-top: 5px; font-size: 10px; color: rgba(255,255,255,0.22) }

  /* ── Done ── */
  @keyframes popin { 0%{ transform:scale(0) rotate(-12deg); opacity:0 } 60%{ transform:scale(1.1) rotate(2deg) } 100%{ transform:scale(1); opacity:1 } }
  .done-icon {
    width: 64px; height: 64px; border-radius: 50%;
    background: rgba(0,255,157,0.1); border: 2px solid #00ff9d;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; margin-bottom: 24px;
    animation: popin 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
  }
  .dactions { display: flex; flex-direction: column; gap: 10px; margin-top: 28px }
  .dlink {
    display: flex; align-items: center; justify-content: space-between;
    padding: 13px 18px; border-radius: 12px;
    font-size: 14px; font-weight: 600;
    border: 1.5px solid rgba(255,255,255,0.08);
    color: #fff; transition: all 0.2s;
    background: rgba(255,255,255,0.02);
  }
  .dlink:hover { border-color: rgba(255,255,255,0.2); transform: translateX(3px) }
  .dlink.prim { background: #00ff9d; color: #000; border-color: transparent }
  .dlink.prim:hover { background: #20ffaa; transform: translateY(-1px); box-shadow: 0 10px 28px rgba(0,255,157,0.22) }

  /* ══ ASIDE ══════════════════════════════════════════════════════ */
  .aside { display: none }
  @media (min-width: 1024px) {
    .aside {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      flex-shrink: 0; width: 46%;
      background: #080b0e;
      position: relative; overflow: hidden;
      padding: 48px 40px;
    }
  }

  /* Glow layers */
  .aside::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 70% 55% at 50% 70%, rgba(0,255,157,0.09) 0%, transparent 65%),
      radial-gradient(ellipse 40% 30% at 20% 20%, rgba(0,255,157,0.04) 0%, transparent 60%);
  }
  /* Grid dots pattern */
  .aside::after {
    content: ''; position: absolute; inset: 0; pointer-events: none; opacity: 0.035;
    background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .aside-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: rgba(255,255,255,0.22);
    margin-bottom: 28px; position: relative; z-index: 1;
    display: flex; align-items: center; gap: 10px;
  }
  .aside-label::before, .aside-label::after {
    content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.08);
  }
  .aside-label-txt { white-space: nowrap }

  /* ── Phone ── */
  .phone-wrap { position: relative; z-index: 1; margin-bottom: 24px }
  /* Decorative glow ring behind phone */
  .phone-wrap::before {
    content: ''; position: absolute;
    inset: -20px; border-radius: 50px;
    background: radial-gradient(ellipse at 50% 60%, rgba(0,255,157,0.12) 0%, transparent 65%);
    pointer-events: none; z-index: 0;
  }
  .phone {
    position: relative; z-index: 1;
    width: 240px; border-radius: 36px; overflow: hidden;
    border: 1.5px solid rgba(255,255,255,0.12);
    box-shadow:
      0 48px 96px rgba(0,0,0,0.65),
      0 0 0 1px rgba(255,255,255,0.05),
      inset 0 1px 0 rgba(255,255,255,0.1);
    transition: box-shadow 0.5s ease, transform 0.5s ease;
  }
  .phone:hover {
    box-shadow:
      0 48px 96px rgba(0,0,0,0.7),
      0 0 80px rgba(0,255,157,0.1),
      0 0 0 1px rgba(255,255,255,0.06),
      inset 0 1px 0 rgba(255,255,255,0.12);
    transform: translateY(-3px);
  }
  .ph-notch {
    height: 26px; display: flex; align-items: center; justify-content: center;
    background: #060809;
  }
  .ph-pill { width: 58px; height: 5px; background: rgba(255,255,255,0.1); border-radius: 3px }
  .ph-screen {
    padding: 20px 14px 24px;
    display: flex; flex-direction: column; align-items: center;
    min-height: 400px; transition: background 0.5s ease;
    background: #0a0a0a;
  }
  .pav {
    width: 60px; height: 60px; border-radius: 50%; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    font-family: "Cabinet Grotesk", sans-serif; font-size: 20px; font-weight: 900;
    margin-bottom: 10px; flex-shrink: 0;
    border: 2px solid #00ff9d;
    background: rgba(0,255,157,0.1); color: #00ff9d;
    transition: all 0.4s ease;
  }
  .pav img { width: 100%; height: 100%; object-fit: cover }
  .pname {
    font-family: "Cabinet Grotesk", sans-serif; font-size: 14px; font-weight: 900;
    color: #fff; text-align: center; letter-spacing: -0.02em;
    margin-bottom: 2px; transition: color 0.3s;
  }
  .phdl { font-size: 10px; color: rgba(255,255,255,0.34); margin-bottom: 6px }
  .pbio {
    font-size: 10px; color: rgba(255,255,255,0.5);
    text-align: center; line-height: 1.5;
    margin-bottom: 16px; max-width: 180px; min-height: 12px; transition: color 0.3s;
  }
  .plinks { width: 100%; display: flex; flex-direction: column; gap: 7px }
  .plink {
    width: 100%; height: 34px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700;
    font-family: "Cabinet Grotesk", sans-serif;
    transition: all 0.45s ease;
  }

  /* ── URL pill ── */
  .url-pill {
    position: relative; z-index: 1;
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 16px; border-radius: 99px;
    font-size: 12px; font-weight: 600;
    background: rgba(0,255,157,0.08);
    border: 1px solid rgba(0,255,157,0.2);
    color: #00ff9d; transition: all 0.35s;
    letter-spacing: 0.01em;
  }
  .url-pill .grey { color: rgba(255,255,255,0.38); font-weight: 400 }

  /* ── Stats row ── */
  .stats-row {
    position: relative; z-index: 1;
    display: flex; align-items: center; gap: 8px;
    margin-top: 28px; width: 100%;
  }
  .stat-card {
    flex: 1; padding: 12px 14px; border-radius: 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    text-align: center;
  }
  .stat-num {
    font-family: "Cabinet Grotesk", sans-serif;
    font-size: 20px; font-weight: 900; color: #fff;
    letter-spacing: -0.03em; line-height: 1;
    margin-bottom: 3px;
  }
  .stat-num span { color: #00ff9d }
  .stat-lbl { font-size: 10px; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.06em }

  /* ── Testimonial ── */
  .testimonial {
    position: relative; z-index: 1;
    margin-top: 12px; padding: 14px 16px; border-radius: 16px;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    width: 100%;
  }
  .testimonial p { font-size: 12px; color: rgba(255,255,255,0.38); line-height: 1.65; font-style: italic }
  .tfoot { display: flex; align-items: center; gap: 8px; margin-top: 10px }
  .tav { width: 24px; height: 24px; border-radius: 50%; background: rgba(0,255,157,0.15); display: flex; align-items: center; justify-content: center; font-size: 10px }
  .tname { font-size: 11px; color: rgba(255,255,255,0.28) }

  /* ── Confetti ── */
  .cf { position: fixed; top: -10px; pointer-events: none; z-index: 999; border-radius: 2px; animation: cffall linear forwards }
  @keyframes cffall { to { transform: translateY(110vh) rotate(720deg); opacity: 0 } }

  /* ── Toast ── */
  #toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%); background: #140000; border: 1px solid rgba(255,80,80,0.22); color: #ff8080; padding: 10px 20px; border-radius: 12px; font-size: 13px; z-index: 999; display: none; white-space: nowrap }
  #toast.show { display: block }
</style>
</head>

</head>
<body>
<div class="root">

  <header class="topbar">
    <a href="/" class="logo">
      <div class="logo-mark"><svg width="14" height="14" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
      <span class="logo-name">BioForge</span>
    </a>
    <div class="dots" id="dots-m">
      <div class="dot active" id="dm0"></div><div class="dot" id="dm1"></div>
      <div class="dot" id="dm2"></div><div class="dot" id="dm3"></div>
    </div>
  </header>

  <main class="main">
    <div class="main-logo">
      <a href="/" class="logo">
        <div class="logo-mark"><svg width="14" height="14" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
        <span class="logo-name">BioForge</span>
      </a>
    </div>
    <div class="inner">
      <div class="dots dots-desktop" id="dots-d">
        <div class="dot active" id="dd0"></div><div class="dot" id="dd1"></div>
        <div class="dot" id="dd2"></div><div class="dot" id="dd3"></div>
      </div>

      <!-- P0 — Username -->
      <div class="panel active" id="p0">
        <p class="eyebrow">Étape 1 sur 4</p>
        <h1 class="title">Ton adresse<em class="accent">sur le web</em></h1>
        <p class="subtitle">Visible dans ton URL : <strong>bioforge.click/@toi</strong></p>
        <div class="field">
          <label class="flabel" for="ui">Pseudo</label>
          <div class="fwrap">
            <span class="fpfx">@</span>
            <input type="text" id="ui" class="inp pfx" maxlength="24" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="tonsuperpseudo"/>
            <span class="ficon" id="u-icon"></span>
          </div>
          <p class="fmsg" id="u-msg">3 à 24 caractères — lettres, chiffres, _</p>
        </div>
        <button class="cta" id="cta0" disabled>
          Continuer
          <svg class="arr" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>

      <!-- P1 — Profil -->
      <div class="panel" id="p1">
        <button class="back" id="back1"><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>Retour</button>
        <p class="eyebrow">Étape 2 sur 4</p>
        <h1 class="title">Qui es-<em class="accent">tu ?</em></h1>
        <p class="subtitle">Un nom mémorable et une bio percutante font toute la différence.</p>
        <div class="field">
          <label class="flabel" for="ni">Nom affiché</label>
          <div class="fwrap"><input type="text" id="ni" class="inp" maxlength="80" placeholder="Ton nom ou pseudonyme"/></div>
        </div>
        <div class="field">
          <div class="flabel"><span>Bio</span><span style="font-weight:400;text-transform:none;color:rgba(255,255,255,0.25)"><span id="bc">0</span>/160</span></div>
          <div class="fwrap"><textarea id="bi" class="inp" rows="3" maxlength="160" placeholder="Créateur · Dev · Humain 🌱"></textarea></div>
        </div>
        <button class="cta" id="cta1">Continuer <svg class="arr" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
      </div>

      <!-- P2 — Style -->
      <div class="panel" id="p2">
        <button class="back" id="back2"><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>Retour</button>
        <p class="eyebrow">Étape 3 sur 4</p>
        <h1 class="title">Ton<em class="accent">identité visuelle</em></h1>
        <p class="subtitle">Un point de départ — tout est modifiable depuis Apparence.</p>
        <div class="presets">
          <button class="preset selected" data-p="dark">
            <div class="pcheck"><svg width="8" height="8" fill="none" stroke="#000" stroke-width="3.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
            <div class="pswatch" style="background:linear-gradient(135deg,#0a0a0a,#0f1f15)"><div class="pdot" style="background:#00ff9d"></div></div>
            <div class="pname">Dark</div><div class="pdesc">Sombre · Néon</div>
          </button>
          <button class="preset" data-p="neon">
            <div class="pcheck"><svg width="8" height="8" fill="none" stroke="#000" stroke-width="3.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
            <div class="pswatch" style="background:linear-gradient(135deg,#1a0033,#0d001a)"><div class="pdot" style="background:#bf00ff"></div></div>
            <div class="pname">Neon</div><div class="pdesc">Violet · Électrique</div>
          </button>
          <button class="preset" data-p="ocean">
            <div class="pcheck"><svg width="8" height="8" fill="none" stroke="#000" stroke-width="3.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
            <div class="pswatch" style="background:linear-gradient(135deg,#001a33,#002244)"><div class="pdot" style="background:#00d4ff"></div></div>
            <div class="pname">Ocean</div><div class="pdesc">Bleu · Profond</div>
          </button>
          <button class="preset" data-p="light">
            <div class="pcheck"><svg width="8" height="8" fill="none" stroke="#000" stroke-width="3.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></div>
            <div class="pswatch" style="background:linear-gradient(135deg,#f0f0f0,#e8f0ff)"><div class="pdot" style="background:#0066ff"></div></div>
            <div class="pname">Light</div><div class="pdesc">Clair · Épuré</div>
          </button>
        </div>
        <button class="cta" id="cta2">Continuer <svg class="arr" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
      </div>

      <!-- P3 — Feedback -->
      <div class="panel" id="p3">
        <button class="back" id="back3"><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 5l-7 7 7 7"/></svg>Retour</button>
        <p class="eyebrow">Étape 4 sur 4</p>
        <h1 class="title" style="font-size:clamp(26px,4.5vw,42px)">Aide-nous à<em class="accent">progresser</em></h1>
        <p class="subtitle">30 secondes · vraiment utile pour nous 🙏</p>
        <p class="flabel" style="margin-bottom:9px">Tu utilises BioForge pour…</p>
        <div class="ugrid">
          <button class="ubtn" data-u="creator"><span style="font-size:15px">🎥</span>Créateur</button>
          <button class="ubtn" data-u="dev"><span style="font-size:15px">💻</span>Dev / Tech</button>
          <button class="ubtn" data-u="brand"><span style="font-size:15px">🏢</span>Marque</button>
          <button class="ubtn" data-u="artist"><span style="font-size:15px">🎨</span>Artiste</button>
          <button class="ubtn" data-u="free"><span style="font-size:15px">🚀</span>Freelance</button>
          <button class="ubtn" data-u="other"><span style="font-size:15px">✨</span>Autre</button>
        </div>
        <p class="flabel" style="margin-bottom:9px">Découvert via…</p>
        <div class="chips">
          <button class="chip" data-s="social">Réseaux sociaux</button>
          <button class="chip" data-s="friend">Bouche à oreille</button>
          <button class="chip" data-s="search">Google</button>
          <button class="chip" data-s="ph">Product Hunt</button>
          <button class="chip" data-s="ad">Pub</button>
          <button class="chip" data-s="other">Autre</button>
        </div>
        <div style="margin-bottom:16px">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:9px">
            <p class="flabel" style="margin-bottom:0">Première impression</p>
            <span id="nps-lbl" style="font-size:12px;color:rgba(255,255,255,0.3);transition:all 0.2s">noter de 0 à 10</span>
          </div>
          <div class="npsrow">
            <button class="npsbtn" data-n="0">0</button><button class="npsbtn" data-n="1">1</button>
            <button class="npsbtn" data-n="2">2</button><button class="npsbtn" data-n="3">3</button>
            <button class="npsbtn" data-n="4">4</button><button class="npsbtn" data-n="5">5</button>
            <button class="npsbtn" data-n="6">6</button><button class="npsbtn" data-n="7">7</button>
            <button class="npsbtn" data-n="8">8</button><button class="npsbtn" data-n="9">9</button>
            <button class="npsbtn" data-n="10">10</button>
          </div>
          <div class="nps-ends"><span>Pas convaincu</span><span>Excellent 🔥</span></div>
        </div>
        <div class="field">
          <div class="flabel"><span>Un mot <span style="font-weight:400;text-transform:none;color:rgba(255,255,255,0.25)">— optionnel</span></span><span style="font-weight:400;text-transform:none"><span id="fbc">0</span>/500</span></div>
          <div class="fwrap"><textarea id="fbi" class="inp" rows="2" maxlength="500" placeholder="Ce que tu attends, une idée, un retour…"></textarea></div>
        </div>
        <button class="cta" id="cta-sub"><span id="sub-txt">Créer mon profil ✦</span><svg class="arr" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></button>
        <p style="text-align:center;font-size:12px;color:rgba(255,255,255,0.25);margin-top:11px">Tu peux passer — vraiment 20 secondes 🙏</p>
      </div>

      <!-- DONE -->
      <div class="panel" id="pdone">
        <div class="done-icon">✦</div>
        <p class="eyebrow">C'est parti !</p>
        <h1 class="title">Ton profil<em class="accent">est prêt</em></h1>
        <p class="subtitle">Tout est en place. Ajoute tes premiers liens et partage ton URL.</p>
        <div class="dactions">
          <a id="done-href" href="#" target="_blank" class="dlink prim"><span>Voir mon profil</span><span>→</span></a>
          <a href="/dashboard" class="dlink"><span>Aller au dashboard</span><span style="color:rgba(255,255,255,0.3)">→</span></a>
          <a href="/dashboard/appearance" class="dlink"><span>Personnaliser l'apparence</span><span style="color:rgba(255,255,255,0.3)">→</span></a>
        </div>
      </div>
    </div>
  </main>

  <aside class="aside">
    <p class="aside-label"><span class="aside-label-txt">Aperçu de ton profil</span></p>
    <div class="phone-wrap">
      <div class="phone">
        <div class="ph-notch"><div class="ph-pill"></div></div>
        <div class="ph-screen" id="phone-body">
          <div class="pav" id="pav">
            {avatarUrl
              ? <img src={avatarUrl} alt=""/>
              : <span id="pavl">?</span>
            }
          </div>
          <div class="pname" id="pname">@bioforge</div>
          <div class="phdl" id="phdl">@username</div>
          <div class="pbio" id="pbio"></div>
          <div class="plinks">
            <div class="plink" id="pl1" style="background:#00ff9d;color:#000">Mon premier lien ✦</div>
            <div class="plink" id="pl2" style="background:rgba(0,255,157,0.09);border:1px solid rgba(0,255,157,0.3);color:#00ff9d">Lien 2</div>
            <div class="plink" id="pl3" style="background:rgba(0,255,157,0.09);border:1px solid rgba(0,255,157,0.3);color:#00ff9d">Lien 3</div>
          </div>
        </div>
      </div>
    </div>

    <div class="url-pill" id="url-pill">
      <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.1-1.1"/></svg>
      <span class="grey">bioforge.click/</span><strong id="url-slug">@username</strong>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-num"><span>∞</span></div>
        <div class="stat-lbl">Liens</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">4</div>
        <div class="stat-lbl">Thèmes</div>
      </div>
      <div class="stat-card">
        <div class="stat-num"><span>✦</span></div>
        <div class="stat-lbl">Gratuit</div>
      </div>
    </div>

    <div class="testimonial">
      <p>"J'ai mis mon profil en ligne en 3 minutes. Mes abonnés ont adoré le design."</p>
      <div class="tfoot">
        <div class="tav">🎙</div>
        <span class="tname">Créateur · 42k abonnés</span>
      </div>
    </div>
  </aside>

</div>

<div id="toast"></div>

<script define:vars={{ avatarUrl, existingName, existingUsername }}>
  var step=0,uValid=false,uVal='',preset='dark',usages=[],src=null,npsVal=null,timer=null;
  var currentUsername=existingUsername||'';
  var P={
    dark: {bg:'#0a0a0a',pc:'#00ff9d',tc:'#fff',   b1:'#00ff9d',b1c:'#000',b2:'rgba(0,255,157,0.09)',  b2c:'#00ff9d'},
    neon: {bg:'#1a0033',pc:'#bf00ff',tc:'#fff',   b1:'#bf00ff',b1c:'#fff',b2:'rgba(191,0,255,0.09)', b2c:'#bf00ff'},
    ocean:{bg:'#001a33',pc:'#00d4ff',tc:'#fff',   b1:'#00d4ff',b1c:'#000',b2:'rgba(0,212,255,0.09)', b2c:'#00d4ff'},
    light:{bg:'#f0f0f0',pc:'#0066ff',tc:'#0a0a0a',b1:'#0066ff',b1c:'#fff',b2:'rgba(0,102,255,0.09)', b2c:'#0066ff'},
  };

  function go(n){
    var cur=document.getElementById(step===99?'pdone':'p'+step);
    if(!cur)return;
    cur.classList.add('leaving');
    setTimeout(function(){
      cur.classList.remove('active','leaving');
      step=n;
      var nxt=document.getElementById(n===99?'pdone':'p'+n);
      if(nxt)nxt.classList.add('active');
      syncDots();
      if(n!==99){var i=nxt&&nxt.querySelector('input,textarea');if(i)setTimeout(function(){i.focus()},120);}
    },190);
  }
  function syncDots(){
    ['m','d'].forEach(function(p){
      for(var i=0;i<4;i++){
        var d=document.getElementById('d'+p+i);if(!d)continue;
        d.className='dot';d.style.width='6px';
        if(i<step){d.classList.add('done');d.style.width='20px';}
        else if(i===step)d.classList.add('active');
      }
    });
  }

  document.getElementById('back1').addEventListener('click',function(){go(0);});
  document.getElementById('back2').addEventListener('click',function(){go(1);});
  document.getElementById('back3').addEventListener('click',function(){go(2);});
  document.getElementById('cta1').addEventListener('click',function(){go(2);});
  document.getElementById('cta2').addEventListener('click',function(){go(3);});

  var ui=document.getElementById('ui'),uic=document.getElementById('u-icon'),umsg=document.getElementById('u-msg'),cta0=document.getElementById('cta0');
  ui.addEventListener('input',function(){
    var v=ui.value.toLowerCase().replace(/[^a-z0-9_]/g,'');
    ui.value=v;
    document.getElementById('phdl').textContent='@'+(v||'username');
    document.getElementById('url-slug').textContent='@'+(v||'username');
    uValid=false;cta0.disabled=true;
    if(v.length<3){setU('idle',v?'Minimum 3 caractères':'3 à 24 caractères — lettres, chiffres, _');return;}
    if(v.length>24){setU('bad','Maximum 24 caractères');return;}
    if(v===currentUsername&&currentUsername.length>=3){uVal=v;uValid=true;cta0.disabled=false;setU('ok','@'+v+' ✓');return;}
    setU('checking','');
    clearTimeout(timer);
    timer=setTimeout(function(){checkU(v);},600);
  });
  ui.addEventListener('keydown',function(e){if(e.key==='Enter'&&uValid)go(1);});
  cta0.addEventListener('click',function(){if(uValid)go(1);});

  async function checkU(v){
    try{
      var r=await fetch('/api/profile/check-username?username='+encodeURIComponent(v));
      var d=await r.json();
      var ok=d.data&&d.data.available;
      if(ok){uVal=v;uValid=true;cta0.disabled=false;setU('ok','@'+v+' est disponible ✓');}
      else setU('bad',(d.data&&!d.data.available)?'Ce pseudo est déjà pris':'Erreur de vérification');
    }catch{setU('bad','Erreur réseau');}
  }
  function setU(s,msg){
    ui.classList.remove('ok','bad');uic.textContent='';uic.style.color='';umsg.className='fmsg';
    if(s==='ok'){ui.classList.add('ok');uic.textContent='✓';uic.style.color='#00ff9d';umsg.classList.add('ok');}
    else if(s==='bad'){ui.classList.add('bad');uic.textContent='✗';uic.style.color='#ff5050';umsg.classList.add('bad');}
    else if(s==='checking'){umsg.classList.add('checking');}
    if(s!=='checking')umsg.textContent=msg;
  }

  var ni=document.getElementById('ni'),bi=document.getElementById('bi');
  if(existingName)ni.value=existingName;
  ni.addEventListener('input',function(){
    var v=ni.value.trim();
    document.getElementById('pname').textContent=v||('@'+(uVal||'bioforge'));
    if(!avatarUrl){var l=document.getElementById('pavl');if(l)l.textContent=v.charAt(0).toUpperCase()||'?';}
    syncP();
  });
  bi.addEventListener('input',function(){document.getElementById('bc').textContent=String(bi.value.length);document.getElementById('pbio').textContent=bi.value.trim();});
  document.getElementById('fbi').addEventListener('input',function(e){document.getElementById('fbc').textContent=String(e.target.value.length);});

  document.querySelectorAll('.preset').forEach(function(b){
    b.addEventListener('click',function(){
      document.querySelectorAll('.preset').forEach(function(x){x.classList.remove('selected');});
      b.classList.add('selected');preset=b.dataset.p;syncP();
    });
  });
  function syncP(){
    var p=P[preset]||P.dark;
    document.getElementById('phone-body').style.background=p.bg;
    document.getElementById('pname').style.color=p.tc;
    document.getElementById('pbio').style.color=p.tc;
    var av=document.getElementById('pav');av.style.borderColor=p.pc;av.style.color=p.pc;
    if(!avatarUrl)av.style.background=p.pc+'18';
    var l1=document.getElementById('pl1');l1.style.background=p.b1;l1.style.color=p.b1c;l1.style.border='none';
    [document.getElementById('pl2'),document.getElementById('pl3')].forEach(function(el){el.style.background=p.b2;el.style.color=p.b2c;el.style.border='1px solid '+p.pc+'40';});
    var pill=document.getElementById('url-pill');pill.style.background=p.pc+'10';pill.style.borderColor=p.pc+'28';pill.style.color=p.pc;
  }

  document.querySelectorAll('.ubtn').forEach(function(b){b.addEventListener('click',function(){b.classList.toggle('selected');var u=b.dataset.u;usages=usages.includes(u)?usages.filter(function(x){return x!==u;}):usages.concat([u]);});});
  document.querySelectorAll('.chip').forEach(function(b){b.addEventListener('click',function(){document.querySelectorAll('.chip').forEach(function(c){c.classList.remove('selected');});b.classList.add('selected');src=b.dataset.s;});});
  document.querySelectorAll('.npsbtn').forEach(function(b){
    b.addEventListener('click',function(){
      document.querySelectorAll('.npsbtn').forEach(function(x){x.classList.remove('selected');});
      b.classList.add('selected');npsVal=parseInt(b.dataset.n);
      var e=['😐','😐','😕','😕','😑','😐','🙂','😊','😄','🤩','🔥'];
      var t=['Très déçu','Déçu','Pas convaincu','Plutôt non','Moyen','Neutre','Bien','Bien !','Super !','Excellent !','Exceptionnel 🔥'];
      document.getElementById('nps-lbl').textContent=e[npsVal]+' '+t[npsVal];
    });
  });

  document.getElementById('cta-sub').addEventListener('click',async function(){
    var btn=document.getElementById('cta-sub'),txt=document.getElementById('sub-txt');
    btn.disabled=true;txt.textContent='Création en cours…';
    try{
      var r=await fetch('/api/profile/onboarding',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:uVal,display_name:ni.value.trim()||uVal,bio:bi.value.trim()||'',preset,feedback:{usages,source:src,nps:npsVal,comment:document.getElementById('fbi').value.trim()||null}})});
      var d=await r.json();
      if(!d.success)throw new Error(d.error||'Erreur');
      document.getElementById('done-href').href='/@'+d.data.username;
      confetti();
      step=99;
      var p3=document.getElementById('p3');p3.classList.add('leaving');
      setTimeout(function(){p3.classList.remove('active','leaving');document.getElementById('pdone').classList.add('active');document.getElementById('dots-m').style.opacity='0';document.getElementById('dots-d').style.opacity='0';},190);
    }catch(e){toast(e.message||'Une erreur est survenue');btn.disabled=false;txt.textContent='Créer mon profil ✦';}
  });

  function confetti(){
    var cols=['#00ff9d','#00cc7a','#fff','#a0ffd6'];
    for(var i=0;i<60;i++){(function(i){setTimeout(function(){var el=document.createElement('div');el.className='cf';el.style.cssText='left:'+Math.random()*100+'vw;background:'+cols[Math.floor(Math.random()*cols.length)]+';width:'+(4+Math.random()*8)+'px;height:'+(4+Math.random()*8)+'px;border-radius:'+(Math.random()>.5?'50%':'2px')+';animation-duration:'+(2+Math.random()*2)+'s;animation-delay:'+(Math.random()*.4)+'s';document.body.appendChild(el);setTimeout(function(){el.remove();},4500);},i*28);})(i);}
  }
  function toast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},4000);}

  syncDots();syncP();
  if(existingName){document.getElementById('pname').textContent=existingName;if(!avatarUrl){var l=document.getElementById('pavl');if(l)l.textContent=existingName.charAt(0).toUpperCase();}}
  if(currentUsername){ui.value=currentUsername;document.getElementById('phdl').textContent='@'+currentUsername;document.getElementById('url-slug').textContent='@'+currentUsername;uVal=currentUsername;uValid=true;cta0.disabled=false;setU('ok','@'+currentUsername+' ✓');}
  else{setTimeout(function(){ui.focus();},300);}
</script>
</body>
</html>
---
// src/pages/legal/cookies.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

const updated  = '07 mars 2026';
const SITE_URL = import.meta.env.PUBLIC_SITE_URL ?? 'https://bioforge.click';

const cookies = [
  {
    cat:  'Essentiels',
    color: '#39ff8f',
    desc: 'Strictement nécessaires au fonctionnement du service. Ils ne peuvent pas être désactivés.',
    items: [
      { name: 'sb-access-token',  origin: 'Supabase',  duration: 'Session',   purpose: 'Token d\'authentification — maintient ta session de connexion.' },
      { name: 'sb-refresh-token', origin: 'Supabase',  duration: '7 jours',   purpose: 'Token de renouvellement de session — te évite de te reconnecter trop souvent.' },
      { name: '__Host-next-auth', origin: 'BioForge',  duration: 'Session',   purpose: 'Jeton CSRF pour sécuriser les formulaires.' },
    ],
  },
  {
    cat:  'Fonctionnels',
    color: '#38bdf8',
    desc: 'Permettent de mémoriser tes préférences pour améliorer ton expérience.',
    items: [
      { name: 'bf_theme',         origin: 'BioForge',  duration: '1 an',      purpose: 'Mémorise ton choix de thème dans l\'éditeur.' },
      { name: 'bf_editor_pref',   origin: 'BioForge',  duration: '6 mois',    purpose: 'Préférences d\'interface (disposition, onglets ouverts).' },
    ],
  },
  {
    cat:  'Analytics',
    color: '#a78bfa',
    desc: 'Nous aident à comprendre comment le service est utilisé, via nos propres outils hébergés en EU. Aucun tiers externe.',
    items: [
      { name: 'bf_analytics_sid', origin: 'BioForge',  duration: '24h',       purpose: 'Identifiant de session anonyme pour agréger les statistiques de visite.' },
      { name: 'bf_uid_anon',      origin: 'BioForge',  duration: '6 mois',    purpose: 'Identifiant visiteur anonymisé pour mesurer les visites uniques.' },
    ],
  },
  {
    cat:  'Paiement',
    color: '#fb923c',
    desc: 'Nécessaires au traitement sécurisé des paiements via Stripe.',
    items: [
      { name: '__stripe_mid',     origin: 'Stripe',    duration: '1 an',      purpose: 'Identifiant de machine Stripe pour la détection de fraude.' },
      { name: '__stripe_sid',     origin: 'Stripe',    duration: '30 min',    purpose: 'Identifiant de session Stripe pour le paiement en cours.' },
    ],
  },
];
---

<BaseLayout title="Politique de cookies — BioForge">
  <Fragment slot="head">
    <meta name="description" content="Politique de cookies de BioForge. Liste complète des cookies utilisés, leur durée et leur utilité." />
    <link rel="canonical" href={`${SITE_URL}/legal/cookies`} />
    <meta name="robots" content="noindex, follow" />
  </Fragment>

  <Header />

  <main class="legal-main">
    <div class="legal-layout">

      <aside class="legal-toc" aria-label="Table des matières">
        <p class="toc-label">Sur cette page</p>
        <nav>
          <a href="#intro" class="toc-link">1. Qu'est-ce qu'un cookie ?</a>
          <a href="#liste" class="toc-link">2. Cookies utilisés</a>
          <a href="#gestion" class="toc-link">3. Gestion des cookies</a>
          <a href="#contact" class="toc-link">4. Contact</a>
        </nav>
        <div class="toc-cats">
          <p class="toc-label" style="margin-top:1rem">Catégories</p>
          {cookies.map(c => (
            <span class="toc-cat-badge" style={`color:${c.color}; background:${c.color}12; border-color:${c.color}22`}>
              {c.cat}
            </span>
          ))}
        </div>
      </aside>

      <article class="legal-content">
        <header class="legal-header">
          <div class="legal-badge">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/>
            </svg>
            Cookies
          </div>
          <h1 class="legal-title">Politique de cookies</h1>
          <p class="legal-updated">Dernière mise à jour : <time datetime="2026-03-07">{updated}</time></p>
          <p class="legal-intro">BioForge utilise un nombre limité de cookies, tous justifiés et documentés ici. Nous ne plaçons aucun cookie publicitaire ou tracker de réseau publicitaire.</p>
        </header>

        <!-- Intro -->
        <section id="intro" class="legal-section">
          <h2 class="legal-section-title">1. Qu'est-ce qu'un cookie ?</h2>
          <div class="legal-body">
            <p>Un cookie est un petit fichier texte déposé sur ton appareil (ordinateur, téléphone, tablette) lors de ta visite sur un site web. Il est ensuite renvoyé au serveur à chaque requête, permettant au site de te "reconnaître".</p>
            <p>Les cookies ont des durées de vie variables : certains expirent à la fermeture du navigateur (cookies "session"), d'autres persistent pendant une durée définie.</p>
            <p>Conformément au RGPD et aux recommandations de la CNIL, seuls les cookies strictement nécessaires peuvent être déposés sans ton consentement préalable. Les autres nécessitent ton accord exprès.</p>
          </div>
        </section>

        <!-- Liste détaillée -->
        <section id="liste" class="legal-section">
          <h2 class="legal-section-title">2. Cookies utilisés</h2>

          {cookies.map(cat => (
            <div class="cookie-cat" style={`--c:${cat.color}`}>
              <div class="cookie-cat-header">
                <div class="cookie-cat-badge" style={`color:${cat.color}; background:${cat.color}12; border-color:${cat.color}22`}>
                  {cat.cat}
                </div>
                <p class="cookie-cat-desc">{cat.desc}</p>
              </div>

              <div class="cookie-table-wrap">
                <table class="cookie-table">
                  <thead>
                    <tr>
                      <th>Nom</th>
                      <th>Origine</th>
                      <th>Durée</th>
                      <th>Finalité</th>
                    </tr>
                  </thead>
                  <tbody>
                    {cat.items.map(item => (
                      <tr>
                        <td><code>{item.name}</code></td>
                        <td>{item.origin}</td>
                        <td>{item.duration}</td>
                        <td>{item.purpose}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ))}
        </section>

        <!-- Gestion -->
        <section id="gestion" class="legal-section">
          <h2 class="legal-section-title">3. Gestion des cookies</h2>
          <div class="legal-body">
            <p>Tu peux contrôler les cookies directement depuis les paramètres de ton navigateur :</p>
            <ul class="cookie-browser-list">
              {[
                { name: 'Chrome',  url: 'https://support.google.com/chrome/answer/95647' },
                { name: 'Firefox', url: 'https://support.mozilla.org/fr/kb/activer-desactiver-cookies' },
                { name: 'Safari',  url: 'https://support.apple.com/fr-fr/guide/safari/sfri11471/mac' },
                { name: 'Edge',    url: 'https://support.microsoft.com/fr-fr/microsoft-edge/supprimer-les-cookies-dans-microsoft-edge-63947406-40ac-c3b8-57b9-2a946a29ae09' },
              ].map(b => (
                <li>
                  <a href={b.url} target="_blank" rel="noopener noreferrer" class="legal-link">
                    {b.name} — instructions officielles →
                  </a>
                </li>
              ))}
            </ul>
            <p>⚠️ La désactivation des cookies essentiels empêchera la connexion au Service.</p>
            <p>Pour les cookies analytiques et fonctionnels, tu peux les refuser sans impacter l'accès au service.</p>
          </div>
        </section>

        <!-- Contact -->
        <section id="contact" class="legal-section">
          <h2 class="legal-section-title">4. Contact</h2>
          <div class="legal-body">
            <p>Pour toute question sur notre utilisation des cookies :</p>
            <p>📧 <strong><a href="mailto:privacy@bioforge.click" class="legal-link">privacy@bioforge.click</a></strong></p>
          </div>
        </section>

      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .legal-main { padding-top: 64px; }
  .legal-layout {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 240px 1fr;
    gap: 4rem; padding: 4rem 1.5rem 6rem; align-items: start;
  }

  /* ToC */
  .legal-toc { position: sticky; top: 88px; background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.07); border-radius: 1rem; padding: 1.25rem; }
  .toc-label { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .09em; color: rgba(255,255,255,.3); margin-bottom: .75rem; }
  .toc-link { display: block; padding: .375rem .5rem; border-radius: .375rem; font-size: .775rem; color: rgba(255,255,255,.45); text-decoration: none; transition: all .15s; margin-bottom: .125rem; line-height: 1.4; }
  .toc-link:hover { color: #a78bfa; background: rgba(167,139,250,.07); }
  .toc-cats { display: flex; flex-direction: column; gap: .375rem; }
  .toc-cat-badge { display: block; padding: .25rem .625rem; border-radius: 99px; border: 1px solid; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }

  /* Content */
  .legal-content { min-width: 0; }
  .legal-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,.07); }
  .legal-badge { display: inline-flex; align-items: center; gap: .4rem; padding: .3rem .875rem; margin-bottom: 1rem; background: rgba(167,139,250,.07); border: 1px solid rgba(167,139,250,.18); border-radius: 99px; font-size: .72rem; font-weight: 700; color: #a78bfa; text-transform: uppercase; letter-spacing: .08em; }
  .legal-title { font-family: 'Syne', sans-serif; font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; color: #fff; letter-spacing: -.03em; margin-bottom: .5rem; }
  .legal-updated { font-size: .8rem; color: rgba(255,255,255,.32); margin-bottom: 1rem; }
  .legal-intro { font-size: 1rem; color: rgba(255,255,255,.55); line-height: 1.7; padding: 1.125rem 1.375rem; background: rgba(167,139,250,.05); border-left: 3px solid rgba(167,139,250,.4); border-radius: 0 .75rem .75rem 0; }

  .legal-section { margin-bottom: 2.75rem; padding-bottom: 2.75rem; border-bottom: 1px solid rgba(255,255,255,.05); }
  .legal-section:last-child { border-bottom: none; }
  .legal-section-title { font-family: 'Syne', sans-serif; font-size: 1.125rem; font-weight: 800; color: #fff; letter-spacing: -.02em; margin-bottom: 1.25rem; }

  .legal-body { font-size: .875rem; color: rgba(255,255,255,.55); line-height: 1.8; }
  .legal-body p { margin-bottom: .875rem; }
  .legal-body p:last-child { margin-bottom: 0; }
  .legal-body strong { color: rgba(255,255,255,.82); font-weight: 600; }
  .legal-link { color: #a78bfa; text-decoration: none; }
  .legal-link:hover { text-decoration: underline; }

  /* Cookies spécifique */
  .cookie-cat { margin-bottom: 2rem; }
  .cookie-cat-header { margin-bottom: 1rem; }
  .cookie-cat-badge { display: inline-block; padding: .25rem .75rem; border-radius: 99px; border: 1px solid; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; margin-bottom: .625rem; }
  .cookie-cat-desc { font-size: .8125rem; color: rgba(255,255,255,.45); line-height: 1.6; }

  .cookie-table-wrap { overflow-x: auto; border-radius: .875rem; border: 1px solid rgba(255,255,255,.07); }
  .cookie-table { width: 100%; border-collapse: collapse; font-size: .8125rem; }
  .cookie-table thead tr { background: rgba(255,255,255,.04); }
  .cookie-table th { padding: .75rem 1rem; text-align: left; font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.38); white-space: nowrap; border-bottom: 1px solid rgba(255,255,255,.08); }
  .cookie-table td { padding: .75rem 1rem; color: rgba(255,255,255,.55); border-bottom: 1px solid rgba(255,255,255,.04); vertical-align: top; }
  .cookie-table tr:last-child td { border-bottom: none; }
  .cookie-table tr:hover td { background: rgba(255,255,255,.02); }
  .cookie-table code { font-family: monospace; font-size: .78em; background: rgba(255,255,255,.08); padding: .15em .45em; border-radius: 4px; color: rgba(255,255,255,.75); }

  .cookie-browser-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .5rem; margin: .875rem 0; }
  .cookie-browser-list li::before { content: '→  '; color: rgba(255,255,255,.2); }

  @media (max-width: 820px) { .legal-layout { grid-template-columns: 1fr; gap: 2rem; } .legal-toc { position: static; } }
  @media (max-width: 480px) { .legal-layout { padding: 2rem 1rem 4rem; } }
</style>
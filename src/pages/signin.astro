---
import { createSupabaseServer } from '@/lib/supabase/server';

const errorMessage = Astro.url.searchParams.get('error');
const successMessage = Astro.url.searchParams.get('success');

const supabase = createSupabaseServer({
  request: Astro.request,
  cookies: Astro.cookies,
});

const ALLOWED_PROVIDERS = ['google', 'discord', 'apple'] as const;
type Provider = typeof ALLOWED_PROVIDERS[number];

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://bioforge-three.vercel.app/';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const provider = formData.get('provider');

  if (provider && ALLOWED_PROVIDERS.includes(provider as Provider)) {
    const { data, error } = await supabase.auth.signInWithOAuth({
      provider: provider as Provider,
      options: { redirectTo: `${siteUrl}/auth/callback` },
    });

    if (error) return Astro.redirect(`/signin?error=oauth_failed`);
    if (data.url) return Astro.redirect(data.url);
  }

  // Magic link email (optionnel)
  const email = formData.get('email');
  if (email && typeof email === 'string') {
    const { data, error } = await supabase.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: `${siteUrl}/auth/callback` },
    });
    if (error) return Astro.redirect(`/signin?error=magiclink_failed`);
    return Astro.redirect('/signin?success=check_email');
  }

  return Astro.redirect('/signin?error=invalid_request');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Sign In</title>
</head>
<body>
  {errorMessage && <div style="color:red">{errorMessage}</div>}
  {successMessage && <div style="color:green">{successMessage}</div>}

  <form method="POST">
    <input type="hidden" name="provider" value="google">
    <button type="submit">Sign in with Google</button>
  </form>

  <form method="POST">
    <input type="hidden" name="provider" value="discord">
    <button type="submit">Sign in with Discord</button>
  </form>

  <form method="POST">
    <input type="hidden" name="provider" value="apple">
    <button type="submit">Sign in with Apple</button>
  </form>

  <form method="POST">
    <input type="email" name="email" placeholder="you@example.com">
    <button type="submit">Send Magic Link</button>
  </form>
</body>
</html>
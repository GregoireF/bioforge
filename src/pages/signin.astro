---
import { createSupabaseServer } from '@/lib/supabase/server';

const errorMessage = Astro.url.searchParams.get('error');
const successMessage = Astro.url.searchParams.get('success');

const supabase = createSupabaseServer({
  request: Astro.request,
  cookies: Astro.cookies,
});

const ALLOWED_PROVIDERS = ['google', 'discord'] as const;
type Provider = typeof ALLOWED_PROVIDERS[number];

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://bioforge.click';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const provider = formData.get('provider');

  if (provider) {
    const { data, error } = await supabase.auth.signInWithOAuth({
      provider: provider as Provider,
      options: { redirectTo: `${siteUrl}/auth/callback` }
    });

    if (error) return Astro.redirect('/signin?error=oauth_failed');
    return Astro.redirect(data.url);
  }
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Connexion — BioForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    :root {
      --bg:     #080a0c;
      --card:   #0d1012;
      --border: rgba(255,255,255,0.07);
      --neon:   #39ff8f;
      --neon2:  #b4ff6e;
      --text:   #e8f0eb;
      --muted:  rgba(255,255,255,0.38);
      --dim:    rgba(255,255,255,0.06);
    }

    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      color: var(--text);
      overflow: hidden;
    }

    /* ── Background ambiance ── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 20% 10%,  rgba(57,255,143,0.06) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 80% 80%,  rgba(57,255,143,0.04) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Grain */
    body::after {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none; opacity: 0.6;
    }

    /* ── Layout ── */
    .page {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 100vh;
      position: relative;
      z-index: 1;
    }

    .wrap {
      width: 100%;
      max-width: 400px;
      display: flex;
      flex-direction: column;
      gap: 2rem;
      animation: fade-up 0.5s cubic-bezier(0.4,0,0.2,1) both;
    }
    @keyframes fade-up {
      from { opacity:0; transform:translateY(16px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* ── Logo ── */
    .logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      justify-content: center;
      text-decoration: none;
    }
    .logo-icon {
      width: 32px; height: 32px;
      background: linear-gradient(135deg, var(--neon), var(--neon2));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }
    .logo-text {
      font-family: 'Syne', sans-serif;
      font-size: 1.125rem;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    /* ── Card ── */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 1.25rem;
      padding: 2rem;
      backdrop-filter: blur(12px);
      box-shadow: 0 24px 80px rgba(0,0,0,0.4), 0 0 0 1px rgba(57,255,143,0.04);
    }

    .card-head {
      text-align: center;
      margin-bottom: 1.75rem;
    }
    .card-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -0.03em;
      margin-bottom: 0.35rem;
    }
    .card-sub {
      font-size: 0.8375rem;
      color: var(--muted);
    }

    /* ── Messages ── */
    .msg {
      padding: 0.75rem 1rem;
      border-radius: 0.625rem;
      font-size: 0.8125rem;
      font-weight: 500;
      margin-bottom: 1.25rem;
      line-height: 1.5;
    }
    .msg-err  { background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.22); color: #ff6b6b; }
    .msg-ok   { background: rgba(57,255,143,0.08);  border: 1px solid rgba(57,255,143,0.22);  color: var(--neon); }

    /* ── OAuth buttons ── */
    .oauth-list { display:flex; flex-direction:column; gap:0.625rem; margin-bottom:1.5rem; }

    .oauth-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.625rem;
      padding: 0.75rem 1rem;
      background: var(--dim);
      border: 1px solid var(--border);
      border-radius: 0.75rem;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      position: relative;
      overflow: hidden;
    }
    .oauth-btn::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
      transform: translateX(-100%);
      transition: transform 0.4s ease;
    }
    .oauth-btn:hover { background: rgba(255,255,255,0.09); border-color: rgba(255,255,255,0.13); transform: translateY(-1px); }
    .oauth-btn:hover::before { transform: translateX(100%); }
    .oauth-btn:active { transform: translateY(0); }

    .oauth-icon { width:18px; height:18px; flex-shrink:0; }

    /* ── Divider ── */
    .divider {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      margin-bottom: 1.5rem;
      color: var(--muted);
      font-size: 0.75rem;
      letter-spacing: 0.05em;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── Email form ── */
    .email-form { display:flex; flex-direction:column; gap:0.75rem; }

    .field-wrap { display:flex; flex-direction:column; gap:0.35rem; }
    .field-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    input[type="email"] {
      padding: 0.75rem 0.9375rem;
      background: var(--dim);
      border: 1px solid var(--border);
      border-radius: 0.75rem;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
      width: 100%;
    }
    input[type="email"]::placeholder { color: rgba(255,255,255,0.2); }
    input[type="email"]:focus {
      border-color: rgba(57,255,143,0.45);
      box-shadow: 0 0 0 3px rgba(57,255,143,0.08);
    }

    .submit-btn {
      padding: 0.8125rem;
      background: linear-gradient(135deg, var(--neon), var(--neon2));
      color: #050c08;
      border: none;
      border-radius: 0.75rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.15s;
      letter-spacing: 0.01em;
    }
    .submit-btn:hover {
      filter: brightness(1.08);
      transform: translateY(-1px);
      box-shadow: 0 6px 24px rgba(57,255,143,0.25);
    }
    .submit-btn:active { transform:translateY(0); }

    /* ── Footer ── */
    .foot {
      text-align: center;
      font-size: 0.73rem;
      color: rgba(255,255,255,0.22);
      line-height: 1.7;
    }
    .foot a { color: var(--neon); text-decoration: none; }
    .foot a:hover { text-decoration: underline; }

    /* Stagger animations */
    .card-head   { animation: fade-up 0.5s 0.05s cubic-bezier(0.4,0,0.2,1) both; }
    .oauth-list  { animation: fade-up 0.5s 0.1s  cubic-bezier(0.4,0,0.2,1) both; }
    .divider     { animation: fade-up 0.5s 0.15s cubic-bezier(0.4,0,0.2,1) both; }
    .email-form  { animation: fade-up 0.5s 0.2s  cubic-bezier(0.4,0,0.2,1) both; }
    .foot        { animation: fade-up 0.5s 0.25s cubic-bezier(0.4,0,0.2,1) both; }
  </style>
</head>
<body>
<div class="page">
  <div class="wrap">

    <!-- Logo -->
    <a href="/" class="logo">
      <div class="logo-icon">⚡</div>
      <span class="logo-text">BioForge</span>
    </a>

    <!-- Card -->
    <div class="card">

      <div class="card-head">
        <h1 class="card-title">Bon retour 👋</h1>
        <p class="card-sub">Connecte-toi à ton compte BioForge</p>
      </div>

      {errorMessage && (
        <div class="msg msg-err">{errorMessage}</div>
      )}
      {successMessage && (
        <div class="msg msg-ok">{successMessage}</div>
      )}

      <!-- OAuth -->
      <div class="oauth-list">

        <form method="POST">
          <input type="hidden" name="provider" value="google" />
          <button type="submit" class="oauth-btn">
            <!-- Google SVG -->
            <svg class="oauth-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Continuer avec Google
          </button>
        </form>

        <form method="POST">
          <input type="hidden" name="provider" value="discord" />
          <button type="submit" class="oauth-btn">
            <!-- Discord SVG -->
            <svg class="oauth-icon" viewBox="0 0 24 24" fill="#5865F2" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.032.053a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
            Continuer avec Discord
          </button>
        </form>

      </div>

      <!-- Divider -->
      <div class="divider">ou par email</div>

      <!-- Email magic link -->
      <form method="POST" class="email-form">
        <div class="field-wrap">
          <label class="field-label" for="email">Adresse email</label>
          <input type="email" id="email" name="email" placeholder="toi@exemple.com" required autocomplete="email" />
        </div>
        <button type="submit" class="submit-btn">Envoyer le lien magique ✦</button>
      </form>

    </div>

    <!-- Footer -->
    <p class="foot">
      En continuant, tu acceptes nos <a href="/legal/terms">CGU</a> et notre <a href="/legal/privacy">Politique de confidentialité</a>
    </p>

  </div>
</div>
</body>
</html>
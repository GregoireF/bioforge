---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getProfileByUsername, getActiveBlocks, incrementProfileView } from '@/lib/supabase/queries';
import QRCode from 'qrcode';

// ==================== PARAMS ====================
const { username } = Astro.params;
if (!username) return Astro.redirect('/404');

// ==================== PROFILE ====================
const profileResult = await getProfileByUsername(username);
if (!profileResult.success) return Astro.redirect('/404');
const profile = profileResult.data;

// ==================== BLOCKS ====================
const blocksResult = await getActiveBlocks(profile.id);
const blocks = blocksResult.success ? blocksResult.data : [];

// ==================== VIEW COUNT ====================
incrementProfileView(username).catch(console.error);

// ==================== SANITIZATION ====================
function sanitizeHex(val: unknown, fallback: string): string {
  return typeof val === 'string' && /^#[0-9A-Fa-f]{6}$/.test(val) ? val : fallback;
}
function sanitizeInt(val: unknown, min: number, max: number, fallback: number): number {
  const n = parseInt(String(val));
  return isFinite(n) && n >= min && n <= max ? n : fallback;
}
const ALLOWED_FONTS = ['Inter','Poppins','Roboto','Montserrat','Open Sans','Lato','Space Grotesk','DM Sans','Geist','Figtree','Afacad'];

// ==================== THEME ====================
const DEFAULT_THEME = {
  preset:           'dark',
  background_color: '#0a0a0a',
  primary_color:    '#00ff9d',
  text_color:       '#ffffff',
  button_style:     'filled',
  border_radius:    12,
  font_family:      'Inter',
  background_style: 'solid',
  gradient_color_2: '#1a1a2e',
  gradient_angle:   135,
  gradient_type:    'linear',
  block_shadow:     true,
  animations:       true,
};

let theme = { ...DEFAULT_THEME };

if (profile.theme) {
  try {
    const raw = typeof profile.theme === 'string' ? JSON.parse(profile.theme) : profile.theme;
    theme = {
      ...DEFAULT_THEME,
      ...raw,
      background_color: sanitizeHex(raw.background_color, DEFAULT_THEME.background_color),
      primary_color:    sanitizeHex(raw.primary_color,    DEFAULT_THEME.primary_color),
      text_color:       sanitizeHex(raw.text_color,       DEFAULT_THEME.text_color),
      gradient_color_2: sanitizeHex(raw.gradient_color_2, DEFAULT_THEME.gradient_color_2),
      font_family:      ALLOWED_FONTS.includes(raw.font_family) ? raw.font_family : DEFAULT_THEME.font_family,
      border_radius:    sanitizeInt(raw.border_radius,  0, 32,  DEFAULT_THEME.border_radius),
      gradient_angle:   sanitizeInt(raw.gradient_angle, 0, 360, DEFAULT_THEME.gradient_angle),
      gradient_type:    ['linear','radial'].includes(raw.gradient_type)            ? raw.gradient_type    : 'linear',
      background_style: ['solid','gradient','blur'].includes(raw.background_style) ? raw.background_style : 'solid',
      button_style:     ['filled','outline','shadow'].includes(raw.button_style)   ? raw.button_style     : 'filled',
      block_shadow:     typeof raw.block_shadow === 'boolean' ? raw.block_shadow   : true,
      animations:       typeof raw.animations   === 'boolean' ? raw.animations     : true,
    };
  } catch { /* keep defaults */ }
}

// ==================== COMPUTED CSS ====================
const br = theme.border_radius;
const pc = theme.primary_color;
const bg = theme.background_color;
const tc = theme.text_color;

let computedBg: string;
if (theme.background_style === 'gradient') {
  computedBg = theme.gradient_type === 'radial'
    ? `background: radial-gradient(circle, ${bg}, ${theme.gradient_color_2});`
    : `background: linear-gradient(${theme.gradient_angle}deg, ${bg}, ${theme.gradient_color_2});`;
} else {
  computedBg = `background-color: ${bg};`;
}

const btnBase = `border-radius: ${br}px; font-family: '${theme.font_family}', sans-serif;`;
let btnStyle: string;
if (theme.button_style === 'outline') {
  btnStyle = `${btnBase} background: transparent; border: 2px solid ${pc}; color: ${pc};`;
} else if (theme.button_style === 'shadow') {
  btnStyle = `${btnBase} background: ${pc}; border: none; color: ${bg}; box-shadow: 0 0 28px ${pc}60;`;
} else {
  btnStyle = `${btnBase} background: ${pc}; border: none; color: ${bg};${theme.block_shadow ? ` box-shadow: 0 8px 24px ${pc}40;` : ''}`;
}

const socialBtnStyle = `background-color: ${pc}; color: ${bg}; border-radius: 50%;${theme.block_shadow ? ` box-shadow: 0 4px 16px ${pc}60;` : ''}`;

// ==================== SEO DATA ====================
const profileUrl    = `https://bioforge.click/@${profile.username}`;
const pageTitle     = profile.display_name
  ? `${profile.display_name} (@${profile.username}) — BioForge`
  : `@${profile.username} — BioForge`;
const pageDesc      = profile.bio
  ? `${profile.bio} — Retrouvez tous les liens de ${profile.display_name || profile.username} sur BioForge.`
  : `Retrouvez tous les liens de ${profile.display_name || profile.username} sur BioForge.`;
const ogImage       = profile.avatar_url || `https://bioforge.click/og-default.png`;

// ==================== GOOGLE FONTS ====================
const fontParam = encodeURIComponent(theme.font_family);
const fontUrl   = `https://fonts.googleapis.com/css2?family=${fontParam}:wght@400;500;600;700&display=swap`;

// ==================== QR CODE (server-side, primary color) ====================
let qrDataUrl = '';
try {
  qrDataUrl = await QRCode.toDataURL(profileUrl, {
    width: 256, margin: 2,
    color: { dark: pc, light: '#00000000' },
    errorCorrectionLevel: 'H',
  });
} catch {}

// ==================== BRIDGE ====================
const bridge = JSON.stringify({
  profileUrl,
  profileName: String(profile.display_name || profile.username || ''),
  primaryColor: pc,
  bgColor: bg,
  textColor: tc,
  qrDataUrl,
});

// ==================== SOCIAL ICONS ====================
const SOCIAL_ICONS: Record<string, string> = {
  twitter:   'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.763l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  instagram: 'M7 1C3.1 1 1 3.1 1 7v10c0 3.9 2.1 6 6 6h10c3.9 0 6-2.1 6-6V7c0-3.9-2.1-6-6-6H7zm8 3a1 1 0 110 2 1 1 0 010-2zm-3 3a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6z',
  facebook:  'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z',
  youtube:   'M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z M9.75 15.02l0-6.89 5.75 3.44z',
  linkedin:  'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z',
  github:    'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22',
  tiktok:    'M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5',
  twitch:    'M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z',
  discord:   'M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z',
};

function getSocialIconPath(url?: string): string {
  if (!url) return 'M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71';
  const u = url.toLowerCase();
  if (u.includes('twitter.com') || u.includes('x.com')) return SOCIAL_ICONS.twitter;
  if (u.includes('instagram.com')) return SOCIAL_ICONS.instagram;
  if (u.includes('facebook.com')) return SOCIAL_ICONS.facebook;
  if (u.includes('youtube.com'))  return SOCIAL_ICONS.youtube;
  if (u.includes('linkedin.com')) return SOCIAL_ICONS.linkedin;
  if (u.includes('github.com'))   return SOCIAL_ICONS.github;
  if (u.includes('tiktok.com'))   return SOCIAL_ICONS.tiktok;
  if (u.includes('twitch.tv'))    return SOCIAL_ICONS.twitch;
  if (u.includes('discord'))      return SOCIAL_ICONS.discord;
  return 'M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71';
}
---

<BaseLayout title={pageTitle}>

  <!-- ===== SEO HEAD ===== -->
  <meta name="description" content={pageDesc} slot="head" />
  <link rel="canonical" href={profileUrl} slot="head" />

  <!-- Open Graph -->
  <meta property="og:type"        content="profile"        slot="head" />
  <meta property="og:url"         content={profileUrl}     slot="head" />
  <meta property="og:title"       content={pageTitle}      slot="head" />
  <meta property="og:description" content={pageDesc}       slot="head" />
  <meta property="og:image"       content={ogImage}        slot="head" />
  <meta property="og:image:width"  content="400"           slot="head" />
  <meta property="og:image:height" content="400"           slot="head" />
  <meta property="og:site_name"   content="BioForge"       slot="head" />
  {profile.username && <meta property="profile:username" content={profile.username} slot="head" />}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary"       slot="head" />
  <meta name="twitter:title"       content={pageTitle}     slot="head" />
  <meta name="twitter:description" content={pageDesc}      slot="head" />
  <meta name="twitter:image"       content={ogImage}       slot="head" />

  <!-- JSON-LD Person schema -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context":   "https://schema.org",
    "@type":      "Person",
    "name":       profile.display_name || profile.username,
    "url":        profileUrl,
    "image":      profile.avatar_url || null,
    "description":profile.bio || null,
    "sameAs":     blocks
      .filter((b: any) => b.type === 'social' && Array.isArray(b.config?.links))
      .flatMap((b: any) => b.config.links.map((l: any) => typeof l === 'string' ? l : l?.url))
      .filter(Boolean),
  })} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={fontUrl} />

  <!-- Bridge -->
  <div id="page-data" class="hidden" data-bridge={bridge}></div>

  <!-- Blur overlay -->
  {theme.background_style === 'blur' && (
    <div class="fixed inset-0 z-0 pointer-events-none"
      style={`background-color: ${bg}CC; backdrop-filter: blur(60px); -webkit-backdrop-filter: blur(60px);`}>
    </div>
  )}

  <!-- ===== PAGE ===== -->
  <div class="min-h-screen flex flex-col items-center justify-start px-4 py-16 relative z-10"
    style={`${computedBg} font-family: '${theme.font_family}', system-ui, sans-serif; color: ${tc};`}>

    <div class="w-full max-w-xl">

      <!-- HEADER -->
      <header class="text-center mb-10 animate-fade-in-up">
        {profile.avatar_url ? (
          <img src={profile.avatar_url} alt={`Photo de profil de ${profile.display_name || profile.username}`}
            class="w-24 h-24 lg:w-28 lg:h-28 rounded-full mx-auto mb-5 object-cover"
            style={`border: 3px solid ${pc}; box-shadow: 0 0 40px ${pc}50;`} loading="eager" />
        ) : (
          <div class="w-24 h-24 lg:w-28 lg:h-28 rounded-full mx-auto mb-5 flex items-center justify-center text-4xl font-bold"
            style={`background: linear-gradient(135deg, ${pc}, ${pc}80); color: ${bg}; box-shadow: 0 0 40px ${pc}50;`}>
            {(profile.display_name || profile.username || '?').charAt(0).toUpperCase()}
          </div>
        )}
        <h1 class="text-2xl lg:text-3xl font-bold mb-2 tracking-tight" style={`color: ${tc};`}>
          {profile.display_name || `@${profile.username}`}
        </h1>
        {profile.display_name && (
          <p class="text-sm mb-3 font-mono" style={`color: ${tc}; opacity: 0.45;`}>@{profile.username}</p>
        )}
        {profile.bio && (
          <p class="text-sm lg:text-base leading-relaxed max-w-sm mx-auto" style={`color: ${tc}; opacity: 0.75;`}>
            {profile.bio}
          </p>
        )}
      </header>

      <!-- BLOCKS -->
      {blocks.length === 0 ? (
        <div class="text-center py-16" style={`color: ${tc}; opacity: 0.4;`}>
          <p class="text-base">No links yet</p>
        </div>
      ) : (
        <div class="space-y-3 mb-12">
          {blocks.map((block: any, index: number) => {
            const animDelay = `animation-delay: ${Math.min(index * 80, 400)}ms;`;

            // ── HEADING ──
            if (block.type === 'heading') return (
              <div class={`text-lg lg:text-xl font-bold text-center py-2 ${theme.animations ? 'animate-fade-in-up' : ''}`}
                style={`color: ${tc}; ${animDelay}`}>
                {block.title || 'Heading'}
              </div>
            );

            // ── SPACER ──
            if (block.type === 'spacer') return <div class="h-6"></div>;

            // ── LINK ──
            if (block.type === 'link') {
              const url     = block.config?.url || '#';
              const iconUrl = block.config?.icon_url || null;
              const hasIcon = Boolean(iconUrl);

              return (
                <div class={`block-dot-wrap group relative ${theme.animations ? 'animate-fade-in-up' : ''}`} style={animDelay}>

                  <!-- Link button -->
                  <a href={url} target="_blank" rel="noopener noreferrer"
                    data-block-id={block.id}
                    class={`flex items-center w-full py-4 px-5 font-semibold transition-all ${theme.animations ? 'hover:scale-[1.02] active:scale-[0.98]' : ''}`}
                    style={btnStyle}>
                    {hasIcon && (
                      <div class="shrink-0 w-9 h-9 rounded-full overflow-hidden mr-4 border-2" style={`border-color: ${bg}40;`}>
                        <img src={iconUrl} alt="" class="w-full h-full object-cover" loading="lazy" />
                      </div>
                    )}
                    <span class={hasIcon ? 'flex-1 text-left' : 'flex-1 text-center'}>
                      {block.title || 'Link'}
                    </span>
                  </a>

                  <!-- 3-dot button — toujours visible -->
                  <button
                    class="block-dot-btn absolute top-1/2 -translate-y-1/2 right-2 z-20
                      w-9 h-9 rounded-full flex items-center justify-center
                      transition-all hover:scale-110 active:scale-95"
                    style={`background: ${bg}CC; border: 1px solid ${tc}30; color: ${tc};`}
                    data-id={String(block.id)}
                    data-title={String(block.title || '')}
                    data-url={url}
                    data-icon={iconUrl || ''}
                    aria-label="Options">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <circle cx="12" cy="5" r="2"/>
                      <circle cx="12" cy="12" r="2"/>
                      <circle cx="12" cy="19" r="2"/>
                    </svg>
                  </button>

                  <!-- DROPDOWN — absolute par rapport au parent relative -->
                  <div
                    class="dot-dropdown hidden absolute right-0 top-full mt-2 z-50 w-52 rounded-2xl shadow-2xl py-2 overflow-hidden"
                    style={`background: ${bg}F5; border: 1px solid ${tc}18; backdrop-filter: blur(16px);`}
                    data-id={String(block.id)}>

                    <button
                      class="dot-copy-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium transition-colors hover:bg-white/8 text-left"
                      style={`color: ${tc};`}
                      data-url={url}>
                      <svg class="w-5 h-5 opacity-60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                      </svg>
                      Copier le lien
                    </button>

                    <button
                      class="dot-share-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium transition-colors hover:bg-white/8 text-left"
                      style={`color: ${tc};`}
                      data-id={String(block.id)}
                      data-title={String(block.title || '')}
                      data-url={url}
                      data-icon={iconUrl || ''}>
                      <svg class="w-5 h-5 opacity-60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                      </svg>
                      Partager le lien
                    </button>

                  </div>
                </div>
              );
            }

            // ── IMAGE ──
            if (block.type === 'image') {
              const imgUrl = block.config?.url;
              const imgLink = block.config?.link;
              if (!imgUrl) return null;
              const img = (
                <img src={imgUrl} alt={block.title || 'Image'}
                  class={`w-full object-cover ${theme.animations ? 'hover:scale-[1.02]' : ''} transition-transform`}
                  style={`border-radius: ${br}px; ${theme.block_shadow ? 'box-shadow: 0 8px 24px rgba(0,0,0,0.3);' : ''}`}
                  loading="lazy" />
              );
              return imgLink
                ? <a href={imgLink} target="_blank" rel="noopener noreferrer" style={animDelay}>{img}</a>
                : <div style={animDelay}>{img}</div>;
            }

            // ── VIDEO ──
            if (block.type === 'video') {
              const videoUrl = block.config?.url;
              if (!videoUrl) return null;
              let embedUrl = videoUrl;
              if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                const id = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/)?.[1];
                if (id) embedUrl = `https://www.youtube.com/embed/${id}`;
              } else if (videoUrl.includes('vimeo.com')) {
                const id = videoUrl.match(/vimeo\.com\/(\d+)/)?.[1];
                if (id) embedUrl = `https://player.vimeo.com/video/${id}`;
              } else if (videoUrl.includes('tiktok.com')) {
                const id = videoUrl.match(/tiktok\.com\/.*\/video\/(\d+)/)?.[1];
                if (id) embedUrl = `https://www.tiktok.com/embed/v2/${id}`;
              }
              return (
                <div class={`relative w-full overflow-hidden ${theme.animations ? 'animate-fade-in-up' : ''}`}
                  style={`padding-bottom: 56.25%; border-radius: ${br}px; ${theme.block_shadow ? 'box-shadow: 0 8px 24px rgba(0,0,0,0.3);' : ''} ${animDelay}`}>
                  <iframe src={embedUrl} class="absolute inset-0 w-full h-full" frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen style={`border-radius: ${br}px;`}></iframe>
                </div>
              );
            }

            // ── SOCIAL ──
            if (block.type === 'social') {
              const links = Array.isArray(block.config?.links) ? block.config.links : [];
              if (!links.length) return null;
              return (
                <div class={`flex items-center justify-center flex-wrap gap-3 py-2 ${theme.animations ? 'animate-fade-in-up' : ''}`} style={animDelay}>
                  {links.map((link: any) => {
                    const url = typeof link === 'string' ? link : link?.url;
                    if (!url) return null;
                    return (
                      <a href={url} target="_blank" rel="noopener noreferrer" data-block-id={block.id}
                        class={`w-12 h-12 flex items-center justify-center transition-all ${theme.animations ? 'hover:scale-110 active:scale-95' : ''}`}
                        style={socialBtnStyle}>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path d={getSocialIconPath(url)} />
                        </svg>
                      </a>
                    );
                  })}
                </div>
              );
            }

            return null;
          })}
        </div>
      )}

      <!-- FOOTER -->
      <footer class="text-center pb-8">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium transition-all hover:opacity-80"
          style={`color: ${pc};`}>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Créer mon BioForge
        </a>
      </footer>

    </div>
  </div>

  <!-- ===== QR CODE FIXE ===== -->
  {qrDataUrl && (
    <div class="fixed bottom-6 right-6 z-50 group">
      <div class="p-3 rounded-2xl shadow-2xl border transition-all group-hover:scale-105"
        style={`background: ${bg}CC; border-color: ${pc}30; backdrop-filter: blur(12px);`}>
        <img src={qrDataUrl} alt={`QR code du profil de ${profile.username}`} class="w-24 h-24 rounded-xl" />
      </div>
    </div>
  )}

  <!-- ===== SHARE MODAL ===== -->
  <div id="share-modal"
    class="fixed inset-0 z-[9999] hidden items-center justify-center p-4"
    role="dialog" aria-modal="true" aria-labelledby="modal-title-text">

    <div id="share-backdrop" class="absolute inset-0 bg-black/75 backdrop-blur-lg"></div>

    <div id="share-inner"
      class="relative w-full max-w-sm rounded-3xl overflow-hidden shadow-2xl transition-all duration-300 scale-95 opacity-0"
      style={`background: ${bg}F2; border: 1px solid ${tc}18; backdrop-filter: blur(24px);`}>

      <!-- Close -->
      <button id="share-close"
        class="absolute top-4 right-4 z-10 p-2 rounded-full bg-black/30 hover:bg-black/50 transition text-white"
        aria-label="Fermer">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div class="px-6 pt-14 pb-7">

        <!-- Preview du block partagé -->
        <div class="text-center mb-6">
          <div class="inline-flex p-1.5 rounded-2xl mb-4" style={`background: ${tc}08; border: 1px solid ${tc}12;`}>
            <div class="w-20 h-20 rounded-xl overflow-hidden border-2 border-white/10">
              <img id="modal-icon-img" src="" alt="" class="hidden w-full h-full object-cover" />
              <div id="modal-icon-fallback"
                class="w-full h-full flex items-center justify-center text-3xl font-bold"
                style={`background: linear-gradient(135deg, ${pc}, ${pc}99); color: ${bg};`}></div>
            </div>
          </div>
          <h2 id="modal-title-text" class="text-xl font-bold mb-1 truncate px-4" style={`color: ${tc};`}></h2>
          <p id="modal-url-text" class="text-xs font-mono opacity-50 break-all px-4" style={`color: ${tc};`}></p>
        </div>

        <!-- QR Code (pre-generated server-side, mis à jour côté client si différent) -->
        <div class="text-center mb-6">
          <p class="text-xs uppercase tracking-widest opacity-50 mb-3 font-semibold" style={`color: ${tc};`}>
            Scanner pour ouvrir
          </p>
          <div class="inline-block p-3 rounded-2xl border" style={`background: ${tc}05; border-color: ${tc}10;`}>
            <img id="modal-qr" src={qrDataUrl} alt="QR Code" class="w-28 h-28 mx-auto rounded-lg" />
          </div>
        </div>

        <!-- Copy row -->
        <button id="copy-btn"
          class="w-full flex items-center gap-3 px-4 py-3 rounded-xl mb-5 transition-all active:scale-[0.98] text-left"
          style={`background: ${tc}08; border: 1px solid ${tc}12;`}>
          <svg class="w-4 h-4 opacity-60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${tc};`}>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
          <span class="flex-1 text-sm font-mono truncate" id="copy-url-display" style={`color: ${tc}; opacity: 0.7;`}></span>
          <span id="copy-btn-label" class="text-xs font-bold shrink-0 px-2.5 py-1 rounded-lg transition-all"
            style={`background: ${pc}; color: ${bg};`}>
            Copier
          </span>
        </button>

        <!-- Réseaux sociaux -->
        <div class="grid grid-cols-4 gap-3 mb-6">
          <!-- X / Twitter -->
          <a id="shr-x" href="#" target="_blank" rel="noopener noreferrer"
            class="flex flex-col items-center gap-2 group">
            <div class="w-13 h-13 w-12 h-12 rounded-2xl flex items-center justify-center transition group-hover:scale-110 bg-black border border-white/10">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.763l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </div>
            <span class="text-xs" style={`color: ${tc}; opacity: 0.5;`}>X</span>
          </a>

          <!-- WhatsApp -->
          <a id="shr-wa" href="#" target="_blank" rel="noopener noreferrer"
            class="flex flex-col items-center gap-2 group">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center transition group-hover:scale-110 bg-[#25D366]">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <span class="text-xs" style={`color: ${tc}; opacity: 0.5;`}>WhatsApp</span>
          </a>

          <!-- Telegram -->
          <a id="shr-tg" href="#" target="_blank" rel="noopener noreferrer"
            class="flex flex-col items-center gap-2 group">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center transition group-hover:scale-110 bg-[#2AABEE]">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </div>
            <span class="text-xs" style={`color: ${tc}; opacity: 0.5;`}>Telegram</span>
          </a>

          <!-- Native share / More -->
          <button id="shr-native"
            class="flex flex-col items-center gap-2 group">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center transition group-hover:scale-110"
              style={`background: ${tc}10; border: 1px solid ${tc}15;`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${tc};`}>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
              </svg>
            </div>
            <span id="shr-native-label" class="text-xs" style={`color: ${tc}; opacity: 0.5;`}>Plus</span>
          </button>
        </div>

        <!-- Footer modal -->
        <div class="text-center text-xs border-t pt-4 flex items-center justify-center gap-3" style={`color: ${tc}; opacity: 0.4; border-color: ${tc}15;`}>
          <span>Powered by BioForge</span>
          <span>•</span>
          <button id="report-btn" class="hover:opacity-70 transition-opacity underline">Signaler</button>
        </div>

      </div>
    </div>
  </div>

  <!-- ===== STYLES ===== -->
  <style>
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up { animation: fade-in-up 0.45s ease both; }
    #share-modal.open   { display: flex; }

    .dot-dropdown button:hover { background: rgba(255,255,255,0.06); }
  </style>

  <!-- ===== SCRIPT ===== -->
  <!--
    BUG CORRIGÉ : Ne jamais wrapper dans astro:page-load sauf si View Transitions
    est activé dans astro.config. Les scripts type="module" sont déjà différés.
    On utilise DOMContentLoaded en fallback universel.
  -->
  <script type="module" define:vars={{ bridgeJson: bridge }}>

    const { profileUrl, profileName, primaryColor: pc, bgColor: bg, textColor: tc, qrDataUrl } = JSON.parse(bridgeJson);

    // ── Dropdown 3-dot ───────────────────────────────────────────────────────
    function closeAllDropdowns() {
      document.querySelectorAll('.dot-dropdown').forEach(d => d.classList.add('hidden'));
      // Réinitialise le z-index des blocs parents
      document.querySelectorAll('.block-dot-wrap').forEach(el => el.classList.remove('z-50'));
    }

    document.addEventListener('click', closeAllDropdowns);
    document.addEventListener('scroll', closeAllDropdowns, { passive: true });

    document.querySelectorAll('.block-dot-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const dropdown = document.querySelector(`.dot-dropdown[data-id="${id}"]`);
        if (!dropdown) return;
        const isOpen = !dropdown.classList.contains('hidden');
        closeAllDropdowns();
        if (!isOpen) {
          dropdown.classList.remove('hidden');
          // Élève le bloc parent pour passer au-dessus des blocs suivants
          btn.closest('.block-dot-wrap')?.classList.add('z-50');
        }
      });
    });

    // ── Copy from dropdown ───────────────────────────────────────────────────
    document.querySelectorAll('.dot-copy-btn').forEach(btn => {
      btn.addEventListener('click', async e => {
        e.stopPropagation();
        const url = btn.dataset.url;
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
          const span = btn.querySelector('span') ?? btn;
          const orig = span.textContent;
          span.textContent = 'Copié ✓';
          setTimeout(() => { span.textContent = orig; }, 2000);
        } catch {}
        closeAllDropdowns();
      });
    });

    // ── Share from dropdown ──────────────────────────────────────────────────
    document.querySelectorAll('.dot-share-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        closeAllDropdowns();
        openShareModal(btn.dataset.title, btn.dataset.url, btn.dataset.icon);
      });
    });

    // ── Share modal ──────────────────────────────────────────────────────────
    const shareModal = document.getElementById('share-modal');
    const shareInner = document.getElementById('share-inner');

    function openShareModal(title = '', url = '', iconUrl = '') {
      const label  = title  || profileName || 'Lien';
      const target = url    || profileUrl;

      // Icon
      const img      = document.getElementById('modal-icon-img');
      const fallback = document.getElementById('modal-icon-fallback');
      if (iconUrl && img && fallback) {
        img.src = iconUrl;
        img.classList.remove('hidden');
        fallback.classList.add('hidden');
      } else if (img && fallback) {
        img.classList.add('hidden');
        fallback.classList.remove('hidden');
        fallback.textContent = (label.charAt(0) || '?').toUpperCase();
      }

      // Title + URL
      const titleEl = document.getElementById('modal-title-text');
      const urlEl   = document.getElementById('modal-url-text');
      const copyEl  = document.getElementById('copy-url-display');
      if (titleEl) titleEl.textContent = label;
      if (urlEl)   urlEl.textContent   = target;
      if (copyEl)  copyEl.textContent  = target;

      // QR — utilise le QR du profil si c'est le même URL, sinon met à jour
      const qrImg = document.getElementById('modal-qr');
      if (qrImg) {
        if (target !== profileUrl) {
          // URL différente d'un block → re-génère via API (seul cas acceptable)
          qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&color=${pc.replace('#','')}&bgcolor=00000000&data=${encodeURIComponent(target)}`;
        } else {
          qrImg.src = qrDataUrl; // QR pré-généré côté serveur, instantané
        }
      }

      // Réseaux sociaux
      const enc = encodeURIComponent(target);
      const msg = encodeURIComponent(`${label} — ${target}`);
      document.getElementById('shr-x')?.setAttribute('href', `https://x.com/intent/tweet?text=${msg}`);
      document.getElementById('shr-wa')?.setAttribute('href', `https://wa.me/?text=${msg}`);
      document.getElementById('shr-tg')?.setAttribute('href', `https://t.me/share/url?url=${enc}&text=${encodeURIComponent(label)}`);

      // Native share
      document.getElementById('shr-native').onclick = async () => {
        if (navigator.share) {
          try { await navigator.share({ title: label, url: target }); return; } catch {}
        }
        // Fallback → copie
        await navigator.clipboard.writeText(target).catch(() => {});
        const lbl = document.getElementById('shr-native-label');
        if (lbl) { lbl.textContent = 'Copié !'; setTimeout(() => lbl.textContent = 'Plus', 2000); }
      };

      // Open
      shareModal?.classList.add('open');
      requestAnimationFrame(() => {
        shareInner?.classList.remove('scale-95', 'opacity-0');
        shareInner?.classList.add('scale-100', 'opacity-100');
      });
    }

    function closeShareModal() {
      shareInner?.classList.remove('scale-100', 'opacity-100');
      shareInner?.classList.add('scale-95', 'opacity-0');
      setTimeout(() => shareModal?.classList.remove('open'), 280);
    }

    document.getElementById('share-backdrop')?.addEventListener('click', closeShareModal);
    document.getElementById('share-close')?.addEventListener('click',    closeShareModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeShareModal(); });

    // ── Copy button dans la modal ────────────────────────────────────────────
    document.getElementById('copy-btn')?.addEventListener('click', async () => {
      const url = document.getElementById('copy-url-display')?.textContent?.trim();
      if (!url) return;
      await navigator.clipboard.writeText(url).catch(() => {});
      const lbl = document.getElementById('copy-btn-label');
      if (lbl) { lbl.textContent = 'Copié ✓'; setTimeout(() => lbl.textContent = 'Copier', 2000); }
    });

    // ── Report ───────────────────────────────────────────────────────────────
    document.getElementById('report-btn')?.addEventListener('click', () => {
      window.open(`/report?url=${encodeURIComponent(profileUrl)}`, '_blank');
    });

    // ── Analytics ────────────────────────────────────────────────────────────
    let clickCooldown = false;
    document.querySelectorAll('[data-block-id]').forEach(el => {
      el.addEventListener('click', async () => {
        if (clickCooldown) return;
        clickCooldown = true;
        setTimeout(() => { clickCooldown = false; }, 1000);
        const blockId = el.getAttribute('data-block-id');
        if (!blockId) return;
        fetch('/api/analytics/click', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-csrf-token': 'dev-bypass' },
          body: JSON.stringify({ block_id: blockId }),
        }).catch(() => {});
      });
    });

  </script>

</BaseLayout>
  />

  <!-- ===== STYLES ===== -->
  <style>
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up { animation: fade-in-up 0.45s ease both; }
    #share-modal.open   { display: flex; }

    .dot-dropdown button:hover { background: rgba(255,255,255,0.06); }
    @keyframes badge-pop {
      0%   { transform: scale(0) rotate(-10deg); opacity: 0; }
      60%  { transform: scale(1.2) rotate(3deg); }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }
    .verified-badge { animation: badge-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both; filter: drop-shadow(0 0 8px var(--pc, #00ff9d)); }
    .scrollbar-none { scrollbar-width: none; -ms-overflow-style: none; }
    .scrollbar-none::-webkit-scrollbar { display: none; }
    #share-modal.open { display: flex; }
  </style>

  <!-- ===== SCRIPT ===== -->
  <!--
    BUG CORRIGÉ : Ne jamais wrapper dans astro:page-load sauf si View Transitions
    est activé dans astro.config. Les scripts type="module" sont déjà différés.
    On utilise DOMContentLoaded en fallback universel.
  -->
  <script type="module" define:vars={{ bridgeJson: bridge }}>

    const { profileId, profileUrl, profileName, primaryColor: pc, bgColor: bg, textColor: tc, qrDataUrl } = JSON.parse(bridgeJson);

    // ── View tracking (gated sur consentement RGPD) ──────────────────────────
    // IMPORTANT : pas de listener bf:consent pour le view tracking.
    // Raison : race condition — le CookieBanner dispatche l'événement au chargement
    // si le consentement est déjà stocké, AVANT que ce listener soit enregistré.
    // Solution : lire localStorage directement, puis écouter pour les nouvelles décisions.

    const _utmParams = new URLSearchParams(window.location.search);
    const utm = (key) => _utmParams.get(key)?.trim() || null;
    let _viewFired = false;

    function fireViewTracking() {
      if (_viewFired) return; // idempotent
      _viewFired = true;
      fetch('/api/analytics/view', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          profile_id:   profileId,
          referrer:     document.referrer || null,
          utm_source:   utm('utm_source'),
          utm_medium:   utm('utm_medium'),
          utm_campaign: utm('utm_campaign'),
          utm_content:  utm('utm_content'),
          utm_term:     utm('utm_term'),
        }),
      }).catch(() => {});
    }

    // 1. Consentement déjà enregistré → fire immédiatement (pas de race condition)
    try {
      const _stored = JSON.parse(localStorage.getItem('bf_consent_analytics') || 'null');
      if (_stored?.analytics === true) {
        fireViewTracking();
      }
    } catch {}

    // 2. Nouvelle décision depuis le banner → fire si accepté
    window.addEventListener('bf:consent', (e) => {
      if (e.detail?.analytics === true) fireViewTracking();
    });

    // ── Dropdown 3-dot ───────────────────────────────────────────────────────
    function closeAllDropdowns() {
      document.querySelectorAll('.dot-dropdown').forEach(d => d.classList.add('hidden'));
      // Réinitialise le z-index des blocs parents
      document.querySelectorAll('.block-dot-wrap').forEach(el => el.classList.remove('z-50'));
    }

    document.addEventListener('click', closeAllDropdowns);
    document.addEventListener('scroll', closeAllDropdowns, { passive: true });

    document.querySelectorAll('.block-dot-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const dropdown = document.querySelector(`.dot-dropdown[data-id="${id}"]`);
        if (!dropdown) return;
        const isOpen = !dropdown.classList.contains('hidden');
        closeAllDropdowns();
        if (!isOpen) {
          dropdown.classList.remove('hidden');
          // Élève le bloc parent pour passer au-dessus des blocs suivants
          btn.closest('.block-dot-wrap')?.classList.add('z-50');
        }
      });
    });

    // ── Copy from dropdown ───────────────────────────────────────────────────
    document.querySelectorAll('.dot-copy-btn').forEach(btn => {
      btn.addEventListener('click', async e => {
        e.stopPropagation();
        const url = btn.dataset.url;
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
          const span = btn.querySelector('span') ?? btn;
          const orig = span.textContent;
          span.textContent = 'Copié ✓';
          setTimeout(() => { span.textContent = orig; }, 2000);
        } catch {}
        closeAllDropdowns();
      });
    });

    // ── Share from dropdown ──────────────────────────────────────────────────
    document.querySelectorAll('.dot-share-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        closeAllDropdowns();
        openShareModal(btn.dataset.title, btn.dataset.url, btn.dataset.icon);
      });
    });

    // ── Share modal ──────────────────────────────────────────────────────────
    const shareModal = document.getElementById('share-modal');
    const shareInner = document.getElementById('share-inner');
    let currentShareUrl = '';

    function openShareModal(title, url, iconUrl, isProfile = false) {
      const label  = title || profileName || 'Lien';
      const target = url   || profileUrl;
      currentShareUrl = target;

      // Mode label
      const modeEl = document.getElementById('modal-mode-label');
      if (modeEl) modeEl.textContent = isProfile ? 'Partager le profil' : 'Partager le lien';

      // Toggle preview cards
      const linkPreview    = document.getElementById('modal-preview-link');
      const profilePreview = document.getElementById('modal-preview-profile');
      if (isProfile) {
        linkPreview?.classList.add('hidden');
        profilePreview?.classList.remove('hidden');
      } else {
        profilePreview?.classList.add('hidden');
        linkPreview?.classList.remove('hidden');
        // Fill link preview
        const iconImg  = document.getElementById('modal-link-icon');
        const iconFb   = document.getElementById('modal-link-fallback');
        const titleEl  = document.getElementById('modal-link-title');
        const urlEl    = document.getElementById('modal-link-url');
        if (titleEl) titleEl.textContent = label;
        if (urlEl)   urlEl.textContent   = target;
        if (iconImg && iconFb) {
          if (iconUrl) {
            iconImg.src = iconUrl;
            iconImg.classList.remove('hidden');
            iconFb.classList.add('hidden');
          } else {
            iconImg.classList.add('hidden');
            iconFb.classList.remove('hidden');
            iconFb.textContent = (label.charAt(0) || '?').toUpperCase();
          }
        }
      }

      // QR code (lazy — hidden by default behind toggle)
      const qrImg = document.getElementById('modal-qr');
      if (qrImg) {
        const bgHex = bg.replace('#','');
        const fgHex = pc.replace('#','');
        if (target === profileUrl) {
          qrImg.src = qrDataUrl; // pré-généré côté serveur, instantané
        } else {
          qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=220x220&color=${fgHex}&bgcolor=${bgHex}&data=${encodeURIComponent(target)}`;
        }
      }

      // Social links
      const enc = encodeURIComponent(target);
      const msg = encodeURIComponent(`${label} — ${target}`);
      document.getElementById('shr-x')?.setAttribute('href',  `https://x.com/intent/tweet?text=${msg}`);
      document.getElementById('shr-fb')?.setAttribute('href', `https://www.facebook.com/sharer/sharer.php?u=${enc}`);
      document.getElementById('shr-wa')?.setAttribute('href', `https://wa.me/?text=${msg}`);
      document.getElementById('shr-tg')?.setAttribute('href', `https://t.me/share/url?url=${enc}&text=${encodeURIComponent(label)}`);
      document.getElementById('shr-li')?.setAttribute('href', `https://www.linkedin.com/sharing/share-offsite/?url=${enc}`);

      // Native share
      const nativeBtn = document.getElementById('shr-native');
      const nativeLbl = document.getElementById('shr-native-label');
      if (nativeBtn) {
        nativeBtn.onclick = async () => {
          if (navigator.share) {
            try { await navigator.share({ title: label, url: target }); return; } catch {}
          }
          await navigator.clipboard.writeText(target).catch(() => {});
          if (nativeLbl) { nativeLbl.textContent = 'Copié !'; setTimeout(() => nativeLbl.textContent = 'Plus', 2000); }
        };
      }

      // Open modal
      shareModal?.classList.add('open');
      requestAnimationFrame(() => {
        shareInner?.classList.remove('translate-y-4', 'opacity-0');
        shareInner?.classList.add('translate-y-0', 'opacity-100');
      });
    }

    function closeShareModal() {
      shareInner?.classList.remove('translate-y-0', 'opacity-100');
      shareInner?.classList.add('translate-y-4', 'opacity-0');
      // Collapse QR panel
      document.getElementById('qr-panel')?.classList.add('hidden');
      document.getElementById('qr-chevron')?.classList.remove('rotate-180');
      setTimeout(() => shareModal?.classList.remove('open'), 280);
    }

    document.getElementById('share-backdrop')?.addEventListener('click', closeShareModal);
    document.getElementById('share-close')?.addEventListener('click',    closeShareModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeShareModal(); });

    // QR toggle accordion
    document.getElementById('qr-toggle')?.addEventListener('click', () => {
      const panel   = document.getElementById('qr-panel');
      const chevron = document.getElementById('qr-chevron');
      panel?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });

    // Copy button
    document.getElementById('copy-btn')?.addEventListener('click', async () => {
      if (!currentShareUrl) return;
      await navigator.clipboard.writeText(currentShareUrl).catch(() => {});
      const lbl = document.getElementById('copy-btn-label');
      if (lbl) { lbl.textContent = 'Copié ✓'; setTimeout(() => lbl.textContent = 'Copier', 2000); }
    });

    // Share profile button
    document.getElementById('share-profile-btn')?.addEventListener('click', () => {
      openShareModal(profileName, profileUrl, '', true);
    });

    // Report
    document.getElementById('report-btn')?.addEventListener('click', () => {
      window.open(`/report?url=${encodeURIComponent(currentShareUrl || profileUrl)}`, '_blank');
    });

    // ── Analytics — clicks (gated sur consentement RGPD) ───────────────────
    // Même logique que le view tracking : lire localStorage directement,
    // pas de race condition possible.
    const _clickSeen = new Map(); // blockId → timestamp dernier click
    let   _clicksEnabled = false;

    function attachClickTracking() {
      if (_clicksEnabled) return;
      _clicksEnabled = true;

      document.addEventListener('click', (e) => {
        const target = e.target;
        const el = target.closest('[data-block-id]');
        if (!el) return;

        const blockId = el.dataset.blockId;
        if (!blockId) return;

        // Cooldown 1s par block — évite double-fire in-app browsers
        const now = Date.now();
        if (_clickSeen.has(blockId) && now - (_clickSeen.get(blockId) || 0) < 1000) return;
        _clickSeen.set(blockId, now);

        fetch('/api/analytics/click', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            block_id:     blockId,
            referrer:     document.referrer || null,
            utm_source:   utm('utm_source'),
            utm_medium:   utm('utm_medium'),
            utm_campaign: utm('utm_campaign'),
          }),
        }).catch(() => {});
      });
    }

    // 1. Consentement déjà enregistré → activer immédiatement
    try {
      const _stored = JSON.parse(localStorage.getItem('bf_consent_analytics') || 'null');
      if (_stored?.analytics === true) {
        attachClickTracking();
      }
    } catch {}

    // 2. Nouvelle décision depuis le banner → activer si accepté
    window.addEventListener('bf:consent', (e) => {
      if (e.detail?.analytics === true) attachClickTracking();
    });

  </script>

</BaseLayout>
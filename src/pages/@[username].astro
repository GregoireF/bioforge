---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getProfileByUsername, getActiveBlocks, incrementProfileView } from '@/lib/supabase/queries';
import QRCode from 'qrcode';

// ==================== GET USERNAME ====================
const { username } = Astro.params;
if (!username) return Astro.redirect('/404');

// ==================== GET PROFILE ====================
const profileResult = await getProfileByUsername(username);
if (!profileResult.success) return Astro.redirect('/404');
const profile = profileResult.data;

// ==================== GET BLOCKS ====================
const blocksResult = await getActiveBlocks(profile.id);
const blocks = blocksResult.success ? blocksResult.data : [];

// ==================== INCREMENT VIEW ====================
incrementProfileView(username).catch(console.error);

// ==================== PARSE THEME ====================
let theme = {
  preset: 'dark',
  background_color: '#0a0a0a',
  primary_color: '#00ff9d',
  text_color: '#ffffff',
  button_style: 'filled',
  border_radius: 12,
  font_family: 'Inter',
  background_style: 'solid',
  block_shadow: true,
  animations: true
};

if (profile.theme) {
  try {
    const parsedTheme = typeof profile.theme === 'string' ? JSON.parse(profile.theme) : profile.theme;
    theme = { ...theme, ...parsedTheme };
  } catch (e) { console.error('Failed to parse theme:', e); }
}

// ==================== BACKGROUND STYLE ====================
let bgStyle = `background-color: ${theme.background_color};`;
if (theme.background_style === 'gradient') {
  bgStyle = `background: linear-gradient(135deg, ${theme.background_color} 0%, ${theme.primary_color}20 100%);`;
} else if (theme.background_style === 'blur') {
  bgStyle = `background-color: ${theme.background_color}; backdrop-filter: blur(20px);`;
}

// ==================== GENERATE QR CODE ====================
let qrDataUrl = '';
try {
  qrDataUrl = await QRCode.toDataURL(`https://bioforge.click/@${profile.username}`, {
    width: 256,
    margin: 1,
    color: { dark: theme.primary_color, light: '#00000000' }
  });
} catch (err) {
  console.error('Failed to generate QR code:', err);
}

// ==================== SOCIAL ICONS ====================
const socialIcons: Record<string, string> = {
  twitter: `<path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>`,
  instagram: `<path d="M7 2C3.1 2 2 3.1 2 7v10c0 3.9 2.1 6 6 6h10c3.9 0 6-2.1 6-6V7c0-3.9-2.1-6-6-6H7zm10 3a1 1 0 110 2 1 1 0 010-2zm-5 2a5 5 0 110 10 5 5 0 010-10z"/>`,
  facebook: `<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>`,
  youtube: `<path d="M10 15l5-3-5-3v6z"/><path d="M21 8s-1-.7-4-1H7s-3 0-4 1-1 3-1 3v2s0 2 1 3 4 1 4 1h10s3 0 4-1 1-3 1-3v-2s0-2-1-3z"/>`,
  linkedin: `<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><path d="M2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/>`,
  github: `<path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48 0-.24-.01-.87-.01-1.71-2.78.61-3.37-1.34-3.37-1.34-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1.01.07 1.54 1.04 1.54 1.04.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.95 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0112 6.8c.85.004 1.71.115 2.51.338 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.85-2.34 4.7-4.57 4.95.36.31.68.93.68 1.87 0 1.35-.01 2.44-.01 2.77 0 .27.16.58.67.48A10.003 10.003 0 0022 12c0-5.52-4.48-10-10-10z"/>`,
  tiktok: `<path d="M12 2v12a4 4 0 1 0 4-4h4a5 5 0 0 0-5-5z"/>`,
  twitch: `<path d="M4 2C2.9 2 2 2.9 2 4v16l4-4h4l4 4h6V4c0-1.1-.9-2-2-2H4zm3 9H5V7h2v4zm4 0H9V7h2v4zm4 0h-2V7h2v4z"/>`,
  discord: `<path d="M20.317 4.369a19.791 19.791 0 00-4.885-1.515s-.453.85-.983 1.577c-1.928-.288-3.826-.288-5.754 0-.53-.727-.983-1.577-.983-1.577a19.791 19.791 0 00-4.885 1.515C2.358 9.11 1.197 13.774 1.554 18.389c1.836 1.472 4.016 2.331 6.189 2.562 0 0 .667-1.098.922-1.658-1.262-.394-2.097-2.03-2.097-2.03s-.506-.636-.858-.981c3.88-.356 7.665-.391 11.524.0-.348.358-.748 1.01-1.068 1.81 0 0-.834 1.64-3.094 2.03.26.56.933 1.66.933 1.66 2.172-.231 4.35-1.09 6.186-2.562.36-4.616-.802-9.28-2.807-14.016z"/>`,
  kick: `<path d="M20.5 4h-17C2.672 4 2 4.672 2 5.5v13c0 .828.672 1.5 1.5 1.5h17c.828 0 1.5-.672 1.5-1.5v-13c0-.828-.672-1.5-1.5-1.5zm-3 10h-2v3h-2v-3H9v-2h4v-3h2v3h2v2z"/>`,
  snapchat: `<path d="M12 2C9.243 2 7 4.243 7 7c0 2.356 1.828 3.888 1.828 5.784 0 1.899-1.828 3.416-1.828 5.716h9c0-2.3-1.828-3.817-1.828-5.716C16.172 10.888 18 9.356 18 7c0-2.757-2.243-5-5-5z"/>`
};

function getSocialIcon(url: string): string {
  if (!url) return '';
  const u = url.toLowerCase();
  if (u.includes('twitter.com') || u.includes('x.com')) return socialIcons.twitter;
  if (u.includes('instagram.com')) return socialIcons.instagram;
  if (u.includes('facebook.com')) return socialIcons.facebook;
  if (u.includes('youtube.com')) return socialIcons.youtube;
  if (u.includes('linkedin.com')) return socialIcons.linkedin;
  if (u.includes('github.com')) return socialIcons.github;
  if (u.includes('tiktok.com')) return socialIcons.tiktok;
  if (u.includes('twitch.tv')) return socialIcons.twitch;
  if (u.includes('discord.com') || u.includes('discord.gg')) return socialIcons.discord;
  if (u.includes('kick.com')) return socialIcons.kick;
  if (u.includes('snapchat.com')) return socialIcons.snapchat;
  return `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>`;
}
---

<BaseLayout title={profile.display_name || profile.username}>
  <div class="min-h-screen flex items-center justify-center p-4 py-12"
       style={`${bgStyle}; font-family: ${theme.font_family}, system-ui, sans-serif;`}>
    <div class="w-full max-w-2xl">

      <!-- PROFILE HEADER -->
      <div class="text-center mb-10 animate-fade-in-up">
        {profile.avatar_url ? (
          <img src={profile.avatar_url} alt={profile.display_name || profile.username}
               class="w-28 h-28 rounded-full mx-auto mb-6 object-cover avatar-glow"
               style={`border: 4px solid ${theme.primary_color}; box-shadow: 0 0 40px ${theme.primary_color}60;`} />
        ) : (
          <div class="w-28 h-28 rounded-full mx-auto mb-6 flex items-center justify-center text-4xl font-bold avatar-glow"
               style={`background: linear-gradient(135deg, ${theme.primary_color}, ${theme.primary_color}80); color: ${theme.background_color}; box-shadow: 0 0 40px ${theme.primary_color}60;`}>
            {(profile.display_name || profile.username).charAt(0).toUpperCase()}
          </div>
        )}

        <h1 class="text-3xl lg:text-4xl font-bold mb-3 animate-scale-in"
            style={`color: ${theme.text_color}`}>{profile.display_name || profile.username}</h1>

        {profile.bio && (
          <p class="text-base lg:text-lg mb-6 max-w-lg mx-auto leading-relaxed animate-fade-in-up stagger-1"
             style={`color: ${theme.text_color}; opacity: 0.85;`}>
            {profile.bio}
          </p>
        )}
      </div>

      <!-- BLOCKS -->
      {blocks.length === 0 ? (
        <div class="text-center py-16 animate-fade-in-up stagger-2"
             style={`color: ${theme.text_color}; opacity: 0.5;`}>
          <p class="text-lg">No links yet</p>
        </div>
      ) : (
        <div class="space-y-4 mb-12">
          {blocks.map((block, index) => {
            const blockId = block.id;
            const staggerClass = `stagger-${Math.min(index + 2, 6)}`;

            // HEADING
            if (block.type === 'heading') {
              return (
                <div class={`text-xl lg:text-2xl font-bold text-center py-3 animate-fade-in-up ${staggerClass}`}
                     style={`color: ${theme.text_color}`}>
                  {block.title || 'Heading'}
                </div>
              );
            }

            // SPACER
            if (block.type === 'spacer') return <div class="h-8"></div>;

            // LINK
            if (block.type === 'link') {
              const url = block.config?.url || '#';
              return (
                <a href={url} target="_blank" rel="noopener noreferrer"
                   class={`block-link block w-full py-4 px-6 font-semibold text-center transition-all animate-fade-in-up ${staggerClass}`}
                   data-block-id={blockId}
                   style={`
                     background-color: ${theme.button_style === 'outline' ? 'transparent' : theme.primary_color};
                     color: ${theme.button_style === 'outline' ? theme.primary_color : theme.background_color};
                     border: ${theme.button_style === 'outline' ? `2px solid ${theme.primary_color}` : 'none'};
                     border-radius: ${theme.border_radius}px;
                     ${theme.block_shadow && theme.button_style !== 'outline' ? `box-shadow: 0 8px 24px ${theme.primary_color}40;` : ''}
                     ${theme.button_style === 'shadow' ? `box-shadow: 0 8px 32px ${theme.primary_color}60;` : ''}
                   `}>
                  {block.title || 'Link'}
                </a>
              );
            }

            // IMAGE
            if (block.type === 'image') {
              const imageUrl = block.config?.url;
              const imageLink = block.config?.link;
              if (!imageUrl) return null;

              const imageElement = (
                <img src={imageUrl} alt={block.title || 'Image'}
                     class={`w-full rounded-lg transition-all hover:scale-105 animate-fade-in-up ${staggerClass}`}
                     style={`border-radius: ${theme.border_radius}px; ${theme.block_shadow ? 'box-shadow: 0 8px 24px rgba(0,0,0,0.3);' : ''}`} />
              );

              if (imageLink) return <a href={imageLink} target="_blank" rel="noopener noreferrer">{imageElement}</a>;
              return <div>{imageElement}</div>;
            }

            // VIDEO
            if (block.type === 'video') {
              const videoUrl = block.config?.url;
              if (!videoUrl) return null;

              let embedUrl = videoUrl;
              if (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be')) {
                const videoId = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/)?.[1];
                if (videoId) embedUrl = `https://www.youtube.com/embed/${videoId}`;
              } else if (videoUrl.includes('vimeo.com')) {
                const videoId = videoUrl.match(/vimeo\.com\/(\d+)/)?.[1];
                if (videoId) embedUrl = `https://player.vimeo.com/video/${videoId}`;
              } else if (videoUrl.includes('tiktok.com')) {
                const videoId = videoUrl.match(/tiktok\.com\/.*\/video\/(\d+)/)?.[1];
                if (videoId) embedUrl = `https://www.tiktok.com/embed/v2/${videoId}`;
              }

              return (
                <div class={`relative w-full overflow-hidden animate-fade-in-up ${staggerClass}`}
                     style={`padding-bottom: 56.25%; border-radius: ${theme.border_radius}px; ${theme.block_shadow ? 'box-shadow: 0 8px 24px rgba(0,0,0,0.3);' : ''}`}>
                  <iframe src={embedUrl} class="absolute top-0 left-0 w-full h-full"
                          frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                          allowfullscreen style={`border-radius: ${theme.border_radius}px;`}></iframe>
                </div>
              );
            }

            // SOCIAL
          if (block.type === 'social') {
            const links = block.config?.links || [];
            if (!Array.isArray(links) || links.length === 0) return null;

            return (
              <div class={`flex items-center justify-center flex-wrap gap-4 animate-fade-in-up ${staggerClass}`}>
                {links.map(link => {
                  const url = typeof link === 'string' ? link : link?.url;
                  if (!url) return null;

                  return (
                    <a href={url} target="_blank" rel="noopener noreferrer"
                      class="w-14 h-14 flex items-center justify-center rounded-full transition-all hover:scale-110"
                      data-block-id={blockId}
                      style={`background-color: ${theme.primary_color}; color: ${theme.background_color}; ${theme.block_shadow ? `box-shadow: 0 4px 16px ${theme.primary_color}60;` : ''}`}>
                      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" set:html={getSocialIcon(url)} />
                    </a>
                  );
                })}
              </div>
            );
          }

            return null;
          })}
        </div>
      )}

      <!-- FOOTER -->
      <div class="text-center py-8 animate-fade-in-up stagger-6">
        <p class="text-sm mb-3" style={`color: ${theme.text_color}; opacity: 0.5;`}>Powered by BioForge</p>
        <a href="/" class="text-sm hover:underline transition-all" style={`color: ${theme.primary_color}`}>Create your own page →</a>
      </div>
    </div>
  </div>

  <!-- QR CODE -->
  {qrDataUrl && (
    <div id="qr-container"
         class="fixed bottom-6 right-6 z-50 opacity-100 translate-y-0 transition-all duration-500 hover:scale-105">
      <div class="p-4 rounded-2xl backdrop-blur-xl shadow-2xl border"
           style={`background-color: ${theme.background_color}CC; border-color: ${theme.primary_color}40;`}>
        <img src={qrDataUrl} alt="QR code" class="w-28 h-28 rounded-2xl"/>
      </div>
    </div>
  )}

  <!-- CLICK TRACKING -->
  <script define:vars={{ profileId: profile.id }}>
    let isClicking = false;
    document.querySelectorAll('[data-block-id]').forEach(element => {
      element.addEventListener('click', async () => {
        if (isClicking) return;
        isClicking = true;
        setTimeout(() => { isClicking = false; }, 1000);

        const blockId = element.getAttribute('data-block-id');
        if (!blockId) return;

        try {
          const res = await fetch('/api/analytics/click', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'x-csrf-token': 'dev-bypass' },
            body: JSON.stringify({ block_id: blockId, profile_id: profileId })
          });
          if (!res.ok) console.error('Click tracking failed', await res.text());
        } catch (err) { console.error(err); }
      });
    });
  </script>
</BaseLayout>
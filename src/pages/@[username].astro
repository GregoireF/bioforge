    .animate-fade-in-up { animation: fade-in-up 0.45s ease both; }
  </style>

  <!-- SCRIPT -->
  <script type="module">
    document.addEventListener('astro:page-load', () => {
      const bridgeData = JSON.parse(document.getElementById('page-data')?.dataset.bridge || '{}');
      const { profileUrl = '', profileName = '', primaryColor: pc = '#00ff9d' } = bridgeData;

      const QR_API = 'https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=';

      function openShareModal(title = '', url = '', iconUrl = '') {
        const label = title || profileName || 'Lien';
        const target = url || profileUrl;

        const img = document.getElementById('modal-icon-img');
        const fallback = document.getElementById('modal-icon-fallback');
        if (img && fallback) {
          if (iconUrl) {
            img.src = iconUrl;
            img.classList.remove('hidden');
            fallback.classList.add('hidden');
          } else {
            img.classList.add('hidden');
            fallback.classList.remove('hidden');
            fallback.textContent = label.charAt(0).toUpperCase() || '?';
            fallback.style.background = `linear-gradient(to bottom right, ${pc}, ${pc}cc)`;
          }
        }

        document.getElementById('modal-title')?.textContent = label;
        document.getElementById('modal-url')?.textContent = target;
        document.getElementById('modal-qr')?.setAttribute('src', QR_API + encodeURIComponent(target));

        const encUrl = encodeURIComponent(target);
        const encMsg = encodeURIComponent(`${label} — ${target}`);

        const social = {
          'shr-x':  `https://x.com/intent/tweet?text=${encMsg}&url=${encUrl}`,
          'shr-ig': 'https://www.instagram.com/',
          'shr-wa': `https://wa.me/?text=${encMsg}`,
          'shr-ms': `fb-messenger://share?link=${encUrl}`,
          'shr-sc': `https://www.snapchat.com/scan?attachmentUrl=${encUrl}`
        };

        Object.entries(social).forEach(([id, href]) => {
          document.getElementById(id)?.setAttribute('href', href);
        });

        const modal = document.getElementById('share-modal');
        if (modal) {
          modal.classList.remove('hidden');
          setTimeout(() => {
            const inner = modal.querySelector('.relative');
            if (inner) {
              inner.classList.remove('scale-95', 'opacity-0');
              inner.classList.add('scale-100', 'opacity-100');
            }
          }, 10);
        }
      }

      function closeModal() {
        const modal = document.getElementById('share-modal');
        if (!modal) return;
        const inner = modal.querySelector('.relative');
        if (inner) inner.classList.add('scale-95', 'opacity-0');
        setTimeout(() => modal.classList.add('hidden'), 300);
      }

      document.getElementById('share-backdrop')?.addEventListener('click', closeModal);
      document.getElementById('share-close')?.addEventListener('click', closeModal);
      document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

      // Dropdown 3 points
      document.addEventListener('click', () => {
        document.querySelectorAll('.dot-dropdown').forEach(d => d.classList.add('hidden'));
      });

      function attachDotListeners() {
        document.querySelectorAll('.block-dot-btn:not([data-listener-attached])').forEach(btn => {
          btn.dataset.listenerAttached = 'true';
          btn.addEventListener('click', e => {
            e.stopPropagation();
            document.querySelectorAll('.dot-dropdown').forEach(d => d.classList.add('hidden'));
            const id = btn.dataset.id;
            if (id) document.querySelector(`.dot-dropdown[data-id="${id}"]`)?.classList.toggle('hidden');
          });
        });
      }

      attachDotListeners();

      const observer = new MutationObserver(attachDotListeners);
      observer.observe(document.body, { childList: true, subtree: true });

      document.querySelectorAll('.dot-copy-btn').forEach(btn => {
        btn.addEventListener('click', async e => {
          e.stopPropagation();
          const url = btn.dataset.url;
          if (!url) return;
          await navigator.clipboard.writeText(url);
          const span = btn.querySelector('span') || btn;
          const orig = span.textContent || 'Copier le lien';
          span.textContent = 'Copié !';
          setTimeout(() => span.textContent = orig, 2000);
          document.querySelectorAll('.dot-dropdown').forEach(d => d.classList.add('hidden'));
        });
      });

      document.querySelectorAll('.dot-share-btn').forEach(btn => {
        btn.addEventListener('click', e => {
          e.stopPropagation();
          document.querySelectorAll('.dot-dropdown').forEach(d => d.classList.add('hidden'));
          openShareModal(btn.dataset.title, btn.dataset.url, btn.dataset.icon);
        });
      });
    });
  </script>


---
// src/pages/auth/callback.astro
import { createSupabaseServer } from '@/lib/infra/supabase/server'
import { UAParser } from 'ua-parser-js'

const supabase = createSupabaseServer({
  request: Astro.request,
  cookies: Astro.cookies,
})

const code  = Astro.url.searchParams.get('code')
const error = Astro.url.searchParams.get('error')

if (error) return Astro.redirect('/signin?error=oauth_failed')

if (!code) return Astro.redirect('/signin?error=no_code')

// ✅ exchangeCodeForSession retourne la session directement
// On utilise cette session au lieu de rappeler getUser() qui ne voit pas
// encore les cookies écrits dans la même requête
const { data: { session }, error: exchangeError } = await supabase.auth.exchangeCodeForSession(code)

if (exchangeError || !session?.user) {
  console.error('[callback] exchange failed:', exchangeError?.message)
  return Astro.redirect('/signin?error=oauth_exchange_failed')
}

const user = session.user

if (!user.email_confirmed_at) {
  await supabase.auth.signOut()
  return Astro.redirect('/signin?error=email_not_verified')
}

// ── Upsert session ────────────────────────────────────────────────────────────
try {
  const ua         = new UAParser(Astro.request.headers.get('user-agent') ?? '')
  const deviceRaw  = ua.getDevice().type ?? 'desktop'
  const deviceType = ['mobile', 'tablet'].includes(deviceRaw) ? deviceRaw : 'desktop'

  const ip =
    Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() ??
    Astro.request.headers.get('cf-connecting-ip') ??
    null

  await supabase.from('user_sessions').insert({
    user_id:     user.id,
    browser:     `${ua.getBrowser().name ?? 'Unknown'} ${ua.getBrowser().version ?? ''}`.trim(),
    os:          `${ua.getOS().name ?? ''} ${ua.getOS().version ?? ''}`.trim() || null,
    device_type: deviceType,
    ip,
    last_seen:   new Date().toISOString(),
  })
} catch (err) {
  console.error('[callback] session upsert failed:', err)
}

// ── First login → onboarding ──────────────────────────────────────────────────
try {
  const { data: profile } = await supabase
    .from('profiles')
    .select('onboarding_completed_at')
    .eq('id', user.id)
    .maybeSingle()

  if (!profile?.onboarding_completed_at) {
    return Astro.redirect('/dashboard/onboarding')
  }
} catch {
  // En cas d'erreur, continuer vers le dashboard
}

return Astro.redirect('/dashboard')
---
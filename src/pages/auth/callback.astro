---
import { createSupabaseServer } from '@/lib/supabase/server';

const supabase = createSupabaseServer({
  request: Astro.request,
  cookies: Astro.cookies,
});

const error = Astro.url.searchParams.get('error');
const code = Astro.url.searchParams.get('code');

if (error) {
  return Astro.redirect('/signin?error=oauth_failed');
}

if (code) {
  // juste le code, PAS siteUrl
  const { error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);

  if (exchangeError) {
    return Astro.redirect('/signin?error=oauth_exchange_failed');
  }
}

const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect('/signin?error=session_not_found');
}

if (!user.email_confirmed_at) {
  await supabase.auth.signOut();
  return Astro.redirect('/signin?error=email_not_verified');
}

// tout est ok → redirection finale
return Astro.redirect('/dashboard');
---
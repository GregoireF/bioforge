---
interface Props {
  avatarUrl?: string | null;
  displayName?: string | null;
  username: string;
  bio?: string | null;
}

const { avatarUrl, displayName, username, bio } = Astro.props;
const finalDisplayName = displayName || username;
---

<div class="profile-header">
  <div class="avatar-container">
    {avatarUrl ? (
      <img src={avatarUrl} alt={finalDisplayName} class="avatar" />
    ) : (
      <div class="avatar-placeholder">
        {finalDisplayName.charAt(0).toUpperCase()}
      </div>
    )}
  </div>
  
  <h1 class="display-name">{finalDisplayName}</h1>
  <p class="username">@{username}</p>
  
  {bio && (
    <p class="bio">{bio}</p>
  )}
</div>

<style>
  .profile-header {
    text-align: center;
    margin-bottom: 2rem;
    animation: fadeIn 0.5s ease-in-out;
  }

  .avatar-container {
    margin: 0 auto 1rem;
    width: 96px;
    height: 96px;
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255, 255, 255, 0.2);
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: bold;
    color: white;
    border: 4px solid rgba(255, 255, 255, 0.2);
  }

  .display-name {
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.25rem;
  }

  .username {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }

  .bio {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.5;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

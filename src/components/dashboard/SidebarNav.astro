---
// src/components/dashboard/SidebarNav.astro
import type { NavItem } from '@/data/nav-dashboard';   // ou le chemin que tu utilises

interface Props {
  items: NavItem[];
  collapsed: boolean;
  currentPath: string;    // ← AJOUTE CETTE LIGNE ICI
}

const { items, collapsed, currentPath } = Astro.props;

function isActive(href: string, exact?: boolean) {
  return exact ? currentPath === href : currentPath.startsWith(href);
}
---

<nav aria-label="Navigation principale" class="space-y-1">
  {items.map(item => {
    const active = isActive(item.href, item.exact);
    return (
      <a
        href={item.href}
        aria-current={active ? 'page' : undefined}
        class:list={[
          "group relative flex items-center rounded-xl text-sm font-medium transition-all duration-200",
          collapsed ? "justify-center px-4 py-3" : "gap-3 px-3 py-2.5",
          active
            ? "text-neon-green before:absolute before:left-0 before:inset-y-0 before:w-1 before:bg-neon-green before:rounded-r before:shadow-[0_0_10px_#10b98180]"
            : "text-gray-400 hover:text-white hover:bg-white/6 hover:scale-102"
        ]}
        title={collapsed ? item.label : undefined}
      >
        <svg aria-hidden="true" class:list={[collapsed ? "w-6 h-6" : "w-5 h-5"]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width={active ? "2.2" : "1.8"} d={item.icon} />
        </svg>
        {!collapsed && (
          <>
            <span class="truncate flex-1">{item.label}</span>
            {item.badge && <span class="ml-auto text-xs px-2 py-0.5 rounded-full bg-neon-green/20 text-neon-green border border-neon-green/30">{item.badge}</span>}
          </>
        )}
      </a>
    );
  })}
</nav>
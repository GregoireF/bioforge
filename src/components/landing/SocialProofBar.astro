---
// src/components/landing/SocialProofBar.astro
// SVGs entièrement inline — plus aucun path passé comme string prop

interface Props {
  stats: { total_profiles: number; total_clicks: number; total_views: number; }
}
const { stats } = Astro.props;

function fmt(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace('.0','') + 'M';
  if (n >= 1_000)     return (n / 1_000).toFixed(1).replace('.0','') + 'k';
  return String(n);
}

const items = [
  { value: fmt(stats.total_profiles), raw: stats.total_profiles, label: 'Créateurs actifs',  color: '#39ff8f', id: 'spb-0' },
  { value: fmt(stats.total_clicks),   raw: stats.total_clicks,   label: 'Clics générés',     color: '#38bdf8', id: 'spb-1' },
  { value: fmt(stats.total_views),    raw: stats.total_views,    label: 'Vues de pages',     color: '#fb923c', id: 'spb-2' },
  { value: '99.9%',                   raw: null,                  label: 'Uptime garanti',   color: '#a78bfa', id: 'spb-3' },
] as const;
---

<div id="social-proof" class="spb" role="region" aria-label="Statistiques BioForge">
  <div class="spb-grid">

    <!-- Créateurs -->
    <div class="spb-item" style="--c:#39ff8f" data-index="0">
      <div class="spb-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#39ff8f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/>
          <path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
      </div>
      <div>
        <p class="spb-val" data-raw={items[0].raw}>{items[0].value}</p>
        <p class="spb-label">{items[0].label}</p>
      </div>
    </div>

    <!-- Clics -->
    <div class="spb-item" style="--c:#38bdf8" data-index="1">
      <div class="spb-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 15 9 9 5 19"/>
          <path d="M9 9l11 4-5 2-2 5-4-11z"/>
        </svg>
      </div>
      <div>
        <p class="spb-val" data-raw={items[1].raw}>{items[1].value}</p>
        <p class="spb-label">{items[1].label}</p>
      </div>
    </div>

    <!-- Vues -->
    <div class="spb-item" style="--c:#fb923c" data-index="2">
      <div class="spb-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fb923c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </div>
      <div>
        <p class="spb-val" data-raw={items[2].raw}>{items[2].value}</p>
        <p class="spb-label">{items[2].label}</p>
      </div>
    </div>

    <!-- Uptime -->
    <div class="spb-item" style="--c:#a78bfa" data-index="3">
      <div class="spb-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div>
        <p class="spb-val">{items[3].value}</p>
        <p class="spb-label">{items[3].label}</p>
      </div>
    </div>

  </div>
</div>

<script>
  // CountUp — vanilla, zéro dépendance
  function easeOut(t: number) { return 1 - Math.pow(2, -10 * t); }

  function animateCount(el: HTMLElement, target: number, dur = 1600) {
    const start = performance.now();
    let suffix = '', display = target;
    if (target >= 1_000_000) { display = target / 1_000_000; suffix = 'M'; }
    else if (target >= 1_000) { display = target / 1_000; suffix = 'k'; }
    const dec = display % 1 !== 0 ? 1 : 0;

    const tick = (now: number) => {
      const p = Math.min((now - start) / dur, 1);
      el.textContent = (display * easeOut(p)).toFixed(dec).replace('.0','') + suffix;
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const val = e.target.querySelector<HTMLElement>('.spb-val');
      if (!val) return;
      const raw = parseInt(val.dataset.raw ?? '0', 10);
      if (raw > 0) animateCount(val, raw);
      io.unobserve(e.target);
    });
  }, { threshold: 0.4 });

  document.querySelectorAll('.spb-item').forEach(el => io.observe(el));
</script>

<style>
  .spb {
    padding: 0 1.5rem 2rem;
  }
  .spb-grid {
    max-width: 1000px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 1.25rem; overflow: hidden;
    background: rgba(255,255,255,0.03);
  }

  .spb-item {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 1.375rem 1.5rem;
    background: rgba(13,16,18,0.6);
    transition: background 0.15s;
    /* Séparateur vertical entre items */
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .spb-item:last-child { border-right: none; }
  .spb-item:hover { background: rgba(255,255,255,0.03); }

  .spb-icon {
    width: 40px; height: 40px; border-radius: 0.625rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb, var(--c) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 18%, transparent);
  }

  .spb-val {
    font-family: 'Syne', sans-serif;
    font-size: 1.375rem; font-weight: 800;
    color: #fff; letter-spacing: -0.03em; line-height: 1;
    margin-bottom: 0.2rem;
    font-variant-numeric: tabular-nums;
  }

  .spb-label {
    font-size: 0.72rem; color: rgba(255,255,255,0.38); font-weight: 500;
  }

  @media (max-width: 860px)  { .spb-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px)  {
    .spb { padding: 0 1rem 1.5rem; }
    .spb-grid { grid-template-columns: 1fr; }
    .spb-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .spb-item:last-child { border-bottom: none; }
  }
</style>
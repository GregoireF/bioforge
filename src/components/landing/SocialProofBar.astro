---
// src/components/landing/SocialProofBar.astro
// Barre de stats réelles — zéro JS library, CountUp en CSS pur

interface Props {
  stats: {
    total_profiles: number;
    total_clicks:   number;
    total_views:    number;
  };
}
const { stats } = Astro.props;

function fmt(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace('.0','') + 'M';
  if (n >= 1_000)     return (n / 1_000).toFixed(1).replace('.0','') + 'k';
  return n.toString();
}

const items = [
  {
    value:  fmt(stats.total_profiles || 0),
    raw:    stats.total_profiles || 0,
    label:  'Créateurs actifs',
    icon:   'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
    color:  '#39ff8f',
  },
  {
    value:  fmt(stats.total_clicks || 0),
    raw:    stats.total_clicks || 0,
    label:  'Clics générés',
    icon:   'M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5',
    color:  '#38bdf8',
  },
  {
    value:  fmt(stats.total_views || 0),
    raw:    stats.total_views || 0,
    label:  'Vues de pages',
    icon:   'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 12m-3 0a3 3 0 106 0 3 3 0 10-6 0',
    color:  '#fb923c',
  },
  {
    value:  '99.9%',
    raw:    null,
    label:  'Uptime garanti',
    icon:   'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    color:  '#a78bfa',
  },
];
---

<div id="social-proof" class="spb" role="region" aria-label="Statistiques BioForge">
  <div class="spb-inner">
    {items.map((item, i) => (
      <div class="spb-item" style={`--c: ${item.color}; animation-delay: ${i * 0.08}s`}>
        <div class="spb-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
               stroke={item.color} stroke-width="2" stroke-linecap="round">
            <path d={item.icon}/>
          </svg>
        </div>
        <div>
          <p class="spb-val" data-raw={item.raw}>
            {item.value}
          </p>
          <p class="spb-label">{item.label}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<!-- CountUp léger — pur vanilla, zéro dépendance -->
<script>
function easeOutExpo(t: number): number {
  return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
}

function animateCount(el: HTMLElement, target: number, duration = 1800) {
  const start = performance.now();

  // Détermine le suffixe et le diviseur
  let suffix = '';
  let displayTarget = target;
  if (target >= 1_000_000) { displayTarget = target / 1_000_000; suffix = 'M'; }
  else if (target >= 1_000) { displayTarget = target / 1_000; suffix = 'k'; }

  const decimals = displayTarget % 1 !== 0 ? 1 : 0;

  function tick(now: number) {
    const elapsed = now - start;
    const progress = Math.min(elapsed / duration, 1);
    const eased = easeOutExpo(progress);
    const current = displayTarget * eased;
    el.textContent = current.toFixed(decimals).replace('.0','') + suffix;
    if (progress < 1) requestAnimationFrame(tick);
    else el.textContent = displayTarget.toFixed(decimals).replace('.0','') + suffix;
  }
  requestAnimationFrame(tick);
}

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    const valEl = entry.target.querySelector('.spb-val') as HTMLElement | null;
    if (!valEl) return;
    const raw = parseInt(valEl.dataset.raw ?? '0', 10);
    if (raw > 0) animateCount(valEl, raw);
    observer.unobserve(entry.target);
  });
}, { threshold: 0.4 });

document.querySelectorAll('.spb-item').forEach(el => observer.observe(el));
</script>

<style>
  .spb {
    position: relative; z-index: 1;
    padding: 0 1.5rem 1rem;
    margin-top: -1px;
  }

  .spb-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 1.25rem;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .spb-item {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 1.25rem 1.5rem;
    background: rgba(13,16,18,0.8);
    opacity: 0;
    animation: spb-in 0.5s ease both;
    transition: background 0.15s;
  }
  .spb-item:hover { background: rgba(255,255,255,0.03); }

  @keyframes spb-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .spb-icon {
    width: 38px; height: 38px; border-radius: 0.625rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb, var(--c) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 20%, transparent);
  }

  .spb-val {
    font-family: 'Syne', sans-serif;
    font-size: 1.375rem; font-weight: 800;
    color: #fff; letter-spacing: -0.03em;
    line-height: 1; margin-bottom: 0.2rem;
    tabular-nums: always;
    font-variant-numeric: tabular-nums;
  }

  .spb-label {
    font-size: 0.75rem; color: rgba(255,255,255,0.38); font-weight: 500;
  }

  @media (max-width: 900px) {
    .spb-inner { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .spb { padding: 0 1rem 1rem; }
    .spb-inner { grid-template-columns: 1fr; }
    .spb-item  { padding: 1rem 1.25rem; }
  }
</style>
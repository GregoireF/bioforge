---
// Testimonials section with real user stories
const testimonials = [
  {
    name: 'Sarah Chen',
    role: 'Content Creator',
    avatar: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
    quote: "BioForge transformed how I connect with my audience. The analytics are insane—I finally understand what content drives clicks. My link clicks increased by 300% in just two months!",
    stats: '+300% clicks',
    platform: 'YouTube'
  },
  {
    name: 'Marcus Rodriguez',
    role: 'Professional Gamer',
    avatar: 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
    quote: "As a pro gamer, my bio link is crucial for sponsors and fans. BioForge's design options let me match my brand perfectly. The mobile experience is flawless—exactly what my audience needs.",
    stats: '50K+ visits/month',
    platform: 'Twitch'
  },
  {
    name: 'Emma Williams',
    role: 'Digital Artist',
    avatar: 'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
    quote: "I've tried every link-in-bio tool out there. BioForge is the only one that doesn't look generic. The customization is incredible, and the load speed is blazing fast. Worth every penny!",
    stats: '5-star experience',
    platform: 'Instagram'
  },
  {
    name: 'Alex Kim',
    role: 'Tech Influencer',
    avatar: 'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
    quote: "The real-time analytics dashboard is a game-changer. I can see exactly which links perform best and optimize on the fly. BioForge pays for itself with the insights alone.",
    stats: 'ROI in week 1',
    platform: 'Twitter'
  }
];
---

<section class="relative py-32 overflow-hidden" data-scroll-section>
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-dark-800 to-dark-900"></div>
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-neon-purple rounded-full blur-[150px] animate-pulse-slow"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-neon-blue rounded-full blur-[150px] animate-pulse-slow" style="animation-delay: 1.5s;"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center space-x-2 px-4 py-2 glass rounded-full text-sm text-neon-purple mb-6">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span>Loved by creators</span>
      </div>
      
      <h2 class="text-5xl sm:text-6xl font-display font-bold text-white mb-6">
        What Creators
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-purple to-neon-pink text-glow-purple">
          Say
        </span>
      </h2>
      <p class="text-xl text-gray-400 leading-relaxed">
        Real stories from real creators who leveled up with BioForge
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-2 gap-6 max-w-6xl mx-auto">
      {testimonials.map((testimonial, index) => (
        <div class="reveal" style={`animation-delay: ${index * 0.1}s`}>
          <div class="glass-strong rounded-3xl p-8 border border-white/10 hover:border-neon-purple/30 transition-all duration-500 h-full group cursor-pointer">
            <!-- Quote Icon -->
            <div class="mb-6">
              <svg class="w-10 h-10 text-neon-purple/30 group-hover:text-neon-purple/50 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
            </div>

            <!-- Quote Text -->
            <p class="text-gray-300 text-lg leading-relaxed mb-6 italic">
              "{testimonial.quote}"
            </p>

            <!-- Author Info -->
            <div class="flex items-center justify-between pt-6 border-t border-white/10">
              <div class="flex items-center space-x-4">
                <!-- Avatar -->
                <div 
                  class="w-14 h-14 rounded-full glow-purple group-hover:scale-110 transition-transform duration-300"
                  style={`background: ${testimonial.avatar}`}
                ></div>
                
                <!-- Name & Role -->
                <div>
                  <p class="font-semibold text-white">{testimonial.name}</p>
                  <p class="text-sm text-gray-400">{testimonial.role}</p>
                </div>
              </div>

              <!-- Stats Badge -->
              <div class="text-right">
                <div class="inline-flex items-center space-x-1 px-3 py-1.5 glass rounded-full border border-neon-purple/30">
                  <svg class="w-4 h-4 text-neon-purple" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/>
                  </svg>
                  <span class="text-xs text-neon-purple font-semibold">{testimonial.stats}</span>
                </div>
                <p class="text-xs text-gray-500 mt-1">{testimonial.platform}</p>
              </div>
            </div>

            <!-- Hover Glow -->
            <div class="absolute inset-0 bg-gradient-to-br from-neon-purple/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl pointer-events-none"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Stars Rating -->
    <div class="text-center mt-16 reveal">
      <div class="inline-flex items-center space-x-2 mb-4">
        {[...Array(5)].map(() => (
          <svg class="w-6 h-6 text-neon-green" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <p class="text-gray-400">
        <span class="text-white font-bold">4.9/5</span> from over <span class="text-neon-green font-semibold">2,500+ reviews</span>
      </p>
    </div>
  </div>
</section>
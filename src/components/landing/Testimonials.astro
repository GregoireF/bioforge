---
// src/components/landing/Testimonials.astro
// Réécriture complète — zéro Tailwind custom, styles scoped uniquement

const testimonials = [
  {
    quote: "J'ai migré depuis Linktree en 10 minutes. Le dashboard analytics est 10x plus lisible et mes clics ont augmenté juste en changeant la mise en page.",
    name:  "Léa Moreau",
    role:  "Créatrice lifestyle · 48k abonnés",
    plan:  "Pro",
    color: "#39ff8f",
    initials: "LM",
    grad: "linear-gradient(135deg,#39ff8f,#0ea5e9)",
  },
  {
    quote: "En tant que streamer Twitch, pouvoir intégrer mes clips et mon planning directement dans ma bio page c'est un game changer. Plus besoin de 4 outils différents.",
    name:  "MaxPlay",
    role:  "Streamer Twitch · 22k viewers",
    plan:  "Creator",
    color: "#a78bfa",
    initials: "MP",
    grad: "linear-gradient(135deg,#7c3aed,#a78bfa)",
  },
  {
    quote: "BioForge est la seule plateforme qui comprend les créateurs gaming. Le design sombre, les blocs Twitch natifs, les stats en temps réel — c'est fait pour nous.",
    name:  "Kira Nyx",
    role:  "Gameuse · YouTubeuse · 31k subs",
    plan:  "Pro",
    color: "#38bdf8",
    initials: "KN",
    grad: "linear-gradient(135deg,#38bdf8,#a78bfa)",
  },
] as const;
---

<section class="tst" aria-labelledby="tst-title">

  <div class="tst-head">
    <div class="tst-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
      Ce qu'ils en pensent
    </div>
    <h2 id="tst-title" class="tst-title">
      Des créateurs qui ont<br>
      <span class="tst-accent">fait le saut</span>
    </h2>
  </div>

  <div class="tst-grid" role="list">
    {testimonials.map((t, i) => (
      <article
        class="tst-card"
        style={`--c:${t.color}; animation-delay:${i * 0.1}s`}
        role="listitem"
      >
        <!-- Quote marks décoratifs -->
        <div class="tst-quote-mark" aria-hidden="true">"</div>

        <!-- Plan badge -->
        <div class="tst-plan" style={`color:${t.color}; border-color:${t.color}22; background:${t.color}12`}>
          {t.plan}
        </div>

        <blockquote class="tst-quote">
          <p>{t.quote}</p>
        </blockquote>

        <div class="tst-author">
          <div class="tst-avatar" style={`background:${t.grad}`} aria-hidden="true">
            {t.initials}
          </div>
          <div>
            <p class="tst-name">{t.name}</p>
            <p class="tst-role">{t.role}</p>
          </div>
        </div>

        <!-- Étoiles -->
        <div class="tst-stars" aria-label="5 étoiles sur 5">
          {Array.from({ length: 5 }).map(() => (
            <svg width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b" stroke="none" aria-hidden="true">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          ))}
        </div>
      </article>
    ))}
  </div>

</section>

<script>
  document.querySelectorAll('.tst-head, .tst-card').forEach(el =>
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('revealed');
      }
    }, { threshold: 0.15 }).observe(el)
  );
</script>

<style>
  .tst {
    padding: 6rem 1.5rem;
    max-width: 1100px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 3.5rem;
  }

  /* Reveal */
  .tst-head, .tst-card {
    opacity: 0; transform: translateY(18px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: var(--delay, 0s);
  }
  .revealed { opacity: 1; transform: none; }

  /* Head */
  .tst-head { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.875rem; }
  .tst-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.875rem;
    background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2);
    border-radius: 99px; font-size: 0.72rem; font-weight: 700;
    color: #f59e0b; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .tst-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 800; color: #fff; letter-spacing: -0.03em; line-height: 1.1;
  }
  .tst-accent {
    background: linear-gradient(90deg, #f59e0b, #fb923c);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Grid */
  .tst-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem; width: 100%;
  }

  /* Card */
  .tst-card {
    position: relative; overflow: hidden;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 1.25rem;
    padding: 1.75rem;
    display: flex; flex-direction: column; gap: 1.125rem;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .tst-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--c) 5%, transparent), transparent);
    pointer-events: none;
  }
  .tst-card:hover {
    border-color: color-mix(in srgb, var(--c) 22%, transparent);
    background: rgba(255,255,255,0.04);
    transform: translateY(-3px);
  }

  /* Quote mark déco */
  .tst-quote-mark {
    position: absolute; top: 1rem; right: 1.25rem;
    font-family: Georgia, serif; font-size: 4rem; line-height: 1;
    color: color-mix(in srgb, var(--c) 12%, transparent);
    pointer-events: none; user-select: none;
  }

  /* Plan badge */
  .tst-plan {
    display: inline-block; width: fit-content;
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; padding: 0.2rem 0.6rem; border-radius: 99px;
    border: 1px solid; /* couleur via style inline */
  }

  /* Quote */
  .tst-quote { margin: 0; }
  .tst-quote p {
    font-size: 0.875rem; color: rgba(255,255,255,0.58); line-height: 1.75;
    font-style: italic;
  }

  /* Author */
  .tst-author { display: flex; align-items: center; gap: 0.75rem; margin-top: auto; }
  .tst-avatar {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700; color: rgba(0,0,0,0.75);
  }
  .tst-name { font-size: 0.875rem; font-weight: 600; color: #fff; }
  .tst-role { font-size: 0.72rem; color: rgba(255,255,255,0.38); margin-top: 0.1rem; }

  /* Stars */
  .tst-stars { display: flex; gap: 2px; }

  /* Responsive */
  @media (max-width: 860px) { .tst-grid { grid-template-columns: 1fr; max-width: 480px; } }
  @media (max-width: 480px) { .tst { padding: 4rem 1rem; } }
</style>
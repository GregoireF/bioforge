---
// src/components/landing/Hero.astro
interface Props { profileCount?: number; }
const { profileCount = 0 } = Astro.props;

const countDisplay = profileCount > 1000
  ? `${(profileCount / 1000).toFixed(1).replace('.0', '')}k+`
  : profileCount > 0 ? `${profileCount}+` : null;

const SITE_URL        = import.meta.env.PUBLIC_SITE_URL ?? 'https://bioforge.click';
const featuredProfile = import.meta.env.PUBLIC_FEATURED_PROFILE ?? '';
const iframeUrl       = featuredProfile ? `${SITE_URL}/@${featuredProfile}` : '';
---

<section class="hero" aria-label="BioForge — présentation">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-glow g1"></div>
    <div class="hero-glow g2"></div>
    <div class="hero-grain"></div>
  </div>

  <div class="hero-inner">

    <!-- Texte -->
    <div class="hero-left">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Plateforme active · Nouvelle feature chaque semaine
      </div>

      <h1 class="hero-h1">
        <span class="h1-dim">Forge ta</span>
        <span class="h1-main">présence<br>en ligne.</span>
      </h1>

      <p class="hero-desc">
        Pas juste une liste de liens — un <strong>hub créateur</strong> avec analytics
        en temps réel, blocs personnalisés et un design qui te ressemble vraiment.
      </p>

      <div class="hero-actions">
        <a href="/signin" class="btn-primary">
          Crée ta page — c'est gratuit
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="#how-it-works" class="btn-ghost">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/>
          </svg>
          Voir comment ça marche
        </a>
      </div>

      <div class="hero-proof">
        <div class="proof-avatars" aria-hidden="true">
          <span style="background:#7c3aed"></span>
          <span style="background:#0ea5e9"></span>
          <span style="background:#f59e0b"></span>
          <span style="background:#39ff8f"></span>
        </div>
        <p class="proof-text">
          {countDisplay
            ? <><strong>{countDisplay}</strong> créateurs ont déjà leur page</>
            : <>Sois parmi les premiers créateurs</>}
        </p>
      </div>

      <div class="hero-trust">
        <span class="trust-chip">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          SSL · RGPD
        </span>
        <span class="trust-sep" aria-hidden="true">·</span>
        <span class="trust-chip">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Aucune CB requise
        </span>
        <span class="trust-sep" aria-hidden="true">·</span>
        <span class="trust-chip">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          Setup en 2 min
        </span>
      </div>
    </div>

    <!-- Visuel device -->
    <div class="hero-right" aria-label="Aperçu d'une page BioForge">
      <div class="device-wrap">
        <div class="device-halo" aria-hidden="true"></div>
        <div class="device">

          <!-- Barre navigateur simulée -->
          <div class="device-bar" aria-hidden="true">
            <div class="device-dots">
              <span class="dot-r"></span>
              <span class="dot-y"></span>
              <span class="dot-g"></span>
            </div>
            <div class="device-url-bar">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
              bioforge.click/{featuredProfile ? `@${featuredProfile}` : '@tonpseudo'}
            </div>
          </div>

          <!-- Écran -->
          <div class="device-screen">
            {iframeUrl ? (
              <iframe
                src={iframeUrl}
                title="Aperçu profil BioForge"
                loading="lazy"
                sandbox="allow-scripts allow-same-origin"
                class="profile-iframe"
              />
            ) : (
              <div class="ph-wrap">
                <div class="ph-avatar"></div>
                <div class="ph-name"></div>
                <div class="ph-bio"></div>
                <div class="ph-block" style="background:rgba(57,255,143,.12)"></div>
                <div class="ph-block" style="background:rgba(56,189,248,.1)"></div>
                <div class="ph-block" style="background:rgba(167,139,250,.1)"></div>
                <div class="ph-row">
                  <div class="ph-stat"></div>
                  <div class="ph-stat"></div>
                  <div class="ph-stat"></div>
                </div>
              </div>
            )}
          </div>

        </div>
      </div>
    </div>

  </div>

  <a href="#social-proof" class="hero-scroll" aria-label="Voir la suite">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <polyline points="19 12 12 19 5 12"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    overflow: hidden; padding: 5rem 1.5rem 4rem;
  }

  /* BG */
  .hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(57,255,143,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(57,255,143,.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }
  .hero-glow { position: absolute; border-radius: 50%; filter: blur(100px); }
  .g1 { width: 480px; height: 480px; top: -10%; left: -5%; background: rgba(57,255,143,.07); animation: gd 14s ease-in-out infinite alternate; }
  .g2 { width: 360px; height: 360px; bottom: 0; right: -5%; background: rgba(124,58,237,.055); animation: gd 18s ease-in-out infinite alternate-reverse; }
  @keyframes gd { from{transform:translate(0,0)} to{transform:translate(24px,16px)} }
  .hero-grain {
    position: absolute; inset: 0; opacity: .3;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
  }

  /* Layout */
  .hero-inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
    max-width: 1200px; width: 100%; margin: 0 auto;
  }

  .hero-left {
    display: flex; flex-direction: column; gap: 1.75rem;
    animation: fu .65s cubic-bezier(.4,0,.2,1) both;
  }
  @keyframes fu { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }

  /* Badge */
  .hero-badge {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .35rem .875rem;
    background: rgba(57,255,143,.08); border: 1px solid rgba(57,255,143,.2);
    border-radius: 99px; font-size: .72rem; font-weight: 600;
    color: #39ff8f; letter-spacing: .02em; width: fit-content;
  }
  .badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #39ff8f; flex-shrink: 0;
    animation: pd 2s ease-in-out infinite;
  }
  @keyframes pd { 0%,100%{box-shadow:0 0 0 0 rgba(57,255,143,.5)} 50%{box-shadow:0 0 0 5px rgba(57,255,143,0)} }

  /* H1 */
  .hero-h1 { display: flex; flex-direction: column; gap: .05em; }
  .h1-dim {
    font-family: 'Syne', sans-serif; font-weight: 800; letter-spacing: -.04em;
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    color: rgba(255,255,255,.42); line-height: 1;
  }
  .h1-main {
    font-family: 'Syne', sans-serif; font-weight: 800; letter-spacing: -.04em;
    font-size: clamp(3rem, 6.5vw, 5rem);
    color: #fff; line-height: .95;
    text-shadow: 0 0 80px rgba(57,255,143,.12);
  }

  .hero-desc {
    font-size: clamp(.9375rem, 1.8vw, 1.0625rem);
    color: rgba(255,255,255,.5); line-height: 1.7; max-width: 460px;
  }
  .hero-desc strong { color: rgba(255,255,255,.82); font-weight: 600; }

  /* Actions */
  .hero-actions { display: flex; align-items: center; gap: .875rem; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: .45rem;
    padding: .875rem 1.5rem;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    color: #050c08; border-radius: .875rem;
    font-size: .9375rem; font-weight: 700;
    text-decoration: none;
    box-shadow: 0 4px 24px rgba(57,255,143,.22);
    transition: filter .15s, transform .15s, box-shadow .15s;
  }
  .btn-primary:hover { filter:brightness(1.07); transform:translateY(-2px); box-shadow:0 8px 32px rgba(57,255,143,.3); }
  .btn-primary:active { transform:none; }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: .45rem;
    padding: .875rem 1.25rem;
    color: rgba(255,255,255,.55);
    border: 1px solid rgba(255,255,255,.12); border-radius: .875rem;
    font-size: .875rem; font-weight: 500; text-decoration: none;
    transition: all .15s;
  }
  .btn-ghost:hover { color:#fff; border-color:rgba(255,255,255,.25); background:rgba(255,255,255,.04); }

  /* Proof */
  .hero-proof { display: flex; align-items: center; gap: .75rem; }
  .proof-avatars { display: flex; }
  .proof-avatars span {
    display: block; width: 26px; height: 26px; border-radius: 50%;
    border: 2px solid #080a0c; margin-left: -8px;
  }
  .proof-avatars span:first-child { margin-left: 0; }
  .proof-text { font-size: .8rem; color: rgba(255,255,255,.42); }
  .proof-text strong { color: rgba(255,255,255,.78); font-weight: 600; }

  /* Trust */
  .hero-trust { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
  .trust-chip { display: inline-flex; align-items: center; gap: .3rem; font-size: .7rem; color: rgba(255,255,255,.3); }
  .trust-sep { color: rgba(255,255,255,.15); font-size: .7rem; }

  /* Device */
  .hero-right { display: flex; align-items: center; justify-content: center; animation: fu .65s .15s cubic-bezier(.4,0,.2,1) both; }
  .device-wrap { position: relative; width: 100%; max-width: 340px; }
  .device-halo {
    position: absolute; inset: -15%;
    background: radial-gradient(ellipse 70% 70% at 50% 50%, rgba(57,255,143,.09), transparent 70%);
    pointer-events: none; z-index: 0;
  }
  .device {
    position: relative; z-index: 1;
    background: #0d1012; border: 1px solid rgba(255,255,255,.1);
    border-radius: 1.5rem; overflow: hidden;
    box-shadow: 0 0 0 1px rgba(57,255,143,.04), 0 32px 80px rgba(0,0,0,.55);
  }
  .device-bar {
    display: flex; align-items: center; gap: .5rem;
    padding: .625rem 1rem;
    background: rgba(255,255,255,.03); border-bottom: 1px solid rgba(255,255,255,.06);
  }
  .device-dots { display: flex; gap: 5px; flex-shrink: 0; }
  .device-dots span { width: 9px; height: 9px; border-radius: 50%; display: block; }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }
  .device-url-bar {
    flex: 1; display: flex; align-items: center; gap: .35rem;
    margin: 0 .5rem;
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.07);
    border-radius: .375rem; padding: .25rem .625rem;
    font-size: .62rem; color: rgba(255,255,255,.38);
    font-family: monospace;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .device-screen { height: 480px; overflow: hidden; background: #0d1012; }
  .profile-iframe { width: 100%; height: 100%; border: none; }

  /* Placeholder skeleton */
  .ph-wrap {
    display: flex; flex-direction: column; align-items: center;
    padding: 1.5rem 1rem; gap: .875rem; height: 100%;
    background: linear-gradient(180deg, #0d1012, #080a0c);
  }
  .ph-avatar { width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, #39ff8f, #0ea5e9); animation: sk 1.8s ease-in-out infinite; }
  .ph-name   { width: 120px; height: 12px; border-radius: 6px; background: rgba(255,255,255,.1); animation: sk 1.8s .1s ease-in-out infinite; }
  .ph-bio    { width: 160px; height: 9px;  border-radius: 5px; background: rgba(255,255,255,.06); animation: sk 1.8s .2s ease-in-out infinite; }
  .ph-block  { width: 100%; height: 44px; border-radius: 10px; animation: sk 1.8s ease-in-out infinite; }
  .ph-row    { display: flex; gap: .5rem; width: 100%; margin-top: .25rem; }
  .ph-stat   { flex: 1; height: 36px; border-radius: 8px; background: rgba(255,255,255,.05); animation: sk 1.8s .4s ease-in-out infinite; }
  @keyframes sk { 0%,100%{opacity:.55} 50%{opacity:.9} }

  /* Scroll hint */
  .hero-scroll {
    position: absolute; bottom: 1.75rem; left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,.2); z-index: 1; transition: color .15s;
    animation: bd 2.5s ease-in-out infinite;
  }
  .hero-scroll:hover { color: rgba(255,255,255,.5); }
  @keyframes bd {
    0%,100%{transform:translateX(-50%) translateY(0)}
    50%{transform:translateX(-50%) translateY(5px)}
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; text-align: center; }
    .hero-left  { align-items: center; }
    .hero-desc  { max-width: 100%; }
    .hero-actions, .hero-proof, .hero-trust { justify-content: center; }
    .hero-right { order: -1; }
    .device-wrap { max-width: 280px; }
    .device-screen { height: 380px; }
  }
  @media (max-width: 480px) {
    .hero { padding: 4rem 1rem 3rem; }
    .btn-primary, .btn-ghost { width: 100%; justify-content: center; }
    .hero-actions { flex-direction: column; }
  }
</style>
---
import Button from '@/components/ui/Button.astro';
---

<!-- Final CTA Section - Ultra Modern -->
    <section class="relative py-32 overflow-hidden" data-scroll-section>
      <!-- Animated Background -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-neon-green/5 via-transparent to-neon-purple/5"></div>
        
        <!-- Morphing gradient orbs -->
        <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-neon-green/15 rounded-full blur-[150px] animate-blob"></div>
        <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-neon-purple/15 rounded-full blur-[150px] animate-blob animation-delay-2000"></div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-neon-blue/15 rounded-full blur-[150px] animate-blob animation-delay-4000"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-5xl mx-auto">
          <!-- Badge -->
          <div class="text-center mb-8">
            <div class="inline-flex items-center space-x-2 px-5 py-2.5 glass rounded-full text-sm border border-neon-green/30">
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-green opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-neon-green"></span>
              </span>
              <span class="text-gray-300">Free forever • No credit card required</span>
            </div>
          </div>

          <!-- Main CTA Content -->
          <div class="glass-strong rounded-[3rem] p-12 md:p-16 border border-white/10 text-center">
            <!-- Heading -->
            <div class="mb-10">
              <h2 class="text-5xl sm:text-6xl lg:text-7xl font-display font-bold text-white leading-tight mb-6 smooth-font">
                Ready to
                <span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-neon-green via-neon-blue to-neon-purple animate-gradient text-glow-green">
                  Level Up?
                </span>
              </h2>
              <p class="text-xl sm:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
                Join <span class="text-neon-green font-semibold count-up" data-count="10" data-suffix="K+">10K+</span> creators who've already transformed their online presence with BioForge.
              </p>
            </div>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-5 justify-center items-center mb-12">
              <Button 
                variant="primary" 
                size="lg" 
                href="/signup"
                class="magnetic glow-green group text-lg px-10 py-5"
              >
                <span class="relative z-10">Start Building — Free</span>
                <svg class="w-6 h-6 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </Button>
              <Button 
                variant="ghost" 
                size="lg" 
                href="/features"
                class="magnetic text-lg px-10 py-5"
              >
                <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Watch Demo
              </Button>
            </div>

            <!-- Trust Badges -->
            <div class="flex flex-wrap items-center justify-center gap-8 text-sm">
              <div class="flex items-center space-x-2 text-gray-400 hover:text-neon-green transition-colors">
                <svg class="w-5 h-5 text-neon-green" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>SSL Secured</span>
              </div>
              <div class="flex items-center space-x-2 text-gray-400 hover:text-neon-green transition-colors">
                <svg class="w-5 h-5 text-neon-green" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>GDPR Compliant</span>
              </div>
              <div class="flex items-center space-x-2 text-gray-400 hover:text-neon-green transition-colors">
                <svg class="w-5 h-5 text-neon-green" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 3.5a1.5 1.5 0 013 0V4a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-.5a1.5 1.5 0 000 3h.5a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-.5a1.5 1.5 0 00-3 0v.5a1 1 0 01-1 1H6a1 1 0 01-1-1v-3a1 1 0 00-1-1h-.5a1.5 1.5 0 010-3H4a1 1 0 001-1V6a1 1 0 011-1h3a1 1 0 001-1v-.5z"/>
                </svg>
                <span>99.9% Uptime</span>
              </div>
              <div class="flex items-center space-x-2 text-gray-400 hover:text-neon-green transition-colors">
                <svg class="w-5 h-5 text-neon-green" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span>4.9/5 Rating</span>
              </div>
            </div>
          </div>

          <!-- Social Proof Logos (Optional) -->
          <div class="mt-16 text-center">
            <p class="text-sm text-gray-500 mb-6 uppercase tracking-wider">Trusted by creators at</p>
            <div class="flex flex-wrap items-center justify-center gap-12 opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-500">
              <!-- Add logo placeholders or text -->
              <div class="text-2xl font-bold text-white">TWITCH</div>
              <div class="text-2xl font-bold text-white">YOUTUBE</div>
              <div class="text-2xl font-bold text-white">DISCORD</div>
              <div class="text-2xl font-bold text-white">TWITTER</div>
            </div>
          </div>
        </div>
      </div>
    </section>
---
// src/components/landing/LiveProfiles.astro
interface Profile {
  username: string;
  display_name: string | null;
  avatar_url: string | null;
  plan: string;
  is_verified: boolean;
}
interface Props { profiles: Profile[]; }
const { profiles } = Astro.props;

const SITE_URL = import.meta.env.PUBLIC_SITE_URL ?? 'https://bioforge.click';

const gradients = [
  'linear-gradient(135deg,#39ff8f,#0ea5e9)',
  'linear-gradient(135deg,#7c3aed,#f59e0b)',
  'linear-gradient(135deg,#f472b6,#fb923c)',
  'linear-gradient(135deg,#38bdf8,#a78bfa)',
  'linear-gradient(135deg,#39ff8f,#b4ff6e)',
  'linear-gradient(135deg,#fb923c,#f472b6)',
  'linear-gradient(135deg,#0ea5e9,#39ff8f)',
];

function initials(p: Profile) {
  return (p.display_name ?? p.username ?? '?').slice(0, 2).toUpperCase();
}
---

<section class="lp" aria-labelledby="lp-title">

  <div class="lp-head">
    <div class="lp-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
        <path d="M16 3.13a4 4 0 010 7.75"/>
      </svg>
      Ils ont déjà forgé leur page
    </div>
    <h2 id="lp-title" class="lp-title">
      De vrais créateurs,<br>
      <span class="lp-accent">pas des exemples</span>
    </h2>
    <p class="lp-sub">Ces profils sont réels — créés par notre communauté.</p>
  </div>

  {profiles.length > 0 ? (
    <div class="lp-grid" role="list" aria-label="Profils récents BioForge">
      {profiles.slice(0, 14).map((profile, i) => (
        <a
          href={`${SITE_URL}/@${profile.username}`}
          class="lp-card"
          style={`animation-delay:${i * 0.04}s`}
          role="listitem"
          aria-label={`Profil de ${profile.display_name ?? profile.username}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="lp-avatar-wrap">
            {profile.avatar_url ? (
              <img
                src={profile.avatar_url}
                alt=""
                class="lp-avatar"
                width="52" height="52"
                loading="lazy" decoding="async"
              />
            ) : (
              <div
                class="lp-avatar lp-avatar-fb"
                style={`background:${gradients[i % gradients.length]}`}
                aria-hidden="true"
              >
                {initials(profile)}
              </div>
            )}

            {profile.is_verified && (
              <div class="lp-verified" aria-label="Vérifié" title="Compte vérifié">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
            )}

            <div class="lp-pulse" aria-hidden="true"></div>
          </div>

          <p class="lp-name">{profile.display_name ?? profile.username}</p>
          <p class="lp-handle">@{profile.username}</p>

          {profile.plan !== 'Free' && (
            <span class="lp-plan">{profile.plan}</span>
          )}
        </a>
      ))}
    </div>
  ) : (
    <div class="lp-empty">
      <p>Sois parmi les premiers ✦</p>
      <a href="/signin" class="lp-empty-btn">Créer ma page</a>
    </div>
  )}

  <a href="/signin" class="lp-join">
    Rejoindre la communauté
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="5" y1="12" x2="19" y2="12"/>
      <polyline points="12 5 19 12 12 19"/>
    </svg>
  </a>
</section>

<script>
  document.querySelectorAll('.lp-card, .lp-head, .lp-join').forEach(el =>
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('revealed');
      }
    }, { threshold: 0.1 }).observe(el)
  );
</script>

<style>
  .lp {
    padding: 6rem 1.5rem;
    max-width: 1100px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 3rem;
  }

  .lp-head, .lp-card, .lp-join {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    transition-delay: var(--delay, 0s);
  }
  .revealed { opacity: 1; transform: none; }

  /* Head */
  .lp-head { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.875rem; }
  .lp-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.875rem;
    background: rgba(56,189,248,0.07); border: 1px solid rgba(56,189,248,0.18);
    border-radius: 99px; font-size: 0.72rem; font-weight: 700;
    color: #38bdf8; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .lp-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 800; color: #fff; letter-spacing: -0.03em; line-height: 1.1;
  }
  .lp-accent {
    background: linear-gradient(90deg, #38bdf8, #a78bfa);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .lp-sub { font-size: 0.875rem; color: rgba(255,255,255,0.4); }

  /* Grid */
  .lp-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.75rem; width: 100%;
  }

  .lp-card {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    padding: 1.125rem 0.625rem;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 1rem;
    text-decoration: none;
    position: relative; overflow: hidden;
    transition: all 0.18s;
  }
  .lp-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(57,255,143,0.05), transparent);
    opacity: 0; transition: opacity 0.2s;
  }
  .lp-card:hover { border-color: rgba(57,255,143,0.2); transform: translateY(-3px); }
  .lp-card:hover::before { opacity: 1; }

  /* Avatar */
  .lp-avatar-wrap { position: relative; width: 52px; height: 52px; flex-shrink: 0; }
  .lp-avatar {
    width: 52px; height: 52px; border-radius: 50%; object-fit: cover;
    border: 2px solid rgba(255,255,255,0.07);
    display: block;
  }
  .lp-avatar-fb {
    display: flex; align-items: center; justify-content: center;
    font-size: 0.875rem; font-weight: 700; color: rgba(0,0,0,0.7);
  }

  .lp-verified {
    position: absolute; bottom: -1px; right: -1px;
    width: 18px; height: 18px; border-radius: 50%;
    background: #39ff8f; border: 2px solid #080a0c;
    display: flex; align-items: center; justify-content: center;
  }

  .lp-pulse {
    position: absolute; top: 0; left: 0;
    width: 10px; height: 10px; border-radius: 50%;
    background: #39ff8f; border: 2px solid #080a0c;
  }
  .lp-pulse::after {
    content: '';
    position: absolute; inset: -2px; border-radius: 50%;
    background: rgba(57,255,143,0.35);
    animation: pp 2.5s ease-in-out infinite;
  }
  @keyframes pp { 0%,100%{transform:scale(1);opacity:.5} 50%{transform:scale(2);opacity:0} }

  .lp-name {
    font-size: 0.72rem; font-weight: 600; color: #fff;
    text-align: center; overflow: hidden; text-overflow: ellipsis;
    white-space: nowrap; width: 100%; transition: color 0.15s;
  }
  .lp-card:hover .lp-name { color: #39ff8f; }

  .lp-handle {
    font-size: 0.62rem; color: rgba(255,255,255,0.3);
    text-align: center; overflow: hidden; text-overflow: ellipsis;
    white-space: nowrap; width: 100%;
  }

  .lp-plan {
    font-size: 0.58rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; padding: 0.15rem 0.45rem; border-radius: 99px;
    background: rgba(57,255,143,0.1); color: #39ff8f;
    border: 1px solid rgba(57,255,143,0.2);
  }

  /* Empty */
  .lp-empty {
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
    padding: 3rem; text-align: center;
    background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.08);
    border-radius: 1.25rem; width: 100%;
  }
  .lp-empty p { color: rgba(255,255,255,0.4); }
  .lp-empty-btn {
    padding: 0.625rem 1.25rem; background: rgba(57,255,143,0.1); color: #39ff8f;
    border: 1px solid rgba(57,255,143,0.22); border-radius: 0.75rem;
    font-size: 0.875rem; font-weight: 600; text-decoration: none; transition: all 0.15s;
  }

  /* CTA */
  .lp-join {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 0.75rem;
    font-size: 0.875rem; font-weight: 500; text-decoration: none;
    transition: all 0.15s;
  }
  .lp-join:hover { background: rgba(255,255,255,0.09); color: #fff; }

  /* Responsive */
  @media (max-width: 1100px) { .lp-grid { grid-template-columns: repeat(5, 1fr); } }
  @media (max-width: 760px)  { .lp-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 520px)  { .lp-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 380px)  {
    .lp-grid { grid-template-columns: repeat(2, 1fr); }
    .lp { padding: 4rem 1rem; }
  }
</style>
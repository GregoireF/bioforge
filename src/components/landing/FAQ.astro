---
// FAQ section with animated accordion
const faqs = [
  {
    question: 'Is BioForge really free?',
    answer: 'Yes! BioForge offers a generous free plan that includes unlimited links, basic analytics, and core customization features. You can upgrade to Pro for advanced analytics, custom domains, and premium themes.'
  },
  {
    question: 'Can I use my own custom domain?',
    answer: 'Absolutely! Pro users can connect their own custom domain (like bio.yoursite.com). This keeps your brand consistent and looks super professional. Setup takes less than 5 minutes with our step-by-step guide.'
  },
  {
    question: 'How does the analytics work?',
    answer: 'Our real-time analytics track every click, view, and interaction on your page. See which links perform best, where your traffic comes from, and when your audience is most active. All data updates instantly and is displayed in beautiful, easy-to-understand graphs.'
  },
  {
    question: 'Can I customize the design?',
    answer: 'Yes! Choose from 50+ professionally designed templates, or fully customize colors, fonts, backgrounds, and layouts. Upload your own images, add custom CSS if you want, and create a page that truly represents your brand.'
  },
  {
    question: 'What integrations do you support?',
    answer: 'BioForge integrates with all major platforms including Instagram, TikTok, YouTube, Twitter, Twitch, Discord, Spotify, and more. Plus, connect Google Analytics, Mailchimp, and other tools to supercharge your workflow.'
  },
  {
    question: 'Is my data secure?',
    answer: 'Security is our top priority. All data is encrypted with industry-standard SSL, we\'re GDPR compliant, and we never sell your data to third parties. Your information and your audience\'s privacy are 100% protected.'
  },
  {
    question: 'Can I migrate from another service?',
    answer: 'Yes! Migrating is super easy. You can import your links from Linktree, Bio.fm, or any other service in just a few clicks. We also keep your old URLs redirecting so you don\'t lose any traffic.'
  },
  {
    question: 'What kind of support do you offer?',
    answer: 'We offer 24/7 email support for all users, live chat for Pro users, and an extensive help center with tutorials and guides. Our average response time is under 2 hours, and we\'re always happy to help!'
  }
];
---

<section class="relative py-32 overflow-hidden" data-scroll-section>
  <!-- Background -->
  <div class="absolute inset-0 bg-dark-900"></div>
  <div class="absolute inset-0 opacity-5">
    <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-neon-blue rounded-full blur-[150px] animate-pulse-slow"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center space-x-2 px-4 py-2 glass rounded-full text-sm text-neon-blue mb-6">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
        </svg>
        <span>Got questions?</span>
      </div>
      
      <h2 class="text-5xl sm:text-6xl font-display font-bold text-white mb-6">
        Frequently Asked
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-blue to-neon-green text-glow-blue">
          Questions
        </span>
      </h2>
      <p class="text-xl text-gray-400 leading-relaxed">
        Everything you need to know about BioForge. Can't find what you're looking for? 
        <a href="/contact" class="text-neon-blue hover:text-neon-green transition-colors">Chat with us</a>.
      </p>
    </div>

    <!-- FAQ Accordion -->
    <div class="max-w-4xl mx-auto space-y-4">
      {faqs.map((faq, index) => (
        <div class="faq-item glass-strong rounded-2xl border border-white/10 overflow-hidden transition-all duration-300 hover:border-neon-blue/30">
          <button 
            class="faq-question w-full px-8 py-6 text-left flex items-center justify-between group"
            data-index={index}
          >
            <span class="text-lg font-semibold text-white group-hover:text-neon-blue transition-colors pr-8">
              {faq.question}
            </span>
            <svg 
              class="faq-icon w-6 h-6 text-neon-blue transition-transform duration-300 flex-shrink-0" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
            <div class="px-8 pb-6 text-gray-400 leading-relaxed">
              {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Still have questions CTA -->
    <div class="text-center mt-16">
      <p class="text-gray-400 mb-6">Still have questions?</p>
      <a 
        href="/contact" 
        class="inline-flex items-center space-x-2 px-6 py-3 glass border border-neon-blue/30 text-neon-blue rounded-xl hover:bg-neon-blue/10 transition-all duration-300 group"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <span>Chat with support</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  // FAQ Accordion functionality
  document.addEventListener('DOMContentLoaded', () => {
    const faqButtons = document.querySelectorAll('.faq-question');
    
    faqButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const faqItem = button.parentElement;
        const faqAnswer = faqItem?.querySelector('.faq-answer');
        const faqIcon = button.querySelector('.faq-icon');
        const isOpen = faqItem?.classList.contains('active');
        
        // Close all other FAQs
        document.querySelectorAll('.faq-item').forEach((item) => {
          if (item !== faqItem) {
            item.classList.remove('active');
            const answer = item.querySelector('.faq-answer');
            const icon = item.querySelector('.faq-icon');
            if (answer) {
              gsap.to(answer, {
                maxHeight: 0,
                duration: 0.3,
                ease: 'power2.inOut'
              });
            }
            if (icon) {
              gsap.to(icon, {
                rotation: 0,
                duration: 0.3,
                ease: 'power2.inOut'
              });
            }
          }
        });
        
        // Toggle current FAQ
        if (isOpen) {
          faqItem?.classList.remove('active');
          if (faqAnswer) {
            gsap.to(faqAnswer, {
              maxHeight: 0,
              duration: 0.3,
              ease: 'power2.inOut'
            });
          }
          if (faqIcon) {
            gsap.to(faqIcon, {
              rotation: 0,
              duration: 0.3,
              ease: 'power2.inOut'
            });
          }
        } else {
          faqItem?.classList.add('active');
          if (faqAnswer) {
            gsap.to(faqAnswer, {
              maxHeight: faqAnswer.scrollHeight + 24, // +24 for padding
              duration: 0.3,
              ease: 'power2.inOut'
            });
          }
          if (faqIcon) {
            gsap.to(faqIcon, {
              rotation: 180,
              duration: 0.3,
              ease: 'power2.inOut'
            });
          }
        }
      });
    });
  });
</script>

<style>
  .faq-item.active {
    border-color: rgba(0, 212, 255, 0.3);
  }
</style>
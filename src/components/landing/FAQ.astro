---
// src/components/landing/FAQ.astro

const faqs = [
  {
    q: 'BioForge est-il vraiment gratuit ?',
    a: 'Oui. Le plan gratuit inclut 5 blocs, ton URL bioforge.click/@toi et les analytics de base — sans CB, sans limite de temps. Les plans payants (Creator 7€/mois, Pro 14€/mois) débloquent les blocs illimités, le domaine custom, les analytics avancés et le support prioritaire.',
  },
  {
    q: 'Puis-je utiliser mon propre nom de domaine ?',
    a: 'Oui, avec le plan Pro. Tu connectes ton domaine (ex: liens.toi.com) depuis le dashboard en quelques clics — sans toucher à une ligne de code. Le certificat SSL est inclus et automatique.',
  },
  {
    q: 'Comment fonctionnent les analytics ?',
    a: "BioForge enregistre chaque vue de ta page et chaque clic sur tes blocs en temps réel. Depuis ton dashboard tu vois les stats par jour, par bloc, les sources de trafic et le taux de clic. Tout est hébergé chez nous — aucune dépendance à Google Analytics.",
  },
  {
    q: 'Puis-je personnaliser le design librement ?',
    a: "Complètement. Couleurs, polices, fond (couleur, gradient, image), disposition des blocs — tout est modifiable depuis l'éditeur. Sur les plans Pro et Enterprise tu peux aussi injecter ton propre CSS.",
  },
  {
    q: "Que se passe-t-il si j'annule mon abonnement ?",
    a: "Ton abonnement reste actif jusqu'à la fin de la période payée. Ensuite tu repasses au plan gratuit : ta page reste en ligne, tes 5 premiers blocs restent actifs, et toutes tes données sont conservées.",
  },
  {
    q: 'Les pages BioForge sont-elles rapides sur mobile ?',
    a: "C'est une priorité. Les pages publiques sont générées statiquement, servent des images optimisées et passent les Core Web Vitals. Nos pages scorent 95+ sur PageSpeed mobile en moyenne.",
  },
] as const;
---

<section class="faq" aria-labelledby="faq-title">

  <div class="faq-head">
    <div class="faq-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
      Questions fréquentes
    </div>
    <h2 id="faq-title" class="faq-title">
      Tout ce que tu veux<br>
      <span class="faq-accent">savoir</span>
    </h2>
    <p class="faq-sub">
      Autre question ?
      <a href="/contact" class="faq-link">Écris-nous</a>
    </p>
  </div>

  <div class="faq-list" role="list">
    {faqs.map((faq, i) => (
      <details class="faq-item" style={`animation-delay:${i * 0.05}s`} role="listitem">
        <summary class="faq-q">
          <span class="faq-q-text">{faq.q}</span>
          <span class="faq-chevron" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </span>
        </summary>
        <div class="faq-a">
          <p>{faq.a}</p>
        </div>
      </details>
    ))}
  </div>

</section>

<script>
  // Accordion : ferme les autres au clic
  document.querySelectorAll('.faq-item').forEach(item => {
    item.addEventListener('toggle', () => {
      if ((item as HTMLDetailsElement).open) {
        document.querySelectorAll('.faq-item').forEach(other => {
          if (other !== item) (other as HTMLDetailsElement).open = false;
        });
      }
    });
  });

  // Reveal
  document.querySelectorAll('.faq-head, .faq-item').forEach(el =>
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) (e.target as HTMLElement).classList.add('revealed');
    }, { threshold: 0.1 }).observe(el)
  );
</script>

<style>
  .faq {
    padding: 6rem 1.5rem;
    max-width: 780px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 3rem;
  }

  /* Reveal */
  .faq-head, .faq-item {
    opacity: 0; transform: translateY(14px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    transition-delay: var(--delay, 0s);
  }
  .revealed { opacity: 1; transform: none; }

  /* Head */
  .faq-head { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.875rem; }
  .faq-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.875rem;
    background: rgba(167,139,250,0.07); border: 1px solid rgba(167,139,250,0.18);
    border-radius: 99px; font-size: 0.72rem; font-weight: 700;
    color: #a78bfa; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .faq-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 800; color: #fff; letter-spacing: -0.03em; line-height: 1.1;
  }
  .faq-accent {
    background: linear-gradient(90deg, #a78bfa, #38bdf8);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .faq-sub { font-size: 0.875rem; color: rgba(255,255,255,0.38); }
  .faq-link { color: #a78bfa; text-decoration: none; transition: color 0.15s; }
  .faq-link:hover { color: #c4b5fd; }

  /* List */
  .faq-list { width: 100%; display: flex; flex-direction: column; gap: 0.5rem; }

  /* Item */
  .faq-item {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.875rem; overflow: hidden;
    transition: border-color 0.2s;
  }
  .faq-item[open] { border-color: rgba(167,139,250,0.22); }

  /* Summary */
  .faq-q {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.125rem 1.375rem;
    cursor: pointer; list-style: none;
    font-size: 0.9375rem; font-weight: 600; color: #fff;
    user-select: none; transition: color 0.15s;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::marker { display: none; }
  .faq-q:hover { color: rgba(255,255,255,0.82); }
  .faq-item[open] .faq-q { color: #a78bfa; }

  .faq-q-text { flex: 1; }

  .faq-chevron {
    flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.25s cubic-bezier(.34,1.2,.64,1), background 0.15s, border-color 0.15s;
    color: rgba(255,255,255,0.5);
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    background: rgba(167,139,250,0.12); border-color: rgba(167,139,250,0.25);
    color: #a78bfa;
  }

  /* Answer */
  .faq-a {
    padding: 0 1.375rem 1.25rem;
    animation: fa-in 0.22s ease both;
  }
  @keyframes fa-in { from{opacity:0;transform:translateY(-4px)} to{opacity:1;transform:none} }
  .faq-a p { font-size: 0.875rem; color: rgba(255,255,255,0.48); line-height: 1.75; }

  /* Responsive */
  @media (max-width: 480px) {
    .faq { padding: 4rem 1rem; }
    .faq-q { font-size: 0.875rem; padding: 1rem 1.125rem; }
    .faq-a { padding: 0 1.125rem 1rem; }
  }
</style>
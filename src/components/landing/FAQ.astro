---
// src/components/landing/FAQ.astro
// Accordion zéro GSAP — HTML details/summary natif + animation CSS

const faqs = [
  {
    q: 'BioForge est-il vraiment gratuit ?',
    a: 'Oui. Le plan gratuit inclut 5 blocs, ton URL bioforge.click/@toi et les analytics de base — sans CB, sans limite de temps. Les plans payants (Creator 7€/mois, Pro 14€/mois) débloquent les blocs illimités, le domaine custom, les analytics avancés et le support prioritaire.',
  },
  {
    q: 'Puis-je utiliser mon propre nom de domaine ?',
    a: 'Oui, avec le plan Pro. Tu connectes ton domaine (ex: liens.toi.com) depuis le dashboard en quelques clics — sans toucher à une ligne de code. Le certificat SSL est inclus et automatique.',
  },
  {
    q: 'Comment fonctionnent les analytics ?',
    a: 'BioForge enregistre chaque vue de ta page et chaque clic sur tes blocs en temps réel. Depuis ton dashboard tu vois les stats par jour, par bloc, les sources de trafic et le taux de clic. Tout est hébergé chez nous — aucune dépendance à Google Analytics.',
  },
  {
    q: 'Puis-je personnaliser le design librement ?',
    a: 'Complètement. Couleurs, polices, fond (couleur, gradient, image), disposition des blocs, border radius — tout est modifiable depuis l\'éditeur. Et si tu veux aller plus loin, tu peux injecter ton propre CSS sur les plans Pro et Enterprise.',
  },
  {
    q: 'Que se passe-t-il si j\'annule mon abonnement ?',
    a: 'Ton abonnement reste actif jusqu\'à la fin de la période payée. Ensuite tu repasses au plan gratuit : ta page reste en ligne, tes 5 premiers blocs restent actifs, et toutes tes données sont conservées. Rien n\'est supprimé.',
  },
  {
    q: 'Puis-je migrer depuis Linktree ou Beacons ?',
    a: 'On n\'a pas encore d\'import automatique, mais le setup prend littéralement 5 minutes. La plupart de nos utilisateurs préfèrent repartir de zéro pour vraiment personnaliser leur page plutôt que de copier l\'ancienne.',
  },
  {
    q: 'Les pages BioForge sont-elles rapides sur mobile ?',
    a: 'C\'est une priorité. Les pages publiques sont générées statiquement, servent des images optimisées et passent les Core Web Vitals. Nos pages scorent 95+ sur PageSpeed mobile en moyenne.',
  },
] as const;
---

<section class="faq" aria-labelledby="faq-title">

  <div class="faq-head reveal">
    <div class="faq-eyebrow">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/>
      </svg>
      Questions fréquentes
    </div>
    <h2 id="faq-title" class="faq-title">
      Tout ce que tu veux<br>
      <span class="faq-accent">savoir</span>
    </h2>
    <p class="faq-sub">
      Une question qui n'est pas là ?
      <a href="/contact" class="faq-contact">Écris-nous</a>
    </p>
  </div>

  <div class="faq-list" role="list">
    {faqs.map((faq, i) => (
      <details
        class="faq-item reveal"
        style={`animation-delay: ${i * 0.06}s`}
        role="listitem"
      >
        <summary class="faq-q" aria-expanded="false">
          <span>{faq.q}</span>
          <div class="faq-chevron" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </div>
        </summary>
        <div class="faq-a">
          <p>{faq.a}</p>
        </div>
      </details>
    ))}
  </div>

</section>

<script>
  // Reveal
  const els = document.querySelectorAll('.reveal');
  new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); }
    }),
    { threshold: 0.1 }
  ).observe ? document.querySelectorAll('.reveal').forEach(el =>
    new IntersectionObserver(
      ([e]) => { if (e.isIntersecting) { el.classList.add('visible'); } },
      { threshold: 0.1 }
    ).observe(el)
  ) : els.forEach(el => el.classList.add('visible'));

  // Ferme les autres <details> quand un s'ouvre (accordion)
  document.querySelectorAll('.faq-item').forEach(item => {
    item.addEventListener('toggle', () => {
      if ((item as HTMLDetailsElement).open) {
        document.querySelectorAll('.faq-item').forEach(other => {
          if (other !== item) (other as HTMLDetailsElement).open = false;
        });
      }
    });
  });
</script>

<style>
  .faq {
    padding: 6rem 1.5rem;
    max-width: 780px;
    margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 3rem;
  }

  .reveal {
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  /* ── Header ── */
  .faq-head { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.875rem; }

  .faq-eyebrow {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.875rem;
    background: rgba(167,139,250,0.07); border: 1px solid rgba(167,139,250,0.18);
    border-radius: 99px; font-size: 0.72rem; font-weight: 700;
    color: #a78bfa; text-transform: uppercase; letter-spacing: 0.08em;
  }

  .faq-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 800; color: #fff; letter-spacing: -0.03em; line-height: 1.1;
  }
  .faq-accent {
    background: linear-gradient(90deg, #a78bfa, #38bdf8);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .faq-sub { font-size: 0.875rem; color: rgba(255,255,255,0.38); }
  .faq-contact {
    color: #a78bfa; text-decoration: none; transition: color 0.15s;
  }
  .faq-contact:hover { color: #c4b5fd; }

  /* ── Liste ── */
  .faq-list { width: 100%; display: flex; flex-direction: column; gap: 0.5rem; }

  .faq-item {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.875rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .faq-item[open] {
    border-color: rgba(167,139,250,0.2);
  }

  .faq-q {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.125rem 1.375rem;
    cursor: pointer; list-style: none;
    font-size: 0.9375rem; font-weight: 600; color: #fff;
    user-select: none;
    transition: color 0.15s;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q:hover { color: rgba(255,255,255,0.85); }
  .faq-item[open] .faq-q { color: #a78bfa; }

  .faq-chevron {
    flex-shrink: 0; width: 28px; height: 28px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.25s cubic-bezier(0.34,1.2,0.64,1), background 0.15s;
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    background: rgba(167,139,250,0.12);
    border-color: rgba(167,139,250,0.25);
  }
  .faq-item[open] .faq-chevron svg { stroke: #a78bfa; }

  .faq-a {
    padding: 0 1.375rem 1.25rem;
    animation: faq-open 0.25s ease both;
  }
  @keyframes faq-open {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: none; }
  }

  .faq-a p {
    font-size: 0.875rem; color: rgba(255,255,255,0.5);
    line-height: 1.75;
  }

  @media (max-width: 480px) {
    .faq { padding: 4rem 1rem; }
    .faq-q { font-size: 0.875rem; padding: 1rem 1.125rem; }
    .faq-a { padding: 0 1.125rem 1rem; }
  }
</style>
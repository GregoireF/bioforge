---
// src/components/layout/Header.astro
const navItems = [
  { label: 'Fonctionnalités', href: '/features' },
  { label: 'Tarifs',          href: '/pricing'  },
];
---

<header id="site-header">
  <div class="header-progress" id="header-progress" aria-hidden="true"></div>

  <div class="header-container">
    <a href="/" class="header-logo" aria-label="BioForge — Accueil">
      <div class="logo-mark" aria-hidden="true">⚡</div>
      <span class="logo-name">BioForge</span>
    </a>

    <nav class="header-nav" aria-label="Navigation principale">
      {navItems.map(item => (
        <a href={item.href} class="header-nav-link">{item.label}</a>
      ))}
    </nav>

    <div class="header-end">
      <a href="/signin" class="header-cta">
        Connexion
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>

      <button
        id="burger-btn"
        class="burger-btn"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" style="display:none">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Menu mobile" aria-hidden="true">
    {navItems.map(item => (
      <a href={item.href} class="mobile-nav-link">{item.label}</a>
    ))}
    <a href="/signin" class="mobile-nav-cta">Créer ma page — gratuit →</a>
  </nav>
</header>

<script>
(function() {
  const header   = document.getElementById('site-header')!;
  const progress = document.getElementById('header-progress')!;
  const burgerBtn = document.getElementById('burger-btn')!;
  const mobileNav = document.getElementById('mobile-nav')!;
  const iconMenu  = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // ── Scroll ──────────────────────────────────────────────────────────────
  let lastY = 0;
  let ticking = false;

  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y      = window.scrollY;
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      const pct    = maxScroll > 0 ? (y / maxScroll) * 100 : 0;

      // Progress bar
      progress.style.transform = `scaleX(${pct / 100})`;

      // Frosted glass après 50px
      if (y > 50) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }

      // Cache en scroll down, montre en scroll up
      if (y > lastY && y > 120) {
        header.classList.add('is-hidden');
      } else {
        header.classList.remove('is-hidden');
      }

      lastY = y;
      ticking = false;
    });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Menu mobile ──────────────────────────────────────────────────────────
  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;
    burgerBtn.setAttribute('aria-expanded', String(isOpen));
    burgerBtn.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
    mobileNav.setAttribute('aria-hidden', String(!isOpen));
    mobileNav.classList.toggle('is-open', isOpen);
    iconMenu.style.display  = isOpen ? 'none'  : 'block';
    iconClose.style.display = isOpen ? 'block' : 'none';
    document.body.style.overflow = isOpen ? 'hidden' : '';
  }

  burgerBtn.addEventListener('click', toggleMenu);
  mobileNav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    if (isOpen) toggleMenu();
  }));
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && isOpen) toggleMenu();
  });
})();
</script>

<style>
  /* ── Reset ── */
  #site-header {
    /* position fixe propre — pas de flex/grid sur l'élément lui-même */
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    /* PAS de display:flex ici — ça casse le fixed sur certains browsers */
    /* PAS de height ici — géré par header-container */
  }

  /* Transition globale */
  #site-header {
    transition: transform 0.3s ease;
  }
  #site-header.is-hidden {
    transform: translateY(-100%);
  }

  /* ── Barre de progression ── */
  .header-progress {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, #39ff8f, #38bdf8, #a78bfa);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.1s linear;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Container principal ── */
  .header-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 64px;
    padding: 0 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    /* Fond transparent par défaut, devient frosted au scroll */
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
  }

  /* Quand scrollé : fond frosted + bordure */
  #site-header.is-scrolled .header-container {
    background: rgba(8, 10, 12, 0.88);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  /* ── Logo ── */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-mark {
    width: 30px; height: 30px;
    border-radius: 7px;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; line-height: 1; flex-shrink: 0;
  }
  .logo-name {
    font-family: 'Syne', sans-serif;
    font-size: 1rem; font-weight: 800;
    color: #fff; letter-spacing: -0.02em;
    transition: color 0.15s;
  }
  .header-logo:hover .logo-name { color: #39ff8f; }

  /* ── Nav desktop ── */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 1.5rem;
    flex: 1;
  }
  .header-nav-link {
    position: relative;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem; font-weight: 500;
    color: rgba(255, 255, 255, 0.52);
    text-decoration: none;
    border-radius: 0.5rem;
    transition: color 0.15s, background 0.15s;
  }
  .header-nav-link::after {
    content: '';
    position: absolute; bottom: -1px; left: 0.75rem; right: 0.75rem;
    height: 1.5px; background: #39ff8f;
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.2s ease;
  }
  .header-nav-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.04);
  }
  .header-nav-link:hover::after { transform: scaleX(1); }

  /* ── End zone ── */
  .header-end {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .header-cta {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.5rem 1.125rem;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    color: #050c08;
    border-radius: 0.625rem;
    font-size: 0.8125rem; font-weight: 700;
    text-decoration: none;
    transition: filter 0.15s, transform 0.15s;
    box-shadow: 0 2px 12px rgba(57, 255, 143, 0.2);
  }
  .header-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  .burger-btn {
    display: none;
    align-items: center; justify-content: center;
    width: 36px; height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    color: rgba(255, 255, 255, 0.75);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .burger-btn:hover {
    background: rgba(255, 255, 255, 0.09);
    color: #fff;
  }

  /* ── Mobile nav ── */
  .mobile-nav {
    position: absolute;
    top: 64px; left: 0; right: 0;
    background: rgba(8, 10, 12, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    padding: 1rem 1.5rem 1.5rem;
    display: flex; flex-direction: column; gap: 0.25rem;

    /* Fermé par défaut */
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .mobile-nav.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mobile-nav-link {
    display: block;
    padding: 0.75rem 1rem;
    font-size: 1rem; font-weight: 500;
    color: rgba(255, 255, 255, 0.58);
    text-decoration: none;
    border-radius: 0.75rem;
    border: 1px solid transparent;
    transition: all 0.15s;
  }
  .mobile-nav-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .mobile-nav-cta {
    display: block; margin-top: 0.5rem;
    padding: 0.875rem 1rem;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    color: #050c08; font-weight: 700; font-size: 0.9375rem;
    border-radius: 0.875rem; text-decoration: none; text-align: center;
    transition: filter 0.15s;
  }
  .mobile-nav-cta:hover { filter: brightness(1.06); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .header-nav { display: none; }
    .header-cta { display: none; }
    .burger-btn { display: flex; }
  }
</style>
---
// src/components/layout/Footer.astro
// Zero GSAP — scroll-to-top + newsletter sans dépendance

const year = new Date().getFullYear();

const cols = [
  {
    title: 'Produit', color: '#39ff8f',
    links: [
      { label: 'Fonctionnalités', href: '/features'  },
      { label: 'Tarifs',          href: '/pricing'   },
      { label: 'Roadmap',         href: '/dashboard/roadmap' },
    ],
  },
  {
    title: 'Créateurs', color: '#38bdf8',
    links: [
      { label: 'Streamers',  href: '/for/streamers'   },
      { label: 'Gamers',     href: '/for/gamers'       },
      { label: 'Artistes',   href: '/for/artists'      },
    ],
  },
  {
    title: 'Ressources', color: '#a78bfa',
    links: [
      { label: 'Documentation', href: '/docs'          },
      { label: 'Aide',          href: '/support'       },
      { label: 'Statut',        href: '/status'        },
    ],
  },
  {
    title: 'Légal', color: '#fb923c',
    links: [
      { label: 'Confidentialité', href: '/legal/privacy' },
      { label: 'CGU',             href: '/legal/terms'   },
      { label: 'Cookies',         href: '/legal/cookies' },
    ],
  },
];

const socials = [
  {
    name: 'Discord', href: 'https://discord.gg/bioforge', color: '#5865F2',
    icon: 'M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z',
  },
  {
    name: 'Twitter / X', href: 'https://twitter.com/bioforge_app', color: '#e2e8f0',
    icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.766l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  },
  {
    name: 'TikTok', href: 'https://tiktok.com/@bioforge', color: '#ff2d55',
    icon: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z',
  },
] as const;
---

<footer class="site-footer" aria-label="Pied de page BioForge">

  <!-- Newsletter -->
  <div class="footer-nl-wrap">
    <div class="footer-nl">
      <div class="nl-text">
        <h3 class="nl-title">
          Reste dans la boucle
          <span class="nl-accent">✦</span>
        </h3>
        <p class="nl-sub">Nouvelles features, tips créateurs et mises à jour produit.</p>
      </div>
      <form id="nl-form" class="nl-form" novalidate>
        <div class="nl-field">
          <input
            type="email"
            name="email"
            class="nl-input"
            placeholder="ton@email.com"
            required
            autocomplete="email"
            aria-label="Ton adresse email"
          />
          <button type="submit" class="nl-btn" id="nl-submit">
            <span id="nl-label">S'abonner</span>
            <svg id="nl-spinner" class="nl-spin hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
          </button>
        </div>
        <p id="nl-msg" class="nl-msg hidden"></p>
      </form>
    </div>
  </div>

  <!-- Corps du footer -->
  <div class="footer-body">

    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="foot-logo" aria-label="BioForge accueil">
        <div class="foot-logo-icon" aria-hidden="true">⚡</div>
        <span class="foot-logo-text">BioForge</span>
      </a>
      <p class="brand-desc">
        Forge ta présence en ligne. Analytics en temps réel, blocs personnalisés, domaine custom.
      </p>

      <!-- Réseaux sociaux -->
      <div class="socials" role="list">
        {socials.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            style={`--sc: ${s.color};`}
            aria-label={s.name}
            role="listitem"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d={s.icon}/>
            </svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Colonnes de liens -->
    {cols.map(col => (
      <div class="footer-col">
        <h4 class="col-title" style={`color: ${col.color};`}>{col.title}</h4>
        <ul role="list">
          {col.links.map(link => (
            <li>
              <a href={link.href} class="col-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}

  </div>

  <!-- Bas de page -->
  <div class="footer-bottom">
    <p class="copy">© {year} BioForge. Fait avec <span aria-label="amour">♥</span> pour les créateurs.</p>
    <div class="bottom-badges">
      <span class="foot-badge">🇫🇷 Hébergé en Europe</span>
      <span class="foot-badge">RGPD conforme</span>
    </div>
  </div>

  <!-- Scroll to top -->
  <button id="scroll-top" class="scroll-top" aria-label="Retour en haut de page">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path d="M12 19V5M5 12l7-7 7 7"/>
    </svg>
  </button>

</footer>

<script>
  // ── Newsletter ─────────────────────────────────────────────────────────────
  const form    = document.getElementById('nl-form')   as HTMLFormElement;
  const submit  = document.getElementById('nl-submit') as HTMLButtonElement;
  const label   = document.getElementById('nl-label')!;
  const spinner = document.getElementById('nl-spinner')!;
  const msg     = document.getElementById('nl-msg')!;

  function showMsg(text: string, ok: boolean) {
    msg.textContent = text;
    msg.className = `nl-msg ${ok ? 'nl-ok' : 'nl-err'}`;
  }

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    if (!email) return;

    label.textContent = '';
    spinner.classList.remove('hidden');
    submit.disabled = true;

    try {
      const res  = await fetch('/api/newsletters/subscribe', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ email }),
      });
      const json = await res.json();
      if (res.ok) {
        showMsg('Inscrit ! Vérifie ta boîte mail 🎉', true);
        form.reset();
      } else {
        showMsg(json.error ?? 'Une erreur est survenue', false);
      }
    } catch {
      showMsg('Erreur réseau, réessaie', false);
    }

    label.textContent = 'S\'abonner';
    spinner.classList.add('hidden');
    submit.disabled = false;
  });

  // ── Scroll to top ──────────────────────────────────────────────────────────
  const topBtn = document.getElementById('scroll-top')!;

  window.addEventListener('scroll', () => {
    topBtn.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });

  topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>

<style>
  .site-footer {
    position: relative;
    background: #05080a;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 2rem;
  }

  /* ── Newsletter ── */
  .footer-nl-wrap {
    padding: 3rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .footer-nl {
    max-width: 1100px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
    flex-wrap: wrap;
  }
  .nl-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.25rem; font-weight: 800; color: #fff; letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }
  .nl-accent { color: #39ff8f; margin-left: 0.2rem; }
  .nl-sub { font-size: 0.8125rem; color: rgba(255,255,255,0.4); }

  .nl-form { display: flex; flex-direction: column; gap: 0.5rem; min-width: 320px; }

  .nl-field {
    display: flex; overflow: hidden;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.09);
    border-radius: 0.75rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .nl-field:focus-within {
    border-color: rgba(57,255,143,0.35);
    box-shadow: 0 0 0 3px rgba(57,255,143,0.08);
  }
  .nl-input {
    flex: 1; min-width: 0; padding: 0.75rem 1rem;
    background: transparent; border: none; outline: none;
    color: #fff; font-size: 0.875rem;
  }
  .nl-input::placeholder { color: rgba(255,255,255,0.22); }
  .nl-btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.75rem 1.125rem; flex-shrink: 0;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    color: #050c08; font-size: 0.8125rem; font-weight: 700;
    border: none; cursor: pointer; transition: filter 0.15s;
  }
  .nl-btn:hover { filter: brightness(1.07); }
  .nl-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .nl-msg { font-size: 0.75rem; padding: 0 0.25rem; }
  .nl-msg.nl-ok  { color: #39ff8f; }
  .nl-msg.nl-err { color: #ff6b6b; }
  .nl-msg.hidden { display: none; }

  .nl-spin { animation: spin 0.7s linear infinite; }
  .nl-spin.hidden { display: none; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Corps ── */
  .footer-body {
    max-width: 1100px; margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 3rem;
    padding: 3rem 1.5rem;
  }

  /* Brand */
  .foot-logo {
    display: flex; align-items: center; gap: 0.5rem;
    text-decoration: none; margin-bottom: 1rem;
  }
  .foot-logo-icon {
    width: 28px; height: 28px; border-radius: 6px;
    background: linear-gradient(135deg, #39ff8f, #b4ff6e);
    display: flex; align-items: center; justify-content: center; font-size: 13px;
  }
  .foot-logo-text {
    font-family: 'Syne', sans-serif; font-size: 0.9375rem;
    font-weight: 800; color: #fff; letter-spacing: -0.02em;
  }
  .brand-desc {
    font-size: 0.8rem; color: rgba(255,255,255,0.38);
    line-height: 1.7; margin-bottom: 1.25rem; max-width: 240px;
  }

  /* Socials */
  .socials { display: flex; gap: 0.5rem; }
  .social-link {
    width: 34px; height: 34px; border-radius: 0.5rem;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.45);
    text-decoration: none; transition: all 0.15s;
  }
  .social-link:hover {
    color: var(--sc);
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.12);
    transform: translateY(-2px);
  }

  /* Colonnes */
  .col-title {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.09em; margin-bottom: 1rem;
  }
  .footer-col ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; }
  .col-link {
    font-size: 0.8125rem; color: rgba(255,255,255,0.42);
    text-decoration: none; transition: color 0.15s;
  }
  .col-link:hover { color: rgba(255,255,255,0.8); }

  /* ── Bottom ── */
  .footer-bottom {
    max-width: 1100px; margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.05);
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    flex-wrap: wrap;
  }
  .copy { font-size: 0.75rem; color: rgba(255,255,255,0.3); }
  .copy span { color: #ff6b6b; }

  .bottom-badges { display: flex; gap: 0.75rem; }
  .foot-badge {
    font-size: 0.68rem; color: rgba(255,255,255,0.28);
    padding: 0.2rem 0.6rem;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 99px;
  }

  /* ── Scroll to top ── */
  .scroll-top {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 50;
    width: 40px; height: 40px; border-radius: 0.625rem;
    background: rgba(13,16,18,0.9); color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.2s;
    opacity: 0; pointer-events: none; transform: translateY(6px);
    backdrop-filter: blur(10px);
  }
  .scroll-top.visible {
    opacity: 1; pointer-events: auto; transform: translateY(0);
  }
  .scroll-top:hover {
    color: #39ff8f; border-color: rgba(57,255,143,0.3);
    background: rgba(57,255,143,0.08);
    transform: translateY(-2px);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .footer-body { grid-template-columns: 1fr 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: 1 / -1; }
    .brand-desc { max-width: 100%; }
  }
  @media (max-width: 640px) {
    .footer-body { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .footer-nl { flex-direction: column; }
    .nl-form { min-width: 0; width: 100%; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
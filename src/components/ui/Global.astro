---
import "../styles/global.css";
---

<div id="cursor-trail" class="pointer-events-none fixed inset-0 z-50"></div>
<div id="particles-container" class="pointer-events-none fixed inset-0 z-0"></div>

<script type="module">
  // Import uniquement ici pour le client
  import { initGlobalEffects } from '@/scripts/globalEffects.ts';
  
  const cleanup = initGlobalEffects();

  // Cleanup sur navigation Astro
  document.addEventListener('astro:before-preparation', () => {
    cleanup?.();
  });
</script>

<style>
  #particles-container {
    opacity: 0.4;
  }

  .cursor-particle {
    position: fixed;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 50;
  }
</style>
---
// Bento Grid Layout for Features - Very 2026
---

<section class="relative py-32 overflow-hidden" data-scroll-section>
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-dark-900 via-dark-800 to-dark-900"></div>
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 left-0 w-[800px] h-[800px] bg-neon-purple rounded-full blur-[200px]"></div>
    <div class="absolute bottom-0 right-0 w-[800px] h-[800px] bg-neon-green rounded-full blur-[200px]"></div>
  </div>

  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-4xl mx-auto mb-20 reveal">
      <div class="inline-flex items-center space-x-2 px-4 py-2 glass rounded-full text-sm text-neon-purple mb-6">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span>Everything you need</span>
      </div>
      
      <h2 class="text-5xl sm:text-6xl lg:text-7xl font-display font-bold text-white mb-6 smooth-font">
        Built for the
        <span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-neon-green via-neon-blue to-neon-purple animate-gradient text-glow-green">
          Modern Creator
        </span>
      </h2>
      <p class="text-xl text-gray-400 leading-relaxed">
        Everything you need to create a professional link-in-bio that converts. No coding required.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-6 auto-rows-[280px]">
      
      <!-- Feature 1: Analytics - Large -->
      <div class="md:col-span-6 lg:col-span-7 row-span-2 group reveal">
        <div class="h-full glass-strong rounded-3xl p-8 border border-white/5 hover:border-neon-green/30 transition-all duration-500 overflow-hidden relative tilt-card cursor-pointer transform hover:scale-[1.02]" data-tilt data-tilt-max="5">
          <div class="relative z-10 h-full flex flex-col">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-neon-green to-neon-blue p-0.5 mb-6 group-hover:scale-110 transition-transform">
              <div class="w-full h-full bg-dark-900 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </div>
            </div>
            
            <h3 class="text-3xl font-display font-bold text-white mb-4 group-hover:text-neon-green transition-colors">
              Advanced Analytics
            </h3>
            <p class="text-gray-400 text-lg mb-auto leading-relaxed">
              Track every click, view, and interaction with real-time analytics. Understand your audience better than ever.
            </p>

            <!-- Mini chart visualization -->
            <div class="mt-6 flex items-end space-x-2 h-24">
              {[60, 80, 45, 90, 70, 95, 85].map((height) => (
                <div class="flex-1 bg-gradient-to-t from-neon-green/50 to-neon-green rounded-t-lg transition-all duration-500 group-hover:from-neon-green group-hover:to-neon-blue" style={`height: ${height}%`}></div>
              ))}
            </div>
          </div>
          <div class="absolute inset-0 bg-gradient-to-br from-neon-green/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Feature 2: Customization - Tall -->
      <div class="md:col-span-3 lg:col-span-5 row-span-2 group reveal">
        <div class="h-full glass-strong rounded-3xl p-8 border border-white/5 hover:border-neon-purple/30 transition-all duration-500 relative overflow-hidden tilt-card cursor-pointer transform hover:scale-[1.02]" data-tilt data-tilt-max="5">
          <div class="relative z-10 h-full flex flex-col">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-neon-purple to-neon-pink p-0.5 mb-6 group-hover:scale-110 transition-transform">
              <div class="w-full h-full bg-dark-900 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-neon-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                </svg>
              </div>
            </div>

            <h3 class="text-3xl font-display font-bold text-white mb-4 group-hover:text-neon-purple transition-colors">
              Full Customization
            </h3>
            <p class="text-gray-400 text-lg mb-auto leading-relaxed">
              Make it uniquely yours with our powerful editor. Themes, layouts, colors — total control.
            </p>

            <!-- Color palette preview -->
            <div class="mt-6 flex space-x-3">
              <div class="w-12 h-12 rounded-xl bg-neon-green glow-green transform group-hover:scale-110 transition-transform"></div>
              <div class="w-12 h-12 rounded-xl bg-neon-purple glow-purple transform group-hover:scale-110 transition-transform"></div>
              <div class="w-12 h-12 rounded-xl bg-neon-blue glow-blue transform group-hover:scale-110 transition-transform"></div>
            </div>
          </div>
          <div class="absolute inset-0 bg-gradient-to-br from-neon-purple/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Feature 3: Speed - Medium -->
      <div class="md:col-span-3 lg:col-span-4 group reveal">
        <div class="h-full glass-strong rounded-3xl p-8 border border-white/5 hover:border-neon-orange/30 transition-all duration-500 relative overflow-hidden tilt-card cursor-pointer transform hover:scale-[1.02]" data-tilt data-tilt-max="5">
          <div class="relative z-10 h-full flex flex-col">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-neon-orange to-neon-pink p-0.5 mb-4 group-hover:scale-110 transition-transform">
              <div class="w-full h-full bg-dark-900 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-neon-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
            </div>
            
            <h3 class="text-2xl font-display font-bold text-white mb-3 group-hover:text-neon-orange transition-colors">
              Lightning Fast
            </h3>
            <p class="text-gray-400 leading-relaxed">
              Optimized for speed. Your page loads instantly.
            </p>
          </div>
          <div class="absolute bottom-0 right-0 w-32 h-32 bg-neon-orange/10 rounded-tl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Feature 4: Mobile - Medium -->
      <div class="md:col-span-3 lg:col-span-4 group reveal">
        <div class="h-full glass-strong rounded-3xl p-8 border border-white/5 hover:border-neon-green/30 transition-all duration-500 relative overflow-hidden tilt-card cursor-pointer transform hover:scale-[1.02]" data-tilt data-tilt-max="5">
          <div class="relative z-10 h-full flex flex-col">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-neon-green to-neon-purple p-0.5 mb-4 group-hover:scale-110 transition-transform">
              <div class="w-full h-full bg-dark-900 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
              </div>
            </div>

            <h3 class="text-2xl font-display font-bold text-white mb-3 group-hover:text-neon-green transition-colors">
              Mobile First
            </h3>
            <p class="text-gray-400 leading-relaxed">
              Perfect on every device. Mobile, tablet, desktop.
            </p>
          </div>
          <div class="absolute bottom-0 right-0 w-32 h-32 bg-neon-green/10 rounded-tl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Feature 5: Security - Medium -->
      <div class="md:col-span-3 lg:col-span-4 group reveal">
        <div class="h-full glass-strong rounded-3xl p-8 border border-white/5 hover:border-neon-blue/30 transition-all duration-500 relative overflow-hidden tilt-card cursor-pointer transform hover:scale-[1.02]" data-tilt data-tilt-max="5">
          <div class="relative z-10 h-full flex flex-col">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-neon-blue to-neon-purple p-0.5 mb-4 group-hover:scale-110 transition-transform">
              <div class="w-full h-full bg-dark-900 rounded-2xl flex items-center justify-center">
                <svg class="w-7 h-7 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
            </div>

            <h3 class="text-2xl font-display font-bold text-white mb-3 group-hover:text-neon-blue transition-colors">
              Secure & Reliable
            </h3>
            <p class="text-gray-400 leading-relaxed">
              99.9% uptime with enterprise security.
            </p>
          </div>
          <div class="absolute bottom-0 right-0 w-32 h-32 bg-neon-blue/10 rounded-tl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>

      <!-- Feature 6: Built for Passion - Wide -->
      <div class="md:col-span-6 lg:col-span-8 group reveal">
        <div class="h-full glass-strong rounded-3xl p-8 border border-white/5 hover:border-neon-pink/30 transition-all duration-500 relative overflow-hidden tilt-card cursor-pointer transform hover:scale-[1.02]" data-tilt data-tilt-max="5">
          <div class="relative z-10 h-full flex flex-col sm:flex-row items-center gap-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-neon-purple to-neon-pink p-0.5 group-hover:scale-110 transition-transform shrink-0">
              <div class="w-full h-full bg-dark-900 rounded-2xl flex items-center justify-center">
                <svg class="w-8 h-8 text-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
              </div>
            </div>

            <div class="flex-1 text-center sm:text-left">
              <h3 class="text-3xl font-display font-bold text-white mb-3 group-hover:text-neon-pink transition-colors">
                Built for Passion
              </h3>
              <p class="text-gray-400 text-lg leading-relaxed">
                Designed for creators, gamers, and modern professionals who want to stand out.
              </p>
            </div>
          </div>
          <div class="absolute inset-0 bg-gradient-to-r from-neon-pink/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="mt-20 text-center reveal">
      <a 
        href="/features" 
        class="inline-flex items-center space-x-3 text-neon-green hover:text-neon-blue transition-colors duration-200 font-medium text-xl group magnetic"
      >
        <span>Explore all features</span>
        <svg class="w-6 h-6 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import VanillaTilt from 'vanilla-tilt';

  document.addEventListener('DOMContentLoaded', () => {
    const tiltElements = document.querySelectorAll('[data-tilt]');
    
    tiltElements.forEach((element) => {
      VanillaTilt.init(element as HTMLElement, {
        max: 5,
        speed: 800,
        scale: 1.02,
        glare: true,
        'max-glare': 0.2
      });
    });
  });
</script>
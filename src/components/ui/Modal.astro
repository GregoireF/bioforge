---
import { cn } from '@/lib/utils/cn';

interface Props {
  id: string;
  title: string;
  description?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const {
  id,
  title,
  description,
  size = 'md',
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  sm: 'max-w-sm',
  md: 'max-w-md',
  lg: 'max-w-2xl',
  xl: 'max-w-4xl',
};

const classes = cn(
  'relative glass-strong rounded-2xl p-6 lg:p-8 border border-white/10 w-full',
  sizes[size],
  className
);
---

<div
  id={id}
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${id}-title`}
  {...rest}
>
  <!-- Backdrop -->
  <div 
    class="fixed inset-0 bg-black/50 backdrop-blur-sm modal-backdrop"
    data-modal-id={id}
  ></div>

  <!-- Modal Content -->
  <div class={classes}>
    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
      <div class="flex-1">
        <h3 id={`${id}-title`} class="text-xl font-bold text-white mb-1">
          {title}
        </h3>
        {description && (
          <p class="text-sm text-gray-400">{description}</p>
        )}
      </div>
      <button
        class="modal-close p-2 glass border border-white/10 rounded-lg hover:border-red-500/30 transition-colors"
        data-modal-id={id}
        aria-label="Close modal"
      >
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="modal-body">
      <slot />
    </div>
  </div>
</div>

<script>
  // Modal utilities
  export function openModal(id: string) {
    const modal = document.getElementById(id);
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  }

  export function closeModal(id: string) {
    const modal = document.getElementById(id);
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }
  }

  // Auto-setup close handlers
  document.addEventListener('DOMContentLoaded', () => {
    // Close on backdrop click
    document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
      backdrop.addEventListener('click', () => {
        const modalId = backdrop.getAttribute('data-modal-id');
        if (modalId) closeModal(modalId);
      });
    });

    // Close on X button click
    document.querySelectorAll('.modal-close').forEach(button => {
      button.addEventListener('click', () => {
        const modalId = button.getAttribute('data-modal-id');
        if (modalId) closeModal(modalId);
      });
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('[role="dialog"]:not(.hidden)').forEach(modal => {
          closeModal(modal.id);
        });
      }
    });
  });
</script>
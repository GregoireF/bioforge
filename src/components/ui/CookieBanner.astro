---
interface Props {
  profileId: string
  primaryColor: string
  bgColor: string
  textColor: string
}

const { profileId, primaryColor, bgColor, textColor } = Astro.props
---

<div
  id="cookie-banner"
  role="dialog"
  aria-modal="true"
  aria-label="Consentement cookies"
  class="fixed bottom-0 left-0 right-0 z-[99999] px-4 pb-4
         translate-y-full opacity-0
         transition-[transform,opacity] duration-500
         ease-[cubic-bezier(.16,1,.3,1)]"
>
  <div
    class="max-w-xl mx-auto rounded-2xl p-5 shadow-2xl backdrop-blur-xl"
    style={`background:${bgColor}F2;border:1px solid ${textColor}15`}
  >
    <div class="flex gap-3">

      <!-- icon -->
      <div
        class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
        style={`background:${primaryColor}20`}
      >
        🍪
      </div>

      <div class="flex-1">

        <p class="text-sm font-semibold mb-1" style={`color:${textColor}`}>
          Respect de votre vie privée
        </p>

        <p class="text-xs leading-relaxed opacity-70" style={`color:${textColor}`}>
          Cette page utilise des statistiques anonymes pour aider le créateur
          à comprendre son audience. Aucun cookie publicitaire ni suivi cross-site.
          <a
            href="/legal/privacy"
            class="underline ml-1"
            style={`color:${primaryColor}`}
          >
            En savoir plus
          </a>
        </p>

        <!-- buttons -->
        <div class="flex gap-2 mt-4 flex-wrap">

          <button
            id="cookie-reject"
            class="px-4 py-2 rounded-xl text-xs font-semibold
                   transition hover:scale-[1.02] active:scale-95"
            style={`background:${textColor}10;color:${textColor}`}
          >
            Refuser
          </button>

          <button
            id="cookie-settings"
            class="px-4 py-2 rounded-xl text-xs font-semibold
                   transition hover:scale-[1.02]"
            style={`color:${textColor};opacity:.7`}
          >
            Personnaliser
          </button>

          <button
            id="cookie-accept"
            class="px-5 py-2 rounded-xl text-xs font-bold
                   transition hover:scale-[1.02] active:scale-95"
            style={`background:${primaryColor};color:${bgColor}`}
          >
            Accepter
          </button>

        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{
  profileId,
  CONSENT_KEY: 'bf_cookie_consent',
  CONSENT_VERSION: 1,
  POLICY_VERSION: '2026-03'
}}>
const banner  = document.getElementById('cookie-banner')
const btnOk   = document.getElementById('cookie-accept')
const btnNo   = document.getElementById('cookie-reject')
const btnSet  = document.getElementById('cookie-settings')

function getConsent() {
  try {
    const raw = localStorage.getItem(CONSENT_KEY)
    if (!raw) return null

    const c = JSON.parse(raw)

    if (c.version !== CONSENT_VERSION) return null
    if (c.policy !== POLICY_VERSION) return null

    if (Date.now() - c.ts > 180*24*60*60*1000) {
      localStorage.removeItem(CONSENT_KEY)
      return null
    }

    return c
  } catch {
    return null
  }
}

function storeConsent(analytics) {
  localStorage.setItem(CONSENT_KEY, JSON.stringify({
    analytics,
    ts: Date.now(),
    version: CONSENT_VERSION,
    policy: POLICY_VERSION
  }))
}

function hideBanner() {
  banner?.classList.add('translate-y-full','opacity-0')
  banner?.classList.remove('translate-y-0','opacity-100')
}

function showBanner() {
  setTimeout(()=>{
    banner?.classList.remove('translate-y-full','opacity-0')
    banner?.classList.add('translate-y-0','opacity-100')
    btnOk?.focus()
  },1500)
}

async function recordConsent(analytics,action) {

  storeConsent(analytics)
  hideBanner()

  window.dispatchEvent(new CustomEvent('bf:consent',{
    detail:{analytics}
  }))

  fetch('/api/rgpd/consent',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      profile_id:profileId,
      analytics,
      action
    })
  }).catch(()=>{})
}

btnOk?.addEventListener('click',()=>recordConsent(true,'accept'))
btnNo?.addEventListener('click',()=>recordConsent(false,'reject'))

btnSet?.addEventListener('click',()=>{
  document.dispatchEvent(new CustomEvent('bf:open-preferences'))
})

document.addEventListener('keydown',(e)=>{
  if(e.key==='Escape') recordConsent(false,'dismiss')
})

requestIdleCallback(()=>{

  const consent=getConsent()

  if(consent){
    window.dispatchEvent(new CustomEvent('bf:consent',{
      detail:{analytics:consent.analytics}
    }))
  }else{
    showBanner()
  }

})
</script>
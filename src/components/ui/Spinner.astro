---
import { cn } from '@/lib/utils/cn';

interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  color?: 'neon-green' | 'neon-pink' | 'neon-purple' | string;
}

const { 
  size = 'md', 
  class: className,
  color = 'neon-green'
} = Astro.props;

const sizes = {
  sm: 'w-5 h-5',
  md: 'w-8 h-8',
  lg: 'w-12 h-12',
};

const glowColor = color.startsWith('neon-') ? color : 'neon-green';

const classes = cn(
  `animate-spin drop-shadow-[0_0_8px_currentColor] transition-all duration-300`, 
  sizes[size],
  `text-${glowColor}`, 
  className
);
---

<svg 
  class={classes} 
  viewBox="0 0 24 24"
  fill="none" 
  aria-hidden="true"
  role="status"
>
  <circle 
    class="opacity-30" 
    cx="12" cy="12" r="10" 
    stroke="currentColor" 
    stroke-width="4" 
  />
  <path 
    class="opacity-80 animate-pulse" 
    fill="currentColor" 
    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
  />
</svg>

<span class="sr-only">Loading...</span>